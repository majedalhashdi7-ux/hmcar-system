{
  "name": "car-auction",
  "version": "1.0.0",
  "main": "server.js",
  "bin": {
    "set-admin-claim": "scripts/setAdminClaim.js"
  },
  "scripts": {
    "set-admin-claim": "node scripts/setAdminClaim.js",
    "create-local-admin": "node scripts/createLocalAdmin.js",
    "create:admin": "node scripts/createProductionAdmin.js",
    "create-firebase-admin": "node scripts/createFirebaseAdmin.js",
    "link-local-to-firebase": "node scripts/linkLocalToFirebase.js",
    "create-full-admin": "node createFullAdmin.js",
    "list-db": "node listCollections.js",
    "fix:live": "node scripts/fix-live-data.js",
    "validate": "node scripts/validate-config.js",
    "check:deploy": "node scripts/check-deployment.js",
    "force:deploy": "node scripts/force-redeploy.js",
    "predeploy": "npm run validate",
    "start": "node server.js",
    "dev": "nodemon --ext js,css --watch modules --watch routes --watch middleware --watch config server.js",
    "auto-deploy": "node scripts/auto-deploy.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run auto-deploy\"",
    "seed": "node seed.js",
    "seed:auctions": "node seed_auctions_bids.js",
    "test": "mocha --timeout 10000 --recursive test --exit",
    "test:unit": "mocha --timeout 10000 test/unit/**/*.test.js --exit",
    "test:unit:models": "mocha --timeout 10000 test/unit/models/**/*.test.js --exit",
    "test:unit:services": "mocha --timeout 10000 test/unit/services/**/*.test.js --exit",
    "test:unit:middleware": "mocha --timeout 10000 test/unit/middleware/**/*.test.js --exit",
    "test:unit:utils": "mocha --timeout 10000 test/unit/utils/**/*.test.js --exit",
    "test:unit:middleware": "mocha --timeout 10000 test/unit/middleware/**/*.test.js --exit",
    "test:integration": "mocha --timeout 15000 test/integration/**/*.test.js --exit",
    "test:integration:api": "mocha --timeout 15000 test/integration/api/**/*.test.js --exit",
    "test:integration:database": "mocha --timeout 15000 test/integration/database/**/*.test.js --exit",
    "test:integration:auth": "mocha --timeout 15000 test/integration/auth/**/*.test.js --exit",
    "test:e2e": "mocha --timeout 30000 test/e2e/**/*.test.js --exit",
    "test:e2e": "mocha --timeout 30000 test/e2e/**/*.test.js --exit",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:coverage": "nyc --reporter=html --reporter=text mocha --timeout 10000 --recursive test --exit",
    "test:watch": "nodemon --exec \"npm test\"",
    "optimize:db": "node scripts/addDatabaseIndexes.js",
    "build": "cd client-app && npm install && npm run build",
    "deploy": "vercel --prod",
    "publish": "node deploy.js",
    "publish:check": "node deploy.js --check",
    "deploy:pm2": "pm2 deploy production",
    "deploy:docker": "docker-compose up -d --build",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop car-auction",
    "pm2:restart": "pm2 restart car-auction",
    "pm2:logs": "pm2 logs car-auction",
    "pm2:monit": "pm2 monit",
    "clean": "powershell -ExecutionPolicy Bypass -File scripts/clean-project.ps1",
    "clean:db": "node scripts/reset-database.js",
    "fresh-start": "npm run clean && npm install && npm run clean:db && npm run dev",
    "check:env": "node scripts/checkEnvironment.js",
    "check:health": "node scripts/healthCheck.js",
    "fix:assets": "node scripts/fixAssetPaths.js",
    "setup:railway": "node scripts/setup-railway.js",
    "health": "node scripts/healthCheck.js",
    "backup": "node scripts/production-backup.js",
    "domain:update": "node scripts/update-domain.js",
    "domain:verify": "node scripts/verify-domain.js",
    "add:tenant": "node scripts/add-tenant.js",
    "list:tenants": "node scripts/list-tenants.js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.2",
    "@sentry/node": "^10.43.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bootstrap-icons": "^1.11.3",
    "cheerio": "^1.2.0",
    "cloudinary": "^1.41.0",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "csurf": "^1.11.0",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.10",
    "ejs-mate": "^4.0.0",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.17.3",
    "firebase-admin": "^12.1.0",
    "helmet": "^7.1.0",
    "i18n": "^0.15.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "method-override": "^3.0.0",
    "mongoose": "^8.23.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.8",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "puppeteer": "^24.39.0",
    "qrcode": "^1.5.3",
    "redis": "^4.7.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.5",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^4.6.3",
    "validator": "^13.12.0",
    "web-push": "^3.6.7",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.9",
    "chai": "^4.3.7",
    "concurrently": "^9.2.1",
    "mocha": "^10.2.0",
    "mongodb-memory-server": "^8.12.0",
    "nodemon": "^3.1.11",
    "nyc": "^15.1.0",
    "sinon": "^21.0.3",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": "22.x"
  }
}
