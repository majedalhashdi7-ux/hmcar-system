rald-400\"\r\n                                    : stock === 0\r\n                                        ? \"bg-white/5 text-white/30 border-2 border-white/10 cursor-not-allowed\"\r\n                                        : \"bg-amber-500 hover:bg-amber-400 text-black border-2 border-amber-400 hover:shadow-amber-500/50\"\r\n                            )}\r\n                        >\r\n                            {cartAdded || inCart ? (\r\n                                <>\r\n                                    <Check className=\"w-4 h-4\" />\r\n                                    <span className=\"hidden sm:inline\">{isRTL ? 'в•ӘШІв”ҳГ ' : 'Added'}</span>\r\n                                </>\r\n                            ) : (\r\n                                <>\r\n                                    <ShoppingCart className=\"w-4 h-4\" />\r\n                                    <span>{isRTL ? 'в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ©' : 'Buy'}</span>\r\n                                </>\r\n                            )}\r\n                        </motion.button>\r\n                    </div>\r\n                </div>\r\n\r\n                {/* в•ӘВ«в•Әв•– в”ҳГ в•ӘШІв”ҳГӘв”ҳГ§в•ӘШҙ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв”ҳВҒв”ҳВ„ */}\r\n                <div className=\"absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-amber-500/0 to-transparent group-hover:via-amber-500/50 transition-all duration-500\" />\r\n            </div>\r\n        </motion.div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\components\\ParticleBackground.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\components\\ProductModal.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'e' is defined but never used.","line":160,"column":22,"nodeType":"Identifier","messageId":"unusedVar","endLine":160,"endColumn":23}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\n/**\r\n * [[ARABIC_COMMENT]] в”ҳГ в•Әв–’в•ӘШ°в•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШІв•ӘШҙ - в•ӘШ°в•ӘШІв•Әв•Ўв”ҳГ в”ҳГЁв”ҳГ  в”ҳГ в•Әв”Өв•ӘШҜв•ӘШ°в”ҳГ§ в”ҳВ„в”ҳВҖ Shein\r\n * в”ҳГЁв”ҳВҸв•Әв•Јв•Әв–’в•Әв•ў в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в•Әв•ўв•Әв•‘в•Әв•– в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШ«в”ҳГЁ в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ в•ӘШ«в”ҳГӘ в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ в•Әв•‘в”ҳГЁв•ӘШҜв•Әв–’\r\n * в”ҳГЁв•ӘШөв•ӘШІв”ҳГӘв”ҳГЁ: в•Әв•Ўв”ҳГӘв•Әв–’в•ӘГ® в•Әв”Ӯв•Әв•Јв•Әв–’в•ӘГ® в”ҳГӘв•Әв•Ўв”ҳВҒв•ӘГ® в•ӘШ«в•Әв–“в•Әв–’в•ӘШҜв•Әв–’ (в”ҳГ в”ҳВҒв•Әв•ўв”ҳВ„в•ӘШұв•ӘГ® в•Әв”Ӯв”ҳВ„в•ӘШұв•ӘГ® в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ©в•ӘГ® в•ӘШӯв•Әв•‘в”ҳВ„в•ӘШҜв”ҳГ©)\r\n */\r\n\r\nimport React, { useState, useEffect, useCallback } from 'react';\r\nimport { motion, AnimatePresence } from 'framer-motion';\r\nimport {\r\n    X, Heart, ShoppingCart, MessageCircle,\r\n    ChevronLeft, ChevronRight, Share2, Check,\r\n    Fuel, Gauge, Settings2, Calendar, Tag, Car as CarIcon,\r\n    Copy\r\n} from 'lucide-react';\r\nimport Image from 'next/image';\r\nimport { useLanguage } from '@/lib/LanguageContext';\r\nimport { useSettings } from '@/lib/SettingsContext';\r\nimport { useToast } from '@/lib/ToastContext';\r\nimport { api } from '@/lib/api';\r\nimport { useAuth } from '@/lib/AuthContext';\r\n\r\n// [[ARABIC_COMMENT]] в”ҳВҶв”ҳГӘв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШІв•ӘШҙ - в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ в•ӘШ«в”ҳГӘ в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ в•Әв•‘в”ҳГЁв•ӘШҜв•Әв–’\r\nexport type ProductType = 'car' | 'part';\r\n\r\nexport interface ProductModalData {\r\n    id: string;\r\n    type: ProductType;\r\n    title: string;\r\n    images: string[];\r\n    price: number;\r\n    displayCurrency?: string;\r\n    description?: string;\r\n    // в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ\r\n    make?: string;\r\n    model?: string;\r\n    year?: number | string;\r\n    color?: string;\r\n    mileage?: number;\r\n    fuelType?: string;\r\n    transmission?: string;\r\n    category?: string;\r\n    // в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ в•Әв•‘в”ҳГЁв•ӘШҜв•Әв–’\r\n    brand?: string;\r\n    condition?: string;\r\n    compatibility?: string[];\r\n    stock?: number;\r\n}\r\n\r\n/**\r\n * в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°в•ӘШұ в”ҳВ„в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в•ӘШҜв”ҳВ„\r\n */\r\n\r\ninterface ProductModalProps {\r\n    product: ProductModalData | null;\r\n    onClose: () => void;\r\n    whatsappNumber?: string;\r\n}\r\n\r\nconst CART_KEY = 'hm_cart';\r\nconst FAVORITES_KEY = 'hm_favorites';\r\n\r\n// [[ARABIC_COMMENT]] в•ӘВ»в•ӘШҜв”ҳВ„в•ӘШұ в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ в”ҳВ„в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШұ в”ҳГ в”ҳВҶ localStorage\r\nfunction getCart(): ProductModalData[] {\r\n    if (typeof window === 'undefined') return [];\r\n    try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); }\r\n    catch { return []; }\r\n}\r\n\r\n// [[ARABIC_COMMENT]] в•ӘВ»в•ӘШҜв”ҳВ„в•ӘШұ в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ в”ҳВ„в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҒв•Әв•ўв”ҳВ„в•ӘШұ в”ҳГ в”ҳВҶ localStorage\r\nfunction getFavorites(): string[] {\r\n    if (typeof window === 'undefined') return [];\r\n    try { return JSON.parse(localStorage.getItem(FAVORITES_KEY) || '[]'); }\r\n    catch { return []; }\r\n}\r\n\r\n// [[ARABIC_COMMENT]] в•ӘШөв•ӘВ»в•ӘШі в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ў в”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ» в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШұ в”ҳВҒв”ҳГЁ Navbar\r\nfunction dispatchCartUpdate() {\r\n    window.dispatchEvent(new Event('hm_cart_updated'));\r\n}\r\n\r\nexport default function ProductModal({ product, onClose, whatsappNumber }: ProductModalProps) {\r\n    const { isRTL } = useLanguage();\r\n    const { formatPrice } = useSettings();\r\n    const [activeImg, setActiveImg] = useState(0);\r\n    const [isFavorite, setIsFavorite] = useState(false);\r\n    const [inCart, setInCart] = useState(false);\r\n    const [addedToCart, setAddedToCart] = useState(false);\r\n    const [copied, setCopied] = useState(false);\r\n    const [showShareMenu, setShowShareMenu] = useState(false);\r\n    const { showToast } = useToast();\r\n    const { user } = useAuth();\r\n\r\n    // [[ARABIC_COMMENT]] в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҒв•Әв•ўв”ҳВ„в•ӘШұ в”ҳГӘв•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШұ в•Әв•Јв”ҳВҶв•ӘВ» в”ҳВҒв•ӘШІв•ӘШө в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШІв•ӘШҙ\r\n    useEffect(() => {\r\n        if (!product) return;\r\n        setActiveImg(0);\r\n        const favs = getFavorites();\r\n        setIsFavorite(favs.includes(product.id));\r\n        const cart = getCart();\r\n        setInCart(cart.some(i => i.id === product.id));\r\n        setAddedToCart(false);\r\n    }, [product]);\r\n\r\n    // [[ARABIC_COMMENT]] в•ӘШӯв•Әв•‘в”ҳВ„в•ӘШҜв”ҳГ© в•ӘШ°в•ӘШҜв”ҳВ„в”ҳВҖ Escape\r\n    useEffect(() => {\r\n        const onKey = (e: KeyboardEvent) => { if (e.key === 'Escape') onClose(); };\r\n        window.addEventListener('keydown', onKey);\r\n        return () => window.removeEventListener('keydown', onKey);\r\n    }, [onClose]);\r\n\r\n    const toggleFavorite = useCallback(() => {\r\n        if (!product) return;\r\n        const favs = getFavorites();\r\n        let newFavs: string[];\r\n        if (favs.includes(product.id)) {\r\n            newFavs = favs.filter(id => id !== product.id);\r\n        } else {\r\n            newFavs = [...favs, product.id];\r\n        }\r\n        localStorage.setItem(FAVORITES_KEY, JSON.stringify(newFavs));\r\n        setIsFavorite(!isFavorite);\r\n    }, [product, isFavorite]);\r\n\r\n    const addToCart = useCallback(() => {\r\n        if (!product) return;\r\n        const cart = getCart();\r\n        if (!cart.some(i => i.id === product.id)) {\r\n            cart.push(product);\r\n            localStorage.setItem(CART_KEY, JSON.stringify(cart));\r\n            dispatchCartUpdate();\r\n            showToast(isRTL ? 'в•ӘШІв”ҳГ в•ӘШІ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в•ӘШӯв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШұ' : 'Added to cart', 'success');\r\n        }\r\n        setInCart(true);\r\n        setAddedToCart(true);\r\n        setTimeout(() => setAddedToCart(false), 2000);\r\n    }, [product, isRTL, showToast]);\r\n\r\n    const buyViaWhatsapp = useCallback(async () => {\r\n        if (!product) return;\r\n\r\n        const phone = (whatsappNumber || '+821080880014').replace(/\\D/g, '');\r\n        const price = formatPrice ? formatPrice(product.price, product.displayCurrency as 'SAR' | 'USD' | 'KRW' | undefined, product.type) : `${product.price?.toLocaleString()} SAR`;\r\n\r\n        // [[ARABIC_COMMENT]] в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв•ӘШІв•Әв–’в”ҳГЁ в”ҳГ в”ҳВҶ localStorage в•ӘШ«в”ҳГӘ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳВҖ user context\r\n        let buyerName = user?.name || '';\r\n        let buyerPhone = user?.phone || '';\r\n        let buyerEmail = user?.email || '';\r\n\r\n        if (!buyerName && typeof window !== 'undefined') {\r\n            try {\r\n                const userJson = localStorage.getItem('hm_user');\r\n                if (userJson) {\r\n                    const u = JSON.parse(userJson);\r\n                    buyerName = u?.name || '';\r\n                    buyerPhone = u?.phone || '';\r\n                    buyerEmail = u?.email || '';\r\n                }\r\n            } catch (e) { }\r\n        }\r\n\r\n        // [[ARABIC_COMMENT]] в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ в•Әв•‘в”ҳГЁв•ӘШҜв•Әв–’ в”ҳГӘв•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„ - в•ӘШ«в•ӘШөв”ҳГӘв”ҳВ„в”ҳГ§ в”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в”ҳГўв”ҳГӘв”ҳВҶв•Әв”Ӯв”ҳГЁв•Әв–’в•ӘШҙ\r\n        if (product.type === 'part' && !buyerName && !buyerPhone) {\r\n            const qp = new URLSearchParams({\r\n                source: 'parts_catalog',\r\n                contactPreference: 'whatsapp',\r\n                partName: product.title || '',\r\n                carName: product.brand || '',\r\n                model: product.compatibility?.[0] || '',\r\n                description: `в•Әв•–в”ҳВ„в•ӘШ° в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ: ${product.title} | в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’: ${price}`,\r\n            });\r\n            window.location.href = `/concierge?${qp.toString()}`;\r\n            return;\r\n        }\r\n\r\n        // [[ARABIC_COMMENT]] в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ° в”ҳВҒв”ҳГЁ в”ҳГ©в•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\r\n        let orderNumber = `HM-${new Date().getFullYear()}-${Math.random().toString(36).substring(2, 7).toUpperCase()}`;\r\n        try {\r\n            const orderRes = await api.orders.create({\r\n                buyerId: user?._id || null,\r\n                items: [{\r\n                    itemType: product.type === 'car' ? 'car' : 'sparePart',\r\n                    refId: product.id,\r\n                    titleSnapshot: product.title,\r\n                    qty: 1,\r\n                    unitPriceSar: product.price\r\n                }],\r\n                pricing: { grandTotalSar: product.price },\r\n                channel: 'whatsapp',\r\n                notes: `${buyerName || 'в•Әв–“в•ӘШҜв•ӘШ®в•Әв–’'} | ${buyerPhone || ''} | ${buyerEmail || ''}`\r\n            });\r\n            if (orderRes?.data?.orderNumber) orderNumber = orderRes.data.orderNumber;\r\n        } catch (err) {\r\n            console.error('Failed to log order:', err);\r\n        }\r\n\r\n        // [[ARABIC_COMMENT]] в•ӘШ°в”ҳВҶв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ - в”ҳВҶв•Әв•Ў в”ҳГ в”ҳГӘв•ӘШөв•ӘВ» в”ҳВ„в”ҳВ„в•ӘШ«в•ӘВ»в”ҳГ в”ҳВҶ в”ҳГӘв•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„\r\n        const now = new Date().toLocaleDateString(isRTL ? 'ar-SA' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' });\r\n\r\n        const itemDetails = product.type === 'car'\r\n            ? `вүЎШ§ШЈГ№ *в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ: ${product.title}*\\nвүЎШ§ВҸШө в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•Әв–’в”ҳГўв•ӘШұ: ${product.make || 'ШёВҖВӨ'} | в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„: ${product.model || 'ШёВҖВӨ'}\\nвүЎШ§ГҙГ  в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҶв•ӘШұ: ${product.year || 'ШёВҖВӨ'} | в•ӘШҜв”ҳВ„в”ҳВ„в”ҳГӘв”ҳВҶ: ${product.color || 'ШёВҖВӨ'}`\r\n            : `вүЎШ§ВӨШҜ *в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ в•Әв•‘в”ҳГЁв•ӘШҜв•Әв–’: ${product.title}*\\nвүЎШ§ВҸШө в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШұ: ${product.brand || 'ШёВҖВӨ'}\\nвүЎШ§ГҙШ® в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ: ${product.condition === 'New' ? 'в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»' : product.condition || 'ШёВҖВӨ'}\\nвүЎШ§ШЈГ№ в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ: ${product.compatibility?.join('в•ӘГ® ') || 'ШёВҖВӨ'}`;\r\n\r\n        // в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в”ҳГ в”ҳВҶ (в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ - в•ӘВ»в•ӘШҜв•ӘВ«в”ҳВ„в”ҳГЁв•ӘШұ)\r\n        const adminMsg = [\r\n            `вүЎШ§ВӨВӨ *в•Әв•–в”ҳВ„в•ӘШ° в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ» - ${orderNumber}*`,\r\n            `ШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒ`,\r\n            `вүЎШ§ГҙГҜ *в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ°:*`,\r\n            itemDetails,\r\n            ``,\r\n            `вүЎШ§Щ‘Ш¬ *в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„:*`,\r\n            `в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ : ${buyerName || 'ШёВҖВӨ'}`,\r\n            `в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ: ${buyerPhone || 'ШёВҖВӨ'}`,\r\n            `в•ӘШҜв”ҳВ„в•ӘШӯв”ҳГЁв”ҳГ в”ҳГЁв”ҳВ„: ${buyerEmail || 'ШёВҖВӨ'}`,\r\n            ``,\r\n            `вүЎШ§Щ’в–‘ *в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’: ${price}*`,\r\n            `вүЎШ§ГҙГ  в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв•Әв–’в”ҳГЁв•ӘВ«: ${now}`,\r\n            `ШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒ`,\r\n            `ШёВЈГ  в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Ј в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„ в”ҳВ„в”ҳВ„в•ӘШІв•ӘШ«в”ҳГўв”ҳГЁв•ӘВ»`\r\n        ].join('\\n');\r\n\r\n        // в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„ (в”ҳВ„в”ҳВ„в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ° в•ӘШҜв”ҳВ„в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в”ҳГЁ)\r\n        const clientMsg = isRTL\r\n            ? [\r\n                `в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШҜв”ҳГ  в•Әв•Јв”ҳВ„в”ҳГЁв”ҳГўв”ҳГ  вүЎШ§Щ‘ГҜ`,\r\n                ``,\r\n                `вүЎШ§ШӨЩ’ *в•Әв•–в”ҳВ„в•ӘШ° в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»*`,\r\n                `ШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒ`,\r\n                itemDetails,\r\n                ``,\r\n                `вүЎШ§Щ’в–‘ *в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’: ${price}*`,\r\n                `вүЎШ§ВӨГ» в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ°: ${orderNumber}`,\r\n                `вүЎШ§ГҙГ  в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв•Әв–’в”ҳГЁв•ӘВ«: ${now}`,\r\n                `ШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒ`,\r\n                `в•ӘШ«в•Әв–’в•ӘШҙв”ҳГӘ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳВ„в”ҳВ„в•ӘШҜв•ӘШІв”ҳВҒв•ӘШҜв”ҳГ© в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ вүЎШ§Ш¬ШҘ`\r\n            ].join('\\n')\r\n            : [\r\n                `Hello вүЎШ§Щ‘ГҜ`,\r\n                ``,\r\n                `вүЎШ§ШӨЩ’ *New Purchase Request*`,\r\n                `ШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒ`,\r\n                product.type === 'car'\r\n                    ? `вүЎШ§ШЈГ№ *Car: ${product.title}*\\nвүЎШ§ВҸШө Make: ${product.make || 'ШёВҖВӨ'} | Model: ${product.model || 'ШёВҖВӨ'}\\nвүЎШ§ГҙГ  Year: ${product.year || 'ШёВҖВӨ'} | Color: ${product.color || 'ШёВҖВӨ'}`\r\n                    : `вүЎШ§ВӨШҜ *Part: ${product.title}*\\nвүЎШ§ВҸШө Brand: ${product.brand || 'ШёВҖВӨ'}\\nвүЎШ§ГҙШ® Condition: ${product.condition || 'ШёВҖВӨ'}`,\r\n                ``,\r\n                `вүЎШ§Щ’в–‘ *Price: ${price}*`,\r\n                `вүЎШ§ВӨГ» Order No: ${orderNumber}`,\r\n                `вүЎШ§ГҙГ  Date: ${now}`,\r\n                `ШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒШёВӨВҒ`,\r\n                `Please contact me to finalize вүЎШ§Ш¬ШҘ`\r\n            ].join('\\n');\r\n\r\n        // [[ARABIC_COMMENT]] в”ҳВҒв•ӘШІв•ӘШө в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ° в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в”ҳГ в”ҳВҶ в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв”ҳГҜ в”ҳВҒв”ҳГЁ в”ҳВҶв•ӘШҜв”ҳВҒв•Әв–‘в•ӘШұ в•ӘВ«в”ҳВ„в”ҳВҒв”ҳГЁв•ӘШұ (silent invoice to admin)\r\n        const adminWaUrl = `https://wa.me/${phone}?text=${encodeURIComponent(adminMsg)}`;\r\n        window.open(adminWaUrl, '_blank');\r\n\r\n        // [[ARABIC_COMMENT]] в”ҳВҒв•ӘШІв•ӘШө в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ° в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШ°в•Әв•Јв•ӘВ» в•ӘШів•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ (в”ҳВ„в”ҳВ„в•ӘШҜв•ӘШІв”ҳВҒв•ӘШҜв”ҳГ©)\r\n        setTimeout(() => {\r\n            window.open(`https://wa.me/${phone}?text=${encodeURIComponent(clientMsg)}`, '_blank');\r\n        }, 800);\r\n\r\n        showToast(isRTL ? `ШёВЈГ  в•ӘШІв”ҳГ  в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•Әв•–в”ҳВ„в•ӘШ°в”ҳГў! в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ°: ${orderNumber}` : `ШёВЈГ  Order sent! Order No: ${orderNumber}`, 'success');\r\n    }, [product, whatsappNumber, formatPrice, isRTL, user, showToast]);\r\n\r\n\r\n    const shareProduct = useCallback(() => {\r\n        if (!product) return;\r\n        const url = product.type === 'car'\r\n            ? `${window.location.origin}/showroom/${product.id}`\r\n            : `${window.location.origin}/parts?item=${product.id}`;\r\n        navigator.clipboard.writeText(url).then(() => {\r\n            setCopied(true);\r\n            showToast(isRTL ? 'в•ӘШІв”ҳГ  в”ҳВҶв•Әв”Ӯв•ӘВ« в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в•Әв•–' : 'Link copied', 'success');\r\n            setTimeout(() => setCopied(false), 2000);\r\n        }).catch(() => { });\r\n    }, [product, showToast, isRTL]);\r\n\r\n    // [[ARABIC_COMMENT]] в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГўв•ӘШұ в•Әв•Јв”ҳВ„в”ҳГ« в•Әв”Ӯв”ҳВҶв•ӘШҜв•ӘШ° в•Әв”Өв•ӘШҜв•ӘШІ\r\n    const shareSnapchat = useCallback(() => {\r\n        if (!product) return;\r\n        const url = product.type === 'car'\r\n            ? `${window.location.origin}/showroom/${product.id}`\r\n            : `${window.location.origin}/parts?item=${product.id}`;\r\n        window.open(`https://www.snapchat.com/scan?attachmentUrl=${encodeURIComponent(url)}`, '_blank');\r\n        setShowShareMenu(false);\r\n    }, [product]);\r\n\r\n    // [[ARABIC_COMMENT]] в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГўв•ӘШұ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШІв”ҳГӘв”ҳГЁв•ӘШІв•Әв–’/X\r\n    const shareTwitter = useCallback(() => {\r\n        if (!product) return;\r\n        const url = product.type === 'car'\r\n            ? `${window.location.origin}/showroom/${product.id}`\r\n            : `${window.location.origin}/parts?item=${product.id}`;\r\n        const text = isRTL\r\n            ? `вүЎШ§ШЈГ№ в•Әв”Өв•ӘШҜв”ҳГ§в•ӘВ» в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШІв•ӘШҙ: ${product.title} - ${url}`\r\n            : `вүЎШ§ШЈГ№ Check this out: ${product.title} - ${url}`;\r\n        window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`, '_blank');\r\n        setShowShareMenu(false);\r\n    }, [product, isRTL]);\r\n\r\n    // [[ARABIC_COMMENT]] в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГўв•ӘШұ в•Әв•Јв•ӘШ°в•Әв–’ в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ°\r\n    const shareWhatsapp = useCallback(() => {\r\n        if (!product) return;\r\n        const url = product.type === 'car'\r\n            ? `${window.location.origin}/showroom/${product.id}`\r\n            : `${window.location.origin}/parts?item=${product.id}`;\r\n        const text = isRTL\r\n            ? `вүЎШ§ШЈГ№ в•Әв”Өв•ӘШҜв”ҳГ§в•ӘВ» в”ҳГ§в•Әв–‘в•ӘШҜ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШІв•ӘШҙ в”ҳГ в”ҳВҶ HM CAR:\\n${product.title}\\n${url}`\r\n            : `вүЎШ§ШЈГ№ Check this from HM CAR:\\n${product.title}\\n${url}`;\r\n        window.open(`https://wa.me/?text=${encodeURIComponent(text)}`, '_blank');\r\n        setShowShareMenu(false);\r\n    }, [product, isRTL]);\r\n\r\n    const images = product?.images?.filter(Boolean) || [];\r\n    const displayPrice = product && formatPrice ? formatPrice(product.price, product.displayCurrency as 'SAR' | 'USD' | 'KRW' | undefined, product.type) : `${product?.price?.toLocaleString()} SAR`;\r\n\r\n    return (\r\n        <AnimatePresence>\r\n            {product && (\r\n                // [[ARABIC_COMMENT]] в•ӘВ«в”ҳВ„в”ҳВҒв”ҳГЁв•ӘШұ в•Әв”Өв”ҳВҒв•ӘШҜв”ҳВҒв•ӘШұ в•ӘВ»в•ӘШҜв”ҳГўв”ҳВҶв•ӘШұ - в•ӘШІв”ҳВҸв•Әв•‘в”ҳВ„в”ҳГ© в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в•ӘШ°в•Әв•Ј в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в•Әв•ўв•Әв•‘в•Әв•– в•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ§в•ӘШҜ\r\n                <motion.div\r\n                    initial={{ opacity: 0 }}\r\n                    animate={{ opacity: 1 }}\r\n                    exit={{ opacity: 0 }}\r\n                    className=\"fixed inset-0 z-[200] bg-black/85 backdrop-blur-md flex items-end sm:items-center justify-center p-0 sm:p-4\"\r\n                    onClick={onClose}\r\n                >\r\n                    {/* [[ARABIC_COMMENT]] в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в•ӘШ°в•Әв•Ј в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁ - в”ҳГЁв”ҳГ в”ҳВҶв•Әв•Ј в•ӘШӯв•Әв•‘в”ҳВ„в•ӘШҜв”ҳГ© в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в•ӘШҜв”ҳВ„ в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в•Әв•ўв•Әв•‘в•Әв•– в•ӘВ»в•ӘШҜв•ӘВ«в”ҳВ„в”ҳГ§ */}\r\n                    <motion.div\r\n                        initial={{ opacity: 0, y: 100, scale: 0.95 }}\r\n                        animate={{ opacity: 1, y: 0, scale: 1 }}\r\n                        exit={{ opacity: 0, y: 80, scale: 0.96 }}\r\n                        transition={{ type: 'spring', damping: 28, stiffness: 300 }}\r\n                        onClick={e => e.stopPropagation()}\r\n                        className=\"relative w-full sm:max-w-2xl bg-[#0c0c0c] border border-white/10 rounded-t-3xl sm:rounded-3xl overflow-hidden max-h-[92vh] sm:max-h-[88vh] flex flex-col\"\r\n                        dir={isRTL ? 'rtl' : 'ltr'}\r\n                    >\r\n                        {/* [[ARABIC_COMMENT]] в•Әв”Өв•Әв–’в”ҳГЁв•Әв•– в•ӘШҜв”ҳВ„в•ӘШӯв”ҳГ в•Әв”Ӯв•ӘШҜв”ҳГў в•ӘШҜв”ҳВ„в•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ в•Әв•Јв”ҳВ„в”ҳГ« в”ҳГ в”ҳГӘв•ӘШ°в•ӘШҜв”ҳГЁв”ҳВ„ */}\r\n                        <div className=\"sm:hidden w-12 h-1 bg-white/20 rounded-full mx-auto mt-3 mb-1 shrink-0\" />\r\n\r\n                        {/* [[ARABIC_COMMENT]] в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•‘в”ҳВ„в•ӘШҜв”ҳГ© */}\r\n                        <button\r\n                            onClick={onClose}\r\n                            className=\"absolute top-4 right-4 z-30 w-9 h-9 rounded-full bg-black/60 border border-white/10 flex items-center justify-center text-white/50 hover:text-white hover:bg-black/80 transition-all backdrop-blur-sm\"\r\n                            aria-label=\"Close\"\r\n                        >\r\n                            <X className=\"w-4 h-4\" />\r\n                        </button>\r\n\r\n                        {/* [[ARABIC_COMMENT]] в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГўв•ӘШұ - в”ҳГЁв”ҳВҒв•ӘШІв•ӘШө в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘВ«в”ҳГЁв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ */}\r\n                        <div className=\"absolute top-4 left-4 z-30\">\r\n                            <button\r\n                                onClick={() => setShowShareMenu(p => !p)}\r\n                                className=\"w-9 h-9 rounded-full bg-black/60 border border-white/10 flex items-center justify-center text-white/50 hover:text-white hover:bg-black/80 transition-all backdrop-blur-sm\"\r\n                                aria-label=\"Share\"\r\n                            >\r\n                                {copied ? <Check className=\"w-4 h-4 text-green-400\" /> : <Share2 className=\"w-4 h-4\" />}\r\n                            </button>\r\n                            {/* в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГўв•ӘШұ */}\r\n                            {showShareMenu && (\r\n                                <div className=\"absolute top-11 left-0 bg-[#111] border border-white/10 rounded-2xl p-2 shadow-2xl min-w-[170px] space-y-1 z-50 backdrop-blur-md\">\r\n                                    <button onClick={shareWhatsapp} className=\"w-full flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/5 transition-all text-left\">\r\n                                        <span className=\"text-xl\">вүЎШ§Щ’Шҙ</span>\r\n                                        <span className=\"text-[11px] font-black uppercase tracking-widest text-white/70\">{isRTL ? 'в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ°' : 'WhatsApp'}</span>\r\n                                    </button>\r\n                                    <button onClick={shareSnapchat} className=\"w-full flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/5 transition-all text-left\">\r\n                                        <span className=\"text-xl\">вүЎШ§Щ‘в•—</span>\r\n                                        <span className=\"text-[11px] font-black uppercase tracking-widest text-white/70\">{isRTL ? 'в•Әв”Ӯв”ҳВҶв•ӘШҜв•ӘШ° в•Әв”Өв•ӘШҜв•ӘШІ' : 'Snapchat'}</span>\r\n                                    </button>\r\n                                    <button onClick={shareTwitter} className=\"w-full flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/5 transition-all text-left\">\r\n                                        <span className=\"text-xl\">вүЎШҘЩҖВҸ</span>\r\n                                        <span className=\"text-[11px] font-black uppercase tracking-widest text-white/70\">{isRTL ? 'в•ӘШІв”ҳГӘв”ҳГЁв•ӘШІв•Әв–’/X' : 'X / Twitter'}</span>\r\n                                    </button>\r\n                                    <button onClick={shareProduct} className=\"w-full flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/5 transition-all text-left border-t border-white/5 mt-1 pt-3\">\r\n                                        <Copy className=\"w-4 h-4 text-white/40\" />\r\n                                        <span className=\"text-[11px] font-black uppercase tracking-widest text-white/70\">{isRTL ? 'в”ҳВҶв•Әв”Ӯв•ӘВ« в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в•Әв•–' : 'Copy Link'}</span>\r\n                                    </button>\r\n                                </div>\r\n                            )}\r\n                        </div>\r\n\r\n                        {/* [[ARABIC_COMMENT]] в”ҳГ©в•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•Әв–’ */}\r\n                        <div className=\"relative bg-black h-60 shrink-0\">\r\n                            {images.length > 0 ? (\r\n                                <>\r\n                                    <Image\r\n                                        src={images[activeImg]}\r\n                                        alt={product.title}\r\n                                        fill\r\n                                        sizes=\"(max-width: 640px) 100vw, 640px\"\r\n                                        quality={75}\r\n                                        priority\r\n                                        className=\"object-cover\"\r\n                                    />\r\n                                    {/* [[ARABIC_COMMENT]] в•ӘШІв•ӘВ»в•Әв–’в•ӘШҙ в”ҳВ„в”ҳГӘв”ҳВҶв”ҳГЁ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв”ҳВҒв”ҳВ„ в”ҳВ„в•ӘВ»в”ҳГ в•ӘШҙ в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•Әв–’в•ӘШұ в”ҳГ в•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ« */}\r\n                                    <div className=\"absolute inset-0 bg-gradient-to-t from-[#0c0c0c] via-transparent to-transparent\" />\r\n\r\n                                    {/* [[ARABIC_COMMENT]] в•ӘШ«в•Әв–“в•Әв–’в•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв”ҳГ©в”ҳВ„ в•ӘШ°в”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•Әв–’ */}\r\n                                    {images.length > 1 && (\r\n                                        <>\r\n                                            <button\r\n                                                onClick={() => setActiveImg(p => (p - 1 + images.length) % images.length)}\r\n                                                title={isRTL ? 'в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГ©в•ӘШұ' : 'Previous image'}\r\n                                                className=\"absolute left-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-black/60 backdrop-blur-sm border border-white/10 flex items-center justify-center text-white hover:bg-black/80 transition-all\"\r\n                                            >\r\n                                                <ChevronLeft className=\"w-4 h-4\" />\r\n                                            </button>\r\n                                            <button\r\n                                                onClick={() => setActiveImg(p => (p + 1) % images.length)}\r\n                                                title={isRTL ? 'в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ' : 'Next image'}\r\n                                                className=\"absolute right-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-black/60 backdrop-blur-sm border border-white/10 flex items-center justify-center text-white hover:bg-black/80 transition-all\"\r\n                                            >\r\n                                                <ChevronRight className=\"w-4 h-4\" />\r\n                                            </button>\r\n\r\n                                            {/* [[ARABIC_COMMENT]] в”ҳВҶв”ҳГ©в•ӘШҜв•Әв•– в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв”ҳГ©в”ҳВ„ */}\r\n                                            <div className=\"absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5\">\r\n                                                {images.map((_, i) => (\r\n                                                    <button\r\n                                                        key={i}\r\n                                                        onClick={() => setActiveImg(i)}\r\n                                                        title={isRTL ? `в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•Әв–’в•ӘШұ ${i + 1}` : `View image ${i + 1}`}\r\n                                                        className={`w-1.5 h-1.5 rounded-full transition-all ${i === activeImg ? 'bg-[#c9a96e] w-4' : 'bg-white/30'}`}\r\n                                                    />\r\n                                                ))}\r\n                                            </div>\r\n                                        </>\r\n                                    )}\r\n                                </>\r\n                            ) : (\r\n                                <div className=\"w-full h-full flex items-center justify-center bg-white/5\">\r\n                                    <CarIcon className=\"w-16 h-16 text-white/10\" />\r\n                                </div>\r\n                            )}\r\n\r\n                            {/* [[ARABIC_COMMENT]] в•Әв•Ўв”ҳГӘв•Әв–’ в”ҳГ в•Әв•Ўв•Әв•‘в•Әв–’в•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв”ҳВҒв”ҳВ„ */}\r\n                            {images.length > 1 && (\r\n                                <div className=\"absolute bottom-10 left-0 right-0 px-4\">\r\n                                    <div className=\"flex gap-2 overflow-x-auto pb-1 scrollbar-none\">\r\n                                        {images.map((img, i) => (\r\n                                            <button\r\n                                                key={i}\r\n                                                onClick={() => setActiveImg(i)}\r\n                                                title={isRTL ? `в•ӘШІв•Әв•Ўв•Әв•‘в”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•Әв–’в•ӘШұ ${i + 1}` : `Thumbnail ${i + 1}`}\r\n                                                className={`relative w-10 h-10 shrink-0 rounded-lg overflow-hidden border-2 transition-all ${i === activeImg ? 'border-[#c9a96e]' : 'border-transparent opacity-50'}`}\r\n                                            >\r\n                                                <Image src={img} alt=\"\" fill sizes=\"40px\" quality={50} className=\"object-cover\" />\r\n                                            </button>\r\n                                        ))}\r\n                                    </div>\r\n                                </div>\r\n                            )}\r\n                        </div>\r\n\r\n                        {/* [[ARABIC_COMMENT]] в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШІв•ӘШҙ - в”ҳГ©в•ӘШҜв•ӘШ°в”ҳВ„ в”ҳВ„в”ҳВ„в•ӘШІв”ҳГ в•Әв–’в”ҳГЁв•Әв–’ */}\r\n                        <div className=\"overflow-y-auto flex-1\">\r\n                            <div className=\"p-5 space-y-4\">\r\n\r\n                                {/* [[ARABIC_COMMENT]] в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•Әв–’в”ҳГўв•ӘШұ в”ҳГӘв•ӘШҜв”ҳВ„в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в”ҳГӘв•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’ */}\r\n                                <div>\r\n                                    <div className=\"text-[10px] font-black text-[#c9a96e]/70 uppercase tracking-[0.3em] mb-1\">\r\n                                        {product.type === 'car' ? (product.make || '') : (product.brand || '')}\r\n                                    </div>\r\n                                    <h2 className=\"text-xl font-black uppercase tracking-tight text-white leading-tight\">\r\n                                        {product.title}\r\n                                    </h2>\r\n                                    <div className=\"text-2xl font-black text-[#c9a96e] mt-2\">\r\n                                        {displayPrice}\r\n                                    </div>\r\n                                </div>\r\n\r\n                                {/* [[ARABIC_COMMENT]] в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВҒв•ӘШҜв•ӘШІ в”ҳВ„в”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ */}\r\n                                {product.type === 'car' && (\r\n                                    <div className=\"grid grid-cols-3 gap-2\">\r\n                                        {[\r\n                                            { icon: Calendar, label: isRTL ? 'в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҶв•ӘШұ' : 'YEAR', value: product.year },\r\n                                            { icon: Gauge, label: isRTL ? 'в”ҳГўв”ҳГЁв”ҳВ„в”ҳГӘв”ҳГ в•ӘШІв•Әв–’' : 'KM', value: product.mileage ? `${Number(product.mileage).toLocaleString()}` : 'ШёВҖВӨ' },\r\n                                            { icon: Fuel, label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в”ҳГӘв•ӘВ»' : 'FUEL', value: product.fuelType || 'ШёВҖВӨ' },\r\n                                            { icon: Settings2, label: isRTL ? 'в”ҳВҶв•ӘШҜв”ҳГ©в”ҳВ„' : 'TRANS', value: product.transmission || 'ШёВҖВӨ' },\r\n                                            { icon: Tag, label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳВ„в”ҳГӘв”ҳВҶ' : 'COLOR', value: product.color || 'ШёВҖВӨ' },\r\n                                            { icon: CarIcon, label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШ®в•ӘШұ' : 'CAT', value: product.category || 'ШёВҖВӨ' },\r\n                                        ].filter(s => s.value && s.value !== 'ШёВҖВӨ').map((spec, i) => (\r\n                                            <div key={i} className=\"bg-white/[0.03] border border-white/5 rounded-xl p-2.5 space-y-1\">\r\n                                                <spec.icon className=\"w-3 h-3 text-[#c9a96e]/50\" />\r\n                                                <div className=\"text-[8px] font-black uppercase tracking-widest text-white/25\">{spec.label}</div>\r\n                                                <div className=\"text-[11px] font-bold text-white/70 truncate\">{String(spec.value)}</div>\r\n                                            </div>\r\n                                        ))}\r\n                                    </div>\r\n                                )}\r\n\r\n                                {/* [[ARABIC_COMMENT]] в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ в•ӘШҜв”ҳВ„в•Әв•‘в”ҳГЁв•ӘШҜв•Әв–’ */}\r\n                                {product.type === 'part' && (\r\n                                    <div className=\"space-y-2\">\r\n                                        {product.condition && (\r\n                                            <div className=\"flex items-center gap-2\">\r\n                                                <span className=\"text-[9px] font-black uppercase tracking-widest text-white/30\">{isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ:' : 'CONDITION:'}</span>\r\n                                                <span className={`text-[10px] font-black px-2 py-0.5 rounded-full ${product.condition === 'NEW' ? 'bg-green-500/20 text-green-400' : product.condition === 'USED' ? 'bg-yellow-500/20 text-yellow-400' : 'bg-blue-500/20 text-blue-400'}`}>\r\n                                                    {product.condition === 'NEW' ? (isRTL ? 'в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»' : 'NEW') : product.condition === 'USED' ? (isRTL ? 'в”ҳГ в•Әв”Ӯв•ӘШІв•Әв•Јв”ҳГ в”ҳВ„' : 'USED') : (isRTL ? 'в”ҳГ в•ӘШҙв•ӘВ»в•ӘВ»' : 'REFURBISHED')}\r\n                                                </span>\r\n                                            </div>\r\n                                        )}\r\n                                        {product.compatibility && product.compatibility.length > 0 && (\r\n                                            <div>\r\n                                                <div className=\"text-[9px] font-black uppercase tracking-widest text-white/30 mb-1\">{isRTL ? 'в”ҳГ в•ӘШІв”ҳГӘв•ӘШҜв”ҳВҒв”ҳГ© в”ҳГ в•Әв•Ј:' : 'COMPATIBLE WITH:'}</div>\r\n                                                <div className=\"flex flex-wrap gap-1\">\r\n                                                    {product.compatibility.map((c, i) => (\r\n                                                        <span key={i} className=\"text-[10px] bg-white/5 border border-white/10 px-2 py-0.5 rounded-full text-white/60\">{c}</span>\r\n                                                    ))}\r\n                                                </div>\r\n                                            </div>\r\n                                        )}\r\n                                        {product.stock !== undefined && (\r\n                                            <div className=\"text-[10px] text-white/40\">\r\n                                                {isRTL ? `в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв”ҳГӘв”ҳВҒв•Әв–’: ${product.stock} в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ` : `In Stock: ${product.stock} units`}\r\n                                            </div>\r\n                                        )}\r\n                                    </div>\r\n                                )}\r\n\r\n                                {/* [[ARABIC_COMMENT]] в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳВҒ */}\r\n                                {product.description && (\r\n                                    <div className=\"bg-white/[0.02] border border-white/5 rounded-xl p-4\">\r\n                                        <div className=\"text-[9px] font-black uppercase tracking-widest text-white/25 mb-2\">{isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳВҒ' : 'DESCRIPTION'}</div>\r\n                                        <p className=\"text-white/55 text-sm leading-relaxed\">{product.description}</p>\r\n                                    </div>\r\n                                )}\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* [[ARABIC_COMMENT]] в•ӘШҜв”ҳВ„в•ӘШ«в•Әв–“в•Әв–’в•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҒв”ҳВ„в”ҳГЁв•ӘШұ - в•ӘШів•ӘШҜв•ӘШ°в•ӘШІв•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв”ҳВҒв”ҳВ„ */}\r\n                        <div className=\"shrink-0 p-4 border-t border-white/5 bg-[#0c0c0c] space-y-3\">\r\n                            {/* [[ARABIC_COMMENT]] в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁ */}\r\n                            <motion.button\r\n                                whileHover={{ scale: 1.02 }}\r\n                                whileTap={{ scale: 0.98 }}\r\n                                onClick={buyViaWhatsapp}\r\n                                className=\"w-full py-4 bg-green-500 hover:bg-green-400 rounded-2xl text-black font-black uppercase text-[12px] tracking-[0.25em] shadow-[0_0_30px_rgba(34,197,94,0.35)] hover:shadow-[0_0_50px_rgba(34,197,94,0.5)] transition-all flex items-center justify-center gap-2.5\"\r\n                            >\r\n                                <MessageCircle className=\"w-5 h-5\" />\r\n                                {isRTL ? 'в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в•Әв•Јв•ӘШ°в•Әв–’ в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ°' : 'BUY VIA WHATSAPP'}\r\n                            </motion.button>\r\n\r\n                            {/* [[ARABIC_COMMENT]] в•ӘШ«в•Әв–“в•Әв–’в•ӘШҜв•Әв–’ в•ӘШів•ӘШҜв”ҳВҶв”ҳГӘв”ҳГЁв•ӘШұ: в•Әв”Ӯв”ҳВ„в•ӘШұ + в”ҳГ в”ҳВҒв•Әв•ўв”ҳВ„в•ӘШұ */}\r\n                            <div className=\"flex gap-3\">\r\n                                {/* [[ARABIC_COMMENT]] в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШұ */}\r\n                                <motion.button\r\n                                    whileHover={{ scale: 1.03 }}\r\n                                    whileTap={{ scale: 0.97 }}\r\n                                    onClick={addToCart}\r\n                                    className={`flex-1 py-3.5 rounded-2xl font-black text-[11px] uppercase tracking-[0.2em] flex items-center justify-center gap-2 transition-all border ${inCart || addedToCart\r\n                                        ? 'bg-[#c9a96e]/20 border-[#c9a96e]/40 text-[#c9a96e]'\r\n                                        : 'bg-white/5 border-white/10 text-white/70 hover:bg-white/10 hover:border-white/20'\r\n                                        }`}\r\n                                >\r\n                                    {addedToCart ? (\r\n                                        <><Check className=\"w-4 h-4 text-green-400\" />{isRTL ? 'в•ӘШІв”ҳГ в•ӘШІ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ ШёВЈГҙ' : 'Added ШёВЈГҙ'}</>\r\n                                    ) : inCart ? (\r\n                                        <><ShoppingCart className=\"w-4 h-4\" />{isRTL ? 'в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШұ' : 'In Cart'}</>\r\n                                    ) : (\r\n                                        <><ShoppingCart className=\"w-4 h-4\" />{isRTL ? 'в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШұ' : 'Add to Cart'}</>\r\n                                    )}\r\n                                </motion.button>\r\n\r\n                                {/* [[ARABIC_COMMENT]] в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҒв•Әв•ўв”ҳВ„в•ӘШұ */}\r\n                                <motion.button\r\n                                    whileHover={{ scale: 1.1 }}\r\n                                    whileTap={{ scale: 0.9 }}\r\n                                    onClick={toggleFavorite}\r\n                                    className={`w-14 h-12 rounded-2xl border flex items-center justify-center transition-all ${isFavorite\r\n                                        ? 'bg-red-500/20 border-red-500/40 text-red-400 shadow-[0_0_20px_rgba(239,68,68,0.2)]'\r\n                                        : 'bg-white/5 border-white/10 text-white/40 hover:text-red-400 hover:border-red-400/30'\r\n                                        }`}\r\n                                    aria-label={isFavorite ? 'Remove from favorites' : 'Add to favorites'}\r\n                                >\r\n                                    <Heart className={`w-5 h-5 transition-all ${isFavorite ? 'fill-red-400 scale-110' : ''}`} />\r\n                                </motion.button>\r\n                            </div>\r\n                        </div>\r\n                    </motion.div>\r\n                </motion.div>\r\n            )}\r\n        </AnimatePresence>\r\n    );\r\n}\r\n\r\n// [[ARABIC_COMMENT]] в•ӘВ»в”ҳГӘв•ӘШҜв”ҳВ„ в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ в”ҳВ„в”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•Әв–’в•ӘШҙв”ҳГЁ\r\nexport { getCart, getFavorites, dispatchCartUpdate, CART_KEY, FAVORITES_KEY };\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\components\\Providers.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\components\\PullToRefresh.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'useEffect' is defined but never used.","line":3,"column":27,"nodeType":"Identifier","messageId":"unusedVar","endLine":3,"endColumn":36,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"useEffect"},"fix":{"range":[39,50],"text":""},"desc":"Remove unused variable \"useEffect\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport React, { useState, useEffect, useRef } from 'react';\nimport { motion, useAnimation } from 'framer-motion';\nimport { RefreshCw } from 'lucide-react';\nimport { useLanguage } from '@/lib/LanguageContext';\n\nexport default function PullToRefresh({ children, onRefresh }: { children: React.ReactNode, onRefresh: () => Promise<void> }) {\n  const [pullY, setPullY] = useState(0);\n  const [refreshing, setRefreshing] = useState(false);\n  const containerRef = useRef<HTMLDivElement>(null);\n  const startYRef = useRef(0);\n  const currentYRef = useRef(0);\n  const controls = useAnimation();\n  const { isRTL } = useLanguage();\n\n  const handleTouchStart = (e: React.TouchEvent) => {\n    if (window.scrollY > 5) return; // Only allow pull when at the very top\n    startYRef.current = e.touches[0].clientY;\n  };\n\n  const handleTouchMove = (e: React.TouchEvent) => {\n    if (window.scrollY > 5 || refreshing) return;\n    currentYRef.current = e.touches[0].clientY;\n    const diff = currentYRef.current - startYRef.current;\n    if (diff > 0) {\n      // Pulling down\n      const newPullY = Math.min(diff * 0.4, 100); // Friction\n      setPullY(newPullY);\n      controls.set({ y: newPullY });\n      if (e.cancelable) e.preventDefault(); // Prevent native browser reload if possible\n    }\n  };\n\n  const handleTouchEnd = async () => {\n    if (refreshing) return;\n    if (pullY > 60) {\n      // Trigger refresh\n      setRefreshing(true);\n      controls.start({ y: 50, transition: { type: 'spring', damping: 20 } });\n      await onRefresh();\n      \n      setRefreshing(false);\n      setPullY(0);\n      controls.start({ y: 0, transition: { type: 'spring', damping: 20 } });\n    } else {\n      // Snap back\n      setPullY(0);\n      controls.start({ y: 0, transition: { type: 'spring', damping: 20 } });\n    }\n  };\n\n  return (\n    <div \n      ref={containerRef}\n      onTouchStart={handleTouchStart} \n      onTouchMove={handleTouchMove} \n      onTouchEnd={handleTouchEnd}\n      className=\"relative w-full\"\n    >\n      <motion.div \n        className=\"absolute top-0 left-0 right-0 flex items-center justify-center -z-10\"\n        animate={controls}\n      >\n        <div className=\"flex items-center gap-2 mt-[-40px] px-4 py-2 bg-[#111] rounded-full border border-white/10 shadow-lg\">\n          <RefreshCw className={`w-4 h-4 text-accent-gold ${refreshing ? 'animate-spin' : ''}`} style={{ transform: `rotate(${pullY * 3}deg)` }} />\n          <span className=\"text-[10px] font-bold text-white/70 tracking-widest uppercase\">\n            {refreshing ? (isRTL ? 'в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі...' : 'REFRESHING...') : (isRTL ? 'в•ӘШҜв•Әв”Ӯв•ӘШөв•ӘШ° в”ҳВ„в”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі' : 'PULL TO REFRESH')}\n          </span>\n        </div>\n      </motion.div>\n      <motion.div animate={controls} 