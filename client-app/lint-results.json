ӘШ°в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШ«в”ҳГӘ в•ӘШ°в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ в”ҳГ в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•Әв•Јв•ӘШ°в•Әв–’ в•Әв–’в”ҳГ в•Әв–“ OTP.\n */\n\nimport { motion, AnimatePresence } from \"framer-motion\";\nimport { useState, useEffect } from \"react\";\nimport { User, ShieldCheck, Lock, ArrowRight, ChevronLeft, ChevronRight, Key, UserCheck, Sparkles, Power, Eye, EyeOff, Phone, AlertOctagon, Copy, MessageCircle } from \"lucide-react\";\nimport Link from \"next/link\";\nimport { cn } from \"@/lib/utils\";\nimport { useLanguage } from \"@/lib/LanguageContext\";\nimport { api } from \"@/lib/api\";\nimport { countryDialCodes } from \"@/lib/countries\";\nimport { useSocket } from \"@/lib/SocketContext\";\nimport { useAuth } from \"@/lib/AuthContext\";\nimport CinematicVideoBackground from \"@/components/CinematicVideoBackground\";\n\nexport default function Login() {\n    const { isRTL } = useLanguage();\n    \n    // --- в•ӘШөв•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•ӘШҙв”ҳГ§в•ӘШұ (States) ---\n    const [role, setRole] = useState<'buyer' | 'admin'>('buyer'); // в•ӘВ»в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁ\n    const [formData, setFormData] = useState({ email: '', password: '' }); // в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШҜв•Әв”Ӯв”ҳГЁв•ӘШұ\n    const [loading, setLoading] = useState(false); // в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„\n    const [error, setError] = useState(''); // в•Әв–’в•Әв”Ӯв•ӘШҜв•ӘШ®в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ«\n    const [rememberMe, setRememberMe] = useState(false); // в•ӘВ«в”ҳГЁв•ӘШҜв•Әв–’ \"в•ӘШІв•Әв–‘в”ҳГўв•Әв–’в”ҳВҶв”ҳГЁ\"\n    const [successMessage, setSuccessMessage] = useState(''); // в•Әв–’в•Әв”Ӯв•ӘШҜв•ӘШ®в”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө\n    const [showPassword, setShowPassword] = useState(false); // в•ӘШӯв•Әв••в”ҳГ§в•ӘШҜв•Әв–’ в•ӘШ«в”ҳГӘ в•ӘШӯв•ӘВ«в”ҳВҒв•ӘШҜв•ӘШ© в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’\n    const [method, setMethod] = useState<'name' | 'phone'>('name'); // в•Әв•–в•Әв–’в”ҳГЁв”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„: в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШ«в”ҳГӘ в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ\n    const [banInfo, setBanInfo] = useState<{ banned: boolean, banCode: string, message: string } | null>(null); // в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШөв•Әв••в•Әв–’ в”ҳВҒв”ҳГЁ в•ӘШөв•ӘШҜв”ҳВ„ в•ӘШІв”ҳГ  в•ӘШөв•Әв••в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв”ҳГ§в•ӘШҜв•Әв–“\n    \n    // --- в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв”ҳВ„ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШ«в•Әв–’в”ҳГ©в•ӘШҜв”ҳГ  ---\n    const countryList = countryDialCodes.map(c => ({ \n        code: c.code, \n        dial: c.dial, \n        name: isRTL ? (c.nameAr || c.nameEn) : c.nameEn \n    }));\n    const [countrySearch, setCountrySearch] = useState(''); // в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі в•Әв•Јв”ҳВҶ в•ӘВ»в”ҳГӘв”ҳВ„в•ӘШұ\n    const [selectedCountry, setSelectedCountry] = useState(countryList[0]); // в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•ӘШІв•ӘШҜв•Әв–’в•ӘШұ в”ҳВ„в”ҳВ„в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв”ҳВ„в”ҳГЁ\n    const [phoneNumber, setPhoneNumber] = useState(''); // в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•ӘВ«в”ҳВ„\n    const [showCountry, setShowCountry] = useState(false); // в•ӘШӯв•Әв••в”ҳГ§в•ӘШҜв•Әв–’ в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв”ҳВ„\n    \n    // --- в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•Әв•Јв•ӘШ°в•Әв–’ OTP ---\n    const [otpRequested, setOtpRequested] = useState(false); // в”ҳГ§в”ҳВ„ в•ӘШІв”ҳГ  в•Әв•–в”ҳВ„в•ӘШ° в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ©в•ӘШ§\n    const [otpCode, setOtpCode] = useState(''); // в•ӘШҜв”ҳВ„в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в•ӘВ«в”ҳВ„ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ \n    const [showRoleSwitcher, setShowRoleSwitcher] = useState(false); // в•ӘШӯв•Әв••в”ҳГ§в•ӘШҜв•Әв–’ в”ҳГ в•ӘШөв”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в”ҳГӘв•ӘШҜв•Әв–’ (в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„/в”ҳГ в•ӘВ»в”ҳГЁв•Әв–’)\n\n    const { socket, isConnected } = useSocket();\n    const { user } = useAuth();\n    const DEV_FAKE = process.env.NEXT_PUBLIC_ENABLE_DEV_ADMIN === '1';\n\n    // в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в”ҳВ„в”ҳВ„в”ҳГ в•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГӘв”ҳВ„в”ҳГ«\n    useEffect(() => {\n        try {\n            const isStandalone = window.matchMedia('(display-mode: standalone)').matches || (window.navigator as any).standalone === true;\n\n            const path = typeof window !== 'undefined' ? window.location.pathname : '';\n            const sp = typeof window !== 'undefined' ? new URLSearchParams(window.location.search) : null;\n            \n            // в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ в”ҳГЁв”ҳГЁв•Әв–“ в•ӘШ°в”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГЁв•ӘШ° в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШІв•Әв•–в•ӘШ°в”ҳГЁв”ҳГ©\n            if (!isStandalone) {\n                // в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Јв•ӘГ® в”ҳВҶв•Әв••в”ҳГ§в•Әв–’ в”ҳГ в•ӘШөв”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в”ҳГӘв•ӘШҜв•Әв–’ в•ӘВ»в•ӘШҜв•ӘШ®в”ҳГ в•ӘШҜв”ҳГҜ\n                setShowRoleSwitcher(true);\n                if (path.includes('/admin/login') || sp?.get('role') === 'admin') {\n                    setRole('admin');\n                }\n            } else {\n                // в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв•Әв•–в•ӘШ°в”ҳГЁв”ҳГ©в•ӘГ® в”ҳВҶв•ӘШ°в•ӘВ»в•ӘШ« в”ҳГўв•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„ в”ҳВҒв”ҳГӘв•Әв–’в•ӘШҜв”ҳГҜ в”ҳГӘв”ҳВҶв•ӘВ«в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв”ҳГӘв”ҳВ„\n                setRole('buyer');\n                setShowRoleSwitcher(false);\n            }\n        } catch { }\n    }, []);\n\n    // в•ӘШІв•ӘШІв•ӘШ°в•Әв•Ј в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„ в”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳГӘв•ӘШӯв•ӘШ°в”ҳВ„в•ӘШҜв•Әв•‘ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в”ҳГ в”ҳВҶ\n    useEffect(() => {\n        if (socket && isConnected) {\n            socket.emit('user_navigation', {\n                userName: user?.name || (isRTL ? 'в•Әв–“в•ӘШҜв•ӘШ®в•Әв–’' : 'Guest'),\n                page: isRTL ? 'в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„' : 'Login Page',\n                timestamp: new Date()\n            });\n        }\n    }, [socket, isConnected, isRTL, user]);\n\n    /**\n     * в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШұ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в•Әв•ўв•Әв•‘в•Әв•– в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•Әв–“в•Әв–’\n     */\n    const handleLogin = async (e: React.FormEvent) => {\n        e.preventDefault();\n        setLoading(true);\n        setError('');\n        setSuccessMessage('');\n\n        try {\n            let response;\n            const deviceId = typeof window !== 'undefined' ? localStorage.getItem('hm_device_id') || '' : '';\n\n            const identifier = formData.email.trim();\n            \n            // --- в•ӘШ«в”ҳГӘв”ҳВ„в•ӘШҜв”ҳГҜ: в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ»в”ҳГЁв•Әв–’ ---\n            if (role === 'admin') {\n                response = await api.auth.login({\n                    identifier: identifier,\n                    password: formData.password,\n                    role,\n                    rememberMe,\n                    deviceId\n                });\n            } else {\n                // --- в•ӘШів•ӘШҜв”ҳВҶв”ҳГЁв•ӘШҜв”ҳГҜ: в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„ ---\n\n                // в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•Әв•Ўв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳГўв•ӘШҜв”ҳВҶв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•–в•Әв–’в”ҳГЁв”ҳГ©в•ӘШұ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ \n                if (method === 'name') {\n                    const parts = identifier.split(/\\s+/).filter(Boolean);\n                    if (parts.length < 2) {\n                        throw new Error('в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в”ҳГЁв”ҳГўв”ҳГӘв”ҳВҶ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ©в”ҳВ„ в•ӘШҜв•Әв”Ӯв”ҳГ в”ҳГЁв”ҳВҶ');\n                    }\n                } else {\n                    // в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•Әв•Ўв•ӘШөв•ӘШұ в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ\n                    const digits = phoneNumber.replace(/\\D/g, '');\n                    if (digits.length < 8 || digits.length > 15) {\n                        throw new Error('в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Ўв•ӘШҜв”ҳВ„в•ӘШө');\n                    }\n                }\n                \n                // в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•Әв•–в”ҳГӘв”ҳВ„ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’\n                if (formData.password.length < 6) {\n                    throw new Error('в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШ«в”ҳВҶ в•ӘШІв”ҳГўв”ҳГӘв”ҳВҶ 6 в•ӘВ«в•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ©в”ҳВ„');\n                }\n\n                const phoneE164 = `${selectedCountry.dial}${phoneNumber.replace(/\\D/g, '')}`;\n\n                // в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ в•Әв•–в”ҳВ„в•ӘШ° в•Әв–’в”ҳГ в•Әв–“ OTP в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳВ„в”ҳГ  в”ҳГЁв•Әв•–в”ҳВ„в•ӘШ° в•ӘШ°в•Әв•Јв•ӘВ» (в”ҳВҒв”ҳГЁ в•ӘШөв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ)\n                if (method === 'phone' && !otpRequested) {\n                    try {\n                        await api.auth.sendOtp({ phone: phoneE164 });\n                        setSuccessMessage(isRTL ? 'в•ӘШІв”ҳГ§в•ӘШҜв”ҳВҶв”ҳГЁв”ҳВҶв•ӘШҜв•ӘГ® в•ӘШІв”ҳГ  в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•ӘШӯв”ҳВ„в”ҳГ« в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒв”ҳГў' : 'Verification code sent to your phone');\n                        setOtpRequested(true);\n                        setLoading(false);\n                        return;\n                    } catch (err: any) {\n                        setError(err.message || (isRTL ? 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ©' : 'Failed to send OTP'));\n                        setLoading(false);\n                        return;\n                    }\n                }\n\n                // в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•Әв–’в”ҳГ в•Әв–“ OTP в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳГўв•ӘШҜв”ҳВҶ в”ҳГ в•Әв•–в”ҳВ„в”ҳГӘв•ӘШ°в•ӘШҜв”ҳГҜ\n                if (method === 'phone' && otpRequested) {\n                    if (!otpCode || otpCode.replace(/\\D/g, '').length < 4) {\n                        throw new Error(isRTL ? 'в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•ӘШҜв”ҳВ„в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШө' : 'Enter valid verification code');\n                    }\n                    try {\n                        await api.auth.verifyOtp({ phone: phoneE164, code: otpCode });\n                    } catch (err: any) {\n                        throw new Error(err.message || (isRTL ? 'в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШөв•ӘГ® в•ӘШ«в”ҳГӘ в•ӘШҜв”ҳВҶв•ӘШІв”ҳГ§в•ӘШІ в•Әв•Ўв”ҳВ„в•ӘШҜв•ӘШөв”ҳГЁв•ӘШІв”ҳГ§' : 'Invalid or expired verification code'));\n                    }\n                }\n\n                // в•ӘШІв”ҳВҶв”ҳВҒв”ҳГЁв•Әв–‘ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁ в•ӘШ«в”ҳГӘ в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШҜв•ӘВ»в”ҳГЁ в”ҳВ„в”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„\n                response = await api.auth.autoLogin({\n                    name: method === 'name' ? identifier : phoneE164,\n                    password: formData.password,\n                    deviceId\n                });\n            }\n\n            if (response.success) {\n                // в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв”ҳГўв”ҳВҶ в”ҳГӘв•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШІв•ӘВ«в•Әв–“в”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв”ҳВ„в”ҳГЁ (LocalStorage)\n                localStorage.setItem('hm_token', response.token);\n                localStorage.setItem('hm_user', JSON.stringify(response.user));\n                const savedRole = response.user?.role || 'buyer';\n                localStorage.setItem('hm_user_role', savedRole);\n\n                // в•ӘШөв”ҳВҒв•Әв•• в”ҳВҒв”ҳГЁ Cookie в”ҳВ„в”ҳВ„в”ҳВҖ middleware - в”ҳВ„в•Әв•ўв”ҳГ в•ӘШҜв”ҳВҶ в•ӘШөв”ҳГ в•ӘШҜв”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в”ҳГ в”ҳВҶ в•ӘШҙв”ҳГ§в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ  (Server-side)\n                const maxAge = rememberMe ? 604800 : 86400; // в•ӘШ«в•Әв”Ӯв•ӘШ°в”ҳГӘв•Әв•Ј в”ҳВҒв”ҳГЁ в•ӘШөв•ӘШҜв”ҳВ„ в•ӘШІв•Әв–‘в”ҳГўв•Әв–’в”ҳВҶв”ҳГЁв•ӘГ® в•ӘШ«в”ҳГӘ в”ҳГЁв”ҳГӘв”ҳГ  в”ҳГӘв•ӘШҜв•ӘШөв•ӘВ»\n                document.cookie = `hm_token=${response.token}; path=/; max-age=${maxAge}; SameSite=Lax`;\n                document.cookie = `hm_user_role=${savedRole}; path=/; max-age=${maxAge}; SameSite=Lax`;\n                if (response.isNewUser) {\n                    setSuccessMessage(isRTL ? 'в•ӘШІв”ҳГ  в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГў в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө! в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„...' : 'Account created! Logging in...');\n                } else {\n                    setSuccessMessage(isRTL ? 'в•ӘШІв”ҳГ  в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө ШёВЈГҙ' : 'Login successful ШёВЈГҙ');\n                }\n\n                // в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҙв”ҳГЁв”ҳГ§ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁ в•ӘШ°в”ҳВҶв•ӘШҜв•ӘШ©в”ҳГҜ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘВ»в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШ«в”ҳГӘ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв”ҳВ„в”ҳГ в•ӘШұ 'redirect'\n                setTimeout(() => {\n                    const userRole = response.user.role || 'buyer';\n                    const params = new URLSearchParams(window.location.search);\n                    const redirectTo = params.get('redirect');\n                    if (redirectTo && redirectTo.startsWith('/')) {\n                        window.location.href = redirectTo;\n                    } else if (userRole === 'admin' || userRole === 'super_admin' || userRole === 'manager') {\n                        window.location.href = \"/admin/dashboard\";\n                    } else {\n                        // в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳГўв•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„ в”ҳГЁв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•Әв•–в•ӘШ°в”ҳГЁв”ҳГ©в•ӘГ® в”ҳВҶв”ҳГӘв•ӘШҙв”ҳГ§в”ҳГ§ в”ҳВ„в”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘШұ (AppHome) в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ўв•ӘШұ в”ҳВ„в”ҳВ„в•ӘШІв•Әв•–в•ӘШ°в”ҳГЁв”ҳГ©\n                        const isApp = window.matchMedia('(display-mode: standalone)').matches || (window.navigator as any).standalone === true;\n                        window.location.href = isApp ? \"/\" : \"/client/dashboard\";\n                    }\n                }, 400);\n\n            } else {\n                setError(response.error || (isRTL ? 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„' : 'Login failed'));\n                setLoading(false);\n            }\n        } catch (err: any) {\n            if (err.banned) {\n                setBanInfo({ banned: true, banCode: err.banCode, message: err.message || (isRTL ? 'в•ӘШІв”ҳГ  в•ӘШөв•Әв••в•Әв–’ в•ӘШҙв”ҳГ§в•ӘШҜв•Әв–“в”ҳГў' : 'Your device is banned') });\n                setLoading(false);\n                return;\n            }\n\n            const errMsg = err.message || '';\n            const identifier = formData.email.trim();\n            // All other login failures show the error - no local bypass allowed\n            setError(errMsg || (isRTL ? 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„. в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШ«в”ҳГӘ в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘВ»в•Әв•Јв”ҳГ .' : 'Login failed. Check your credentials or contact support.'));\n            setLoading(false);\n        }\n    };\n\n    useEffect(() => {\n        try {\n            const saved = localStorage.getItem('hm_remember');\n            if (saved) {\n                const data = JSON.parse(saved);\n                if (data && typeof data.identifier === 'string' && typeof data.password === 'string') {\n                    // в”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ°в•ӘШҜв•ӘШ° в•ӘШ«в”ҳГ в”ҳВҶв”ҳГЁв•ӘШұ: в”ҳВ„в•ӘШҜ в”ҳВҶв”ҳГ©в”ҳГӘв”ҳГ  в•ӘШ°в•ӘШІв•Әв•Јв•ӘШ°в•ӘШ®в•ӘШұ в”ҳГ в•Әв•Јв•Әв–’в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в”ҳГ в”ҳВҶ в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв”ҳГҜ в•ӘШөв•ӘШІв”ҳГ« в”ҳВ„в•ӘШҜ в”ҳГЁв•Әв–’в•ӘШҜв”ҳГ§ в•ӘШ«в”ҳГЁ в•Әв”Өв•ӘВ«в•Әв•Ў в”ҳГЁв”ҳГ©в”ҳВҒ в•ӘШ°в•ӘШҙв•ӘШҜв”ҳВҶв•ӘШ° в•ӘШҜв”ҳВ„в•Әв”Өв•ӘШҜв•Әв”Өв•ӘШұ\n                    const isSystemAccount = data.role === 'admin' || data.identifier.toLowerCase().includes('admin');\n                    setFormData({\n                        email: isSystemAccount ? '' : data.identifier,\n                        password: data.password\n                    });\n                    setRememberMe(true);\n                    if (data.role) setRole(data.role);\n                }\n            }\n        } catch { }\n    }, []);\n\n    // в•ӘШІв”ҳГ  в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШІв•Әв•Јв•ӘШ°в•ӘШ®в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ в”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в”ҳГ в”ҳВҶ в”ҳВ„в•ӘШ«в•Әв”Ӯв•ӘШ°в•ӘШҜв•ӘШ° в•ӘШ«в”ҳГ в”ҳВҶв”ҳГЁв•ӘШұ\n\n    return (\n        <div className={`relative min-h-screen bg-black text-white flex items-center justify-center p-6 overflow-hidden ${isRTL ? 'font-arabic' : ''}`} dir={isRTL ? 'rtl' : 'ltr'}>\n            {/* в•ӘШҜв”ҳВ„в•ӘВ«в”ҳВ„в”ҳВҒв”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв”ҳВҶв”ҳГ в•ӘШҜв•ӘШ®в”ҳГЁв•ӘШұ - Cinematic Background */}\n            <CinematicVideoBackground\n                videoSrc=\"/videos/video.mp4\"\n                fallbackImage=\"/images/photo_2026-02-07_22-24-18.jpg\"\n                mobileImage=\"/images/hmcar.jpg\"\n                overlayOpacity={0.55}\n            />\n\n            {/* в•ӘШҜв”ҳВ„в”ҳГўв•Әв–’в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•ўв”ҳГӘв•ӘШ®в”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ«в”ҳВ„в”ҳВҒв”ҳГЁв•ӘШұ - AMBIENT ORBS */}\n            <div className=\"fixed inset-0 pointer-events-none z-[1]\">\n                <div className=\"orb orb-gold w-[600px] h-[600px] top-[-200px] right-[-200px] animate-breathe blur-[100px] opacity-30\" />\n                <div className=\"orb orb-blue w-[400px] h-[400px] bottom-[-100px] left-[-100px] animate-breathe delay-1000 blur-[100px] opacity-20\" />\n            </div>\n\n\n\n            {/* в•ӘШ°в•Әв•–в•ӘШҜв”ҳГ©в•ӘШұ в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШ«в”ҳГӘ в•ӘШ°в•Әв•–в•ӘШҜв”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШөв•Әв••в•Әв–’ - LOGIN CARD OR BAN CARD */}\n            <motion.div\n                initial={{ opacity: 0.5, y: 15 }}\n                animate={{ opacity: 1, y: 0 }}\n                transition={{ duration: 0.4, ease: \"easeOut\" }}\n                className=\"relative z-10 w-full max-w-md px-2\"\n            >\n                {banInfo ? (\n                    <div className=\"relative glass-card p-6 sm:p-10 md:p-12 rounded-3xl border border-red-500/20 bg-red-950/20 backdrop-blur-3xl shadow-2xl overflow-hidden\">\n                        <div className=\"absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-transparent via-red-500 to-transparent shadow-[0_0_20px_rgba(239,68,68,0.5)]\"></div>\n                        <div className=\"text-center space-y-6\">\n                            <motion.div\n                                animate={{ scale: [1, 1.1, 1] }}\n                                transition={{ repeat: Infinity, duration: 2 }}\n                                className=\"mx-auto w-20 h-20 bg-red-500/10 rounded-full flex items-center justify-center border border-red-500/20\"\n                            >\n                                <AlertOctagon className=\"w-10 h-10 text-red-500\" />\n                            </motion.div>\n                            <div>\n                                <h2 className=\"text-3xl font-black text-white\">{isRTL ? \"в•ӘШІв”ҳГ  в•ӘШөв•Әв••в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв”ҳГ§в•ӘШҜв•Әв–“\" : \"DEVICE BANNED\"}</h2>\n                                <p className=\"text-white/60 mt-2 text-sm max-w-xs mx-auto text-balance font-medium leading-relaxed\">{banInfo.message}</p>\n                            </div>\n\n                            <div className=\"bg-black/40 p-5 rounded-2xl border border-white/5 space-y-3\">\n                                <span className=\"text-[10px] font-bold text-white/40 uppercase tracking-widest\">{isRTL ? \"в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШөв•Әв••в•Әв–’\" : \"BAN CODE\"}</span>\n                                <div className=\"flex items-center justify-between bg-white/5 rounded-xl p-3 border border-white/10 group hover:border-red-500/30 transition-all\">\n                                    <span className=\"font-mono text-xl tracking-[0.2em] font-bold text-red-400\">{banInfo.banCode}</span>\n                                    <button\n                                        onClick={() => {\n                                            navigator.clipboard.writeText(banInfo.banCode);\n                                            setSuccessMessage(isRTL ? 'в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Ӯв•ӘВ«!' : 'Copied!');\n                                            setTimeout(() => setSuccessMessage(''), 2000);\n                                        }}\n                                        className=\"p-2 hover:bg-white/10 rounded-lg transition-colors text-white/50 hover:text-white\"\n                                        title={isRTL ? \"в”ҳВҶв•Әв”Ӯв•ӘВ« в•ӘШҜв”ҳВ„в•Әв–’в”ҳГ в•Әв–“\" : \"Copy Code\"}\n                                    >\n                                        <Copy className=\"w-5 h-5\" />\n                                    </button>\n                                </div>\n                                {successMessage && <div className=\"text-green-400 text-xs text-center font-bold mt-2\">{successMessage}</div>}\n                            </div>\n\n                            <a\n                                href={`https://wa.me/967781007805?text=${encodeURIComponent(isRTL ? `в”ҳГ в•Әв–’в•ӘШөв•ӘШ°в•ӘШҜв”ҳГҜв•ӘГ® в•ӘШІв”ҳГ  в•ӘШөв•Әв••в•Әв–’ в•ӘШҙв”ҳГ§в•ӘШҜв•Әв–“в”ҳГЁ в”ҳГӘв”ҳГ§в•Әв–‘в•ӘШҜ в”ҳГ§в”ҳГӘ в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШөв•Әв••в•Әв–’:\\n*${banInfo.banCode}*` : `Hello, my device is banned. Ban code:\\n*${banInfo.banCode}*`)}`}\n                                target=\"_blank\"\n                                rel=\"noopener noreferrer\"\n                                className=\"w-full relative overflow-hidden flex items-center justify-center gap-3 py-4 rounded-xl font-bold bg-[#25D366]/10 text-[#25D366] border border-[#25D366]/30 hover:bg-[#25D366] hover:text-black transition-all duration-300\"\n                            >\n                                <MessageCircle className=\"w-5 h-5\" />\n                                {isRTL ? \"в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳВ„в”ҳВҒв”ҳГў в•ӘШҜв”ҳВ„в•ӘШөв•Әв••в•Әв–’\" : \"CONTACT SUPPORT\"}\n                            </a>\n\n                            <button\n                                onClick={() => { setBanInfo(null); setFormData({ email: '', password: '' }); setError(''); }}\n                                className=\"w-full py-3 text-xs font-bold text-white/30 hover:text-white/70 tracking-wider uppercase transition-colors\"\n                            >\n                                {isRTL ? \"в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГӘв•ӘВ»в•ӘШұ в”ҳВ„в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„\" : \"BACK TO LOGIN\"}\n                            </button>\n                        </div>\n                    </div>\n                ) : (\n                    <div className=\"relative glass-card p-6 sm:p-10 md:p-12 rounded-3xl border border-white/10 backdrop-blur-3xl shadow-2xl\">\n                        <motion.div\n                            initial={{ opacity: 0, scale: 0.8 }}\n                            animate={{ opacity: 1, scale: 1 }}\n                            transition={{ delay: 0.4 }}\n                            className={`absolute top-4 ${isRTL ? 'left-4' : 'right-4'} z-20`}\n                        >\n                            <Link href=\"/\">\n                                <motion.div\n                                    whileHover={{ scale: 1.1 }}\n                                    whileTap={{ scale: 0.95 }}\n                                    title={isRTL ? 'в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘШұ' : 'Home'}\n                                    className=\"w-10 h-10 rounded-xl border border-white/10 bg-white/5 backdrop-blur-md flex items-center justify-center text-white/40 hover:text-accent-gold hover:border-accent-gold/40 hover:bg-accent-gold/10 transition-all duration-300 shadow-lg\"\n                                >\n                                    {isRTL ? <ChevronRight className=\"w-4 h-4\" /> : <ChevronLeft className=\"w-4 h-4\" />}\n                                </motion.div>\n                            </Link>\n                        </motion.div>\n\n                        {/* в•ӘШҜв”ҳВ„в”ҳГ§в”ҳГЁв•ӘВ»в•Әв–’ в”ҳГӘв•ӘШҜв”ҳВ„в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ - Header */}\n                        <div className=\"text-center space-y-6 mb-10\">\n                            {/* Animated badge */}\n                            <motion.div\n                                animate={{ opacity: [0.4, 0.8, 0.4] }}\n                                transition={{ duration: 3, repeat: Infinity }}\n                                className=\"inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full bg-white/[0.03] border border-white/10 shadow-[0_0_15px_rgba(255,255,255,0.05)]\"\n                            >\n                                <Key className={cn(\"w-3 h-3\", role === 'admin' ? \"text-accent-red\" : \"text-accent-gold\")} />\n                                <span className=\"text-[8px] font-bold uppercase tracking-[0.4em] text-white/50\">\n                                    {role === 'admin'\n                                        ? (isRTL ? \"в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ \" : \"SYSTEM ACCESS\")\n                                        : (isRTL ? \"в”ҳГ в”ҳВҶ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„\" : \"CLIENT ACCESS\")\n                                    }\n                                </span>\n                            </motion.div>\n\n                            {/* Title */}\n                            <div>\n                                <h1 className=\"text-4xl sm:text-5xl font-black tracking-[-0.04em] uppercase leading-[0.9] text-white\">\n                                    {isRTL ? \"в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„\" : \"SIGN\"}\n                                    <br />\n                                    <span className=\"text-transparent bg-clip-text bg-gradient-to-b from-white to-white/40\">{isRTL ? \"в•ӘШҜв”ҳВ„в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„\" : \"IN\"}</span>\n                                </h1>\n                            </div>\n                        </div>\n\n                        {/* в”ҳГ в•ӘШөв”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в”ҳГӘв•ӘШҜв•Әв–’ - Role Switcher */}\n                        {showRoleSwitcher && (\n                            <div className=\"flex bg-black/20 p-1 rounded-xl border border-white/5 mb-8 backdrop-blur-md\">\n                                <button\n                                    onClick={() => setRole('buyer')}\n                                    className={cn(\n                                        \"relative overflow-hidden flex-1 py-3 rounded-lg flex items-center justify-center gap-2 transition-all duration-500 text-[9px] sm:text-[10px] font-bold uppercase tracking-[0.1em] sm:tracking-[0.15em]\",\n                                        role === 'buyer'\n                                            ? \"bg-white text-black shadow-lg shadow-white/10\"\n                                            : \"text-white/30 hover:text-white/50\"\n                                    )}\n                                >\n                                    <UserCheck className=\"w-3 sm:w-3.5 h-3 sm:h-3.5\" />\n                                    {isRTL ? \"в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„\" : \"CLIENT\"}\n                                </button>\n                                <button\n                                    onClick={() => {\n                                        setRole('admin');\n                                        if (formData.email.toLowerCase().includes('admin')) {\n                                            setFormData(prev => ({ ...prev, email: '' }));\n                                        }\n                                    }}\n                                    className={cn(\n                                        \"relative overflow-hidden flex-1 py-3 rounded-lg flex items-center justify-center gap-2 transition-all duration-500 text-[9px] sm:text-[10px] font-bold uppercase tracking-[0.1em] sm:tracking-[0.15em]\",\n                                        role === 'admin'\n                                            ? \"bg-accent-red text-white shadow-lg shadow-red-500/20\"\n                                            : \"text-white/30 hover:text-white/50\"\n                                    )}\n                                >\n                                    <ShieldCheck className=\"w-3 sm:w-3.5 h-3 sm:h-3.5\" />\n                                    {isRTL ? \"в”ҳГ в•ӘВ»в”ҳГЁв•Әв–’\" : \"ADMIN\"}\n                                </button>\n                            </div>\n                        )}\n\n                        {/* в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ - Form */}\n                        <form onSubmit={handleLogin} className=\"space-y-6\">\n                            {/* Alert Messages */}\n                            <AnimatePresence mode=\"wait\">\n                                {error && (\n                                    <motion.div\n                                        initial={{ opacity: 0, height: 0 }}\n                                        animate={{ opacity: 1, height: 'auto' }}\n                                        exit={{ opacity: 0, height: 0 }}\n                                        className=\"px-4 py-3 bg-accent-red/10 border border-accent-red/20 rounded-xl text-center backdrop-blur-md\"\n                                    >\n                                        <span className=\"text-[10px] font-bold text-accent-red uppercase tracking-widest\">{error}</span>\n                                    </motion.div>\n                                )}\n                                {successMessage && (\n                                    <motion.div\n                                        initial={{ opacity: 0, height: 0 }}\n                                        animate={{ opacity: 1, height: 'auto' }}\n                                        className=\"px-4 py-3 bg-green-500/10 border border-green-500/20 rounded-xl text-center backdrop-blur-md\"\n                                    >\n                                        <span className=\"text-[10px] font-bold text-green-400 uppercase tracking-widest\">{successMessage}</span>\n                                    </motion.div>\n                                )}\n                            </AnimatePresence>\n\n                            {/* Identifier */}\n                            <div className=\"space-y-2\">\n                                {role === 'buyer' ? (\n                                    <div className=\"space-y-3\">\n                                        <div className=\"flex gap-2\">\n                                            <button\n                                                type=\"button\"\n                                                onClick={() => setMethod('name')}\n                                                className={cn(\"flex-1 px-3 py-2 rounded-lg border text-xs font-bold uppercase tracking-widest flex items-center justify-center gap-2\",\n                                                    method === 'name' ? \"border-blue-500/40 bg-blue-500/10 text-white\" : \"border-white/10 text-white/40 hover:text-white/70\")}\n                                            >\n                                                <User className=\"w-3.5 h-3.5\" />\n                                                {isRTL ? \"в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ \" : \"Name\"}\n                                            </button>\n                                            <button\n                                                type=\"button\"\n                                                onClick={() => setMethod('phone')}\n                                                className={cn(\"flex-1 px-3 py-2 rounded-lg border text-xs font-bold uppercase tracking-widest flex items-center justify-center gap-2\",\n                                                    method === 'phone' ? \"border-blue-500/40 bg-blue-500/10 text-white\" : \"border-white/10 text-white/40 hover:text-white/70\")}\n                                            >\n                                                <Phone className=\"w-3.5 h-3.5\" />\n                                                {isRTL ? \"в•ӘШ°в•ӘШҜв”ҳВ„в•Әв–’в”ҳГ©в”ҳГ \" : \"Phone\"}\n                                            </button>\n                                        </div>\n                                        {method === 'name' ? (\n                                            <div className=\"relative group\">\n                                                <span className=\"pointer-events-none absolute inset-0 -m-px rounded-xl blur-xl opacity-50 -z-10 bg-blue-500/25\" />\n                                                <User className={cn(\n                                                    \"absolute top-1/2 -translate-y-1/2 w-4 h-4 text-white/20 group-focus-within:text-blue-400 transition-colors\",\n                                                    isRTL ? \"right-4\" : \"left-4\"\n                                                )} />\n                                                <input\n                                                    type=\"text\"\n                                                    required\n                                                    value={formData.email}\n                                                    name=\"client_name_field\"\n                                                    autoComplete=\"off\"\n                                                    onChange={(e) => setFormData({ ...formData, email: e.target.value })}\n                                                    className={cn(\n                                                        \"w-full glass-input bg-white/5 focus:bg-white/10 outline-none border border-blue-500/30 ring-1 ring-blue-500/20\",\n                                                        isRTL ? \"pr-12 pl-4\" : \"pl-12 pr-4\"\n                                                    )}\n                                                    placeholder={isRTL ? \"в•ӘШҜв”ҳГўв•ӘШІв•ӘШ° в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГўв•ӘШҜв”ҳГ в”ҳВ„\" : \"Enter full name\"}\n                                                />\n                                            </div>\n                                        ) : (\n                                            <div className=\"space-y-2\">\n                                                <div className=\"flex gap-2\">\n                                                    <div className=\"relative\">\n                                                        <button\n                                                            type=\"button\"\n                                                            onClick={() => setShowCountry((v) => !v)}\n                                                            className=\"flex items-center px-3 py-2 rounded-lg border border-blue-500/30 bg-blue-500/10 text-white\"\n                                                        >\n                                                            {selectedCountry.dial}\n                                                        </button>\n                                                        {showCountry && (\n                                                            <div className={cn(\"absolute top-full mt-2 w-64 bg-[#0a0a0a]/95 border border-white/10 rounded-xl z-50 shadow-2xl backdrop-blur-2xl\", isRTL ? \"right-0\" : \"left-0\")}>\n                                                                <div className=\"p-2 border-b border-white/10\">\n                                                                    <input\n                                                                        type=\"text\"\n                                                                        value={countrySearch}\n                                                                        onChange={(e) => setCountrySearch(e.target.value)}\n                                                                        placeholder={isRTL ? \"в•ӘШ°в•ӘШөв•ӘШі в•ӘШҜв”ҳВ„в•ӘВ»в”ҳГӘв”ҳВ„в•ӘШұ...\" : \"Search country...\"}\n                                                                        className={cn(\"w-full bg-white/5 border border-white/10 focus:border-blue-500/40 focus:bg-white/10 outline-none px-3 py-2 rounded-lg text-xs text-white\", isRTL ? \"text-right\" : \"text-left\")}\n                                                                    />\n                                                                </div>\n                                                                <div className=\"max-h-40 overflow-auto\">\n                                                                    {countryList\n                                                                        .filter(c => c.name.toLowerCase().includes(countrySearch.toLowerCase()) || c.dial.includes(countrySearch))\n                                                                        .map((c) => (\n                                                                            <button\n                                                                                key={c.code}\n                                                                                type=\"button\"\n                                                                                onClick={() => { setSelectedCountry(c); setCountrySearch(''); setShowCountry(false); }}\n                                                                                className={cn(\"w-full px-4 py-3 text-white/80 hover:bg-white/10 flex items-center justify-between transition-colors border-b border-white/[0.03] last:border-0\", isRTL ? \"flex-row-reverse\" : \"flex-row\")}\n                                                                            >\n                                                                                <span className=\"text-[11px] font-medium\">{c.name}</span>\n                                                                                <span className=\"text-[11px] font-bold text-blue-400\">{c.dial}</span>\n                                                                            </button>\n                                                                        ))}\n                                                                </div>\n                                                            </div>\n                                                        )}\n                                                    </div>\n                                                    <input\n                                                        type=\"tel\"\n                                                        value={phoneNumber}\n                                                        onChange={(e) => setPhoneNumber(e.target.value)}\n                                                        required\n                                                        placeholder={isRTL ? \"в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ\" : \"Phone number\"}\n                                                        className=\"flex-1 glass-input bg-white/5 border-blue-500/30 focus:bg-white/10 outline-none px-3 py-2 rounded-lg\"\n                                                    />\n                                                </div>\n                                            </div>\n                                        )}\n                                    </div>\n                                ) : (\n                                    <div className=\"space-y-2\">\n                                        <label className=\"text-[9px] font-bold text-white/30 uppercase tracking-[0.3em] block px-1\">\n                                            {isRTL ? \"в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  / в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в”ҳЩ‘в”ҳВҒ\" : \"USERNAME / ACCESS ID\"}\n                                        </label>\n                                        <div className=\"relative\">\n                                            <span className=\"pointer-events-none absolute inset-0 -m-px rounded-xl blur-xl opacity-50 -z-10 bg-red-500/25\" />\n                                            <input\n                                                type=\"text\"\n                                                required\n                                                value={formData.email}\n                                                name=\"admin_name_field\"\n                                                autoComplete=\"off\"\n                                                autoCapitalize=\"none\"\n                                                autoCorrect=\"off\"\n                                                spellCheck=\"false\"\n                                                onChange={(e) => setFormData({ ...formData, email: e.target.value })}\n                                                className={cn(\"w-full glass-input bg-white/5 focus:bg-white/10 outline-none border border-red-500/30 ring-1 ring-red-500/20\", isRTL ? \"pr-4 pl-4\" : \"pl-4 pr-4\")}\n                                                placeholder={isRTL ? \"в•ӘШҜв”ҳГЁв”ҳГ в”ҳГЁв”ҳВ„   (ACCESS ID)\" : \"SECRET ACCESS ID\"}\n                                            />\n                                        </div>\n                                    </div>\n                                )}\n                            </div>\n\n                            {/* Password Field */}\n                            <div className=\"space-y-2\">\n                                <label className=\"text-[9px] font-bold text-white/30 uppercase tracking-[0.3em] block px-1\">\n                                    {isRTL ? \"в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’\" : \"PASSWORD\"}\n                                </label>\n                                <div className=\"relative group\">\n                                    <span className={cn(\"pointer-events-none absolute inset-0 -m-px rounded-xl blur-xl opacity-50 -z-10\", role === 'buyer' ? \"bg-blue-500/25\" : \"bg-red-500/25\")} />\n                                    <Lock className={cn(\n                                        \"absolute top-1/2 -translate-y-1/2 w-4 h-4 text-white/20 group-focus-within:text-[#c9a96e] transition-colors\",\n                                        isRTL ? \"right-4\" : \"left-4\"\n                                    )} />\n                                    <input\n                                        type={showPassword ? \"text\" : \"password\"}\n                                        required\n                                        minLength={6}\n                                        autoCapitalize=\"none\"\n                                        autoComplete=\"new-password\"\n                                        name=\"user_password_field\"\n                                        autoCorrect=\"off\"\n                                        value={formData.password}\n                                        onChange={(e) => setFormData({ ...formData, password: e.target.value })}\n                                        className={cn(\n                                            \"w-full glass-input bg-white/5 focus:bg-white/10 outline-none\",\n                                            isRTL ? \"pr-12 pl-4\" : \"pl-12 pr-4\",\n                                            role === 'buyer'\n                                                ? \"border border-blue-500/30 ring-1 ring-blue-500/20 shadow-[0_0_20px_rgba(59,130,246,0.25)]\"\n                                                : \"border border-red-500/30 ring-1 ring-red-500/20 shadow-[0_0_20px_rgba(255,0,0,0.2)]\"\n                                        )}\n                                        placeholder=\"ШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘ\"\n                                    />\n                                    <button\n                                        type=\"button\"\n                                        onClick={() => setShowPassword((v) => !v)}\n                                        className={cn(\"absolute top-1/2 -translate-y-1/2 text-white/40 hover:text-white/80 transition-colors\", isRTL ? \"left-4\" : \"right-4\")}\n                                    >\n                                        {showPassword ? <EyeOff className=\"w-4 h-4\" /> : <Eye className=\"w-4 h-4\" />}\n                                    </button>\n                                </div>\n                            </div>\n\n                            {method === 'phone' && otpRequested && (\n                                <div className=\"space-y-2\">\n                                    <label className=\"text-[9px] font-bold text-white/30 uppercase tracking-[0.3em] block px-1\">\n                                        {isRTL ? \"в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ©\" : \"Verification Code\"}\n                                    </label>\n                                    <div className=\"flex gap-2\">\n                                        <input\n                                            type=\"text\"\n                                            inputMode=\"numeric\"\n                                            value={otpCode}\n                                            onChange={(e) => setOtpCode(e.target.value.replace(/\\s/g, ''))}\n                                            placeholder={isRTL ? \"в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в•ӘШҜв”ҳВ„в•Әв–’в”ҳГ в•Әв–“\" : \"Enter code\"}\n                                            className=\"flex-1 glass-input bg-white/5 border-white/10 focus:bg-white/10 outline-none px-3 py-2 rounded-lg\"\n                                        />\n                                        <button\n                                            type=\"button\"\n                                            onClick={async () => {\n                                                const phoneE164 = `${selectedCountry.dial}${phoneNumber.replace(/\\D/g, '')}`;\n                                                try {\n                                                    await api.auth.sendOtp({ phone: phoneE164 });\n                                                    setSuccessMessage(isRTL ? 'в•ӘШІв”ҳГ  в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв–’в”ҳГ в•Әв–“ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«' : 'Code resent');\n                                                } catch (err: any) {\n                                                    setSuccessMessage(isRTL ? 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв–’в”ҳГ в•Әв–“ в”ҳГ в•Әв–’в•ӘШұ в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ«' : 'Failed to resend code');\n                                                }\n                                            }}\n                                            className=\"px-4 py-2 rounded-lg border border-white/10 text-white/80 hover:text-white hover:bg-white/10\"\n                                        >\n                                            {isRTL ? \"в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„\" : \"Resend\"}\n                                        </button>\n                                    </div>\n                                </div>\n                            )}\n\n                            {/* Options Row */}\n                            <div className=\"flex items-center justify-between px-1\">\n                                <div className=\"flex items-center gap-3 cursor-pointer\" onClick={() => setRememberMe(!rememberMe)}>\n                                    <div className={cn(\n                                        \"w-4.5 h-4.5 rounded-md border flex items-center justify-center transition-all\",\n                                        rememberMe\n                                            ? (role === 'admin' ? \"bg-accent-red border-accent-red\" : \"bg-[#c9a96e] border-[#c9a96e]\")\n                                            : \"border-white/10 bg-white/5\"\n                                    )}>\n                                        {rememberMe && <Sparkles className={cn(\"w-2.5 h-2.5 text-black\")} />}\n                                    </div>\n                                    <span className=\"text-[9px] font-bold text-white/30 uppercase tracking-[0.15em] hover:text-white/50 transition-colors\">\n                                        {isRTL ? \"в•ӘШІв•Әв–‘в”ҳГўв•Әв–’в”ҳВҶв”ҳГЁ\" : \"REMEMBER ME\"}\n                                    </span>\n                                </div>\n                                <Link\n                                    href=\"/register\"\n                                    className=\"text-[9px] font-bold text-[#c9a96e]/70 uppercase tracking-[0.15em] hover:text-[#c9a96e] transition-colors hover:underline underline-offset-4 decoration-[#c9a96e]/30\"\n                                >\n                                    {isRTL ? \"в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ° в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»\" : \"NEW ACCOUNT\"}\n                                </Link>\n                            </div>\n\n                            {/* Submit Button - Start Engine Style */}\n                            <button\n                                type=\"submit\"\n                                disabled={loading}\n                                className={cn(\n                                    \"w-full btn-start-engine py-5 rounded-xl group mt-4 flex items-center justify-center gap-3\",\n                                    loading && \"opacity-50 pointer-events-none\"\n                                )}\n                            >\n                                {loading ? (\n                                    <div className=\"w-5 h-5 border-2 border-current border-t-transparent rounded-full animate-spin\" />\n                                ) : (\n                                    <>\n                                        <Power className=\"w-5 h-5 group-hover:animate-pulse\" />\n                                        <span className=\"text-sm font-bold tracking-widest\">{isRTL ? \"в•ӘШ°в•ӘВ»в•ӘШ© в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•Әв–’в”ҳГў (в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„)\" : \"START ENGINE (LOGIN)\"}</span>\n                                        <ArrowRight className={cn(\"w-4 h-4 transition-transform opacity-50 group-hover:opacity-100\", isRTL ? \"rotate-180 group-hover:-translate-x-1\" : \"group-hover:translate-x-1\")} />\n                                    </>\n                                )}\n                            </button>\n                        </form>\n                    </div>\n                )}\n            </motion.div>\n\n            {/* ШёВӨВҖШёВӨВҖ Bottom Branding ШёВӨВҖШёВӨВҖ */}\n            <div className=\"fixed bottom-8 text-center opacity-20 hover:opacity-40 transition-opacity duration-500\">\n                <span className=\"text-[8px] font-bold uppercase tracking-[0.6em] text-white\">\n                    HM CAR // PREMIER EXPERIENCE\n                </span>\n            </div>\n        </div >\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\messages\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\not-found.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\notifications\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'MOCK_NOTIFICATIONS' is assigned a value but never used.","line":27,"column":7,"nodeType":"Identifier","messageId":"unusedVar","endLine":27,"endColumn":25}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\nimport { useState, useEffect } from 'react';\r\nimport { motion, AnimatePresence } from 'framer-motion';\r\nimport {\r\n    Bell, Check, CheckCheck, Trash2, Clock,\r\n    Car, Gavel, ShoppingBag, AlertTriangle, Gift,\r\n    Settings, Volume2, VolumeX, Sparkles,\r\n    X, Eye, ArrowLeft, ArrowRight, Filter\r\n} from 'lucide-react';\r\nimport { useRouter } from 'next/navigation';\r\nimport Navbar from '@/components/Navbar';\r\nimport { cn } from '@/lib/utils';\r\nimport { useLanguage } from '@/lib/LanguageContext';\r\nimport { api } from '@/lib/api';\r\n\r\n// ШёВӨВҖШёВӨВҖШёВӨВҖ Types ШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖ\r\nconst NOTIFICATION_TYPES = {\r\n    bid: { icon: Gavel, color: 'from-amber-500 to-orange-600', bg: 'bg-amber-500/10', border: 'border-amber-500/20', label: 'в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШҜв•ӘШІ', labelEn: 'Bids' },\r\n    order: { icon: ShoppingBag, color: 'from-emerald-500 to-green-600', bg: 'bg-emerald-500/10', border: 'border-emerald-500/20', label: 'в•Әв•–в”ҳВ„в•ӘШ°в•ӘШҜв•ӘШІ', labelEn: 'Orders' },\r\n    car: { icon: Car, color: 'from-blue-500 to-cyan-600', bg: 'bg-blue-500/10', border: 'border-blue-500/20', label: 'в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ', labelEn: 'Cars' },\r\n    promo: { icon: Gift, color: 'from-pink-500 to-rose-600', bg: 'bg-pink-500/10', border: 'border-pink-500/20', label: 'в•Әв•Јв•Әв–’в”ҳГӘв•Әв•ў', labelEn: 'Promos' },\r\n    system: { icon: Settings, color: 'from-slate-500 to-gray-600', bg: 'bg-slate-500/10', border: 'border-slate-500/20', label: 'в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ ', labelEn: 'System' },\r\n    alert: { icon: AlertTriangle, color: 'from-red-500 to-rose-600', bg: 'bg-red-500/10', border: 'border-red-500/20', label: 'в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§в•ӘШҜв•ӘШІ', labelEn: 'Alerts' },\r\n};\r\n\r\nconst MOCK_NOTIFICATIONS: any[] = [];\r\n\r\n// ШёВӨВҖШёВӨВҖШёВӨВҖ Main Page ШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖ\r\nexport default function NotificationsPage() {\r\n    const { isRTL } = useLanguage();\r\n    const router = useRouter();\r\n\r\n    const [notifications, setNotifications] = useState<any[]>([]);\r\n\r\n    useEffect(() => {\r\n        api.notifications?.list?.().then(res => {\r\n            if (res?.success && Array.isArray(res.data)) {\r\n                setNotifications(res.data);\r\n            }\r\n        }).catch(err => console.error(\"Failed to load notifications\", err));\r\n    }, []);\r\n    const [filter, setFilter] = useState<string>('all');\r\n    const [soundEnabled, setSoundEnabled] = useState(true);\r\n    const [selected, setSelected] = useState<any>(null);\r\n\r\n    const unreadCount = notifications.filter(n => !n.read).length;\r\n\r\n    const filtered = filter === 'all'\r\n        ? notifications\r\n        : filter === 'unread'\r\n            ? notifications.filter(n => !n.read)\r\n            : notifications.filter(n => n.type === filter);\r\n\r\n    const markRead = (id: number) => setNotifications(p => p.map(n => n.id === id ? { ...n, read: true } : n));\r\n    const markAllRead = () => setNotifications(p => p.map(n => ({ ...n, read: true })));\r\n    const remove = (id: number) => setNotifications(p => p.filter(n => n.id !== id));\r\n    const clearAll = () => setNotifications([]);\r\n\r\n    // sidebar filter items\r\n    const filterItems = [\r\n        { key: 'all', label: 'в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„', labelEn: 'All', icon: Sparkles, count: notifications.length },\r\n        { key: 'unread', label: 'в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГ©в•Әв–’в”ҳГӘв•ӘШ©', labelEn: 'Unread', icon: Eye, count: unreadCount },\r\n        ...Object.entries(NOTIFICATION_TYPES).map(([key, val]) => ({\r\n            key, label: val.label, labelEn: val.labelEn, icon: val.icon,\r\n            count: notifications.filter(n => n.type === key).length,\r\n        })),\r\n    ];\r\n\r\n    return (\r\n        <div className={cn(\"min-h-screen bg-black text-white font-sans overflow-x-hidden\", isRTL && \"rtl\")}>\r\n            <Navbar />\r\n\r\n            {/* Cinematic Background */}\r\n            <div className=\"fixed inset-0 z-0 pointer-events-none\">\r\n                <div className=\"absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-cinematic-neon-blue/8 via-black to-black\" />\r\n                <div className=\"absolute inset-0 bg-[linear-gradient(rgba(0,240,255,0.015)_1px,transparent_1px),linear-gradient(90deg,rgba(0,240,255,0.015)_1px,transparent_1px)] bg-[size:60px_60px]\" />\r\n                <motion.div animate={{ y: [0, -20, 0], opacity: [0.15, 0.3, 0.15] }} transition={{ duration: 8, repeat: Infinity }} className=\"absolute top-1/3 right-1/4 w-80 h-80 bg-cinematic-neon-blue/10 rounded-full blur-[100px]\" />\r\n                <motion.div animate={{ y: [0, 25, 0], opacity: [0.1, 0.2, 0.1] }} transition={{ duration: 11, repeat: Infinity, delay: 3 }} className=\"absolute bottom-1/4 left-1/4 w-64 h-64 bg-purple-500/10 rounded-full blur-[90px]\" />\r\n            </div>\r\n\r\n            <div className=\"relative z-10 flex h-screen pt-20\">\r\n\r\n                {/* ШёВӨВҖШёВӨВҖ LEFT SIDEBAR (Filters + Stats) ШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖ */}\r\n                <aside className={cn(\r\n                    \"hidden lg:flex flex-col w-72 shrink-0 h-[calc(100vh-5rem)] sticky top-20\",\r\n                    \"bg-white/[0.02] backdrop-blur-2xl border-white/5 overflow-y-auto\",\r\n                    isRTL ? \"border-l\" : \"border-r\"\r\n                )}>\r\n                    <div className=\"p-6 flex flex-col h-full gap-6\">\r\n\r\n                        {/* Header */}\r\n                        <div>\r\n                            <button\r\n                                onClick={() => router.back()}\r\n                                title={isRTL ? 'в•Әв–’в•ӘШҙв”ҳГӘв•Әв•Ј' : 'Back'}\r\n                                aria-label={isRTL ? 'в•Әв–’в•ӘШҙв”ҳГӘв•Әв•Ј' : 'Back'}\r\n                                className={cn(\r\n                                    \"inline-flex items-center justify-center w-11 h-11 rounded-xl bg-white/5 border border-white/10 text-white/60 hover:text-white hover:bg-white/10 transition-all mb-5\"\r\n                                )}\r\n                            >\r\n                                {isRTL ? <ArrowRight className=\"w-4 h-4\" /> : <ArrowLeft className=\"w-4 h-4\" />}\r\n                            </button>\r\n\r\n                            {/* Bell Icon + Count */}\r\n                            <div className=\"flex items-center gap-3 mb-2\">\r\n                                <div className=\"relative\">\r\n                                    <div className=\"w-12 h-12 rounded-2xl bg-gradient-to-br from-cinematic-neon-blue to-purple-600 flex items-center justify-center shadow-[0_0_30px_rgba(0,240,255,0.3)]\">\r\n                                        <Bell className=\"w-6 h-6 text-white\" />\r\n                                    </div>\r\n                                    {unreadCount > 0 && (\r\n                                        <motion.span\r\n                                            initial={{ scale: 0 }} animate={{ scale: 1 }}\r\n                                            className=\"absolute -top-1.5 -right-1.5 w-5 h-5 bg-cinematic-neon-red rounded-full text-[9px] font-black flex items-center justify-center shadow-[0_0_12px_rgba(255,0,60,0.6)]\"\r\n                                        >\r\n                                            {unreadCount}\r\n                                        </motion.span>\r\n                                    )}\r\n                                </div>\r\n                                <div>\r\n                                    <h1 className=\"text-xl font-black uppercase italic tracking-tight\">\r\n                                        {isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ' : 'Notifications'}\r\n                                    </h1>\r\n                                    <p className=\"text-[10px] text-white/30 uppercase tracking-widest\">\r\n                                        {isRTL ? `${unreadCount} в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в”ҳГ©в•Әв–’в”ҳГӘв•ӘШ©в•ӘШұ` : `${unreadCount} unread`}\r\n                                    </p>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* Filter List */}\r\n                        <div className=\"flex-1 space-y-1\">\r\n                            <p className={cn(\"text-[9px] font-black uppercase tracking-[0.3em] text-white/20 mb-3 flex items-center gap-2\", isRTL && \"flex-row-reverse\")}>\r\n                                <Filter className=\"w-3 h-3\" /> {isRTL ? 'в•ӘШІв•Әв•Ўв”ҳВҒв”ҳГЁв•ӘШұ' : 'Filter by'}\r\n                            </p>\r\n                            {filterItems.map(item => (\r\n                                <button\r\n                                    key={item.key}\r\n                                    onClick={() => setFilter(item.key)}\r\n                                    className={cn(\r\n                                        \"w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all text-[11px] font-black uppercase tracking-wider\",\r\n                                        isRTL && \"flex-row-reverse text-right\",\r\n                                        filter === item.key\r\n                                            ? \"bg-white text-black shadow-lg\"\r\n                                            : item.key === 'unread' && item.count > 0\r\n                                                ? \"bg-cinematic-neon-blue/10 text-cinematic-neon-blue border border-cinematic-neon-blue/20 hover:bg-cinematic-neon-blue/20\"\r\n                                                : \"text-white/50 hover:text-white hover:bg-white/5\"\r\n                                    )}\r\n                                >\r\n                                    <item.icon className=\"w-4 h-4 shrink-0\" />\r\n                                    <span className=\"flex-1\">{isRTL ? item.label : item.labelEn}</span>\r\n                                    {item.count > 0 && (\r\n                                        <span className={cn(\r\n                                            \"px-2 py-0.5 rounded-md text-[9px] shrink-0\",\r\n                                            filter === item.key ? \"bg-black/10\" : \"bg-white/10\"\r\n                                        )}>\r\n                                            {item.count}\r\n                                        </span>\r\n                                    )}\r\n                                </button>\r\n                            ))}\r\n                        </div>\r\n\r\n                        {/* Bottom Actions */}\r\n                        <div className=\"space-y-2 pt-4 border-t border-white/5\">\r\n                            {/* Sound Toggle */}\r\n                            <button\r\n                                onClick={() => setSoundEnabled(!soundEnabled)}\r\n                                className={cn(\r\n                                    \"w-full flex items-center gap-3 px-4 py-3 rounded-xl border transition-all text-[11px] font-black uppercase tracking-wider\",\r\n                                    isRTL && \"flex-row-reverse\",\r\n                                    soundEnabled\r\n                                        ? \"bg-cinematic-neon-blue/10 border-cinematic-neon-blue/20 text-cinematic-neon-blue\"\r\n                                        : \"bg-white/5 border-white/10 text-white/40\"\r\n                                )}\r\n                            >\r\n                                {soundEnabled ? <Volume2 className=\"w-4 h-4\" /> : <VolumeX className=\"w-4 h-4\" />}\r\n                                <span>{isRTL ? (soundEnabled ? 'в•Әв•Ўв”ҳГӘв•ӘШІ в”ҳГ в”ҳВҒв•Әв•Јв”ҳЩ‘в”ҳВ„' : 'в•Әв•Ўв”ҳГӘв•ӘШІ в”ҳГ в”ҳГўв•ӘШІв”ҳГӘв”ҳГ ') : (soundEnabled ? 'Sound On' : 'Sound Off')}</span>\r\n                            </button>\r\n\r\n                            {/* Mark All Read */}\r\n                            <button\r\n                                onClick={markAllRead}\r\n                                disabled={unreadCount === 0}\r\n                                className=\"w-full flex items-center gap-3 px-4 py-3 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all text-[11px] font-black uppercase tracking-wider text-white/60 hover:text-white disabled:opacity-30 disabled:cursor-not-allowed\"\r\n                                style={{ flexDirection: isRTL ? 'row-reverse' : 'row' }}\r\n                            >\r\n                                <CheckCheck className=\"w-4 h-4 shrink-0\" />\r\n                                <span>{isRTL ? 'в”ҳГ©в•Әв–’в•ӘШҜв•ӘШ©в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„' : 'Mark All Read'}</span>\r\n                            </button>\r\n\r\n                            {/* Clear All */}\r\n                            <button\r\n                                onClick={clearAll}\r\n                                disabled={notifications.length === 0}\r\n                                className=\"w-full flex items-center gap-3 px-4 py-3 rounded-xl bg-cinematic-neon-red/10 border border-cinematic-neon-red/20 text-cinematic-neon-red hover:bg-cinematic-neon-red/20 transition-all text-[11px] font-black uppercase tracking-wider disabled:opacity-30 disabled:cursor-not-allowed\"\r\n                                style={{ flexDirection: isRTL ? 'row-reverse' : 'row' }}\r\n                            >\r\n                                <Trash2 className=\"w-4 h-4 shrink-0\" />\r\n                                <span>{isRTL ? 'в”ҳГ в•Әв”Ӯв•ӘШө в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„' : 'Clear All'}</span>\r\n                            </button>\r\n                        </div>\r\n                    </div>\r\n                </aside>\r\n\r\n                {/* ШёВӨВҖШёВӨВҖ MAIN CONTENT ШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖ */}\r\n                <main className=\"flex-1 h-[calc(100vh-5rem)] overflow-y-auto\">\r\n                    <div className=\"max-w-3xl mx-auto px-4 md:px-8 py-8\">\r\n\r\n                        {/* Mobile Header */}\r\n                        <div className=\"lg:hidden mb-6\">\r\n                            <div className=\"flex items-center justify-between mb-4\">\r\n                                <button onClick={() => router.back()} className=\"p-2 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all\">\r\n                                    {isRTL ? <ArrowRight className=\"w-5 h-5\" /> : <ArrowLeft className=\"w-5 h-5\" />}\r\n                                </button>\r\n                                <h1 className=\"text-2xl font-black uppercase italic\">\r\n                                    {isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ' : 'Notifications'}\r\n                                </h1>\r\n                                <div className=\"flex items-center gap-2\">\r\n                                    <button onClick={() => setSoundEnabled(!soundEnabled)} className=\"p-2 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all\">\r\n                                        {soundEnabled ? <Volume2 className=\"w-4 h-4\" /> : <VolumeX className=\"w-4 h-4\" />}\r\n                                    </button>\r\n                                </div>\r\n                            </div>\r\n                            {/* Mobile Filter Scroll */}\r\n                            <div className=\"flex gap-2 overflow-x-auto scrollbar-hide pb-2\">\r\n                                {filterItems.map(item => (\r\n                                    <button\r\n                                        key={item.key}\r\n                                        onClick={() => setFilter(item.key)}\r\n                                        className={cn(\r\n                                            \"flex items-center gap-1.5 px-3 py-2 rounded-xl text-[10px] font-black uppercase tracking-wider whitespace-nowrap shrink-0 transition-all\",\r\n                                            filter === item.key ? \"bg-white text-black\" : \"bg-white/5 text-white/40 hover:text-white hover:bg-white/10\"\r\n                                        )}\r\n                                    >\r\n                                        <item.icon className=\"w-3.5 h-3.5\" />\r\n                                        {isRTL ? item.label : item.labelEn}\r\n                                        {item.count > 0 && <span className=\"ml-1 opacity-60\">{item.count}</span>}\r\n                                    </button>\r\n                                ))}\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* Section Title */}\r\n                        <div className={cn(\"flex items-center justify-between mb-6\", isRTL && \"flex-row-reverse\")}>\r\n                            <div className={cn(\"flex items-center gap-3\", isRTL && \"flex-row-reverse\")}>\r\n                                <div className=\"h-[2px] w-8 bg-cinematic-neon-blue shadow-[0_0_10px_rgba(0,240,255,1)]\" />\r\n                                <span className=\"text-[10px] font-black uppercase tracking-[0.4em] text-cinematic-neon-blue\">\r\n                                    {filter === 'all' ? (isRTL ? 'в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ' : 'All Notifications')\r\n                                        : filter === 'unread' ? (isRTL ? 'в•Әв•‘в”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ©в•Әв–’в”ҳГӘв•ӘШ©в•ӘШұ' : 'Unread')\r\n                                            : isRTL ? NOTIFICATION_TYPES[filter as keyof typeof NOTIFICATION_TYPES]?.label : NOTIFICATION_TYPES[filter as keyof typeof NOTIFICATION_TYPES]?.labelEn}\r\n                                </span>\r\n                            </div>\r\n                            <span className=\"text-[10px] text-white/20 font-black uppercase tracking-wider\">\r\n                                {filtered.length} {isRTL ? 'в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’' : 'items'}\r\n                            </span>\r\n                        </div>\r\n\r\n                        {/* Notifications List */}\r\n                        <div className=\"space-y-3\">\r\n                            <AnimatePresence mode=\"popLayout\">\r\n                                {filtered.length === 0 ? (\r\n                                    <motion.div\r\n                                        key=\"empty\"\r\n                                        initial={{ opacity: 0, scale: 0.95 }}\r\n                                        animate={{ opacity: 1, scale: 1 }}\r\n                                        className=\"py-24 text-center\"\r\n                                    >\r\n                                        <div className=\"w-20 h-20 mx-auto mb-5 rounded-full bg-white/[0.03] border border-white/5 flex items-center justify-center\">\r\n                                            <Bell className=\"w-9 h-9 text-white/10\" />\r\n                                        </div>\r\n                                        <h3 className=\"text-xl font-black uppercase italic text-white/20 mb-2\">\r\n                                            {isRTL ? 'в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ' : 'No Notifications'}\r\n                                        </h3>\r\n                                        <p className=\"text-[11px] text-white/10 uppercase tracking-[0.3em]\">\r\n                                            {isRTL ? 'в•ӘШ«в”ҳВҶв•ӘШІ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв•Әв•–в”ҳВ„в•ӘШҜв•Әв•Ј в•ӘШ°в”ҳГўв”ҳВ„ в•Әв”Өв”ҳГЁв•ӘШ©!' : \"You're all caught up!\"}\r\n                                        </p>\r\n                                    </motion.div>\r\n                                ) : (\r\n                                    filtered.map((notification, idx) => (\r\n                                        <NotifCard\r\n                                            key={notification.id}\r\n                                            n={notification}\r\n                                            idx={idx}\r\n                                            isRTL={isRTL}\r\n                                            onRead={() => markRead(notification.id)}\r\n                                            onDelete={() => remove(notification.id)}\r\n                                            onSelect={() => { markRead(notification.id); setSelected(notification); }}\r\n                                        />\r\n                                    ))\r\n                                )}\r\n                            </AnimatePresence>\r\n                        </div>\r\n\r\n                    </div>\r\n                </main>\r\n\r\n                {/* ШёВӨВҖШёВӨВҖ DETAIL PANEL (right side on wide screens) ШёВӨВҖШёВӨВҖ */}\r\n                <AnimatePresence>\r\n                    {selected && (\r\n                        <>\r\n                            {/* Overlay for small screens */}\r\n                            <motion.div\r\n                                initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}\r\n                                className=\"fixed inset-0 z-40 bg-black/70 backdrop-blur-sm lg:hidden\"\r\n                                onClick={() => setSelected(null)}\r\n                            />\r\n\r\n                            {/* Panel */}\r\n                            <motion.div\r\n                                initial={{ x: isRTL ? '-100%' : '100%' }}\r\n                                animate={{ x: 0 }}\r\n                                exit={{ x: isRTL ? '-100%' : '100%' }}\r\n                                transition={{ type: 'spring', damping: 28, stiffness: 300 }}\r\n                                className={cn(\r\n                                    \"fixed top-20 bottom-0 z-50 w-full max-w-sm\",\r\n                                    \"bg-zinc-950/95 backdrop-blur-2xl border-white/10\",\r\n                                    \"flex flex-col shadow-[-20px_0_60px_rgba(0,0,0,0.6)]\",\r\n                                    isRTL ? \"left-72 border-r\" : \"right-72 border-l\",\r\n                                    \"lg:sticky lg:top-20 lg:h-[calc(100vh-5rem)] lg:w-80 lg:shrink-0 lg:flex\"\r\n                                )}\r\n                            >\r\n                                <DetailPanel\r\n                                    n={selected}\r\n                                    isRTL={isRTL}\r\n                                    onClose={() => setSelected(null)}\r\n                                    onDelete={() => { remove(selected.id); setSelected(null); }}\r\n                                />\r\n                            </motion.div>\r\n                        </>\r\n                    )}\r\n                </AnimatePresence>\r\n\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n\r\n// ШёВӨВҖШёВӨВҖШёВӨВҖ Notification Card ШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖ\r\nfunction NotifCard({ n, idx, isRTL, onRead, onDelete, onSelect }: any) {\r\n    const typeInfo = NOTIFICATION_TYPES[n.type as keyof typeof NOTIFICATION_TYPES];\r\n    const TypeIcon = typeInfo?.icon || Bell;\r\n\r\n    return (\r\n        <motion.div\r\n            layout\r\n            initial={{ opacity: 0, y: 16 }}\r\n            animate={{ opacity: 1, y: 0 }}\r\n            exit={{ opacity: 0, x: isRTL ? -60 : 60, scale: 0.95 }}\r\n            transition={{ delay: idx * 0.04, duration: 0.3 }}\r\n            onClick={onSelect}\r\n            className={cn(\r\n                \"group relative flex items-start gap-4 p-5 rounded-2xl border cursor-pointer transition-all duration-300\",\r\n                n.read\r\n                    ? \"bg-white/[0.015] border-white/5 hover:bg-white/[0.03] hover:border-white/10\"\r\n                    : \"bg-white/[0.04] border-white/10 hover:bg-white/[0.06] shadow-[0_4px_24px_rgba(0,0,0,0.3)]\",\r\n                isRTL && \"flex-row-reverse\"\r\n            )}\r\n        >\r\n            {/* Priority Stripe */}\r\n            {n.priority === 'high' && !n.read && (\r\n                <div className={cn(\r\n                    \"absolute top-0 bottom-0 w-[3px] rounded-full bg-gradient-to-b from-cinematic-neon-red via-orange-500 to-cinematic-neon-red\",\r\n                    isRTL ? \"right-0 rounded-r-2xl\" : \"left-0 rounded-l-2xl\"\r\n                )} />\r\n            )}\r\n\r\n            {/* Icon */}\r\n            <div className={cn(\r\n                \"w-12 h-12 rounded-xl bg-gradient-to-br flex items-center justify-center shrink-0 shadow-lg\",\r\n                typeInfo?.color || 'from-gray-500 to-slate-600'\r\n            )}>\r\n                <TypeIcon className=\"w-5 h-5 text-white\" />\r\n            </div>\r\n\r\n            {/* Content */}\r\n            <div className=\"flex-1 min-w-0\">\r\n                <div className={cn(\"flex items-start justify-between gap-3 mb-1\", isRTL && \"flex-row-reverse\")}>\r\n                    <h3 className={cn(\"font-bold text-[14px] leading-snug\", n.read ? \"text-white/60\" : \"text-white\")}>\r\n                        {isRTL ? n.title : n.titleEn}\r\n                    </h3>\r\n                    <span className={cn(\"text-[10px] text-white/25 uppercase tracking-wider flex items-center gap-1 shrink-0\", isRTL && \"flex-row-reverse\")}>\r\n                        <Clock className=\"w-3 h-3\" />\r\n                        {isRTL ? n.time : n.timeEn}\r\n                    </span>\r\n                </div>\r\n                <p className={cn(\"text-[12px] leading-relaxed line-clamp-2\", n.read ? \"text-white/30\" : \"text-white/50\")}>\r\n                    {isRTL ? n.message : n.messageEn}\r\n                </p>\r\n            </div>\r\n\r\n            {/* Unread Dot */}\r\n            {!n.read && (\r\n                <div className=\"w-2 h-2 rounded-full bg-cinematic-neon-blue mt-1 shrink-0 shadow-[0_0_8px_rgba(0,240,255,0.8)]\" />\r\n            )}\r\n\r\n            {/* Hover Actions */}\r\n            <div className={cn(\r\n                \"absolute top-4 flex items-center gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity\",\r\n                isRTL ? \"left-4\" : \"right-4\"\r\n            )}>\r\n                {!n.read && (\r\n                    <button onClick={e => { e.stopPropagation(); onRead(); }}\r\n                        className=\"p-1.5 rounded-lg bg-white/5 hover:bg-cinematic-neon-blue/20 text-white/30 hover:text-cinematic-neon-blue transition-all\">\r\n                        <Check className=\"w-3.5 h-3.5\" />\r\n                    </button>\r\n                )}\r\n                <button onClick={e => { e.stopPropagation(); onDelete(); }}\r\n                    className=\"p-1.5 rounded-lg bg-white/5 hover:bg-cinematic-neon-red/20 text-white/30 hover:text-cinematic-neon-red transition-all\">\r\n                    <Trash2 className=\"w-3.5 h-3.5\" />\r\n                </button>\r\n            </div>\r\n        </motion.div>\r\n    );\r\n}\r\n\r\n// ШёВӨВҖШёВӨВҖШёВӨВҖ Detail Panel ШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖ\r\nfunction DetailPanel({ n, isRTL, onClose, onDelete }: any) {\r\n    const typeInfo = NOTIFICATION_TYPES[n.type as keyof typeof NOTIFICATION_TYPES];\r\n    const TypeIcon = typeInfo?.icon || Bell;\r\n\r\n    return (\r\n        <div className=\"flex flex-col h-full\">\r\n            {/* Panel Header */}\r\n            <div className={cn(\"flex items-center justify-between p-5 border-b border-white/5\", isRTL && \"flex-row-reverse\")}>\r\n                <span className=\"text-[10px] font-black uppercase tracking-[0.3em] text-white/30\">\r\n                    {isRTL ? 'в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’' : 'Notification Detail'}\r\n                </span>\r\n                <button onClick={onClose} className=\"p-1.5 rounded-lg bg-white/5 hover:bg-white/10 transition-all text-white/40 hover:text-white\">\r\n                    <X className=\"w-4 h-4\" />\r\n                </button>\r\n            </div>\r\n\r\n            {/* Content */}\r\n            <div className=\"flex-1 overflow-y-auto p-6\">\r\n                {/* Icon & Badge */}\r\n                <div className=\"flex flex-col items-center text-center mb-8\">\r\n                    <div className={cn(\r\n                        \"w-20 h-20 rounded-3xl bg-gradient-to-br flex items-center justify-center mb-4 shadow-2xl\",\r\n                        typeInfo?.color || 'from-gray-500 to-slate-600'\r\n                    )}>\r\n                        <TypeIcon className=\"w-10 h-10 text-white\" />\r\n                    </div>\r\n\r\n                    {/* Type Badge */}\r\n                    <span className={cn(\r\n                        \"px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-[0.2em] border\",\r\n                        typeInfo?.bg, typeInfo?.border,\r\n                        \"text-white/70\"\r\n                    )}>\r\n                        {isRTL ? typeInfo?.label : typeInfo?.labelEn}\r\n                    </span>\r\n                </div>\r\n\r\n                {/* Title */}\r\n                <h2 className=\"text-2xl font-black uppercase italic mb-3 text-center leading-tight\">\r\n                    {isRTL ? n.title : n.titleEn}\r\n                </h2>\r\n\r\n                {/* Message */}\r\n                <p className=\"text-white/60 leading-relaxed text-sm text-center mb-6\">\r\n                    {isRTL ? n.message : n.messageEn}\r\n                </p>\r\n\r\n                {/* Time */}\r\n                <div className={cn(\"flex items-center justify-center gap-2 text-white/25 text-[11px] uppercase tracking-wider mb-8\")}>\r\n                    <Clock className=\"w-4 h-4\" />\r\n                    {isRTL ? n.time : n.timeEn}\r\n                </div>\r\n\r\n                {/* Priority Tag */}\r\n                {n.priority === 'high' && (\r\n                    <div className=\"flex items-center justify-center gap-2 mb-6 px-4 py-2 bg-cinematic-neon-red/10 border border-cinematic-neon-red/20 rounded-xl\">\r\n                        <AlertTriangle className=\"w-4 h-4 text-cinematic-neon-red\" />\r\n                        <span className=\"text-[10px] font-black uppercase tracking-wider text-cinematic-neon-red\">\r\n                            {isRTL ? 'в•ӘШ«в”ҳГӘв”ҳВ„в”ҳГӘв”ҳГЁв•ӘШұ в•Әв•Јв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ' : 'High Priority'}\r\n                        </span>\r\n                    </div>\r\n                )}\r\n\r\n                {/* Divider */}\r\n                <div className=\"border-t border-white/5 mb-6\" />\r\n\r\n                {/* Actions */}\r\n                <div className=\"space-y-3\">\r\n                    <button className=\"w-full py-4 bg-white text-black font-black uppercase tracking-[0.2em] text-xs rounded-xl hover:bg-cinematic-neon-blue hover:text-white transition-all shadow-lg\">\r\n                        {isRTL ? 'в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„' : 'View Details'}\r\n                    </button>\r\n                    <button\r\n                        onClick={onDelete}\r\n                        className=\"w-full py-3 bg-cinematic-neon-red/10 border border-cinematic-neon-red/20 text-cinematic-neon-red font-black uppercase tracking-[0.2em] text-xs rounded-xl hover:bg-cinematic-neon-red/20 transition-all flex items-center justify-center gap-2\"\r\n                    >\r\n                        <Trash2 className=\"w-4 h-4\" />\r\n                        {isRTL ? 'в•ӘШөв•Әв–‘в”ҳВҒ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’' : 'Delete'}\r\n                    </button>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\offline\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\orders\\[id]\\invoice\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\orders\\[id]\\page.tsx","messages":[],"suppressedMessages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadOrder'. Either include it or remove the dependency array.","line":42,"column":8,"nodeType":"ArrayExpression","endLine":42,"endColumn":17,"suggestions":[{"desc":"Update the dependencies array to be: [loadOrder, orderId]","fix":{"range":[1854,1863],"text":"[loadOrder, orderId]"}}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErro