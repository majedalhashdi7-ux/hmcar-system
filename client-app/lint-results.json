-widest bg-cinematic-neon-blue/10 px-4 py-2 rounded-lg border border-cinematic-neon-blue/20\">\r\n                                            <Plus className=\"w-4 h-4\" /> Add Car\r\n                                        </button>\r\n                                    </div>\r\n\r\n                                    <div className=\"space-y-6\">\r\n                                        {formData.cars.map((car, idx) => (\r\n                                            <div key={idx} className=\"bg-white/5 p-6 rounded-2xl border border-white/10 relative space-y-4\">\r\n                                                <button onClick={() => removeCar(idx)} className=\"absolute top-4 right-4 text-red-500 hover:text-red-400\"><Trash2 className=\"w-4 h-4\" /></button>\r\n\r\n                                                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n                                                    <input value={car.title} onChange={e => updateCar(idx, 'title', e.target.value)} className=\"bg-black/40 border border-white/10 p-3 rounded-lg text-sm\" placeholder=\"Car Name (e.g. Ford Mustang 2021)\" />\r\n                                                    <input value={car.condition} onChange={e => updateCar(idx, 'condition', e.target.value)} className=\"bg-black/40 border border-white/10 p-3 rounded-lg text-sm\" placeholder=\"Condition/Damage (e.g. Frontal Damage)\" />\r\n                                                    <input value={car.priceEstimate} onChange={e => updateCar(idx, 'priceEstimate', e.target.value)} className=\"bg-black/40 border border-white/10 p-3 rounded-lg text-sm\" placeholder=\"Max Bid / Estimate\" />\r\n                                                    <div className=\"flex items-center gap-4\">\r\n                                                        <label className=\"cursor-pointer bg-white/5 hover:bg-white/10 p-3 rounded-lg border border-white/10 text-[10px] font-black uppercase tracking-widest flex items-center gap-2 transition-all\">\r\n                                                            <ImageIcon className=\"w-4 h-4\" /> Upload Images\r\n                                                            <input type=\"file\" multiple className=\"hidden\" onChange={e => handleImageUpload(idx, e.target.files)} />\r\n                                                        </label>\r\n                                                        <span className=\"text-[10px] text-white/40\">{car.images?.length || 0} images</span>\r\n                                                    </div>\r\n                                                </div>\r\n                                                <textarea value={car.description} onChange={e => updateCar(idx, 'description', e.target.value)} className=\"w-full bg-black/40 border border-white/10 p-3 rounded-lg text-sm h-20\" placeholder=\"Full details, engine status, problem, etc...\"></textarea>\r\n\r\n                                                <div className=\"flex gap-2 overflow-x-auto pb-2\">\r\n                                                    {car.images?.map((img: string, i: number) => (\r\n                                                        <img key={i} src={img} className=\"w-16 h-16 object-cover rounded-lg border border-white/10\" />\r\n                                                    ))}\r\n                                                </div>\r\n                                            </div>\r\n                                        ))}\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n\r\n                            <div className=\"p-8 border-t border-white/5 bg-black/50\">\r\n                                <button onClick={handleSave} disabled={isLoading} className=\"w-full py-5 bg-cinematic-neon-red text-white font-black uppercase tracking-[0.5em] text-xs rounded-2xl shadow-[0_0_30px_rgba(255,0,60,0.3)] disabled:opacity-50\">\r\n                                    {editingId ? \"SAVE CHANGES\" : \"CREATE SESSION\"}\r\n                                </button>\r\n                            </div>\r\n                        </motion.div>\r\n                    </div>\r\n                )}\r\n            </AnimatePresence>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\live-auctions\\requests\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Clock' is defined but never used.","line":6,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":15,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Clock"},"fix":{"range":[155,161],"text":""},"desc":"Remove unused variable \"Clock\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CheckCircle' is defined but never used.","line":6,"column":17,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":28,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"CheckCircle"},"fix":{"range":[160,173],"text":""},"desc":"Remove unused variable \"CheckCircle\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'XCircle' is defined but never used.","line":6,"column":30,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":37,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"XCircle"},"fix":{"range":[173,182],"text":""},"desc":"Remove unused variable \"XCircle\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Trophy' is defined but never used.","line":6,"column":39,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":45,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Trophy"},"fix":{"range":[182,190],"text":""},"desc":"Remove unused variable \"Trophy\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'X' is defined but never used.","line":6,"column":47,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":48,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"X"},"fix":{"range":[190,193],"text":""},"desc":"Remove unused variable \"X\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Search' is defined but never used.","line":6,"column":50,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":56,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Search"},"fix":{"range":[193,201],"text":""},"desc":"Remove unused variable \"Search\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'DollarSign' is defined but never used.","line":6,"column":58,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":68,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"DollarSign"},"fix":{"range":[146,236],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'error' is defined but never used.","line":70,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":70,"endColumn":23}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":8,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport { useState, useEffect } from \"react\";\nimport { api } from \"@/lib/api\";\nimport { useLanguage } from \"@/lib/LanguageContext\";\nimport { Clock, CheckCircle, XCircle, Trophy, X, Search, DollarSign } from \"lucide-react\";\n\nexport default function LiveAuctionRequests() {\n    const { isRTL } = useLanguage();\n    const [requests, setRequests] = useState<any[]>([]);\n    const [loading, setLoading] = useState(true);\n\n    const loadRequests = async () => {\n        try {\n            const res = await api.liveAuctionRequests.list();\n            if (res?.success) setRequests(res.data);\n        } catch (error) {\n            console.error('Failed to load requests', error);\n        } finally {\n            setLoading(false);\n        }\n    };\n\n    useEffect(() => {\n        loadRequests();\n    }, []);\n\n    const StatusBadge = ({ status }: { status: string }) => {\n        const styles: Record<string, string> = {\n            pending: \"bg-yellow-500/10 text-yellow-500 border-yellow-500/20\",\n            approved: \"bg-blue-500/10 text-blue-500 border-blue-500/20\",\n            rejected: \"bg-red-500/10 text-red-500 border-red-500/20\",\n            won: \"bg-green-500/10 text-green-500 border-green-500/20\",\n            lost: \"bg-zinc-500/10 text-zinc-500 border-zinc-500/20\",\n        };\n        const labels: Record<string, string> = {\n            pending: isRTL ? \"в”ҳГ©в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в•ӘШҜв•ӘШҙв•Әв•Јв•ӘШұ\" : \"Pending\",\n            approved: isRTL ? \"в”ҳГ в”ҳГӘв•ӘШҜв”ҳВҒв”ҳГ© в•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ§\" : \"Approved\",\n            rejected: isRTL ? \"в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв–’в”ҳВҒв•Әв•ў\" : \"Rejected\",\n            won: isRTL ? \"в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© (в•«Ш¬в”ҳВҸв•Әв–“в”ҳВҶв•ӘШҜ)\" : \"Won\",\n            lost: isRTL ? \"в•ӘВ«в•Әв”Ӯв•Әв–’в”ҳВҶв•ӘШҜ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»\" : \"Lost\",\n        };\n        return <span className={`px-3 py-1 rounded-full text-xs font-bold border ${styles[status] || styles.pending}`}>{labels[status] || status}</span>;\n    };\n\n    const handleUpdateStatus = async (id: string, newStatus: string) => {\n        let agreedMaxPrice = undefined;\n        let finalPurchasePrice = undefined;\n\n        if (newStatus === 'approved') {\n            const price = prompt(isRTL ? \"в•ӘШ«в•ӘВ»в•ӘВ«в”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ©в•Әв•Ўв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв”ҳВҒв”ҳГ© в•Әв•Јв”ҳВ„в”ҳГЁв”ҳГ§ в”ҳВ„в”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШұ:\" : \"Enter agreed maximum bid price:\");\n            if (price === null) return;\n            agreedMaxPrice = Number(price);\n        } else if (newStatus === 'won') {\n            const price = prompt(isRTL ? \"в•ӘШ«в”ҳВ„в”ҳВҒ в”ҳГ в•ӘШ°в•Әв–’в”ҳГӘв”ҳГў! в”ҳГ в•ӘШҜ в”ҳГ§в”ҳГӘ в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ§в•ӘШҜв•ӘШ®в”ҳГЁ в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГЁ в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в•ӘШ°в”ҳГ§в•ӘШ§ (в•Әв”Ӯв”ҳГЁв•Әв•Ўв•ӘВ»в•Әв–’ в•ӘШ°в”ҳГ§ в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ):\" : \"Final winning price? (Invoice will be generated):\");\n            if (price === null) return;\n            finalPurchasePrice = Number(price);\n        }\n\n        try {\n            const res = await api.liveAuctionRequests.updateStatus(id, { \n                status: newStatus, \n                agreedMaxPrice: agreedMaxPrice || undefined, \n                finalPurchasePrice: finalPurchasePrice || undefined \n            });\n            if (res.success) {\n                alert(isRTL ? 'в•ӘШІв”ҳГ  в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ° в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө' : 'Status updated successfully');\n                loadRequests();\n            }\n        } catch (error) {\n            alert('Failed to update status');\n        }\n    };\n\n    return (\n        <div className={`min-h-screen bg-[#050505] text-white overflow-x-hidden ${isRTL ? 'font-arabic' : ''}`} dir={isRTL ? 'rtl' : 'ltr'}>\n            <div className=\"p-4 md:p-8 max-w-7xl mx-auto space-y-8\">\n                <div className=\"flex flex-col md:flex-row items-start md:items-center justify-between gap-4\">\n                    <div className=\"w-full\">\n                        <h1 className=\"text-xl md:text-3xl font-black uppercase text-cinematic-neon-blue break-words\">\n                            {isRTL ? \"в•Әв•–в”ҳВ„в•ӘШ°в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’в•ӘШұ (в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШұ)\" : \"Live Proxy Bidding Requests\"}\n                        </h1>\n                        <p className=\"text-white/40 mt-2\">{isRTL ? \"в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ°в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГЁ в•ӘШІв•Әв•Ўв”ҳВ„в”ҳГў в•ӘШ«в•ӘШів”ҳВҶв•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШі в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’\" : \"Manage requests coming in during live streams\"}</p>\n                    </div>\n                </div>\n\n                {loading ? (\n                    <div className=\"text-center py-20 text-white/40\">Loading...</div>\n                ) : (\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n                        {requests.length === 0 && <div className=\"col-span-full text-center py-20 text-white/40\">в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•Әв•–в”ҳВ„в•ӘШ°в•ӘШҜв•ӘШІ в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШұ в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШҜв”ҳГҜ.</div>}\n                        {requests.map(req => (\n                            <div key={req._id} className=\"bg-white/5 border border-white/10 rounded-2xl p-6 space-y-6 flex flex-col justify-between\">\n                                <div>\n                                    <div className=\"flex justify-between items-start mb-4\">\n                                        <StatusBadge status={req.status} />\n                                        <div className=\"text-[10px] text-white/30\">{new Date(req.createdAt).toLocaleTimeString()}</div>\n                                    </div>\n                                    <h3 className=\"text-lg font-black uppercase mb-1\">{req.car.title}</h3>\n                                    <div className=\"text-sm text-cinematic-neon-blue mb-4\">Lot: {req.car.lotNumber || 'N/A'} - {req.sessionTitle || req.session?.title}</div>\n                                    \n                                    <div className=\"bg-black/30 p-4 rounded-xl space-y-2 text-sm\">\n                                        <p><span className=\"text-white/40\">в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„:</span> {req.guestName}</p>\n                                        <p><span className=\"text-white/40\">в•ӘШҜв”ҳВ„в”ҳГ§в•ӘШҜв•ӘШІв”ҳВҒ:</span> {req.guestPhone}</p>\n                                    </div>\n\n                                    {(req.agreedMaxPrice > 0 || req.finalPurchasePrice > 0) && (\n                                        <div className=\"mt-4 space-y-1 bg-cinematic-neon-blue/10 p-3 rounded-lg border border-cinematic-neon-blue/20\">\n                                            {req.agreedMaxPrice > 0 && <p className=\"text-xs\"><span className=\"text-white/40\">в•ӘШҜв”ҳВ„в•ӘШөв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ©в•Әв•Ўв”ҳГ« в”ҳВ„в”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШұ:</span> <strong className=\"text-cinematic-neon-blue\">{req.agreedMaxPrice}</strong></p>}\n                                            {req.finalPurchasePrice > 0 && <p className=\"text-xs\"><span className=\"text-white/40\">в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в•ӘШ°в•Әв”Ӯв•Әв•Јв•Әв–’:</span> <strong className=\"text-green-400\">{req.finalPurchasePrice}</strong></p>}\n                                        </div>\n                                    )}\n\n                                    {/* Invoice Link if generated */}\n                                    {req.invoice && (\n                                        <div className=\"mt-4 flex gap-4\">\n                                            <a href={`/admin/invoices/${typeof req.invoice === 'object' ? req.invoice._id : req.invoice}/edit`} target=\"_blank\" className=\"text-xs text-yellow-500 underline hover:text-white transition\">в•ӘШӯв”ҳГўв”ҳГ в•ӘШҜв”ҳВ„/в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ</a>\n                                            <a href={`/admin/invoices/${typeof req.invoice === 'object' ? req.invoice._id : req.invoice}`} target=\"_blank\" className=\"text-xs text-cinematic-neon-red underline hover:text-white transition\">в•Әв•–в•ӘШ°в•ӘШҜв•Әв•Јв•ӘШұ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШҜв•ӘШІв•ӘШҙв•ӘШұ</a>\n                                        </div>\n                                    )}\n                                </div>\n\n                                <div className=\"grid grid-cols-2 gap-2 pt-4 border-t border-white/5\">\n                                    {req.status === 'pending' && (\n                                        <>\n                                            <button onClick={() => handleUpdateStatus(req._id, 'approved')} className=\"py-2 bg-blue-500/20 text-blue-500 rounded-lg text-xs font-bold hover:bg-blue-500 hover:text-white transition\">в”ҳГ в”ҳГӘв•ӘШҜв”ҳВҒв”ҳГ©в•ӘШұ в”ҳГӘв•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘВ» в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’</button>\n                                            <button onClick={() => handleUpdateStatus(req._id, 'rejected')} className=\"py-2 bg-red-500/20 text-red-500 rounded-lg text-xs font-bold hover:bg-red-500 hover:text-white transition\">в•Әв–’в”ҳВҒв•Әв•ў</button>\n                                        </>\n                                    )}\n                                    {req.status === 'approved' && (\n                                        <>\n                                            <button onClick={() => handleUpdateStatus(req._id, 'won')} className=\"py-2 bg-green-500/20 text-green-500 rounded-lg text-xs font-bold hover:bg-green-500 hover:text-white transition\">в”ҳВҒв”ҳВҸв•Әв–“в”ҳВҶв•ӘШҜ (в•ӘШӯв•Әв•Ўв•ӘВ»в•ӘШҜв•Әв–’ в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ)</button>\n                                            <button onClick={() => handleUpdateStatus(req._id, 'lost')} className=\"py-2 bg-zinc-500/20 text-zinc-500 rounded-lg text-xs font-bold hover:bg-zinc-500 hover:text-white transition\">в•ӘВ«в•Әв”Ӯв•Әв–’в”ҳВҶв•ӘШҜ</button>\n                                        </>\n                                    )}\n                                    {(req.status === 'won' || req.status === 'lost' || req.status === 'rejected') && (\n                                        <div className=\"col-span-2 text-center text-xs text-white/20\">в”ҳВ„в•ӘШҜ в”ҳГЁв”ҳГ в”ҳГўв”ҳВҶ в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШ°в•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШөв•Әв”Ӯв”ҳГ </div>\n                                    )}\n                                </div>\n                            </div>\n                        ))}\n                    </div>\n                )}\n            </div>\n        </div>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\market\\page.tsx","messages":[{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":221,"column":49,"nodeType":"JSXOpeningElement","endLine":226,"endColumn":51}],"suppressedMessages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadClassicAuctions'. Either include it or remove the dependency array.","line":74,"column":8,"nodeType":"ArrayExpression","endLine":74,"endColumn":33,"suggestions":[{"desc":"Update the dependencies array to be: [activeMode, activeArena, loadClassicAuctions]","fix":{"range":[3015,3040],"text":"[activeMode, activeArena, loadClassicAuctions]"}}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport { motion, AnimatePresence } from \"framer-motion\";\nimport { \n    Plus, Clock, TrendingUp, Trash2, Edit2, Play, Square, ExternalLink, \n    Link as LinkIcon, Radio, Gavel, RefreshCw, X, \n    Activity, Info, Car\n} from \"lucide-react\";\nimport { useState, useEffect, Suspense } from \"react\";\nimport { useSearchParams } from 'next/navigation';\nimport Link from \"next/link\";\nimport { cn } from \"@/lib/utils\";\nimport { useLanguage } from \"@/lib/LanguageContext\";\nimport { api } from \"@/lib/api\";\nimport { useToast } from \"@/lib/ToastContext\";\nimport AdminPageShell from '@/components/AdminPageShell';\n\n// ШёВӨВҖШёВӨВҖ Types ШёВӨВҖШёВӨВҖ\nconst MODE_LIVE = 'live';\nconst MODE_AUCTIONS = 'auctions';\n\nfunction MarketHubContent() {\n    const { isRTL } = useLanguage();\n    const { showToast } = useToast();\n    const searchParams = useSearchParams();\n    \n    const [activeMode, setActiveMode] = useState(searchParams?.get('tab') === MODE_AUCTIONS ? MODE_AUCTIONS : MODE_LIVE);\n    const [loading, setLoading] = useState(false);\n\n    // ШёВӨВҖШёВӨВҖ Live Sessions State ШёВӨВҖШёВӨВҖ\n    const [sessions, setSessions] = useState<any[]>([]);\n    const [isLiveModalOpen, setIsLiveModalOpen] = useState(false);\n    const [editingLiveId, setEditingLiveId] = useState<string | null>(null);\n    const [liveForm, setLiveForm] = useState({ title: '', externalUrl: '', whatsappNumber: '', auctionUsername: '', auctionPassword: '', cars: [] as any[] });\n\n    // ШёВӨВҖШёВӨВҖ Classic Auctions State ШёВӨВҖШёВӨВҖ\n    const [auctions, setAuctions] = useState<any[]>([]);\n    const [cars, setCars] = useState<any[]>([]);\n    const [activeArena, setActiveArena] = useState('LIVE');\n    const [isAuctionModalOpen, setIsAuctionModalOpen] = useState(false);\n    const [auctionForm, setAuctionForm] = useState({ carId: '', startPrice: '', startsAt: '', endsAt: '' });\n    const [imageErrors, setImageErrors] = useState<Record<string, boolean>>({});\n\n    // ШёВӨВҖШёВӨВҖ Loaders ШёВӨВҖШёВӨВҖ\n    const loadLiveSessions = async () => {\n        setLoading(true);\n        try {\n            const res = await api.liveAuctions.list();\n            if (res.success) setSessions(res.data);\n        } catch { } finally { setLoading(false); }\n    };\n\n    const loadClassicAuctions = async () => {\n        setLoading(true);\n        try {\n            let status = 'running';\n            if (activeArena === 'SCHEDULED') status = 'scheduled';\n            if (activeArena === 'SETTLED') status = 'ended';\n            if (activeArena === 'AUDIT') status = 'all';\n\n            const [aucRes, carRes] = await Promise.all([\n                api.auctions.list({ status, limit: 50 }),\n                api.cars.list({ status: 'active' })\n            ]);\n            if (aucRes.success) setAuctions(aucRes.data || []);\n            if (carRes.success) setCars(carRes.data.cars || []);\n        } catch { } finally { setLoading(false); }\n    };\n\n    useEffect(() => {\n        if (activeMode === MODE_LIVE) loadLiveSessions();\n        else loadClassicAuctions();\n        // eslint-disable-next-line react-hooks/exhaustive-deps\n    }, [activeMode, activeArena]);\n\n    // ШёВӨВҖШёВӨВҖ Actions: Live ШёВӨВҖШёВӨВҖ\n    const handleStatusUpdate = async (id: string, action: 'start' | 'end') => {\n        try {\n            if (action === 'start') await api.liveAuctions.start(id);\n            else await api.liveAuctions.end(id);\n            loadLiveSessions();\n            showToast(isRTL ? 'в•ӘШІв”ҳГ  в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ' : 'Status updated', 'success');\n        } catch { }\n    };\n\n    const handleDeleteLive = async (id: string) => {\n        if (!confirm(isRTL ? 'в”ҳГ§в”ҳВ„ в•ӘШ«в”ҳВҶв•ӘШІ в”ҳГ в•ӘШІв•ӘШ«в”ҳГўв•ӘВ»в•ӘШ§' : 'Are you sure?')) return;\n        try {\n            await api.liveAuctions.delete(id);\n            loadLiveSessions();\n            showToast(isRTL ? 'в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШөв•Әв–‘в”ҳВҒ' : 'Deleted', 'success');\n        } catch { }\n    };\n\n    // ШёВӨВҖШёВӨВҖ Actions: Auctions ШёВӨВҖШёВӨВҖ\n    const handleLaunchAuction = async () => {\n        const { carId, startPrice, startsAt, endsAt } = auctionForm;\n        if (!carId || !startPrice || !startsAt || !endsAt) return showToast(isRTL ? 'в•ӘШ«в”ҳГўв”ҳГ в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ' : 'Fill all fields', 'error');\n        setLoading(true);\n        try {\n            const res = await api.auctions.create(auctionForm);\n            if (res.success) {\n                setIsAuctionModalOpen(false);\n                setAuctionForm({ carId: '', startPrice: '', startsAt: '', endsAt: '' });\n                loadClassicAuctions();\n                showToast(isRTL ? 'вүЎШ§ШЈВҖ в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•–в”ҳВ„в•ӘШҜв”ҳГ©' : 'вүЎШ§ШЈВҖ Launched', 'success');\n            }\n        } catch { } finally { setLoading(false); }\n    };\n\n    const handleDeleteAuction = async (id: string) => {\n        if (!confirm(isRTL ? 'в”ҳГ в•ӘШІв•ӘШ«в”ҳГўв•ӘВ»в•ӘШ§' : 'Sure?')) return;\n        try {\n            await api.auctions.delete(id);\n            loadClassicAuctions();\n            showToast(isRTL ? 'вүЎШ§Г№Щ‘ЩҠв••ВҸ в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШөв•Әв–‘в”ҳВҒ' : 'вүЎШ§Г№Щ‘ЩҠв••ВҸ Deleted', 'success');\n        } catch { }\n    };\n\n    return (\n        <div className=\"relative min-h-screen text-white font-sans overflow-hidden\" dir={isRTL ? 'rtl' : 'ltr'}>\n            <AdminPageShell\n                title={isRTL ? 'в”ҳГ в•Әв–’в”ҳГўв•Әв–“ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҙв•ӘШҜв•Әв–’в•ӘШұ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ' : 'MARKET HUB'}\n                titleEn=\"TRADE & AUCTION CENTER\"\n                backHref=\"/admin/dashboard\"\n                isRTL={isRTL}\n                actions={\n                    <button onClick={() => activeMode === MODE_LIVE ? loadLiveSessions() : loadClassicAuctions()} title={isRTL ? \"в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі\" : \"Refresh\"} className=\"w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all text-red-500\">\n                        <RefreshCw className={cn('w-5 h-5', loading && 'animate-spin')} />\n                    </button>\n                }\n            >\n                {/* Hub Tabs */}\n                <div className=\"flex bg-white/5 p-1 rounded-2xl border border-white/5 mb-10 w-full max-w-lg\">\n                    <button onClick={() => setActiveMode(MODE_LIVE)}\n                        className={cn('flex-1 py-3 rounded-xl text-[11px] font-black uppercase tracking-[0.1em] transition-all flex items-center justify-center gap-3', \n                        activeMode === MODE_LIVE ? 'bg-[#00f0ff] text-black shadow-[0_0_20px_rgba(0,240,255,0.3)]' : 'text-white/40 hover:text-white/60')}>\n                        <Radio size={16} />\n                        {isRTL ? 'в•Әв”Ӯв•ӘШҜв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•ӘШөв”ҳГЁ' : 'LIVE ARENA'}\n                    </button>\n                    <button onClick={() => setActiveMode(MODE_AUCTIONS)}\n                        className={cn('flex-1 py-3 rounded-xl text-[11px] font-black uppercase tracking-[0.1em] transition-all flex items-center justify-center gap-3', \n                        activeMode === MODE_AUCTIONS ? 'bg-red-500 text-white shadow-[0_0_20px_rgba(239,68,68,0.3)]' : 'text-white/40 hover:text-white/60')}>\n                        <Gavel size={16} />\n                        {isRTL ? 'в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ ' : 'SYSTEM AUCTIONS'}\n                    </button>\n                </div>\n\n                {activeMode === MODE_LIVE ? (\n                    <div className=\"space-y-6\">\n                        <div className=\"flex justify-between items-center bg-white/[0.02] p-6 rounded-3xl border border-white/5\">\n                            <div>\n                                <h3 className=\"text-xl font-black uppercase italic\">{isRTL ? 'в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•ӘШөв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’' : 'LIVE SHOWROOM SESSIONS'}</h3>\n                                <p className=\"text-[10px] text-white/30 uppercase tracking-[0.2em]\">{isRTL ? 'в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШі в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•Әв–’в•ӘШҙв”ҳГЁв•ӘШұ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГЁв•ӘВ»в”ҳГӘв”ҳГЁв•ӘШұ' : 'Manage external feeds & manual streams'}</p>\n                            </div>\n                            <button onClick={() => { setLiveForm({ title: '', externalUrl: '', whatsappNumber: '', auctionUsername: '', auctionPassword: '', cars: [] }); setEditingLiveId(null); setIsLiveModalOpen(true); }} className=\"px-6 py-3 bg-[#00f0ff] text-black font-black uppercase text-[10px] tracking-widest rounded-xl hover:scale-105 transition-all shadow-[0_0_20px_rgba(0,240,255,0.2)]\">\n                                <Plus size={14} className=\"inline mr-2\" /> {isRTL ? 'в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШұ' : 'INITIATE'}\n                            </button>\n                        </div>\n\n                        <div className=\"grid grid-cols-1 gap-4\">\n                            {sessions.map(s => (\n                                <motion.div key={s._id} initial={{ opacity: 0 }} animate={{ opacity: 1 }} className=\"ck-card p-6 flex flex-col md:flex-row items-center gap-6 group\">\n                                    <div className=\"flex-1 space-y-2\">\n                                        <div className=\"flex items-center gap-3\">\n                                            <span className={cn('px-2.5 py-1 rounded-lg text-[8px] font-black uppercase tracking-wider', s.status === 'live' ? 'bg-red-500/20 text-red-500 border border-red-500/40' : 'bg-white/5 text-white/30 border border-white/10')}>\n                                                {s.status === 'live' ? (isRTL ? 'в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ' : 'LIVE') : (isRTL ? 'в”ҳГ в•ӘШІв”ҳГӘв”ҳГ©в”ҳВҒ' : 'ENDED')}\n                                            </span>\n                                            <h4 className=\"text-lg font-black uppercase italic tracking-tighter\">{s.title}</h4>\n                                        </div>\n                                        <div className=\"flex items-center gap-4 text-[9px] text-white/40 font-bold uppercase tracking-widest\"><LinkIcon size={12} /> {s.externalUrl || (isRTL ? 'в”ҳВ„в•ӘШҜ в”ҳГЁв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШ°в•ӘШі в•ӘВ«в•ӘШҜв•Әв–’в•ӘШҙв”ҳГЁ' : 'No External Feed')}</div>\n                                    </div>\n                                    <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-2 w-full md:w-auto shrink-0\">\n                                        <button onClick={() => handleStatusUpdate(s._id, s.status === 'live' ? 'end' : 'start')} title={s.status === 'live' ? (isRTL ? 'в•ӘШӯв”ҳГЁв”ҳГ©в•ӘШҜв”ҳВҒ' : 'Stop') : (isRTL ? 'в•ӘШ°в•ӘВ»в•ӘШ©' : 'Start')} className={cn('p-3 rounded-xl border flex flex-col items-center gap-1 transition-all', s.status === 'live' ? 'border-red-500/40 text-red-500 hover:bg-red-500/10' : 'border-[#00f0ff]/40 text-[#00f0ff] hover:bg-[#00f0ff]/10')}>\n                                            {s.status === 'live' ? <Square size={16} /> : <Play size={16} />}\n                                            <span className=\"text-[7px] font-black\">{s.status === 'live' ? (isRTL ? 'в•ӘШӯв”ҳГЁв”ҳГ©в•ӘШҜв”ҳВҒ' : 'STOP') : (isRTL ? 'в•ӘШІв•Әв”Өв•Әв•‘в”ҳГЁв”ҳВ„' : 'LIVE')}</span>\n                                        </button>\n                                        <button onClick={() => { setLiveForm(s); setEditingLiveId(s._id); setIsLiveModalOpen(true); }} title={isRTL ? 'в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„' : 'Edit'} className=\"p-3 rounded-xl border border-white/5 text-white/40 hover:text-white hover:bg-white/5 flex flex-col items-center gap-1\">\n                                            <Edit2 size={16} />\n                                            <span className=\"text-[7px] font-black uppercase\">{isRTL ? 'в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„' : 'Edit'}</span>\n                                        </button>\n                                        <button onClick={() => handleDeleteLive(s._id)} title={isRTL ? 'в•ӘШөв•Әв–‘в”ҳВҒ' : 'Delete'} className=\"p-3 rounded-xl border border-white/5 text-white/20 hover:text-red-500 hover:bg-red-500/10 flex flex-col items-center gap-1\">\n                                            <Trash2 size={16} />\n                                            <span className=\"text-[7px] font-black uppercase\">{isRTL ? 'в•ӘШөв•Әв–‘в”ҳВҒ' : 'Del'}</span>\n                                        </button>\n                                        <Link href={`/auctions/live/${s._id}`} target=\"_blank\" title={isRTL ? 'в•Әв•Јв•Әв–’в•Әв•ў' : 'View'} className=\"p-3 rounded-xl border border-white/5 text-white/40 hover:text-[#00f0ff] hover:bg-[#00f0ff]/10 flex flex-col items-center gap-1\">\n                                            <ExternalLink size={16} />\n                                            <span className=\"text-[7px] font-black uppercase\">{isRTL ? 'в•Әв•Јв•Әв–’в•Әв•ў' : 'View'}</span>\n                                        </Link>\n                                    </div>\n                                </motion.div>\n                            ))}\n                        </div>\n                    </div>\n                ) : (\n                    <div className=\"space-y-8\">\n                        <div className=\"flex bg-white/5 p-1 rounded-2xl border border-white/5 w-fit\">\n                            {[\n                                { id: 'LIVE', label: isRTL ? 'в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ' : 'LIVE' },\n                                { id: 'SCHEDULED', label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҙв•ӘВ»в”ҳГӘв”ҳВ„в•ӘШұ' : 'SCHEDULED' },\n                                { id: 'SETTLED', label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШІв”ҳГ§в”ҳГЁв•ӘШұ' : 'SETTLED' },\n                                { id: 'AUDIT', label: isRTL ? 'в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГўв•ӘШҜв”ҳГ в”ҳВ„' : 'AUDIT' }\n                            ].map(tab => (\n                                <button key={tab.id} onClick={() => setActiveArena(tab.id)} className={cn('px-6 py-2.5 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all', activeArena === tab.id ? 'bg-red-500 text-white shadow-lg' : 'text-white/40 hover:text-white')}>{tab.label}</button>\n                            ))}\n                        </div>\n\n                        <div className=\"grid grid-cols-1 gap-4\">\n                            {auctions.map(auc => (\n                                <motion.div key={auc.id} initial={{ opacity: 0 }} animate={{ opacity: 1 }} className=\"ck-card p-6 flex flex-col md:flex-row items-center gap-8 group\">\n                                    <div className=\"w-full md:w-36 h-24 rounded-xl overflow-hidden border border-white/5 shrink-0 relative\">\n                                        {(() => {\n                                            const imageKey = String(auc.id || auc._id || auc.car?._id || 'auction');\n                                            const imageSrc = typeof auc.car?.images?.[0] === 'string' ? auc.car.images[0].trim() : '';\n                                            const showFallback = !imageSrc || imageErrors[imageKey];\n                                            return showFallback ? (\n                                                <div className=\"w-full h-full flex items-center justify-center bg-gradient-to-br from-white/5 via-black/40 to-black/80\">\n                                                    <Car className=\"w-8 h-8 text-white/20\" />\n                                                </div>\n                                            ) : (\n                                                <img\n                                                    src={imageSrc}\n                                                    className=\"w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700\"\n                                                    alt=\"\"\n                                                    onError={() => setImageErrors(prev => ({ ...prev, [imageKey]: true }))}\n                                                />\n                                            );\n                                        })()}\n                                        {auc.status === 'running' && <div className=\"absolute top-2 left-2 w-2 h-2 rounded-full bg-red-500 animate-pulse shadow-[0_0_8px_rgba(255,0,0,0.8)]\" />}\n                                    </div>\n                                    <div className=\"flex-1 min-w-0 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n                                        <div>\n                                            <p className=\"text-[10px] font-black text-red-500/50 uppercase tracking-[0.2em] italic mb-0.5\">{auc.car?.make || (isRTL ? 'в”ҳГ в•Әв–’в”ҳГўв•ӘШ°в•ӘШұ' : 'Vehicle')}</p>\n                                            <h4 className=\"text-md font-black italic uppercase truncate\">{auc.car?.title || (isRTL ? 'в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒв•ӘШұ' : 'Unknown Car')}</h4>\n                                        </div>\n                                        <div>\n                                            <p className=\"flex items-center gap-2 text-[9px] font-black text-white/20 uppercase tracking-widest mb-1\"><TrendingUp size={12} /> {isRTL ? 'в•ӘШ«в•Әв•Јв”ҳВ„в”ҳГ« в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШұ' : 'Live Bid'}</p>\n                                            <p className=\"text-xl font-black italic text-red-500\">{Number(auc.currentBid).toLocaleString()} <span className=\"text-[9px]\">{auc.currency}</span></p>\n                                        </div>\n                                        <div className=\"hidden lg:block\">\n                                            <p className=\"flex items-center gap-2 text-[9px] font-black text-white/20 uppercase tracking-widest mb-1\"><Clock size={12} /> {isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ§в•Ә