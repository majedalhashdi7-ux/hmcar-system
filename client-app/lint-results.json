t, CheckCircle2, XCircle\n} from 'lucide-react';\nimport { api } from '@/lib/api';\nimport { useLanguage } from '@/lib/LanguageContext';\nimport { cn } from '@/lib/utils';\nimport { useToast } from '@/lib/ToastContext';\nimport AdminPageShell from '@/components/AdminPageShell';\n\n// ШёВӨВҖШёВӨВҖ в•ӘШ«в”ҳВҶв”ҳГӘв•ӘШҜв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ ШёВӨВҖШёВӨВҖ\ninterface TrustFactors {\n    successfulLogins: number;\n    daysActive: number;\n    consistentUsage: boolean;\n    adminApproved: boolean;\n    failedAttempts: number;\n    accountSwitchAttempts: number;\n    suspiciousActions: number;\n    ipChanges: number;\n}\n\ninterface SecurityEvent {\n    type: string;\n    detail: string;\n    ip: string;\n    username: string;\n    timestamp: string;\n}\n\ninterface SecurityDevice {\n    _id: string;\n    ip: string;\n    deviceId?: string;\n    fingerprintHash?: string;\n    browser?: string;\n    browserVersion?: string;\n    os?: string;\n    osVersion?: string;\n    platform?: string;\n    screenResolution?: string;\n    timezone?: string;\n    linkedUsername?: string;\n    linkedUserId?: string;\n    attemptedUsernames?: { username: string; attempts: number; lastAttempt: string }[];\n    trustScore: number;\n    trustLevel: string;\n    trustFactors: TrustFactors;\n    banned: boolean;\n    banCode?: string;\n    banReason?: string;\n    bannedAt?: string;\n    banExpiresAt?: string;\n    exemptFromSecurity: boolean;\n    exemptReason?: string;\n    failedAttempts: number;\n    securityEvents?: SecurityEvent[];\n    ipHistory?: { ip: string; firstSeen: string; lastSeen: string; hitCount: number }[];\n    adminNotes?: string;\n    userAgent?: string;\n    updatedAt?: string;\n    createdAt?: string;\n}\n\ninterface DashboardData {\n    overview: {\n        totalDevices: number;\n        bannedDevices: number;\n        trustedDevices: number;\n        suspiciousDevices: number;\n        exemptDevices: number;\n        totalUsers: number;\n        activeUsers: number;\n        activeSessions: number;\n        threatLevel: string;\n    };\n    recentEvents: any[];\n    topThreats: any[];\n}\n\n// ШёВӨВҖШёВӨВҖ в•ӘВ»в”ҳГӘв•ӘШҜв”ҳВ„ в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ ШёВӨВҖШёВӨВҖ\nfunction getTrustColor(level: string) {\n    switch (level) {\n        case 'trusted': return 'text-emerald-400';\n        case 'high': return 'text-green-400';\n        case 'medium': return 'text-yellow-400';\n        case 'low': return 'text-orange-400';\n        case 'unknown': return 'text-red-400';\n        case 'blocked': return 'text-red-500';\n        default: return 'text-white/40';\n    }\n}\n\nfunction getTrustBg(level: string) {\n    switch (level) {\n        case 'trusted': return 'bg-emerald-500/10 border-emerald-500/20';\n        case 'high': return 'bg-green-500/10 border-green-500/20';\n        case 'medium': return 'bg-yellow-500/10 border-yellow-500/20';\n        case 'low': return 'bg-orange-500/10 border-orange-500/20';\n        case 'unknown': return 'bg-red-500/10 border-red-500/20';\n        case 'blocked': return 'bg-red-600/10 border-red-600/30';\n        default: return 'bg-white/5 border-white/10';\n    }\n}\n\nfunction getTrustLabel(level: string, isRTL: boolean) {\n    const labels: Record<string, [string, string]> = {\n        trusted: ['в”ҳГ в”ҳГӘв•ӘШів”ҳГӘв”ҳГ©', 'TRUSTED'],\n        high: ['в•Әв•Јв•ӘШҜв”ҳВ„в”ҳГЁ', 'HIGH'],\n        medium: ['в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–', 'MEDIUM'],\n        low: ['в”ҳГ в”ҳВҶв•ӘВ«в”ҳВҒв•Әв•ў', 'LOW'],\n        unknown: ['в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв”ҳВҒ', 'UNKNOWN'],\n        blocked: ['в”ҳГ в•ӘШөв•Әв••в”ҳГӘв•Әв–’', 'BLOCKED'],\n    };\n    return labels[level]?.[isRTL ? 0 : 1] || level.toUpperCase();\n}\n\nfunction getEventIcon(type: string) {\n    switch (type) {\n        case 'login_success': return <CheckCircle2 className=\"w-3.5 h-3.5 text-green-400\" />;\n        case 'login_failed': return <XCircle className=\"w-3.5 h-3.5 text-red-400\" />;\n        case 'account_switch': return <Users className=\"w-3.5 h-3.5 text-orange-400\" />;\n        case 'banned_manually': case 'auto_banned': return <ShieldOff className=\"w-3.5 h-3.5 text-red-500\" />;\n        case 'unbanned_manually': return <ShieldCheck className=\"w-3.5 h-3.5 text-green-500\" />;\n        case 'trusted': return <ShieldCheck className=\"w-3.5 h-3.5 text-emerald-400\" />;\n        case 'suspicious_activity': return <AlertTriangle className=\"w-3.5 h-3.5 text-yellow-400\" />;\n        default: return <Activity className=\"w-3.5 h-3.5 text-white/40\" />;\n    }\n}\n\nfunction getDeviceIcon(platform?: string) {\n    switch (platform) {\n        case 'mobile': return <Smartphone className=\"w-5 h-5\" />;\n        case 'tablet': return <Monitor className=\"w-5 h-5\" />;\n        default: return <Laptop className=\"w-5 h-5\" />;\n    }\n}\n\nfunction getDeviceType(ua?: string) {\n    if (!ua) return 'desktop';\n    const l = ua.toLowerCase();\n    if (l.includes('mobile') || l.includes('android') || l.includes('iphone')) return 'mobile';\n    if (l.includes('tablet') || l.includes('ipad')) return 'tablet';\n    return 'desktop';\n}\n\n// ШёВӨВҖШёВӨВҖ Trust Score Bar ШёВӨВҖШёВӨВҖ\nfunction TrustScoreBar({ score, level }: { score: number; level: string }) {\n    const color = level === 'blocked' ? 'bg-red-500' : score >= 80 ? 'bg-emerald-500' : score >= 60 ? 'bg-green-500' : score >= 40 ? 'bg-yellow-500' : score >= 20 ? 'bg-orange-500' : 'bg-red-500';\n    return (\n        <div className=\"flex items-center gap-2\">\n            <div className=\"flex-1 h-1.5 rounded-full bg-white/10 overflow-hidden\">\n                <motion.div initial={{ width: 0 }} animate={{ width: `${score}%` }} transition={{ duration: 0.8 }} className={cn('h-full rounded-full', color)} />\n            </div>\n            <span className={cn('text-[10px] font-black w-8 text-right', getTrustColor(level))}>{score}</span>\n        </div>\n    );\n}\n\n// ШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗ\n// в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳЩ‘в”ҳВҶ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁ\n// ШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗ\nexport default function AdminSecurity() {\n    const { isRTL } = useLanguage();\n    const { showToast } = useToast();\n\n    // ШёВӨВҖШёВӨВҖ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ ШёВӨВҖШёВӨВҖ\n    const [activeTab, setActiveTab] = useState<'dashboard' | 'devices' | 'sessions'>('dashboard');\n    const [dashboard, setDashboard] = useState<DashboardData | null>(null);\n    const [devices, setDevices] = useState<SecurityDevice[]>([]);\n    const [sessions, setSessions] = useState<any[]>([]);\n    const [loading, setLoading] = useState(true);\n    const [searchTerm, setSearchTerm] = useState('');\n    const [filterTab, setFilterTab] = useState<'all' | 'banned' | 'suspicious' | 'trusted' | 'exempt'>('all');\n    const [selectedDevice, setSelectedDevice] = useState<SecurityDevice | null>(null);\n    const [selectedIds, setSelectedIds] = useState<string[]>([]);\n    const [banReason, setBanReason] = useState('');\n    const [banDuration, setBanDuration] = useState('permanent');\n    const [showBanDialog, setShowBanDialog] = useState<SecurityDevice | null>(null);\n    const [deviceNote, setDeviceNote] = useState('');\n\n    // ШёВӨВҖШёВӨВҖ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ ШёВӨВҖШёВӨВҖ\n    const loadDashboard = useCallback(async () => {\n        try {\n            const res = await api.security.getDashboard();\n            if (res.success) setDashboard(res.data);\n        } catch (e) { console.warn('Dashboard load failed:', e); }\n    }, []);\n\n    const loadDevices = useCallback(async () => {\n        try {\n            setLoading(true);\n            const res = await api.security.getDevices({ filter: filterTab, search: searchTerm, limit: 50 });\n            const list = res.data || res.devices || [];\n            setDevices(Array.isArray(list) ? list : []);\n        } catch (e) {\n            console.error('Devices load failed:', e);\n            showToast(isRTL ? 'в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШҙв”ҳГ§в•Әв–“в•ӘШұ' : 'Failed to load devices', 'error');\n        } finally { setLoading(false); }\n    }, [filterTab, searchTerm, isRTL, showToast]);\n\n    const loadSessions = useCallback(async () => {\n        try {\n            const res = await api.security.getSessions();\n            setSessions(res.data || []);\n        } catch (e) { console.warn('Sessions load failed:', e); }\n    }, []);\n\n    useEffect(() => {\n        loadDashboard();\n        loadDevices();\n    }, [loadDashboard, loadDevices]);\n\n    useEffect(() => {\n        if (activeTab === 'sessions') loadSessions();\n    }, [activeTab, loadSessions]);\n\n    // ШёВӨВҖШёВӨВҖ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•Әв–’в•ӘШҜв•ӘШ©в•ӘШҜв•ӘШІ ШёВӨВҖШёВӨВҖ\n    const handleToggleBan = async (device: SecurityDevice, reason?: string, duration?: string) => {\n        try {\n            const res = await api.security.toggleBan(device._id, { reason, duration });\n            if (res.success) {\n                showToast(res.message || (device.banned ? 'ШёВЈГ  в•ӘШІв”ҳГ  в”ҳВҒв”ҳГў в•ӘШҜв”ҳВ„в•ӘШөв•Әв••в•Әв–’' : 'вүЎШ§ШЈШі в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШөв•Әв••в•Әв–’'), 'success');\n                loadDevices();\n                loadDashboard();\n                if (selectedDevice?._id === device._id) {\n                    const detail = await api.security.getDeviceDetails(device._id);\n                    if (detail.success) setSelectedDevice(detail.data.device);\n                }\n            }\n        } catch (e: any) { showToast(e.message || 'в”ҳВҒв•Әв”Өв”ҳВ„', 'error'); }\n    };\n\n    const handleToggleExempt = async (device: SecurityDevice) => {\n        try {\n            const res = await api.security.toggleExempt(device._id);\n            if (res.success) {\n                showToast(res.message || 'ШёВЈГ  в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі', 'success');\n                loadDevices();\n                loadDashboard();\n            }\n        } catch (e: any) { showToast(e.message || 'в”ҳВҒв•Әв”Өв”ҳВ„', 'error'); }\n    };\n\n    const handleTrustAction = async (device: SecurityDevice, action: 'boost' | 'reduce' | 'reset') => {\n        try {\n            const res = await api.security.updateTrust(device._id, action);\n            if (res.success) {\n                showToast(res.message || 'ШёВЈГ  в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі', 'success');\n                loadDevices();\n                if (selectedDevice?._id === device._id) {\n                    const detail = await api.security.getDeviceDetails(device._id);\n                    if (detail.success) setSelectedDevice(detail.data.device);\n                }\n            }\n        } catch (e: any) { showToast(e.message || 'в”ҳВҒв•Әв”Өв”ҳВ„', 'error'); }\n    };\n\n    const handleSaveNote = async (device: SecurityDevice) => {\n        try {\n            await api.security.addNote(device._id, deviceNote);\n            showToast('ШёВЈГ  в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в•ӘШҜв•ӘШөв•Әв••в•ӘШұ', 'success');\n        } catch { showToast('в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в•ӘШҜв•ӘШөв•Әв••в•ӘШұ', 'error'); }\n    };\n\n    const handleBulkAction = async (action: 'ban' | 'unban' | 'delete') => {\n        if (selectedIds.length === 0) return;\n        try {\n            const res = await api.security.bulkAction(selectedIds, action);\n            if (res.success) {\n                showToast(res.message || 'ШёВЈГ  в•ӘШІв”ҳГ ', 'success');\n                setSelectedIds([]);\n                loadDevices();\n                loadDashboard();\n            }\n        } catch (e: any) { showToast(e.message || 'в”ҳВҒв•Әв”Өв”ҳВ„', 'error'); }\n    };\n\n    const handleTerminateSession = async (sessionId: string) => {\n        try {\n            const res = await api.security.terminateSession(sessionId);\n            if (res.success) { showToast('ШёВЈГ  в•ӘШІв”ҳГ  в•ӘШӯв”ҳВҶв”ҳГ§в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШұ', 'success'); loadSessions(); }\n        } catch { showToast('в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШӯв”ҳВҶв”ҳГ§в•ӘШҜв•ӘШ© в•ӘШҜв”ҳВ„в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШұ', 'error'); }\n    };\n\n    // ШёВӨВҖШёВӨВҖ Stats Cards ШёВӨВҖШёВӨВҖ\n    const ov = dashboard?.overview;\n\n    return (\n        <div className=\"min-h-screen text-white bg-black overflow-hidden\" dir={isRTL ? 'rtl' : 'ltr'}>\n            <div className=\"fixed inset-0 pointer-events-none\">\n                <div className=\"absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(139,92,246,0.08),transparent_70%)]\" />\n                <div className=\"absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:100px_100px]\" />\n            </div>\n\n            <AdminPageShell\n                title={isRTL ? 'в”ҳГ в•Әв–’в”ҳГўв•Әв–“ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ' : 'SECURITY CENTER'}\n                titleEn=\"ADVANCED THREAT PROTECTION\"\n                backHref=\"/admin/dashboard\"\n                isRTL={isRTL}\n                actions={\n                    <button onClick={() => { loadDashboard(); loadDevices(); }} title=\"Refresh\"\n                        className=\"w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all text-violet-400\">\n                        <RefreshCw className={cn('w-5 h-5', loading && 'animate-spin')} />\n                    </button>\n                }\n            >\n                {/* ШёВӨВҖШёВӨВҖ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШ°в”ҳГӘв”ҳГЁв•ӘШ°в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘШұ ШёВӨВҖШёВӨВҖ */}\n                <div className=\"flex gap-2 mb-6 overflow-x-auto pb-2\">\n                    {[\n                        { id: 'dashboard', label: isRTL ? 'вүЎШ§ГҙГЁ в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ' : 'вүЎШ§ГҙГЁ Dashboard', icon: BarChart3 },\n                        { id: 'devices', label: isRTL ? 'вүЎШ§Гҙв–’ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШҙв”ҳГ§в•Әв–“в•ӘШұ' : 'вүЎШ§Гҙв–’ Devices', icon: Smartphone },\n                        { id: 'sessions', label: isRTL ? 'вүЎШ§ВӨГ№ в•ӘШҜв”ҳВ„в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ' : 'вүЎШ§ВӨГ№ Sessions', icon: Wifi },\n                    ].map(t => (\n                        <button key={t.id} onClick={() => setActiveTab(t.id as any)}\n                            className={cn('px-5 py-3 rounded-2xl text-xs font-black tracking-wider transition-all whitespace-nowrap flex items-center gap-2',\n                                activeTab === t.id ? 'bg-violet-500/20 text-violet-300 border border-violet-500/30 shadow-[0_0_20px_rgba(139,92,246,0.2)]' : 'bg-white/5 text-white/40 border border-white/5 hover:bg-white/10'\n                            )}>\n                            {t.label}\n                        </button>\n                    ))}\n                </div>\n\n                {/* ШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗ в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ«в”ҳГ в•ӘШҜв”ҳВҶ ШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗ */}\n                {activeTab === 'dashboard' && (\n                    <div className=\"space-y-6\">\n                        {/* в•ӘШ°в•Әв•–в•ӘШҜв”ҳГ©в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШөв•Әв•Ўв•ӘШҜв•ӘШ®в”ҳГЁв•ӘШҜв•ӘШІ */}\n                        <div className=\"grid grid-cols-2 md:grid-cols-4 gap-3\">\n                            {[\n                                { label: isRTL ? 'в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШҙв”ҳГ§в•Әв–“в•ӘШұ' : 'Total Devices', value: ov?.totalDevices || 0, icon: Smartphone, color: 'text-violet-400', bg: 'bg-violet-500/10 border-violet-500/20' },\n                                { label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•Әв••в”ҳГӘв•Әв–’в•ӘШұ' : 'Banned', value: ov?.bannedDevices || 0, icon: ShieldAlert, color: 'text-red-400', bg: 'bg-red-500/10 border-red-500/20' },\n                                { label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШів”ҳГӘв”ҳГ©в•ӘШұ' : 'Trusted', value: ov?.trustedDevices || 0, icon: ShieldCheck, color: 'text-emerald-400', bg: 'bg-emerald-500/10 border-emerald-500/20' },\n                                { label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Өв•ӘШ°в”ҳГӘв”ҳГ§в•ӘШұ' : 'Suspicious', value: ov?.suspiciousDevices || 0, icon: AlertTriangle, color: 'text-orange-400', bg: 'bg-orange-500/10 border-orange-500/20' },\n                            ].map((s, i) => (\n                                <motion.div key={i} initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: i * 0.1 }}\n                                    className={cn('p-5 rounded-2xl border', s.bg)}>\n                                    <s.icon className={cn('w-5 h-5 mb-3', s.color)} />\n                                    <div className=\"text-2xl font-black mb-1\">{s.value}</div>\n                                    <div className=\"text-[9px] font-bold text-white/30 uppercase tracking-wider\">{s.label}</div>\n                                </motion.div>\n                            ))}\n                        </div>\n\n                        {/* в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ§в•ӘВ»в”ҳГЁв•ӘВ» + в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ */}\n                        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3\">\n                            <div className={cn('p-5 rounded-2xl border', ov?.threatLevel === 'high' ? 'bg-red-500/10 border-red-500/30' : ov?.threatLevel === 'medium' ? 'bg-yellow-500/10 border-yellow-500/30' : 'bg-emerald-500/10 border-emerald-500/30')}>\n                                <Shield className={cn('w-5 h-5 mb-2', ov?.threatLevel === 'high' ? 'text-red-400' : ov?.threatLevel === 'medium' ? 'text-yellow-400' : 'text-emerald-400')} />\n                                <div className=\"text-lg font-black uppercase\">{ov?.threatLevel === 'high' ? (isRTL ? 'в•ӘШІв”ҳГ§в•ӘВ»в”ҳГЁв•ӘВ» в•Әв•Јв•ӘШҜв”ҳВ„в”ҳГЁ' : 'HIGH THREAT') : ov?.threatLevel === 'medium' ? (isRTL ? 'в•ӘШІв”ҳГ§в•ӘВ»в”ҳГЁв•ӘВ» в”ҳГ в•ӘШІв”ҳГӘв•Әв”Ӯв•Әв•–' : 'MEDIUM') : (isRTL ? 'в•ӘШӘв”ҳГ в”ҳВҶ' : 'SECURE')}</div>\n                                <div className=\"text-[9px] text-white/30 uppercase tracking-wider\">{isRTL ? 'в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ§в•ӘВ»в”ҳГЁв•ӘВ»' : 'THREAT LEVEL'}</div>\n                            </div>\n                            <div className=\"p-5 rounded-2xl border bg-blue-500/10 border-blue-500/20\">\n                                <Users className=\"w-5 h-5 mb-2 text-blue-400\" />\n                                <div className=\"text-2xl font-black\">{ov?.activeUsers || 0}</div>\n                                <div className=\"text-[9px] text-white/30 uppercase tracking-wider\">{isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ в”ҳГӘв”ҳВҶ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв•–в”ҳГӘв”ҳВҶ' : 'ACTIVE USERS'}</div>\n                            </div>\n                            <div className=\"p-5 rounded-2xl border bg-cyan-500/10 border-cyan-500/20\">\n                                <Wifi className=\"w-5 h-5 mb-2 text-cyan-400\" />\n                                <div className=\"text-2xl font-black\">{ov?.activeSessions || 0}</div>\n                                <div className=\"text-[9px] text-white/30 uppercase tracking-wider\">{isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ' : 'ACTIVE SESSIONS'}</div>\n                            </div>\n                        </div>\n\n                        {/* в•ӘШ«в•ӘШөв•ӘВ»в•ӘШі в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ§в•ӘВ»в”ҳГЁв•ӘВ»в•ӘШҜв•ӘШІ */}\n                        {dashboard?.topThreats && dashboard.topThreats.length > 0 && (\n                            <div className=\"p-5 rounded-2xl border border-red-500/20 bg-red-500/[0.03]\">\n                                <h3 className=\"text-xs font-black text-red-400 uppercase tracking-widest mb-4 flex items-center gap-2\">\n                                    <AlertTriangle className=\"w-4 h-4\" /> {isRTL ? 'в•ӘШ«в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв”ҳГ§в•ӘВ»в”ҳГЁв•ӘВ»в•ӘШҜв•ӘШІ' : 'TOP THREATS'}\n                                </h3>\n                                <div className=\"space-y-3\">\n                                    {dashboard.topThreats.map((t: any, i: number) => (\n                                        <div key={i} className=\"flex items-center gap-3 p-3 rounded-xl bg-white/[0.02] border border-white/5\">\n                                            <ShieldAlert className=\"w-4 h-4 text-red-400 shrink-0\" />\n                                            <div className=\"flex-1 min-w-0\">\n                                                <span className=\"text-xs font-bold\">{t.linkedUsername || t.ip}</span>\n                                                <span className=\"text-[9px] text-white/30 mx-2\">ШёВҖШӘ</span>\n                                                <span className=\"text-[9px] text-white/30\">IP: {t.ip}</span>\n                                            </div>\n                                            <TrustScoreBar score={t.trustScore} level={t.trustLevel} />\n                                        </div>\n                                    ))}\n                                </div>\n                            </div>\n                        )}\n                    </div>\n                )}\n\n                {/* ШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШҙв”ҳГ§в•Әв–“в•ӘШұ ШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗ */}\n                {activeTab === 'devices' && (\n                    <div className=\"space-y-4\">\n                        {/* в•Әв”Өв•Әв–’в”ҳГЁв•Әв•– в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі в”ҳГӘв•ӘШҜв”ҳВ„в”ҳВҒв”ҳВ„в•ӘШІв•Әв–’в•ӘШұ */}\n                        <div className=\"flex flex-col md:flex-row gap-3\">\n                            <div className=\"relative flex-1\">\n                                <Search className={cn('absolute top-1/2 -translate-y-1/2 w-4 h-4 text-white/20', isRTL ? 'right-4' : 'left-4')} />\n                                <input type=\"text\" placeholder={isRTL ? 'в•ӘШ°в•ӘШөв•ӘШі в•ӘШ°в”ҳВҖ IPв•ӘГ® в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ в•ӘГ® в•Әв–’в”ҳГ в•Әв–“ в•ӘШҜв”ҳВ„в•ӘШөв•Әв••в•Әв–’...' : 'Search by IP, username, ban code...'}\n                                    value={searchTerm} onChange={e => setSearchTerm(e.target.value)}\n                                    className={cn('w-full h-12 bg-white/5 border border-white/10 rounded-2xl text-sm focus:border-violet-500/40 focus:outline-none transition-all', isRTL ? 'pr-12 pl-4' : 'pl-12 pr-4')} />\n                            </div>\n                            <div className=\"flex gap-1 p-1 bg-white/5 border border-white/10 rounded-2xl overflow-x-auto\">\n                                {[\n                                    { id: 'all', label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„' : 'ALL' },\n                                    { id: 'banned', label: isRTL ? 'в”ҳГ в•ӘШөв•Әв••в”ҳГӘв•Әв–’' : 'BANNED' },\n                                    { id: 'suspicious', label: isRTL ? 'в”ҳГ в•Әв”Өв•ӘШ°в”ҳГӘв”ҳГ§' : 'SUSPECT' },\n                                    { id: 'trusted', label: isRTL ? 'в”ҳГ в”ҳГӘв•ӘШів”ҳГӘв”ҳГ©' : 'TRUSTED' },\n                                    { id: 'exempt', label: isRTL ? 'в”ҳГ в•Әв”Ӯв•ӘШІв•ӘШів”ҳВҶв”ҳГ«' : 'EXEMPT' },\n                                ].map(t => (\n                                    <button key={t.id} onClick={() => setFilterTab(t.id as any)}\n                                        className={cn('px-4 py-2 rounded-xl text-[10px] font-black tracking-wider transition-all whitespace-nowrap',\n                                            filterTab === t.id ? 'bg-violet-500 text-white shadow-[0_0_15px_rgba(139,92,246,0.4)]' : 'text-white/40 hover:text-white/70'\n                                        )}>{t.label}</button>\n                                ))}\n                            </div>\n                        </div>\n\n                        {/* в•ӘШӯв•ӘШҙв•Әв–’в•ӘШҜв•ӘШ©в•ӘШҜв•ӘШІ в•ӘШҙв”ҳГ в•ӘШҜв•Әв•Јв”ҳГЁв•ӘШұ */}\n                        {selectedIds.length > 0 && (\n                            <motion.div initial={{ opacity: 0, y: -10 }} animate={{ opacity: 1, y: 0 }}\n                                className=\"flex items-center gap-3 p-3 rounded-2xl bg-violet-500/10 border border-violet-500/20\">\n                                <span className=\"text-xs font-bold\">{selectedIds.length} {isRTL ? 'в”ҳГ в•ӘШөв•ӘВ»в•ӘВ»' : 'selected'}</span>\n                                <div className=\"flex-1\" />\n                                <button onClick={() => handleBulkAction('ban')} className=\"px-3 py-1.5 rounded-xl text-[10px] font-black bg-red-500/20 text-red-400 hover:bg-red-500 hover:text-white transition-all\">{isRTL ? 'в•ӘШөв•Әв••в•Әв–’ в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„' : 'BAN ALL'}</button>\n                                <button onClick={() => handleBulkAction('unban')} className=\"px-3 py-1.5 rounded-xl text-[10px] font-black bg-green-500/20 text-green-400 hover:bg-green-500 hover:text-black transition-all\">{isRTL ? 'в”ҳВҒв”ҳГў в•ӘШөв•Әв••в•Әв–’ в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„' : 'UNBAN ALL'}</button>\n                                <button onClick={() => setSelectedIds([])} className=\"px-3 py-1.5 rounded-xl text-[10px] font-black bg-white/10 text-white/40 hover:bg-white/20 transition-all\"><X className=\"w-3 h-3\" /></button>\n                            </motion.div>\n                        )}\n\n                        {/* в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШҙв”ҳГ§в•Әв–“в•ӘШұ */}\n                        <div className=\"space-y-2\">\n                            {loading ? Array.from({ length: 5 }).map((_, i) => (\n                                <div key={i} className=\"h-20 rounded-2xl bg-white/[0.02] animate-pulse border border-white/5\" />\n                            )) : devices.length === 0 ? (\n                                <div className=\"py-20 text-center\">\n                                    <Shield className=\"w-12 h-12 text-white/10 mx-auto mb-4\" />\n                                    <p className=\"text-sm text-white/30\">{isRTL ? 'в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШ«в•ӘШҙв”ҳГ§в•Әв–“в•ӘШұ' : 'No devices found'}</p>\n                                </div>\n                            ) : devices.map((device, i) => (\n                                <motion.div key={device._id} initial={{ opacity: 0, y: 5 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: i * 0.03 }}\n                                    className={cn('group p-4 rounded-2xl border transition-all hover:bg-white/[0.02] cursor-pointer',\n                                        device.banned ? 'border-red-500/20 bg-red-500/[0.02]' : getTrustBg(device.trustLevel)\n                                    )}\n                                    onClick={() => setSelectedDevice(device)}\n                                >\n                                    <div className=\"flex items-center gap-4\">\n                                        {/* Checkbox */}\n                                        <input type=\"checkbox\" checked={selectedIds.includes(device._id)}\n                                            onChange={e => { e.stopPropagation(); setSelectedIds(p => p.includes(device._id) ? p.filter(x => x !== device._id) : [...p, device._id]); }}\n                                            onClick={e => e.stopPropagation()}\n                                            className=\"w-4 h-4 rounded border-white/20 bg-white/5 accent-violet-500 shrink-0\" />\n\n                                        {/* в•ӘШ«в”ҳГЁв”ҳГ©в”ҳГӘв”ҳВҶв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШҙв”ҳГ§в•ӘШҜв•Әв–“ */}\n                                        <div className={cn('w-10 h-10 rounded-xl flex items-center justify-center border shrink-0',\n                                            device.banned ? 'bg-red-500/10 border-red-500/20 text-red-400' : getTrustBg(device.trustLevel) + ' ' + getTrustColor(device.trustLevel)\n                                        )}>\n                                            {device.banned ? <ShieldAlert className=\"w-5 h-5\" /> : getDeviceIcon(device.platform || getDeviceType(device.userAgent))}\n                                        </div>\n\n                                        {/* в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ */}\n                                        <div className=\"flex-1 min-w-0\">\n                                            <div className=\"flex items-center gap-2 flex-wrap mb-1\">\n                                                <span className=\"text-sm font-bold truncate\">{device.linkedUsername || device.ip || 'Unknown'}</span>\n                                                {device.linkedUsername && <span className=\"text-[9px] text-white/30 font-mono\">{device.ip}</span>}\n                                                <span className={cn('px-2 py-0.5 rounded-full text-[8px] font-black uppercase border', getTrustBg(device.trustLevel), getTrustColor(device.trustLevel))}>\n                                                    {getTrustLabel(device.trustLevel, isRTL)}\n                                                </span>\n                                                {device.exemptFromSecurity && <span className=\"px-2 py-0.5 rounded-full text-[8px] font-black bg-cyan-500/10 text-cyan-400 border border-cyan-500/20\">{isRTL ? 'в”ҳГ в•Әв”Ӯв•ӘШІв•ӘШів”ҳВҶв”ҳГ«' : 'EXEMPT'}</span>}\n                                            </div>\n                                            <div className=\"flex items-center gap-3 text-[10px] text-white/30\">\n                                                <span>{device.browser || device.os || getDeviceType(device.userAgent)}</span>\n                                                <span>ШёВҖШӘ</span>\n                                                <span className=\"flex items-center gap-1\"><Clock className=\"w-3 h-3\" />{device.updatedAt ? new Date(device.updatedAt).toLocaleDateString() : '---'}</span>\n                                            </div>\n                                        </div>\n\n                                        {/* Trust Score */}\n                                        <div className=\"w-24 hidden md:block\">\n                                            <TrustScoreBar score={device.trustScore || 50} level={device.trustLevel} />\n                                        </div>\n\n                                        {/* в•ӘШ«в•Әв–“в•Әв–’в•ӘШҜв•Әв–’ в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Јв•ӘШұ */}\n                                        <div className=\"flex gap-1.5 shrink-0\" onClick={e => e.stopPropagation()}>\n                                            <button onClick={() => device.banned ? handleToggleBan(device) : setShowBanDialog(device)} title={device.banned ? 'Unban' : 'Ban'}\n                                                className={cn('w-8 h-8 rounded-lg flex items-center justify-center text-xs transition-all',\n                                                    device.banned ? 'bg-green-500/10 text-green-400 hover:bg-green-500 hover:text-black' : 'bg-red-500/10 text-red-400 hover:bg-red-500 hover:text-white'\n                                                )}>\n                                                {device.banned ? <Unlock className=\"w-3.5 h-3.5\" /> : <Lock className=\"w-3.5 h-3.5\" />}\n                                            </button>\n                                            <button onClick={() => handleToggleExempt(device)} title=\"Exempt\"\n                                                className={cn('w-8 h-8 rounded-lg flex items-center justify-center transition-all',\n                                                    device.exemptFromSecurity ? 'bg-cyan-500/10 text-cyan-400 hover:bg-cyan-500/20' : 'bg-white/5 text-white/30 hover:bg-white/10'\n                                                )}>\n                                                <ShieldCheck className=\"w-3.5 h-3.5\" />\n                                            </button>\n                                        </div>\n                                    </div>\n                                </motion.div>\n                            ))}\n                        </div>\n                    </div>\n                )}\n\n                {/* ШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗ в•ӘШҜв”ҳВ„в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ ШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗ */}\n                {activeTab === 'sessions' && (\n                    <div className=\"space-y-3\">\n                        {sessions.length === 0 ? (\n                            <div className=\"py-20 text-center\">\n                                <Wifi className=\"w-12 h-12 text-white/10 mx-auto mb-4\" />\n                                <p className=\"text-sm text-white/30\">{isRTL ? 'в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ' : 'No active sessions'}</p>\n                            </div>\n                        ) : sessions.map((s: any) => (\n                            <div key={s._id} className=\"p-4 rounded-2xl border border-white/10 bg-white/[0.02] flex items-center gap-4\">\n                                <div className=\"w-10 h-10 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center text-green-400\">\n                                    <Wifi className=\"w-5 h-5\" />\n                                </div>\n                                <div className=\"flex-1 min-w-0\">\n                                    <div className=\"text-sm font-bold\">{s.userId?.name || s.ip || 'Unknown'}</div>\n                                    <div className=\"text-[10px] text-white/30\">{s.ip} ШёВҖШӘ {s.userId?.role || ''}</div>\n                                </div>\n                                <div className=\"text-[10px] text-white/30\">{s.lastActivity ? new Date(s.lastActivity).toLocaleString() : ''}</div>\n                                <button onClick={() => handleTerminateSession(s._id)}\n                                    className=\"px-3 py-1.5 rounded-xl text-[10px] font-black bg-red-500/10 text-red-400 hover:bg-red-500 hover:text-white transition-all\">\n                                    {isRTL ? 'в•ӘШӯв”ҳВҶв”ҳГ§в•ӘШҜв•ӘШ©' : 'END'}\n                                </button>\n                            </div>\n                        ))}\n                    </div>\n                )}\n            </AdminPageShell>\n\n            {/* ШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗ в”ҳВҶв•ӘШҜв”ҳВҒв•Әв–‘в•ӘШұ в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШҙв”ҳГ§в•ӘШҜв•Әв–“ ШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗШёЩҖВҗ */}\n            <AnimatePresence>\n                {selectedDevice && (\n                    <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}\n                        className=\"fixed inset-0 z-[120] flex items-center justify-center p-4 bg-black/90 backdrop-blur-xl\"\n                        onClick={() => setSelectedDevice(null)}>\n                        <motion.div initial={{ scale: 0.9, y: 20 }} animate={{ scale: 1, y: 0 }} exit={{ scale: 0.9, y: 20 }}\n                            onClick={e => e.stopPropagation()}\n                            className=\"bg-[#0a0a1a] border border-white/10 rounded-[2rem] p-6 max-w-2xl w-full max-h-[85vh] overflow-y-auto shadow-[0_0_80px_rgba(139,92,246,0.1)]\"\n                            dir={isRTL ? 'rtl' : 'ltr'}>\n\n                            {/* Header */}\n                            <div className=\"flex items-center justify-between mb-6\">\n                                <div className=\"flex items-center gap-3\">\n                                    <div className={cn('w-12 h-12 rounded-2xl flex items-center justify-center border', getTrustBg(selectedDevice.trustLevel), getTrustColor(selectedDevice.trustLevel))}>\n                                        {getDeviceIcon(selectedDevice.platform || getDeviceType(selectedDevice.userAgent))}\n                                    </div>\n                                    <div>\n                                        <h2 className=\"text-lg font-black\">{selectedDevice.linkedUsername || selectedDevice.ip}</h2>\n                                        <div className=\"flex items-center gap-2\">\n                                            <span className={cn('text-[10px] font-black uppercase', getTrustColor(selectedDevice.trustLevel))}>\n                                                {getTrustLabel(selectedDevice.trustLevel, isRTL)}\n                                            </span>\n                                            <span className=\"text-[10px] text-white/30\">ШёВҖШӘ Score: {selectedDevice.trustScore}</span>\n                                        </div>\n                                    </div>\n                                </div>\n                                <button onClick={() => setSelectedDevice(null)} className=\"w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 hover:bg-white/10 transition-all\">\n                                    <X className=\"w-5 h-5\" />\n                                </button>\n                            </div>\n\n                            {/* Trust Score Bar */}\n                            <div className=\"mb-6 p-4 rounded-2xl bg-white/[0.03] border border-white/5\">\n                                <div className=\"text-[9px] font-bold text-white/30 uppercase mb-2\">{isRTL ? 'в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШів”ҳГ©в•ӘШұ' : 'TRUST SCORE'}</div>\n                                <TrustScoreBar score={selectedDevice.trustScore || 50} level={selectedDevice.trustLevel} />\n                                <div className=\"grid grid-cols-4 gap-2 mt-3 text-center\">\n                                    <div><div className=\"text-lg font-black text-green-400\">{selectedDevice.trustFactors?.successfulLogins || 0}</div><div className=\"text-[8px] text-white/20\">{isRTL ? 'в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„ в”ҳВҶв•ӘШҜв•ӘШҙв•ӘШө' : 'Logins'}</div></div>\n                                    <div><div className=\"text-lg font-black text-red-400\">{selectedDevice.trustFactors?.failedAttempts || 0}</div><div className=\"text-[8px] text-white/20\">{isRTL ? 'в”ҳВҒв•ӘШҜв•Әв”Өв”ҳВ„в•ӘШұ' : 'Failed'}</div></div>\n                                    <div><div className=\"text-lg font-black text-orange-400\">{selectedDevice.trustFactors?.accountSwitchAttempts || 0}</div><div className=\"text-[8px] text-white/20\">{isRTL ? 'в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в•ӘШөв•Әв”Ӯв•ӘШҜв•ӘШ°' : 'Switches'}</div></div>\n                                    <div><div className=\"text-lg font-black text-blue-400\">{selectedDevice.trustFactors?.ipChanges || 0}</div><div className=\"text-[8px] text-white/20\">{isRTL ? 'в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ IP' : 'IP Changes'}</div></div>\n                                </div>\n                            </div>\n\n                            {/* в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҙв”ҳГ§в•ӘШҜв•Әв–“ */}\n                            <div className=\"grid grid-cols-2 gap-3 mb-6\">\n                                <div className=\"p-3 rounded-xl bg-white/[0.03] border border-white/5\">\n                                    <div className=\"text-[8px] text-white/20 uppercase mb-1\">IP</div>\n                                    <div className=\"text-xs font-mono text-blue-400\">{selectedDevice.ip}</div>\n                                </div>\n                                <div className=\"p-3 rounded-xl bg-white/[0.03] border border-white/5\">\n                                    <div className=\"text-[8px] text-white/20 uppercase mb-1\">{isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•Әв•Ўв”ҳВҒв•ӘШө' : 'Browser'}</div>\n                                    <div className=\"text-xs font-bold\">{selectedDevice.browser || 'Unknown'} {selectedDevice.browserVersion || ''}</div>\n                                </div>\n                                <div className=\"p-3 rounded-xl bg-white/[0.03] border border-white/5\">\n                                    <div className=\"text-[8px] text-white/20 uppercase mb-1\">{isRTL ? 'в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ ' : 'OS'}</div>\n                                    <div className=\"text-xs font-bold\">{selectedDevice.os || 'Unknown'}</div>\n                                </div>\n                                <div className=\"p-3 rounded-xl bg-white/[0.03] border border-white/5\">\n                                    <div className=\"text-[8px] text-white/20 uppercase mb-1\">{isRTL ? 'в•ӘШҜв”ҳВ„в•Әв”Өв•ӘШҜв•Әв”Өв•ӘШұ' : 'Screen'}</div>\n                                    <div className=\"text-xs font-bold\">{selectedDevice.screenResolution || '---'}</div>\n                                </div>\n                            </div>\n\n                            {/* в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШөв•ӘВ»в•ӘШҜв•ӘШі */}\n                            {selectedDevice.securityEvents && selectedDevice.securityEvents.length > 0 && (\n                                <div className=\"mb-6\">\n                                    <div className=\"text-[9px] font-black text-white/30 uppercase mb-3 flex items-center gap-2\"><History className=\"w-3.5 h-3.5\" /> {isRTL ? 'в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘШөв•ӘВ»в•ӘШҜв•ӘШі' : 'EVENT LOG'}</div>\n                                    <div className=\"space-y-1.5 max-h-40 overflow-y-auto\">\n                                        {selectedDevice.securityEvents.slice(-10).reverse().map((ev, i) => (\n                                            <div key={i} className=\"flex items-center gap-2 p-2 rounded-lg bg-white/[0.02]\">\n                                                {getEventIcon(ev.type)}\n                                                <span className=\"text-[10px] flex-1 truncate\">{ev.detail}</span>\n                                                <span className=\"text-[8px] text-white/20 shrink-0\">{new Date(ev.timestamp).toLocaleDateString()}</span>\n                                            </div>\n                                        ))}\n                                    </div>\n                                </div>\n                            )}\n\n                            {/* в”ҳГ в”ҳВ„в•ӘШҜв•ӘШөв•Әв••в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШ«в•Ә