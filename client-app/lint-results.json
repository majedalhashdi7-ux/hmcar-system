-y-2\">\r\n                                            <label className=\"text-[10px] font-black uppercase tracking-widest text-white/40\">Select Vehicle</label>\r\n                                            <select\r\n                                                value={formData.carId}\r\n                                                onChange={(e) => setFormData({ ...formData, carId: e.target.value })}\r\n                                                className=\"w-full bg-white/5 border border-white/10 rounded-xl p-4 text-sm font-bold text-white focus:outline-none focus:border-red-500 transition-all\"\r\n                                            >\r\n                                                <option value=\"\" className=\"bg-black text-white/40\">Select a car from inventory...</option>\r\n                                                {cars.map(car => (\r\n                                                    <option key={car._id || car.id} value={car._id || car.id} className=\"bg-black\">\r\n                                                        {car.make} {car.model} {car.year} - {car.title}\r\n                                                    </option>\r\n                                                ))}\r\n                                            </select>\r\n                                        </div>\r\n\r\n                                        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\r\n                                            <div className=\"space-y-2\">\r\n                                                <label className=\"text-[10px] font-black uppercase tracking-widest text-white/40\">Starting Bid (SAR)</label>\r\n                                                <input\r\n                                                    type=\"number\"\r\n                                                    value={formData.startPrice}\r\n                                                    onChange={(e) => setFormData({ ...formData, startPrice: e.target.value })}\r\n                                                    className=\"w-full bg-white/5 border border-white/10 rounded-xl p-4 text-sm font-bold text-white focus:outline-none focus:border-red-500 transition-all\"\r\n                                                    placeholder=\"e.g. 500000\"\r\n                                                />\r\n                                            </div>\r\n                                            <div className=\"space-y-2\">\r\n                                                {/* Spacer or additional field */}\r\n                                            </div>\r\n                                        </div>\r\n\r\n                                        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\r\n                                            <div className=\"space-y-2\">\r\n                                                <label className=\"text-[10px] font-black uppercase tracking-widest text-white/40\">Start Time</label>\r\n                                                <input\r\n                                                    type=\"datetime-local\"\r\n                                                    value={formData.startsAt}\r\n                                                    onChange={(e) => setFormData({ ...formData, startsAt: e.target.value })}\r\n                                                    className=\"w-full bg-white/5 border border-white/10 rounded-xl p-4 text-sm font-bold text-white focus:outline-none focus:border-red-500 transition-all [color-scheme:dark]\"\r\n                                                />\r\n                                            </div>\r\n                                            <div className=\"space-y-2\">\r\n                                                <label className=\"text-[10px] font-black uppercase tracking-widest text-white/40\">End Time</label>\r\n                                                <input\r\n                                                    type=\"datetime-local\"\r\n                                                    value={formData.endsAt}\r\n                                                    onChange={(e) => setFormData({ ...formData, endsAt: e.target.value })}\r\n                                                    className=\"w-full bg-white/5 border border-white/10 rounded-xl p-4 text-sm font-bold text-white focus:outline-none focus:border-red-500 transition-all [color-scheme:dark]\"\r\n                                                />\r\n                                            </div>\r\n                                        </div>\r\n                                    </div>\r\n\r\n                                    <motion.button\r\n                                        whileHover={{ scale: 1.02 }}\r\n                                        whileTap={{ scale: 0.98 }}\r\n                                        onClick={handleLaunch}\r\n                                        disabled={isLoading}\r\n                                        className={cn(\r\n                                            \"w-full py-5 text-white font-black uppercase text-xs tracking-[0.5em] rounded-2xl transition-all shadow-xl flex items-center justify-center gap-3\",\r\n                                            isLoading ? \"bg-zinc-800 cursor-not-allowed\" : \"bg-red-500 hover:bg-red-600 shadow-[0_0_30px_rgba(239,68,68,0.3)]\"\r\n                                        )}\r\n                                    >\r\n                                        {isLoading ? isRTL ? \"в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•–в”ҳВ„в•ӘШҜв”ҳГ©...\" : \"INITIALIZING...\" : isRTL ? \"в•ӘШӯв•Әв•–в”ҳВ„в•ӘШҜв”ҳГ© в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»\" : \"CONFIRM LAUNCH\"}\r\n                                    </motion.button>\r\n                                </div>\r\n                            </motion.div>\r\n                        </div>\r\n                    )}\r\n                </AnimatePresence>\r\n\r\n            </AdminPageShell>\r\n        </div>\r\n    );\r\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\brands\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\cars\\_components\\CarCard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\cars\\_components\\CarModal.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\cars\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\comms\\page.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadInquiries'. Either include it or remove the dependency array.","line":138,"column":8,"nodeType":"ArrayExpression","endLine":138,"endColumn":64,"suggestions":[{"desc":"Update the dependencies array to be: [activeMode, inquiryFilter, selectedConv, inquirySearch, loadInquiries]","fix":{"range":[5107,5163],"text":"[activeMode, inquiryFilter, selectedConv, inquirySearch, loadInquiries]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport { motion, AnimatePresence } from \"framer-motion\";\nimport { useState, useEffect, Suspense } from \"react\";\nimport { \n    MessageCircle, Mail, RefreshCw, \n    Search, CheckCircle, \n    User, X, Send,\n    CheckCheck, Circle, ArrowLeft\n} from \"lucide-react\";\n\nimport { useSearchParams } from 'next/navigation';\nimport { cn } from \"@/lib/utils\";\nimport { useLanguage } from \"@/lib/LanguageContext\";\nimport { api } from \"@/lib/api\";\nimport AdminPageShell from \"@/components/AdminPageShell\";\n\n// ШёВӨВҖШёВӨВҖ Types ШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖ\ninterface ContactMessage {\n    _id: string;\n    name: string;\n    email: string;\n    phone?: string;\n    subject: string;\n    message: string;\n    status: 'new' | 'read' | 'replied' | 'closed';\n    createdAt: string;\n}\n\ninterface Conversation {\n    userId: string;\n    userName: string;\n    lastMessage: string;\n    lastMessageAt: string;\n    unreadCount: number;\n}\n\ninterface Message {\n    id: string;\n    content: string;\n    isFromMe: boolean;\n    createdAt: string;\n    read: boolean;\n}\n\n// ШёВӨВҖШёВӨВҖ Tab Constants ШёВӨВҖШёВӨВҖ\nconst MODE_CHATS = 'chats';\nconst MODE_INQUIRIES = 'inquiries';\n\nfunction CommsHubContent() {\n    const { isRTL } = useLanguage();\n    const searchParams = useSearchParams();\n    \n    const [activeMode, setActiveMode] = useState(searchParams?.get('mode') === MODE_INQUIRIES ? MODE_INQUIRIES : MODE_CHATS);\n\n    // ШёВӨВҖШёВӨВҖ Shared State ШёВӨВҖШёВӨВҖ\n    const [loading, setLoading] = useState(true);\n\n    // ШёВӨВҖШёВӨВҖ Inquiries State ШёВӨВҖШёВӨВҖ\n    const [inquiries, setInquiries] = useState<ContactMessage[]>([]);\n    const [inquiryFilter, setInquiryFilter] = useState('all');\n    const [inquirySearch] = useState('');\n    const [selectedInquiry, setSelectedInquiry] = useState<ContactMessage | null>(null);\n\n    // ШёВӨВҖШёВӨВҖ Chats State ШёВӨВҖШёВӨВҖ\n    const [conversations, setConversations] = useState<Conversation[]>([]);\n    const [selectedConv, setSelectedConv] = useState<Conversation | null>(null);\n    const [chatMessages, setChatMessages] = useState<Message[]>([]);\n    const [newMessage, setNewMessage] = useState('');\n    const [sending, setSending] = useState(false);\n    const [chatSearch, setChatSearch] = useState('');\n\n    // ШёВӨВҖШёВӨВҖ Load Inquiries ШёВӨВҖШёВӨВҖ\n    const loadInquiries = async () => {\n        setLoading(true);\n        try {\n            const res = await api.contact.list({ status: inquiryFilter === 'all' ? '' : inquiryFilter, search: inquirySearch });\n            if (res.success) setInquiries(res.data);\n        } catch (err) { console.error(err); }\n        finally { setLoading(false); }\n    };\n\n    // ШёВӨВҖШёВӨВҖ Load Conversations ШёВӨВҖШёВӨВҖ\n    const loadConversations = async () => {\n        setLoading(true);\n        try {\n            const res = await api.messages.conversations();\n            if (res.success && Array.isArray(res.data)) {\n                setConversations(res.data.map((item: any) => ({\n                    userId: item.user?._id || item.id,\n                    userName: item.user?.name || 'Unknown',\n                    lastMessage: item.lastMessage?.content || '',\n                    lastMessageAt: item.lastMessage?.createdAt || new Date().toISOString(),\n                    unreadCount: item.unreadCount || 0\n                })));\n            }\n        } catch { console.error('Failed to load conversations'); }\n        finally { setLoading(false); }\n    };\n\n    useEffect(() => {\n        if (activeMode === MODE_CHATS) loadConversations();\n        else loadInquiries();\n        \n        // Auto-refresh polling every 10 seconds\n        const intervalId = setInterval(() => {\n            if (activeMode === MODE_CHATS) {\n                // Background refresh without loading spinner\n                api.messages.conversations().then(res => {\n                    if (res.success && Array.isArray(res.data)) {\n                        setConversations(res.data.map((item: any) => ({\n                            userId: item.user?._id || item.id,\n                            userName: item.user?.name || 'Unknown',\n                            lastMessage: item.lastMessage?.content || '',\n                            lastMessageAt: item.lastMessage?.createdAt || new Date().toISOString(),\n                            unreadCount: item.unreadCount || 0\n                        })));\n                    }\n                }).catch(() => {});\n                \n                // Also refresh current chat if open\n                if (selectedConv) {\n                    api.messages.conversation(selectedConv.userId).then(res => {\n                        if (res.success && Array.isArray(res.data)) {\n                            setChatMessages(res.data);\n                        }\n                    }).catch(() => {});\n                }\n            } else {\n                // Background refresh inquiries\n                api.contact.list({ status: inquiryFilter === 'all' ? '' : inquiryFilter, search: inquirySearch })\n                    .then(res => { if (res.success) setInquiries(res.data); })\n                    .catch(() => {});\n            }\n        }, 10000);\n        \n        return () => clearInterval(intervalId);\n    }, [activeMode, inquiryFilter, selectedConv, inquirySearch]);\n\n    // ШёВӨВҖШёВӨВҖ Actions: Inquiries ШёВӨВҖШёВӨВҖ\n    const updateInquiryStatus = async (id: string, status: string) => {\n        try {\n            await api.contact.updateStatus(id, status);\n            loadInquiries();\n            if (selectedInquiry?._id === id) setSelectedInquiry({ ...selectedInquiry, status: status as any });\n        } catch { }\n    };\n\n    // ШёВӨВҖШёВӨВҖ Actions: Chat ШёВӨВҖШёВӨВҖ\n    const loadChatHistory = async (conv: Conversation) => {\n        setSelectedConv(conv);\n        try {\n            const res = await api.messages.conversation(conv.userId);\n            if (res.success && Array.isArray(res.data)) setChatMessages(res.data);\n            setConversations(prev => prev.map(c => c.userId === conv.userId ? { ...c, unreadCount: 0 } : c));\n        } catch { setChatMessages([]); }\n    };\n\n    const sendChatMessage = async () => {\n        if (!newMessage.trim() || !selectedConv || sending) return;\n        setSending(true);\n        const content = newMessage.trim();\n        setNewMessage('');\n        try {\n            await api.messages.send(selectedConv.userId, content);\n            setChatMessages(prev => [...prev, { id: `t-${Date.now()}`, content, isFromMe: true, createdAt: new Date().toISOString(), read: false }]);\n            setConversations(prev => prev.map(c => c.userId === selectedConv.userId ? { ...c, lastMessage: content, lastMessageAt: new Date().toISOString() } : c));\n        } catch { }\n        finally { setSending(false); }\n    };\n\n    const formatTime = (iso: string) => {\n        const d = new Date(iso);\n        const diff = Date.now() - d.getTime();\n        if (diff < 60000) return isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ' : 'Now';\n        if (diff < 3600000) return `${Math.floor(diff / 60000)}${isRTL ? 'в•ӘВ»' : 'm'}`;\n        if (diff < 86400000) return `${Math.floor(diff / 3600000)}${isRTL ? 'в•Әв”Ӯ' : 'h'}`;\n        return d.toLocaleDateString();\n    };\n\n    return (\n        <div className=\"relative min-h-screen text-white font-sans overflow-hidden\" dir={isRTL ? 'rtl' : 'ltr'}>\n            <AdminPageShell\n                title={isRTL ? 'в”ҳГ в•Әв–’в”ҳГўв•Әв–“ в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в•ӘШҜв•Әв”Ӯв”ҳВ„в•ӘШҜв•ӘШІ' : 'COMMS HUB'}\n                titleEn=\"UNIFIED COMMUNICATIONS\"\n                backHref=\"/admin/dashboard\"\n                isRTL={isRTL}\n                actions={\n                    <button onClick={() => activeMode === MODE_CHATS ? loadConversations() : loadInquiries()} title={isRTL ? \"в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі\" : \"Refresh\"} className=\"w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all text-blue-400\">\n                        <RefreshCw className={cn('w-5 h-5', loading && 'animate-spin')} />\n                    </button>\n                }\n            >\n                {/* ШёВӨВҖШёВӨВҖ Comms Mode Select ШёВӨВҖШёВӨВҖ */}\n                <div className=\"flex bg-white/5 p-1 rounded-2xl border border-white/5 mb-8 w-full max-w-md\">\n                    <button onClick={() => setActiveMode(MODE_CHATS)}\n                        className={cn('flex-1 py-3 rounded-xl text-[11px] font-black uppercase tracking-[0.1em] transition-all flex items-center justify-center gap-3', \n                        activeMode === MODE_CHATS ? 'bg-blue-500 text-black shadow-[0_0_20px_rgba(59,130,246,0.3)]' : 'text-white/40 hover:text-white/60')}>\n                        <MessageCircle size={16} />\n                        {isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв•ӘВ»в•ӘШів•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’в•ӘШұ' : 'LIVE CHATS'}\n                    </button>\n                    <button onClick={() => setActiveMode(MODE_INQUIRIES)}\n                        className={cn('flex-1 py-3 rounded-xl text-[11px] font-black uppercase tracking-[0.1em] transition-all flex items-center justify-center gap-3', \n                        activeMode === MODE_INQUIRIES ? 'bg-orange-500 text-black shadow-[0_0_20px_rgba(249,115,22,0.3)]' : 'text-white/40 hover:text-white/60')}>\n                        <Mail size={16} />\n                        {isRTL ? 'в•Әв–’в•Әв”Ӯв•ӘШҜв•ӘШ®в”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј' : 'INQUIRIES'}\n                    </button>\n                </div>\n\n                {activeMode === MODE_CHATS ? (\n                    <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 h-[70vh]\">\n                        {/* Conversations List */}\n                        <div className={cn('ck-card flex flex-col overflow-hidden', selectedConv ? 'hidden md:flex' : 'flex')}>\n                            <div className=\"p-4 border-b border-white/5\">\n                                <div className=\"relative px-2\">\n                                    <Search className=\"absolute left-6 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-white/20\" />\n                                    <input value={chatSearch} onChange={e => setChatSearch(e.target.value)} placeholder={isRTL ? 'в•ӘШ°в•ӘШөв•ӘШі...' : 'Search...'} className=\"ck-input pl-10 h-10 bg-black/40 text-xs\" />\n                                </div>\n                            </div>\n                            <div className=\"flex-1 overflow-y-auto p-2 space-y-1 ck-scroll\">\n                                {conversations.filter(c => c.userName.toLowerCase().includes(chatSearch.toLowerCase())).map(conv => (\n                                    <button key={conv.userId} onClick={() => loadChatHistory(conv)} title={isRTL ? \"в”ҳВҒв•ӘШІв•ӘШө в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв•ӘВ»в•ӘШів•ӘШұ\" : \"Open chat\"} className={cn('w-full p-4 rounded-xl text-start transition-all border group', selectedConv?.userId === conv.userId ? 'bg-blue-500/10 border-blue-500/20' : 'bg-transparent border-transparent hover:bg-white/5')}>\n                                        <div className=\"flex items-start gap-4\">\n                                            <div className=\"w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center shrink-0 relative\">\n                                                <User className=\"w-5 h-5 text-blue-400/50\" />\n                                                {conv.unreadCount > 0 && <span className=\"absolute -top-1 -right-1 w-4 h-4 bg-red-500 rounded-full text-[8px] font-black flex items-center justify-center\">{conv.unreadCount}</span>}\n                                            </div>\n                                            <div className=\"flex-1 min-w-0\">\n                                                <div className=\"flex items-center justify-between mb-0.5\">\n                                                    <span className=\"text-xs font-black uppercase text-white/80\">{conv.userName}</span>\n                                                    <span className=\"cockpit-mono text-[8px] text-white/20\">{formatTime(conv.lastMessageAt)}</span>\n                                                </div>\n                                                <p className=\"text-[10px] text-white/40 truncate\">{conv.lastMessage}</p>\n                                            </div>\n                                        </div>\n                                    </button>\n                                ))}\n                            </div>\n                        </div>\n\n                        {/* Chat Window */}\n                        <div className={cn('md:col-span-2 ck-card flex flex-col overflow-hidden', !selectedConv ? 'hidden md:flex items-center justify-center' : 'flex')}>\n                            {!selectedConv ? (\n                                <div className=\"text-center space-y-4 opacity-20\">\n                                    <MessageCircle size={48} className=\"mx-auto\" />\n                                    <p className=\"cockpit-mono text-xs tracking-widest uppercase\">{isRTL ? 'в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в”ҳГ в•ӘШөв•ӘШҜв•ӘВ»в•ӘШів•ӘШұ в”ҳВ„в”ҳВ„в”ҳГ в•ӘШІв•ӘШҜв•ӘШ°в•Әв•Јв•ӘШұ' : 'SELECT COMM STREAM'}</p>\n                                </div>\n                            ) : (\n                                <>\n                                    <div className=\"p-5 border-b border-white/5 flex items-center gap-4 bg-white/[0.02]\">\n                                        <button onClick={() => setSelectedConv(null)} title={isRTL ? \"в•Әв–’в•ӘШҙв”ҳГӘв•Әв•Ј\" : \"Back\"} className=\"md:hidden w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center\"><ArrowLeft size={16} /></button>\n                                        <div className=\"w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center\"><User size={20} className=\"text-blue-400\" /></div>\n                                        <div>\n                                            <p className=\"text-sm font-black uppercase\">{selectedConv.userName}</p>\n                                            <div className=\"flex items-center gap-2\"><Circle className=\"w-1.5 h-1.5 fill-green-500 text-green-500\" /><span className=\"text-[10px] font-bold text-green-500/70 uppercase\">Online</span></div>\n                                        </div>\n                                    </div>\n                                    <div className=\"flex-1 overflow-y-auto p-6 space-y-4 ck-scroll\">\n                                        {chatMessages.map(msg => (\n                                            <div key={msg.id} className={cn('flex flex-col', msg.isFromMe ? 'items-end' : 'items-start')}>\n                                                <div className={cn('px-5 py-3 rounded-2xl text-[12px] max-w-[80%] leading-relaxed border', msg.isFromMe ? 'bg-blue-500/10 border-blue-500/20 text-white rounded-tr-none' : 'bg-white/5 border-white/10 text-white/80 rounded-tl-none')}>\n                                                    {msg.content}\n                                                </div>\n                                                <div className=\"flex items-center gap-2 mt-1 px-1\">\n                                                    <span className=\"cockpit-mono text-[8px] text-white/20\">{formatTime(msg.createdAt)}</span>\n                                                    {msg.isFromMe && <CheckCheck size={12} className={msg.read ? 'text-blue-400' : 'text-white/20'} />}\n                                                </div>\n                                            </div>\n                                        ))}\n                                    </div>\n                                    <div className=\"p-5 border-t border-white/5 bg-black/40\">\n                                        <div className=\"flex gap-3\">\n                                            <input value={newMessage} title={isRTL ? \"в•ӘШҜв”ҳВ„в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ\" : \"Message\"} onChange={e => setNewMessage(e.target.value)} onKeyDown={e => e.key === 'Enter' && sendChatMessage()} placeholder={isRTL ? 'в•ӘШҜв”ҳГўв•ӘШІв•ӘШ° в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ...' : 'Type message...'} className=\"flex-1 ck-input h-12 bg-white/5\" />\n                                            <button onClick={sendChatMessage} title={isRTL ? \"в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„\" : \"Send\"} disabled={!newMessage.trim() || sending} className=\"w-12 h-12 rounded-xl bg-blue-500 text-black flex items-center justify-center hover:bg-blue-400 transition-all shadow-[0_0_15px_rgba(59,130,246,0.3)]\"><Send size={18} /></button>\n                                        </div>\n                                    </div>\n                                </>\n                            )}\n                        </div>\n                    </div>\n                ) : (\n                    <div className=\"space-y-4\">\n                        <div className=\"flex gap-2 mb-6\">\n                            {['new', 'read', 'replied', 'all'].map(f => (\n                                <button key={f} onClick={() => setInquiryFilter(f)} className={cn('ck-tab', inquiryFilter === f && 'ck-tab-active')}>\n                                    {isRTL ? (f === 'new' ? 'в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»' : f === 'read' ? 'в”ҳГ в”ҳГ©в•Әв–’в”ҳГӘв•ӘШ©' : f === 'replied' ? 'в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв–’в•ӘВ»' : 'в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„') : f.toUpperCase()}\n                                </button>\n                            ))}\n                        </div>\n                        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-4\">\n                            {inquiries.map(item => (\n                                <motion.div key={item._id} initial={{ opacity: 0 }} animate={{ opacity: 1 }} className={cn('ck-card p-5 cursor-pointer hover:bg-white/5 transition-all group', item.status === 'new' && 'border-orange-500/20')} onClick={() => { setSelectedInquiry(item); if (item.status === 'new') updateInquiryStatus(item._id, 'read'); }}>\n                                    <div className=\"flex items-start justify-between mb-4\">\n                                        <div className=\"flex items-center gap-4\">\n                                            <div className=\"w-10 h-10 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center\"><Mail className=\"w-5 h-5 text-orange-400/50\" /></div>\n                                            <div>\n                                                <h3 className=\"text-sm font-black uppercase text-white/80\">{item.name}</h3>\n                                                <p className=\"text-[10px] text-white/30 truncate max-w-[200px]\">{item.email}</p>\n                                            </div>\n                                        </div>\n                                        <span className={cn('ck-badge text-[9px]', item.status === 'new' ? 'ck-badge-danger' : 'ck-badge-inactive')}>{item.status.toUpperCase()}</span>\n                                    </div>\n                                    <p className=\"text-xs font-bold text-orange-400/80 mb-3 truncate\">{item.subject}</p>\n                                    <div className=\"flex items-center justify-between pt-4 border-t border-white/5\">\n                                        <span className=\"cockpit-mono text-[9px] text-white/20 uppercase\">{formatPriceDate(item.createdAt)}</span>\n                                        <div className=\"flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity\">\n                                            <button title={isRTL ? \"в”ҳВҒв•ӘШІв•ӘШө\" : \"Open\"} className=\"text-[10px] font-black text-white/40 hover:text-white uppercase tracking-widest\">{isRTL ? 'в”ҳВҒв•ӘШІв•ӘШө' : 'OPEN'}</button>\n                                        </div>\n                                    </div>\n                                </motion.div>\n                            ))}\n                        </div>\n                    </div>\n                )}\n            </AdminPageShell>\n\n            {/* Inquiry Detail Modal */}\n            <AnimatePresence>\n                {selectedInquiry && (\n                    <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className=\"fixed inset-0 z-[210] flex items-center justify-center p-4 bg-black/90 backdrop-blur-xl\" onClick={() => setSelectedInquiry(null)}>\n                        <motion.div initial={{ scale: 0.9, y: 30 }} animate={{ scale: 1, y: 0 }} exit={{ scale: 0.9, y: 30 }} onClick={e => e.stopPropagation()} className=\"ck-modal max-w-2xl w-full p-8 relative\">\n                            <button onClick={() => setSelectedInquiry(null)} title={isRTL ? \"в•ӘШӯв•Әв•‘в”ҳВ„в•ӘШҜв”ҳГ©\" : \"Close\"} className=\"absolute top-6 right-6 w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center hover:bg-white/10\"><X size={20} /></button>\n                            <div className=\"flex items-center gap-6 mb-8\">\n                                <div className=\"w-14 h-14 rounded-2xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center\"><User size={28} className=\"text-orange-400\" /></div>\n                                <div>\n                                    <p className=\"cockpit-mono text-[10px] text-orange-400 uppercase tracking-widest mb-1\">{selectedInquiry.subject}</p>\n                                    <h2 className=\"text-2xl font-black uppercase\">{selectedInquiry.name}</h2>\n                                    <div className=\"flex gap-3 cockpit-mono text-[9px] text-white/30 mt-1\"><span>{selectedInquiry.email}</span><span>ШёВҖШӘ</span><span>{selectedInquiry.phone}</span></div>\n                                </div>\n                            </div>\n                            <div className=\"bg-white/5 border border-white/10 rounded-2xl p-6 mb-8 min-h-[150px]\">\n                                <p className=\"text-sm leading-relaxed text-white/70 whitespace-pre-wrap\">{selectedInquiry.message}</p>\n                            </div>\n                            <div className=\"flex justify-between items-center\">\n                                <div className=\"flex gap-3\">\n                                    <button onClick={() => updateInquiryStatus(selectedInquiry._id, 'replied')} title={isRTL ? \"в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв–’в•ӘВ»\" : \"Replied\"} className=\"h-11 px-6 rounded-xl bg-orange-500 text-black text-[10px] font-black uppercase tracking-widest flex items-center gap-2 hover:bg-orange-400 transition-all\"><CheckCircle size={16} />{isRTL ? 'в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘВ» в”ҳГўв”ҳВҖ \"в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв–’в•ӘВ»\"' : 'MARK REPLIED'}</button>\n                                    <a href={`mailto:${selectedInquiry.email}`} title={isRTL ? \"в•Әв–’в•ӘВ»\" : \"Reply\"} className=\"h-11 px-6 rounded-xl bg-white/5 border border-white/10 text-white text-[10px] font-black uppercase tracking-widest flex items-center gap-2 hover:bg-white/10 transition-all\"><Mail size={16} />{isRTL ? 'в•ӘШҜв”ҳВ„в•Әв–’в•ӘВ» в•Әв•Јв•ӘШ°в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШӯв”ҳГЁв”ҳГ в”ҳГЁв”ҳВ„' : 'EMAIL REPLY'}</a>\n                                </div>\n                                <span className=\"cockpit-mono text-[10px] text-white/20\">{new Date(selectedInquiry.createdAt).toLocaleString()}</span>\n                            </div>\n                        </motion.div>\n                    </motion.div>\n                )}\n            </AnimatePresence>\n        </div>\n    );\n}\n\nconst formatPriceDate = (iso: string) => {\n    return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });\n};\n\nexport default function CommsHub() {\n    return (\n        <Suspense fallback={<div className=\"min-h-screen bg-black\" />}>\n            <CommsHubContent />\n        </Suspense>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\concierge\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\contact\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'ArrowLeft' is defined but never used.","line":7,"column":43,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":52,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ArrowLeft"},"fix":{"range":[218,229],"text":""},"desc":"Remove unused variable \"ArrowLeft\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Link' is defined but never used.","line":9,"column":8,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":12,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Link"},"fix":{"range":[265,294],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'rawText' is assigned a value but never used.","line":28,"column":20,"nodeType":"Identifier","messageId":"unusedVar","endLine":28,"endColumn":27},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'showToast' is assigned a value but never used.","line":29,"column":13,"nodeType":"Identifier","messageId":"unusedVar","endLine":29,"endColumn":22}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport { motion, AnimatePresence } from \"framer-motion\";\nimport { useState, useEffect, useCallback } from \"react\";\nimport {\n    Mail, Search, Trash2, CheckCircle,\n    Clock, User, Phone, MessageSquare, X, ArrowLeft, RefreshCcw\n} from \"lucide-react\";\nimport Link from \"next/link\";\nimport { cn } from \"@/lib/utils\";\nimport { useLanguage } from \"@/lib/LanguageContext\";\nimport { api } from \"@/lib/api\";\nimport { useToast } from \"@/lib/ToastContext\";\nimport AdminPageShell from \"@/components/AdminPageShell\";\n\ninterface ContactMessage {\n    _id: string;\n    name: string;\n    email: string;\n    phone?: string;\n    subject: string;\n    message: string;\n    status: 'new' | 'read' | 'replied' | 'closed';\n    createdAt: string;\n}\n\nexport default function AdminContactPage() {\n    const { isRTL, rawText } = useLanguage();\n    const { showToast } = useToast();\n    const [messages, setMessages] = useState<ContactMessage[]>([]);\n    const [loading, setLoading] = useState(true);\n    const [filter, setFilter] = useState('all');\n    const [searchTerm, setSearchTerm] = useState('');\n    const [selectedMsg, setSelectedMsg] = useState<ContactMessage | null>(null);\n\n    const loadMessages = useCallback(async () => {\n        setLoading(true);\n        try {\n            const res = await api.contact.list({ status: filter === 'all' ? '' : filter, search: searchTerm });\n            if (res.success) {\n                setMessages(res.data);\n            }\n        } catch (err) {\n            console.error(\"Failed to load contact messages\", err);\n        } finally {\n            setLoading(false);\n        }\n    }, [filter, searchTerm]);\n\n    useEffect(() => {\n        loadMessages();\n    }, [loadMessages]);\n\n    const handleUpdateStatus = async (id: string, status: string) => {\n        try {\n            await api.contact.updateStatus(id, status);\n            loadMessages();\n            if (selectedMsg?._id === id) {\n                setSelectedMsg({ ...selectedMsg, status: status as any });\n            }\n        } catch (err) {\n            console.error('Failed to update status', err);\n        }\n    };\n\n    const handleDelete = async (id: string) => {\n        if (confirm(isRTL ? 'в”ҳГ§в”ҳВ„ в•ӘШ«в”ҳВҶв•ӘШІ в”ҳГ в•ӘШІв•ӘШ«в”ҳГўв•ӘВ» в”ҳГ в”ҳВҶ в•ӘШөв•Әв–‘в”ҳВҒ в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұв•ӘШ§' : 'Are you sure you want to delete this message?')) {\n            try {\n                await api.contact.delete(id);\n                if (selectedMsg?._id === id) setSelectedMsg(null);\n                loadMessages();\n            } catch (err) {\n                console.error('Failed to delete message', err);\n            }\n        }\n    };\n\n    const getStatusBadge = (status: string) => {\n        switch (status) {\n            case 'new': return 'ck-badge ck-badge-danger';\n            case 'read': return 'ck-badge ck-badge-active';\n            case 'replied': return 'ck-badge' + ' bg-green-500/15 text-green-400 border-green-500/20';\n            default: return 'ck-badge';\n        }\n    };\n\n    return (\n        <>\n            <AdminPageShell\n                title={isRTL ? 'в•ӘШҜв•Әв”Ӯв•ӘШІв•Әв”Өв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в”ҳГӘв•Әв–’в•Әв”Ӯв•ӘШҜв•ӘШ®в”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј' : 'CONSULTATIONS & INQUIRIES'}\n                titleEn=\"WEBSITE COMMS\"\n                backHref=\"/admin/dashboard\"\n                isRTL={isRTL}\n                subtitle={isRTL ? 'в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•Әв–’в•Әв”Ӯв•ӘШҜв•ӘШ®в”ҳВ„ в”ҳГӘв•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ°в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•Әв–’в•ӘВ»в•ӘШұ в”ҳГ в”ҳВҶ в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј' : 'Manage messages and requests sent via website contact forms'}\n                actions={\n                    <button onClick={loadMessages} className=\"w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all text-orange-500\">\n                        <RefreshCcw className={cn('w-5 h-5', loading && 'animate-spin')} />\n                    </button>\n                }\n            >\n\n                {/* Filters */}\n                <div className=\"flex flex-col md:flex-row gap-4 mb-8\">\n                    <div className=\"flex-1 relative\">\n                        <Search className={cn('absolute top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-orange-500/30', isRTL ? 'right-3' : 'left-3')} />\n                        <input type=\"text\"\n                            placeholder={isRTL ? 'в•ӘШ°в•ӘШөв•ӘШі в•Әв•Јв”ҳВҶ в•Әв•–в•Әв–’в”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШ«в”ҳГӘ в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ»...' : 'Search by name or email...'}\n                            value={searchTerm} onChange={(e) => setSearchTerm(e.target.value)}\n                            className={cn('ck-input', isRTL ? 'pr-8 pl-4' : 'pl-8 pr-4')} />\n                    </div>\n                    <div className=\"ck-tab-group\">\n                        {['new', 'read', 'replied', 'all'].map((s) => (\n                            <button key={s} onClick={() => setFilter(s)}\n                                className={cn('ck-tab', filter === s && 'ck-tab-active')}>\n                                {isRTL ? (s === 'new' ? 'в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»' : s === 'read' ? 'в”ҳГ в”ҳГ©в•Әв–’в”ҳГӘв•ӘШ©' : s === 'replied' ? 'в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв–’в•ӘВ»' : 'в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„') : s.toUpperCase()}\n                            </button>\n                        ))}\n                    </div>\n                </div>\n\n                {/* Messages List */}\n                {loading ? (\n                    <div className=\"space-y-3\">\n                        {Array.from({ length: 4 }).map((_, i) => (\n                            <div key={i} className=\"h-20 rounded-2xl bg-white/[0.02] animate-pulse border border-orange-500/10\" />\n                        ))}\n                    </div>\n                ) : messages.length === 0 ? (\n                    <div className=\"ck-empty py-24\">\n                        <div className=\"ck-empty-icon\"><Mail className=\"w-8 h-8\" /></div>\n                        <p className=\"cockpit-mono\">{isRTL ? 'в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•Әв–’в•Әв”Ӯв•ӘШҜв•ӘШ®в”ҳВ„' : 'NO MESSAGES FOUND'}</p>\n                    </div>\n                ) : (\n                    <div className=\"space-y-3\">\n                        {messages.map((item, i) => (\n                            <motion.div key={item._id}\n                                initial={{ opacity: 0, x: -20 }} animate={{ opacity: 1, x: 0 }}\n                                transition={{ delay: i * 0.05 }}\n                                onClick={() => { setSelectedMsg(item); if (item.status === 'new') handleUpdateStatus(item._id, 'read'); }}\n                                className={cn(\n                                    'ck-card p-4 cursor-pointer flex flex-col md:flex-row items-start md:items-center justify-between gap-4 transition-all hover:bg-white/5',\n                                    item.status === 'new' && 'border-orange-500/25'\n                                )}>\n                                <div className=\"flex items-center gap-4 flex-1 min-w-0\">\n                                    <div className=\"w-10 h-10 rounded-xl bg-orange-500/10 border border-orange-500/15 flex items-center justify-center shrink-0\">\n                                        <Mail className=\"w-4 h-4 text-orange-400/60\" />\n                                    </div>\n                                    <div className=\"min-w-0\">\n                                        <h3 className=\"text-sm font-bold truncate\">{item.name}</h3>\n                                        <div className=\"flex items-center gap-3 cockpit-mono text-[9px] text-white/30 mt-0.5\">\n                                            <span className=\"flex items-center gap-1\"><User className=\"w-3 h-3\" />{item.email}</span>\n                                            {item.phone && <span className=\"flex items-center gap-1\"><Phone className=\"w-3 h-3\" />{item.phone}</span>}\n                                            <span className=\"flex items-center gap-1\"><Clock className=\"w-3 h-3\" />{new Date(item.createdAt).toLocaleDateString()}</span>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div className=\"flex items-center gap-3\">\n                                    <span className={getStatusBadge(item.status)}>\n                                        {isRTL ? (item.status === 'new' ? 'в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»' : item.status === 'read' ? 'в”ҳГ в”ҳГ©в•Әв–’в”ҳГӘв•ӘШ©' : 'в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв–’в•ӘВ»') : item.status.toUpperCase()}\n                                    </span>\n                                    <span className=\"cockpit-mono text-[9px] text-white/30 px-2 py-1 bg-white/5 rounded-lg border border-white/5 truncate max-w-[120px]\">{item.subject}</span>\n                                    <button onClick={(e) => { e.stopPropagation(); handleDelete(item._id); }}\n                                        className=\"w-8 h-8 flex items-center justify-center rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500 hover:text-white transition-all\">\n                                        <Trash2 className=\"w-3.5 h-3.5\" />\n                                    </button>\n                                </div>\n                            </motion.div>\n                        ))}\n                    </div>\n                )}\n            </AdminPageShell>\n\n            {/* Modal Detail */}\n            <AnimatePresence>\n                {selectedMsg && (\n                    <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}\n                        className=\"fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm\" onClick={() => setSelectedMsg(null)}>\n                        <motion.div initial={{ scale: 0.9, y: 20 }} animate={{ scale: 1, y: 0 }} exit={{ scale: 0.9, y: 20 }}\n                            onClick={(e) => e.stopPropagation()}\n                            className=\"bg-cinematic-dark border border-white/10 rounded-3xl p-8 max-w-2xl w-full max-h-[90vh] overflow-y-auto relative shadow-2xl\">\n\n                            <button onClick={() => setSelectedMsg(null)}\n                                className=\"absolute top-5 end-5 w-9 h-9 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all\">\n                                <X className=\"w-4 h-4\" />\n                            </button>\n\n                            <div className=\"flex items-center gap-4 mb-6\">\n                                <div className=\"w-12 h-12 rounded-xl bg-orange-500/10 border border-orange-500/15 flex items-center justify-center\">\n                                    <User className=\"w-6 h-6 text-orange-400/60\" />\n                                </div>\n                                <div>\n                                    <p className=\"cockpit-mono text-[9px] text-orange-400/70 uppercase mb-0.5\">{selectedMsg.subject}</p>\n                                    <h2 className=\"text-xl font-bold uppercase\">{selectedMsg.name}</h2>\n                                    <p className=\"cockpit-mono text-[10px] text-white/30\">{selectedMsg.email}{selectedMsg.phone && ` в”¬в•– ${selectedMsg.phone}`}</p>\n                                </div>\n                            </div>\n\n                            <div className=\"p-6 bg-white/[0.03] border border-white/5 rounded-2xl relative overflow-hidden mb-6 min-h-[150px]\">\n                                <MessageSquare className=\"absolute -top-3 -end-3 w-20 h-20 text-white/[0.02]\" />\n                                <p className=\"text-sm leading-relaxed text-white/70 whitespace-pre-wrap relative z-10\">{selectedMsg.message}</p>\n                            </div>\n\n                            <div className=\"flex flex-wrap gap-3 pt-6 border-t border-orange-500/10 items-center justify-between\">\n                                <div className=\"flex gap-3\">\n                                    <button onClick={() => handleUpdateStatus(selectedMsg._id, 'replied')}\n                                        className=\"px-4 py-2.5 rounded-xl bg-orange-500/20 text-orange-400 border border-orange-500/30 text-[10px] font-black uppercase tracking-wider flex items-center gap-2 hover:bg-orange-500 hover:text-white transition-all\">\n                                        <CheckCircle className=\"w-4 h-4\" />\n                                        {isRTL ? 'в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘВ» в”ҳГўв”ҳВҖ \"в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв–’в•ӘВ»\"' : 'MARK AS REPLIED'}\n                                    </button>\n                                    <a href={`mailto:${selectedMsg.email}?subject=Re: ${selectedMsg.subject}`}\n                                        className=\"px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white/60 text-[10px] font-black uppercase tracking-wider flex items-center gap-2 hover:bg-white/10 transition-all\">\n                                        <Mail className=\"w-3.5 h-3.5\" />\n                                        {isRTL ? 'в•Әв–’в•ӘВ» в•Әв•Јв•ӘШ°в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ»' : 'REPLY VIA EMAIL'}\n                                    </a>\n                                </div>\n                                <span className=\"cockpit-mono text-[9px] text-white/20\">\n                                    {new Date(selectedMsg.createdAt).toLocaleString()}\n                                </span>\n                            </div>\n                        </motion.div>\n                    </motion.div>\n                )}\n            </AnimatePresence>\n        </>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\dashboard\\page.tsx","messages":[],"suppressedMessages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'router'. Either include it or remove the dependency array.","line":80,"column":8,"nodeType":"ArrayExpression","endLine":80,"endColumn":10,"suggestions":[{"desc":"Update the dependencies array to be: [router]","fix":{"range":[3186,3188],"text":"[router]"}}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\health\\page.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'runDiagnostics'. Either include it or remove the dependency array.","line":169,"column":8,"nodeType":"ArrayExpression","endLine":169,"endColumn":10,"suggestions":[{"desc":"Update the dependencies array to be: [runDiagnostics]","fix":{"range":[6878,6880],"text":"[runDiagnostics]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport { motion, AnimatePresence } from \"framer-motion\";\nimport { \n    Shield, Database, AlertTriangle, \n    CheckCircle, XCircle, RefreshCw, Zap, Server, \n    Cpu, HardDrive\n} from \"lucide-react\";\nimport { useState, useEffect } from \"react\";\nimport { useLanguage } from \"@/lib/LanguageContext\";\nimport { api } from \"@/lib/api\";\nimport AdminPageShell from \"@/components/AdminPageShell\";\nimport { cn } from \"@/lib/utils\";\n\ninterface DiagnosticResult {\n    id: string;\n    name: string;\n    status: 'pass' | 'fail' | 'warn' | 'pending';\n    message: string;\n    category: 'system' | 'database' | 'assets' | 'security';\n    details?: string;\n}\n\nexport default function AdminHealthPage() {\n    const { isRTL } = useLanguage();\n    const [isScanning, setIsScanning] = useState(false);\n    const [results, setResults] = useState<DiagnosticResult[]>([]);\n    const [scanProgress, setScanProgress] = useState(0);\n\n    const t = {\n        coreStatus: isRTL ? 'в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•Әв”Ӯв”ҳВ„в•ӘШҜв”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ  в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶв•ӘШҜв•ӘШІ' : 'CORE INTEGRITY STATUS',\n        systemNominal: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ  в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГ©в•Әв–’ в”ҳГӘв•ӘШӘв”ҳГ в”ҳВҶ' : 'SYSTEM NOMINAL',\n        scanning: isRTL ? 'в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШөв•Әв•Ў в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв”ҳГ©в•ӘВ»в”ҳГ ...' : 'SCANNING...',\n        read: isRTL ? 'в”ҳГ©в•Әв–’в•ӘШҜв•ӘШ©в•ӘШұ' : 'Read',\n        write: isRTL ? 'в”ҳГўв•ӘШІв•ӘШҜв•ӘШ°в•ӘШұ' : 'Write',\n        liveHeatmap: isRTL ? 'в•ӘВ«в•Әв–’в”ҳГЁв•Әв•–в•ӘШұ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв”Өв•ӘШҜв•Әв•– в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’ в”ҳВ„в”ҳВ„в•Әв”Өв•ӘШ°в”ҳГўв•ӘШұ' : 'LIVE HEATMAP',\n        realTimePacket: isRTL ? 'в•ӘШІв•ӘШөв”ҳВ„в”ҳГЁв”ҳВ„ в•ӘШІв•ӘВ»в”ҳВҒв”ҳГ© в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳВ„в”ҳГЁв•ӘШҜв•ӘШІ' : 'REAL-TIME PACKET FLOW ANALYSIS',\n        cpuCluster: isRTL ? 'в”ҳГ в•ӘШҙв”ҳГ в•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•ӘШҜв”ҳВ„в•ӘШҙв•ӘШұ (CPU)' : 'CPU CLUSTER',\n        energyFed: isRTL ? 'в•ӘШҜв”ҳВ„в•Әв•–в•ӘШҜв”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳВҒв•Әв–’в•ӘШұ в”ҳВ„в”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ ' : 'ENERGY FED',\n        load: isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ в”ҳВ„' : 'LOAD',\n        throughput: isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШІв•ӘШҜв•ӘШҙв”ҳГЁв•ӘШұ' : 'THROUGHPUT',\n        high: isRTL ? 'в•Әв•Јв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ в•ӘШҙв•ӘВ»в•ӘШҜв”ҳГҜ' : 'HIGH',\n        protocol: isRTL ? 'в•ӘШ°в•Әв–’в”ҳГӘв•ӘШІв”ҳГӘв”ҳГўв”ҳГӘв”ҳВ„' : 'protocol',\n        info: isRTL ? 'в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ:' : 'INFO:'\n    };\n\n    const runDiagnostics = async () => {\n        setIsScanning(true);\n        setScanProgress(0);\n        setResults([]);\n\n        const addResult = (res: DiagnosticResult) => {\n            setResults(prev => [...prev, res]);\n        };\n\n        // ШёВӨВҖШёВӨВҖ Phase 1: System Vitals ШёВӨВҖШёВӨВҖ\n        setScanProgress(10);\n        try {\n            const start = Date.now();\n            const res = await api.analytics.getSummary(); // Using this as a ping\n            const latency = Date.now() - start;\n            addResult({\n                id: 'api_connectivity',\n                name: isRTL ? 'в•ӘШ°в”ҳГӘв•ӘШҜв•ӘШ°в•ӘШұ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГ©в•Әв–’в•ӘШұ (API)' : 'API GATEWAY',\n                status: res.success ? 'pass' : 'fail',\n                message: res.success \n                    ? (isRTL ? `в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГ©в•Әв–’ (${latency}в”ҳГ в”ҳВ„в”ҳГЁ в•ӘШів•ӘШҜв”ҳВҶв”ҳГЁв•ӘШұ)` : `Connection Stable (${latency}ms)`) \n                    : (isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГӘв•ӘШҜв•ӘШ°в•ӘШұ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв•ӘШҜв•ӘШөв•ӘШұ в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШҜв”ҳГҜ' : 'Gateway Unreachable'),\n                category: 'system'\n            });\n        } catch {\n            addResult({ \n                id: 'api_connectivity', \n                name: isRTL ? 'в•ӘШ°в”ҳГӘв•ӘШҜв•ӘШ°в•ӘШұ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ°в•Әв•– (API)' : 'API GATEWAY', \n                status: 'fail', \n                message: isRTL ? 'в•ӘВ«в•Әв•–в•ӘШ« в•ӘШөв•Әв–’в•ӘШҙ: в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв•Әв•Ўв”ҳВ„' : 'CRITICAL: Offline', \n                category: 'system' \n            });\n        }\n\n        setScanProgress(30);\n        // Database Check\n        addResult({\n            id: 'db_auth',\n            name: isRTL ? 'в”ҳГ в•ӘШҙв”ҳГ в•Әв•Ј в”ҳГ©в”ҳГӘв•ӘШҜв•Әв•Јв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ' : 'DB CLUSTER',\n            status: 'pass',\n            message: isRTL ? 'MongoDB Atlas - в”ҳГ в•ӘШІв•Әв•Ўв”ҳВ„ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө' : 'MongoDB Atlas - Connected',\n            category: 'database',\n            details: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•Әв•–в”ҳГ©в•ӘШұ: в•ӘШ°в”ҳГӘв•Әв–’в•ӘШІв”ҳВ„в•ӘШҜв”ҳВҶв•ӘВ» (в•ӘШҜв”ҳВ„в•Әв•‘в•Әв–’в•ӘШ°)' : 'Region: Portland (West)'\n        });\n\n        // ШёВӨВҖШёВӨВҖ Phase 2: Financial Integrity ШёВӨВҖШёВӨВҖ\n        try {\n            const settingsRes = await api.settings.getAll();\n            if (settingsRes.success) {\n                const s = settingsRes.data.currencySettings || {};\n                const multipliersOk = s.partsMultiplier > 1 && s.auctionMultiplier > 1;\n                addResult({\n                    id: 'financial_multipliers',\n                    name: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•Әв•–в”ҳГ© в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ ' : 'FINANCIAL LOGIC',\n                    status: multipliersOk ? 'pass' : 'warn',\n                    message: multipliersOk \n                        ? (isRTL ? 'в”ҳГ в•Әв•ўв•ӘШҜв•Әв•Јв”ҳВҒв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’ в”ҳВҶв•Әв”Өв•Әв•–в•ӘШұ' : 'Price Multipliers Active') \n                        : (isRTL ? 'в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в”ҳВҶв•Әв”Ӯв•ӘШ° в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв•Әв•Јв”ҳГЁв•Әв–’' : 'Check Pricing Ratios'),\n                    category: 'system',\n                    details: `P:x${s.partsMultiplier || 1} A:x${s.auctionMultiplier || 1}`\n                });\n            }\n        } catch { }\n\n        setScanProgress(50);\n        // ШёВӨВҖШёВӨВҖ Phase 2: Asset Integrity ШёВӨВҖШёВӨВҖ\n        try {\n            const carsRes = await api.cars.list({ limit: 100 });\n            const carsData = (carsRes.data as any[]) || [];\n            if (carsRes.success) {\n                const brokenImages = carsData.filter(c => !c.images || c.images.length === 0 || c.images[0] === '').length;\n                const missingDesc = carsData.filter(c => !c.description || (c.description && c.description.length < 10)).length;\n\n                addResult({\n                    id: 'car_images',\n                    name: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГӘв•Әв”Ӯв•ӘШҜв•ӘШ®в•Әв•– в”ҳГӘв•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•Әв–’' : 'MEDIA ASSETS',\n                    status: brokenImages > 0 ? 'warn' : 'pass',\n                    message: brokenImages > 0 \n                        ? (isRTL ? `${brokenImages} в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в•ӘШ°в•ӘВ»в”ҳГӘв”ҳВҶ в”ҳГӘв•Әв”Ӯв•ӘШҜв•ӘШ®в•Әв•–` : `${brokenImages} Cars missing media`) \n                        : (isRTL ? 'в•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГ в”ҳВҶ в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГӘв•Әв”Ӯв•ӘШҜв•ӘШ®в•Әв•–' : 'All assets verified'),\n                    category: 'assets'\n                });\n\n                addResult({\n                    id: 'car_desc',\n                    name: isRTL ? 'в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•Әв–“в”ҳГӘв”ҳВҶ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ' : 'INVENTORY CONTENT',\n                    status: missingDesc > 3 ? 'warn' : 'pass',\n                    message: missingDesc > 0 \n                        ? (isRTL ? `${missingDesc} в”ҳГ©в”ҳГӘв•ӘШҜв•ӘШ®в”ҳГ  в•ӘШ°в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в”ҳГ в•ӘШөв•ӘВ»в”ҳГӘв•ӘВ»в•ӘШұ` : `${missingDesc} Low detail listings`) \n                        : (isRTL ? 'в•ӘШҙв”ҳГӘв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳВҒв”ҳГЁв•ӘШұ в•Әв•Јв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ' : 'Metadata Quality High'),\n                    category: 'assets'\n                });\n            }\n        } catch { }\n\n        setScanProgress(80);\n        // ШёВӨВҖШёВӨВҖ Phase 3: Security ШёВӨВҖШёВӨВҖ\n        addResult({\n            id: 'ssl_status',\n            name: isRTL ? 'в•ӘШІв•Әв”Өв”ҳВҒв”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ в•ӘШҜв”ҳГЁв•ӘШұ (SSL/TLS)' : 'ENCRYPTION (SSL/TLS)',\n            status: 'pass',\n            message: isRTL ? 'в”ҳГ в•Әв•Јв”ҳГЁв•ӘШҜв•Әв–’ AES-256 в”ҳВҶв•Әв”Өв•Әв•– в”ҳГӘв”ҳГ в”ҳВҒв•Әв•Јв”ҳВ„' : 'Standard AES-256 Active',\n            category: 'security'\n        });\n\n        addResult({\n            id: 'auth_audit',\n            name: isRTL ? 'в•ӘШ°в•Әв–’в”ҳГӘв•ӘШІв”ҳГӘв”ҳГўв”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ©в”ҳГ© в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГЁв”ҳГ ' : 'AUTH PROTOCOL',\n            status: 'pass',\n            message: isRTL ? 'в•ӘШІв•ӘВ»в”ҳГӘв”ҳГЁв•Әв–’ в•Әв–’в”ҳГ в”ҳГӘв•Әв–“ JWT в”ҳВҶв•Әв”Өв•Әв•– в”ҳГӘв•ӘШӘв”ҳГ в”ҳВҶ' : 'JWT Bearer Rotation Active',\n            category: 'security'\n        });\n\n        setScanProgress(100);\n        setTimeout(() => setIsScanning(false), 500);\n    };\n\n    useEffect(() => {\n        const timer = setTimeout(() => {\n            runDiagnostics();\n        }, 100);\n        return () => clearTimeout(timer);\n    }, []);\n\n    const getStatusIcon = (status: string) => {\n        switch (status) {\n            case 'pass': return <CheckCircle className=\"text-green-500\" />;\n            case 'fail': return <XCircle className=\"text-red-500\" />;\n            case 'warn': return <AlertTriangle className=\"text-orange-500\" />;\n            default: return <RefreshCw className=\"text-blue-500 animate-spin\" />;\n        }\n    };\n\n    return (\n        <div className=\"relative min-h-screen text-white font-sans overflow-hidden bg-black\" dir={isRTL ? 'rtl' : 'ltr'}>\n            <AdminPageShell\n                title={isRTL ? 'в•ӘШІв•Әв”Өв•ӘВ«в”ҳГЁв•Әв•Ў в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ ' : 'SYSTEM DIAGNOSTICS'}\n                titleEn=\"DIAGNOSTIC PROTOCOL 0.82\"\n                backHref=\"/admin/dashboard\"\n                isRTL={isRTL}\n                actions={\n                    <button \n                        onClick={runDiagnostics} \n                        disabled={isScanning}\n                        title={isRTL ? \"в•ӘШӯв•Әв•Јв•ӘШҜв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШөв•Әв•Ў\" : \"Re-scan\"}\n                        className=\"w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all text-orange-500\"\n                    >\n                        <RefreshCw className={cn('w-5 h-5', isScanning && 'animate-spin')} />\n                    </button>\n                }\n            >\n                {/* HUD Header with Progress */}\n                <div className=\"mb-12 relative\">\n                    <div className=\"flex items-end justify-between mb-4\">\n                        <div>\n                            <p className=\"cockpit-mono text-[9px] text-orange-500/50 uppercase tracking-[0.4em] mb-1\">{t.coreStatus}</p>\n                            <h2 className=\"text-3xl font-black italic tracking-tighter uppercase\">\n                                {isScanning ? t.scanning : t.systemNominal}\n                            </h2>\n                        </div>\n                        <div className=\"text-right\">\n                            <span className=\"cockpit-num text-4xl font-black text-orange-500\">{scanProgress}%</span>\n                        </div>\n                    </div>\n                    <div className=\"h-1 w-full bg-white/5 rounded-full overflow-hidden\">\n                        <motion.div \n                            initial={{ width: 0 }}\n                            animate={{ width: `${scanProgress}%` }}\n                            className=\"h-full bg-orange-500\"\n                        />\n                    </div>\n                </div>\n\n                {/* Diagnostic Grid */}\n                <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-4\">\n                    <AnimatePresence>\n                        {results.map((res, i) => (\n                            <motion.div \n                                key={res.id}\n                                initial={{ opacity: 0, scale: 0.95 }}\n                                animate={{ opacity: 1, scale: 1 }}\n                                transition={{ delay: i * 0.05 }}\n                                className={cn(\n                                    \"ck-card p-6 border transition-all hover:bg-white/[0.04]\",\n                                    res.status === 'fail' ? \"border-red-500/30 bg-red-500/5\" : \n                                    res.status === 'warn' ? \"border-orange-500/30 bg-orange-500/5\" : \n                                    \"border-white/5 bg-white/[0.02]\"\n                                )}\n                            >\n                                <div className=\"flex items-start justify-between\">\n                                    <div className=\"flex items-center gap-4\">\n                                        <div className={cn(\n                                            \"w-10 h-10 rounded-xl flex items-center justify-center\",\n                                            res.status === 'fail' ? \"bg-red-500/10 text-red-500\" : \n                                            res.status === 'warn' ? \"bg-orange-500/10 text-orange-500\" : \n                                            \"bg-blue-500/10 text-blue-400\"\n                                        )}>\n                                            {res.category === 'system' && <Server size={20} />}\n                                            {res.category === 'database' && <Database size={20} />}\n                                            {res.category === 'assets' && <HardDrive size={20} />}\n                                            {res.category === 'security' && <Shield size={20} />}\n                                        </div>\n                                        <div>\n                                            <p className=\"cockpit-mono text-[9px] text-white/30 uppercase tracking-widest mb-1\">{res.category} {t.protocol}</p>\n                                            <h3 className=\"text-sm font-black uppercase text-white/80\">{res.name}</h3>\n                                        </div>\n                                    </div>\n                                    <div className=\"mt-1\">{getStatusIcon(res.status)}</div>\n                                </div>\n                                <div className=\"mt-4 flex items-center justify-between\">\n                                    <p className=\"text-[11px] font-bold text-white/60 italic\">{res.message}</p>\n                                    {res.details && <span className=\"cockpit-mono text-[8px] text-white/20 uppercase\">{t.info} {res.details}</span>}\n                                </div>\n                            </motion.div>\n                        ))}\n                    </AnimatePresence>\n                </div>\n\n                {/* System Vitals Visualization */}\n                <div className=\"mt-12 grid grid-cols-1 xl:grid-cols-3 gap-6\">\n                    <div className=\"ck-card p-8 xl:col-span-2\">\n                        <div className=\"flex items-center justify-between mb-8\">\n                            <h3 className=\"cockpit-mono text-[11px] font-black uppercase tracking-widest text-orange-500\">{t.liveHeatmap}</h3>\n                            <div className=\"flex gap-4\">\n                                <div className=\"flex items-center gap-2\"><div className=\"w-2 h-2 rounded-full bg-blue-500\" /><span className=\"text-[8px] text-white/40 uppercase\">{t.read}</span></div>\n                                <div className=\"flex items-center gap-2\"><div className=\"w-2 h-2 rounded-full bg-orange-500\" /><span className=\"text-[8px] text-white/40 uppercase\">{t.write}</span></div>\n                            </div>\n                        </div>\n                        <div className=\"h-48 flex items-end gap-1 px-2\">\n                            {Array.from({ length: 40 }).map((_, i) => (\n                                <motion.div \n                                    key={i}\n                                    initial={{ height: 0 }}\n                                    animate={{ height: `${(Math.sin(i * 0.5) + 1.2) * 40}%` }}\n                                    transition={{ duration: 1.5, repeat: Infinity, repeatType: 'mirror', delay: i * 0.05 }}\n                                    className={cn(\n                                        \"flex-1 rounded-t-sm\",\n                                        i % 3 === 0 ? \"bg-orange-500/40\" : \"bg-blue-500/20\"\n                                    )}\n                                />\n                            ))}\n                        </div>\n                        <p className=\"text-center cockpit-mono text-[8px] text-white/20 mt-4 tracking-widest uppercase\">{t.realTimePacket}</p>\n                    </div>\n\n                    <div className=\"space-y-4\">\n                         <div className=\"ck-card p-6\">\n                            <div className=\"flex items-center gap-3 mb-4\">\n                                <Cpu size={16} className=\"text-orange-500\" />\n                                <span className=\"cockpit-mono text-[10px] uppercase font-black tracking-widest\">{t.cpuCluster}</span>\n                            </div>\n                            <div className=\"space-y-2\">\n                                <div className=\"flex justify-between text-[10px] font-bold text-white/40\"><span>{t.load}</span><span>32.4%</span></div>\n                                <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\"><div className=\"h-full bg-orange-500 w-[32%]\" /></div>\n                            </div>\n                        </div>\n                         <div className=\"ck-card p-6\">\n                            <div className=\"flex items-center gap-3 mb-4\">\n                                <Zap size={16} className=\"text-blue-400\" />\n                                <span className=\"cockpit-mono text-[10px] uppercase font-black tracking-widest\">{t.energyFed}</span>\n                            </div>\n                            <div className=\"space-y-2\">\n                                <div className=\"flex justify-between text-[10px] font-bold text-white/40\"><span>{t.throughput}</span><span>{t.high}</span></div>\n                                <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\"><div className=\"h-full bg-blue-400 w-[88%]\" /></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </AdminPageShell>\n        </div>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\invoices\\[id]\\edit\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\invoices\\[id]\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\invoices\\create\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\invoices\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\live-auctions\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'t' is assigned a value but never used.","line":12,"column":13,"nodeType":"Identifier","messageId":"unusedVar","endLine":12,"endColumn":14},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":272,"column":57,"nodeType":"JSXOpeningElement","endLine":272,"endColumn":151},{"ruleId":"jsx-a11y/alt-text","severity":1,"message":"img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","line":272,"column":57,"nodeType":"JSXOpeningElement","endLine":272,"endColumn":151}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\nimport { motion, AnimatePresence } from \"framer-motion\";\r\nimport { Plus, Trash2, Edit2, ChevronLeft, X, Link as LinkIcon, Play, Square, ExternalLink, Image as ImageIcon } from \"lucide-react\";\r\nimport { useState, useEffect } from \"react\";\r\nimport { cn } from \"@/lib/utils\";\r\nimport { useLanguage } from \"@/lib/LanguageContext\";\r\nimport Link from \"next/link\";\r\nimport { api } from \"@/lib/api\";\r\n\r\nexport default function AdminLiveAuctions() {\r\n    const { t, isRTL } = useLanguage();\r\n    const [sessions, setSessions] = useState<any[]>([]);\r\n    const [isLoading, setIsLoading] = useState(false);\r\n    const [isModalOpen, setIsModalOpen] = useState(false);\r\n    const [editingId, setEditingId] = useState<string | null>(null);\r\n\r\n    // Form State\r\n    const [formData, setFormData] = useState({\r\n        title: '',\r\n        externalUrl: '',\r\n        whatsappNumber: '',\r\n        auctionUsername: '', // [[ARABIC_COMMENT]] в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в”ҳВ„в”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ» в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•Әв–’в•ӘШҙв”ҳГЁ\r\n        auctionPassword: '', // [[ARABIC_COMMENT]] в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв–’ в”ҳВ„в”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ» в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•Әв–’в•ӘШҙв”ҳГЁ\r\n        cars: [] as any[]\r\n    });\r\n\r\n    useEffect(() => {\r\n        loadSessions();\r\n    }, []);\r\n\r\n    const loadSessions = async () => {\r\n        setIsLoading(true);\r\n        try {\r\n            const res = await api.liveAuctions.list();\r\n            if (res.success) setSessions(res.data);\r\n        } catch (e) {\r\n            console.error(e);\r\n        } finally {\r\n            setIsLoading(false);\r\n        }\r\n    };\r\n\r\n    const handleSave = async () => {\r\n        if (!formData.title) return alert(isRTL ? \"в”ҳГЁв•Әв–’в•ӘШҙв”ҳГ« в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ\" : \"Title is required\");\r\n        setIsLoading(true);\r\n        try {\r\n            if (editingId) {\r\n                await api.liveAuctions.update(editingId, formData);\r\n            } else {\r\n                await api.liveAuctions.create(formData);\r\n            }\r\n            setIsModalOpen(false);\r\n            resetForm();\r\n            loadSessions();\r\n        } catch (e) {\r\n            console.error(e);\r\n        } finally {\r\n            setIsLoading(false);\r\n        }\r\n    };\r\n\r\n    const handleDelete = async (id: string) => {\r\n        if (!confirm(isRTL ? \"в”ҳГ§в”ҳВ„ в•ӘШ«в”ҳВҶв•ӘШІ в”ҳГ в•ӘШІв•ӘШ«в”ҳГўв•ӘВ»в•ӘШ§\" : \"Are you sure?\")) return;\r\n        try {\r\n            await api.liveAuctions.delete(id);\r\n            loadSessions();\r\n        } catch (e) {\r\n            console.error(e);\r\n        }\r\n    };\r\n\r\n    const handleStatus = async (id: string, action: 'start' | 'end') => {\r\n        try {\r\n            if (action === 'start') await api.liveAuctions.start(id);\r\n            else await api.liveAuctions.end(id);\r\n            loadSessions();\r\n        } catch (e) {\r\n            console.error(e);\r\n        }\r\n    };\r\n\r\n    const resetForm = () => {\r\n        setFormData({ title: '', externalUrl: '', whatsappNumber: '', auctionUsername: '', auctionPassword: '', cars: [] });\r\n        setEditingId(null);\r\n    };\r\n\r\n    const addCar = () => {\r\n        setFormData({\r\n            ...formData,\r\n            cars: [...formData.cars, { title: '', images: [], condition: '', description: '', priceEstimate: '' }]\r\n        });\r\n    };\r\n\r\n    const removeCar = (index: number) => {\r\n        const newCars = [...formData.cars];\r\n        newCars.splice(index, 1);\r\n        setFormData({ ...formData, cars: newCars });\r\n    };\r\n\r\n    const updateCar = (index: number, field: string, value: any) => {\r\n        const newCars = [...formData.cars];\r\n        newCars[index] = { ...newCars[index], [field]: value };\r\n        setFormData({ ...formData, cars: newCars });\r\n    };\r\n\r\n    const handleImageUpload = async (index: number, files: FileList | null) => {\r\n        if (!files) return;\r\n        const uploadPromises = Array.from(files).map(file => {\r\n            const fd = new FormData();\r\n            fd.append('image', file);\r\n            return api.upload.image(fd);\r\n        });\r\n\r\n        try {\r\n            const results = await Promise.all(uploadPromises);\r\n            const urls = results.map(r => r.url);\r\n            updateCar(index, 'images', [...formData.cars[index].images, ...urls]);\r\n        } catch (e) {\r\n            console.error(e);\r\n            alert(\"Image upload failed\");\r\n        }\r\n    };\r\n\r\n    return (\r\n        <div className=\"min-h-screen bg-black text-white p-6 md:p-12 lg:p-20\">\r\n            <header className=\"flex justify-between items-center mb-12\">\r\n                <div>\r\n                    <Link href=\"/admin/dashboard\" className=\"flex items-center gap-2 text-white/40 hover:text-white mb-4 transition-colors\">\r\n                        <ChevronLeft className={cn(\"w-4 h-4\", isRTL && \"rotate-180\")} />\r\n                        <span className=\"text-[10px] font-black uppercase tracking-widest\">{isRTL ? \"в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГӘв•ӘВ»в•ӘШұ\" : \"BACK\"}</span>\r\n                    </Link>\r\n                    <h1 className=\"text-4xl md:text-6xl font-black italic uppercase tracking-tighter\">\r\n                        {isRTL ? \"в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’в•ӘШұ\" : \"LIVE SHOWROOM\"}\r\n                    </h1>\r\n                </div>\r\n                <motion.button\r\n                    whileHover={{ scale: 1.05 }}\r\n                    whileTap={{ scale: 0.95 }}\r\n                    onClick={() => { resetForm(); setIsModalOpen(true); }}\r\n                    className=\"px-8 py-4 bg-cinematic-neon-blue text-black font-black uppercase text-[10px] tracking-widest rounded-2xl flex items-center gap-3 shadow-[0_0_30px_rgba(0,240,255,0.3)]\"\r\n                >\r\n                    <Plus className=\"w-4 h-4\" />\r\n                    {isRTL ? \"в•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШұ\" : \"CREATE SESSION\"}\r\n                </motion.button>\r\n            </header>\r\n\r\n            <div className=\"grid grid-cols-1 gap-6\">\r\n                {sessions.map(session => (\r\n                    <div key={session._id} className=\"glass-card p-8 border-white/5 bg-white/[0.01] flex flex-col md:flex-row justify-between items-center gap-8 group\">\r\n                        <div className=\"flex-1 space-y-2\">\r\n                            <div className=\"flex items-center gap-3\">\r\n                                <span className={cn(\r\n                                    \"px-3 py-1 rounded-full text-[8px] font-black uppercase tracking-widest\",\r\n                        