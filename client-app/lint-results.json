                         className=\"bg-zinc-950 border border-white/10 p-8 rounded-3xl w-full max-w-lg relative\"\r\n                        >\r\n                            <button onClick={() => setShowBroadcastModal(false)} className=\"absolute top-6 right-6 text-white/40 hover:text-white transition-all\"><X className=\"w-6 h-6\" /></button>\r\n                            <h2 className=\"text-2xl font-black uppercase tracking-tighter mb-6 flex items-center gap-3 text-cinematic-neon-blue\">\r\n                                <Send className=\"w-6 h-6\" />\r\n                                {isRTL ? 'в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’ в”ҳВ„в”ҳВ„в”ҳГўв”ҳВ„' : 'NEW BROADCAST'}\r\n                            </h2>\r\n                            <form onSubmit={handleBroadcast} className=\"space-y-6\">\r\n                                <div>\r\n                                    <label className=\"block text-[10px] font-black text-white/40 uppercase tracking-widest mb-2\">{isRTL ? 'в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’' : 'TITLE'}</label>\r\n                                    <input required placeholder={isRTL ? 'в”ҳГ в•ӘШів•ӘШҜв”ҳВ„: в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»!' : 'e.g., NEW OFFER!'} value={broadcastForm.title} onChange={e => setBroadcastForm(prev => ({ ...prev, title: e.target.value }))} className=\"w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm focus:border-cinematic-neon-blue focus:outline-none transition-all\" />\r\n                                </div>\r\n                                <div>\r\n                                    <label className=\"block text-[10px] font-black text-white/40 uppercase tracking-widest mb-2\">{isRTL ? 'в”ҳВҶв•Әв•Ў в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’' : 'MESSAGE CONTENT'}</label>\r\n                                    <textarea required rows={4} placeholder={isRTL ? 'в•ӘШҜв”ҳГўв•ӘШІв•ӘШ° в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШІв”ҳГў в”ҳВ„в”ҳВ„в”ҳГ в•Әв”