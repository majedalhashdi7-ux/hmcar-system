ing;\n    _id: string;\n    name: string;\n    nameEn?: string;  // в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв”ҳВ„в”ҳГЁв•Әв–“в”ҳГЁв•ӘШұ\n    nameAr?: string;\n    brand: string;\n    model: string;\n    price: number;\n    images?: string[];\n    img?: string;\n    image?: string;\n    condition: 'NEW' | 'USED' | 'REFURBISHED';\n    category: string;\n    categoryAr?: string;\n    stockQty: number;\n    compatibility: string[];\n    carMakeEn?: string;  // в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•Әв–’в”ҳГўв•ӘШұ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв”ҳВ„в”ҳГЁв•Әв–“в”ҳГЁв•ӘШұ\n    carModelEn?: string; // в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв”ҳВ„в”ҳГЁв•Әв–“в”ҳГЁв•ӘШұ\n}\n\nfunction resolvePartImage(part: Part): string {\n    const candidate = part.img || part.image || part.images?.[0] || '';\n    const normalized = typeof candidate === 'string' ? candidate.trim() : '';\n    return normalized || '/images/placeholder.jpg';\n}\n\ninterface Agency {\n    id: string;\n    brandId?: string;\n    name: string;    // в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в•Әв•Јв•Әв–’в•ӘШ°в”ҳГЁ\n    nameEn?: string; // в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв”ҳВ„в”ҳГЁв•Әв–“в”ҳГЁ\n    logo: string;\n    models: string[];\n    modelsEn?: string[]; // в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв”ҳВ„в”ҳГЁв•Әв–“в”ҳГЁв•ӘШұ (в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГ©в•ӘШ°в”ҳВ„в•ӘШҜв”ҳГҜ)\n}\n\nexport default function PartsPage() {\n    const router = useRouter();\n    const { isRTL } = useLanguage();\n    const { formatPrice: formatGlobalPrice, socialLinks } = useSettings();\n    const formatPrice = (price: number) => formatGlobalPrice(Number(price || 0), undefined, 'part');\n    const { isLoggedIn } = useAuth();\n    // в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ° - в”ҳГЁв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в”ҳГ в”ҳВҶ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШ«в”ҳГӘ в•ӘШҜв”ҳВ„в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в•ӘШҜв”ҳВҒв•ӘШІв•Әв–’в•ӘШҜв•Әв•ўв”ҳГЁ\n    const WHATSAPP_NUMBER = (socialLinks?.whatsapp || '+821080880014').replace(/\\D/g, '');\n    // в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в•ӘШҜв”ҳВ„ (в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҶв•ӘШ°в•ӘШів”ҳГ©) - null в•ӘШІв•Әв•Јв”ҳВҶв”ҳГЁ в”ҳГ в•Әв•‘в”ҳВ„в”ҳГ©в•ӘГ® в”ҳГӘв•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГўв•ӘШҜв•ӘШ®в”ҳВҶ в•ӘШІв•Әв•Јв”ҳВҶв”ҳГЁ в”ҳГ в”ҳВҒв•ӘШІв”ҳГӘв•ӘШө\n    const [modalProduct, setModalProduct] = useState<ProductModalData | null>(null);\n\n    const [viewMode, setViewMode] = useState<'AGENCIES' | 'PARTS'>('AGENCIES');\n    const [selectedAgency, setSelectedAgency] = useState<Agency | null>(null);\n    const [selectedModel, setSelectedModel] = useState<string>('ALL'); // 'ALL' = show all models\n\n    const [agencySearchQuery, setAgencySearchQuery] = useState(''); // [[ARABIC_COMMENT]] в•ӘШ°в•ӘШөв•ӘШі в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ в”ҳГ в”ҳВҶв”ҳВҒв•Әв•Ўв”ҳВ„\n    const [partSearchQuery, setPartSearchQuery] = useState('');    // [[ARABIC_COMMENT]] в•ӘШ°в•ӘШөв•ӘШі в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Ј в”ҳГ в”ҳВҶв”ҳВҒв•Әв•Ўв”ҳВ„\n    const [parts, setParts] = useState<Part[]>([]);\n    const [loading, setLoading] = useState(false);\n\n    // --- Agencies from API (Parts brands) ---\n    const [agencies, setAgencies] = useState<Agency[]>([]);\n\n    useEffect(() => {\n        const fetchAgencies = async () => {\n            try {\n                // 1. в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ўв•ӘШұ в”ҳВ„в”ҳГ©в•Әв•–в•Әв•Ј в•ӘШҜв”ҳВ„в•Әв•‘в”ҳГЁв•ӘШҜв•Әв–’ - в”ҳВҶв•Әв•Јв•Әв–’в•Әв•ўв”ҳГ§в•ӘШҜ в”ҳВҒв”ҳГӘв•Әв–’в•ӘШҜв”ҳГҜ\n                const res = await api.brands.list('parts');\n                const hasBrands = res?.success && Array.isArray(res.brands) && res.brands.length > 0;\n\n                if (hasBrands) {\n                    // в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ в”ҳВҒв”ҳГӘв•Әв–’в•ӘШҜв”ҳГҜ в•ӘШ°в•ӘВ»в”ҳГӘв”ҳВҶ в”ҳВҒв”ҳВ„в•ӘШІв•Әв–’\n                    setAgencies(res.brands.map((b: any) => ({\n                        id: b._id,\n                        brandId: b._id,\n                        name: b.name,\n                        nameEn: b.nameEn || b.name, // в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв”ҳВ„в”ҳГЁв•Әв–“в”ҳГЁ\n                        logo: b.logoUrl || '/images/placeholder.jpg',\n                        models: []\n                    })));\n                }\n\n                // 2. в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Ј в”ҳВ„в•ӘШ°в”ҳВҶв•ӘШҜв•ӘШ© в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ©в”ҳГЁв”ҳГ©в”ҳГЁв•ӘШұ\n                const partsRes = await api.parts.list({ limit: 2000 });\n                const allParts: any[] = partsRes?.parts || [];\n\n                if (hasBrands && allParts.length > 0) {\n                    // в•ӘШ°в”ҳВҶв•ӘШҜв•ӘШ© в•ӘВ«в•Әв–’в”ҳГЁв•Әв•–в•ӘШұ: brand._id => Set of carModels\n                    const brandModelsMap: Record<string, Set<string>> = {};\n                    allParts.forEach((p: any) => {\n                        const rawBrand = p.brand;\n                        // в”ҳВҶв•ӘШөв•ӘШҜв”ҳГӘв”ҳВ„ в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•Әв–’в•ӘШҜв•ӘШҙ brandId в•ӘШ°в•ӘШ«в”ҳГўв•ӘШів•Әв–’ в”ҳГ в”ҳВҶ в•Әв•–в•Әв–’в”ҳГЁв”ҳГ©в•ӘШұ\n                        const brandId = rawBrand?._id\n                            ? String(rawBrand._id)\n                            : (typeof rawBrand === 'string' && rawBrand.length === 24 ? rawBrand : null);\n                        if (!brandId) return;\n                        if (!brandModelsMap[brandId]) brandModelsMap[brandId] = new Set();\n                        if (p.carModel) brandModelsMap[brandId].add(p.carModel);\n                    });\n\n                    // в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШ°в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШөв”ҳГ©в”ҳГЁв”ҳГ©в”ҳГЁв•ӘШұ (в”ҳВҶв”ҳВҸв•Әв••в”ҳГ§в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШ°в•Әв•‘в•Әв•ў в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•Әв–’ в•Әв•Јв”ҳВҶ в•Әв•Јв•ӘВ»в•ӘВ» в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Ј)\n                    setAgencies(res.brands.map((b: any) => ({\n                        id: b._id,\n                        brandId: b._id,\n                        name: b.name,\n                        nameEn: b.nameEn || b.name,\n                        logo: b.logoUrl || '/images/placeholder.jpg',\n                        models: Array.from(brandModelsMap[String(b._id)] || new Set())\n                    })));\n                } else if (!hasBrands && allParts.length > 0) {\n                    // Fallback: group by carMake в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ в”ҳГ в•Әв”Ӯв•ӘШҙв”ҳВ„в•ӘШұ\n                    const makeMap: Record<string, { logo: string; brandId?: string; models: Set<string> }> = {};\n                    allParts.forEach((p: any) => {\n                        const rawBrand = p.brand;\n                        const brandId = rawBrand?._id ? String(rawBrand._id) : undefined;\n                        const brandName = (rawBrand && typeof rawBrand === 'object' && rawBrand.name)\n                            ? rawBrand.name\n                            : (typeof rawBrand === 'string' && rawBrand.length < 30 ? rawBrand : null);\n                        const make = brandName || p.carMake || '';\n                        if (!make || make === 'в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШөв•ӘВ»в•ӘВ»') return;\n                        if (!makeMap[make]) makeMap[make] = { logo: rawBrand?.logoUrl || '/images/placeholder.jpg', brandId, models: new Set() };\n                        if (p.carModel) makeMap[make].models.add(p.carModel);\n                    });\n                    setAgencies(Object.entries(makeMap).map(([name, val]) => ({\n                        id: val.brandId || name,\n                        brandId: val.brandId,\n                        name,\n                        logo: val.logo,\n                        models: Array.from(val.models)\n                    })));\n                }\n            } catch (err) {\n                console.error(\"Failed to fetch agencies\", err);\n            }\n        };\n        fetchAgencies();\n    }, [isRTL]);\n\n    // в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’ в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШұ: в”ҳВҶв•Әв–‘в”ҳГ§в•ӘШ° в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’в•ӘШұ в”ҳВ„в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Ј (в•ӘШ°в•ӘВ»в”ҳГӘв”ҳВҶ в•Әв”Өв•ӘШҜв•Әв”Өв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ)\n    const handleAgencySelect = (agency: Agency) => {\n        setSelectedAgency(agency);\n        setSelectedModel('ALL');\n        setViewMode('PARTS');\n        loadParts(agency);\n        window.scrollTo({ top: 0, behavior: 'smooth' });\n    };\n\n    // в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв•ӘВ«в•ӘШІв”ҳГЁв•ӘШҜв•Әв–’ в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„ (в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳВҒв”ҳВ„в•ӘШҜв•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГЁв•ӘШұ): в”ҳВҶв”ҳВҸв”ҳВҒв”ҳВ„в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв”ҳГ в”ҳВ„в•ӘШұ в”ҳГ в•Әв”Ӯв•ӘШ°в”ҳГ©в•ӘШҜв”ҳГҜ\n    const handleModelFilter = (model: string) => {\n        setSelectedModel(model);\n        // в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Ј в”ҳГ в•ӘШөв”ҳГ в”ҳВ„в•ӘШұ в”ҳГ в•Әв”Ӯв•ӘШ°в”ҳГ©в•ӘШҜв”ҳГҜ ШёВҖВӨ в”ҳВ„в•ӘШҜ в”ҳВҶв•ӘШөв•ӘШІв•ӘШҜв•ӘШҙ API call в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘГ® в”ҳВҶв”ҳВҸв”ҳВҒв”ҳВ„в•ӘШІв•Әв–’ в”ҳВҒв”ҳГ©в•Әв•–\n    };\n\n    const loadParts = async (agency: Agency) => {\n        setLoading(true);\n        setPartSearchQuery('');\n        try {\n            const params: Record<string, string | number> = { limit: 500 };\n            if (agency.brandId) {\n                params.brandId = agency.brandId;\n            } else {\n                params.brand = agency.name;\n            }\n            // в”ҳВҶв•ӘШҙв”ҳВ„в•ӘШ° в”ҳГўв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Ј в•ӘВ»в”ҳВҒв•Әв•Јв•ӘШұв”ҳГҜ в”ҳГӘв•ӘШҜв•ӘШөв•ӘВ»в•ӘШұ - в•ӘШҜв”ҳВ„в”ҳВҒв”ҳВ„в•ӘШІв•Әв–’ в”ҳГЁв•ӘШІв”ҳГ  в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳВҖ Frontend\n            const res = await api.parts.list(params);\n            const allParts = res?.parts || res?.data?.parts || [];\n            setParts(allParts);\n        } catch (error) {\n            console.error(\"Failed to load parts\", error);\n            setParts([]);\n        } finally {\n            setLoading(false);\n        }\n    };\n\n    const resetToAgencies = () => {\n        setViewMode('AGENCIES');\n        setSelectedAgency(null);\n        setSelectedModel('ALL');\n        setAgencySearchQuery('');\n        setPartSearchQuery('');\n        setParts([]);\n    };\n\n    // в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•ӘШҜв•ӘШөв•ӘШұ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв”ҳГ в”ҳВ„в•ӘШұ\n    const availableModels: string[] = Array.from(\n        new Set(parts.map((p: any) => p.carModel).filter(Boolean))\n    ).sort();\n\n    // [[ARABIC_COMMENT]] в”ҳВҒв”ҳВ„в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШ°в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ в”ҳГЁв”ҳВҶ в•ӘШҜв”ҳВ„в•Әв•Јв•Әв–’в•ӘШ°в”ҳГЁ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШӯв”ҳВҶв•ӘШҙв”ҳВ„в”ҳГЁв•Әв–“в”ҳГЁ\n    const filteredAgencies = agencies.filter(a => {\n        const q = agencySearchQuery.toLowerCase();\n        if (!q) return true;\n        return a.name.toLowerCase().includes(q) || (a.nameEn || '').toLowerCase().includes(q);\n    });\n    const filteredParts = parts.filter((part: any) => {\n        if (selectedModel !== 'ALL' && part.carModel !== selectedModel) return false;\n        const q = partSearchQuery.trim().toLowerCase();\n        if (!q) return true;\n        return [part.nameAr, part.nameEn, part.name, part.brand, part.carModel, part.category, part.categoryAr]\n            .filter(Boolean)\n            .some(v => String(v).toLowerCase().includes(q));\n    });\n\n    // в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШөв•Әв”Ӯв•ӘШ° в•ӘШҜв”ҳВ„в”ҳВ„в•Әв•‘в•ӘШұ\n    const getAgencyDisplayName = (agency: Agency) =>\n        (!isRTL && agency.nameEn) ? agency.nameEn : agency.name;\n\n    // в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ в•ӘШөв•Әв”Ӯв•ӘШ° в•ӘШҜв”ҳВ„в”ҳВ„в•Әв•‘в•ӘШұ\n    const getPartDisplayName = (part: any) => {\n        if (!isRTL) {\n            return part.nameEn || part.name;\n        }\n        return part.nameAr || part.name;\n    };\n\n    // [[ARABIC_COMMENT]] в”ҳВҒв•ӘШІв•ӘШө в”ҳГ в”ҳГӘв•ӘВ»в•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ в”ҳГ в•Әв•Ј в•ӘШІв•ӘШөв”ҳГӘв”ҳГЁв”ҳВ„ в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІв”ҳГ§в•ӘШҜ в”ҳВ„в•Әв•Ўв”ҳГЁв•Әв•‘в•ӘШұ ProductModalData\n    const openPartModal = (part: Part) => {\n        if (!isLoggedIn) {\n            router.push('/login');\n            return;\n        }\n        setModalProduct({\n            id: part._id,\n            type: 'part',\n            title: part.nameAr || part.name,\n            images: (part.images || [part.img]).filter((img): img is string => !!img),\n            price: part.price,\n            brand: part.brand,\n            condition: part.condition,\n            compatibility: part.compatibility,\n            stock: part.stockQty,\n            description: undefined,\n        });\n    };\n\n    return (\n        <>\n            {/* [[ARABIC_COMMENT]] в”ҳГ в”ҳГӘв•ӘВ»в•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ - Shein-style */}\n            <ProductModal\n                product={modalProduct}\n                onClose={() => setModalProduct(null)}\n                whatsappNumber={WHATSAPP_NUMBER}\n            />\n            <div className={`relative min-h-screen bg-[#050505] text-white overflow-x-hidden ${isRTL ? 'font-arabic' : ''}`} dir={isRTL ? 'rtl' : 'ltr'}>\n                <Navbar />\n\n                {/* ШёВӨВҖШёВӨВҖ ADVANCED TECH BACKGROUND ШёВӨВҖШёВӨВҖ */}\n                <div className=\"fixed inset-0 -z-20\">\n                    <div\n                        className=\"absolute inset-0 bg-cover bg-center opacity-30 brightness-[0.4] contrast-125\"\n                        style={{ backgroundImage: \"url('/images/gata.jpg')\" }}\n                    />\n                    <div className=\"absolute inset-0 bg-gradient-to-b from-[#050505] via-transparent to-[#050505]\" />\n                    <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,_rgba(0,240,255,0.05)_0%,_transparent_50%)]\" />\n                </div>\n\n                {/* ШёВӨВҖШёВӨВҖ FLOATING PARTICLES ШёВӨВҖШёВӨВҖ */}\n                <div className=\"fixed inset-0 pointer-events-none z-0\">\n                    {[...Array(15)].map((_, i) => (\n                        <motion.div\n                            key={i}\n                            initial={{ opacity: 0, scale: 0 }}\n                            animate={{\n                                opacity: [0, 0.4, 0],\n                                scale: [0, 1, 0],\n                                x: [(i % 5) * 200 - 400, (i % 3) * 300 - 450, (i % 5) * 200 - 400],\n                                y: [(i % 4) * 200 - 400, (i % 2) * 400 - 400, (i % 4) * 200 - 400]\n                            }}\n                            transition={{\n                                duration: 15 + (i % 10),\n                                repeat: Infinity,\n                                delay: i * 0.5\n                            }}\n                            className=\"absolute top-1/2 left-1/2 w-1.5 h-1.5 bg-cinematic-neon-blue rounded-full blur-[3px]\"\n                        />\n                    ))}\n                </div>\n\n                {/* ШёВӨВҖШёВӨВҖ BACK BUTTON ШёВӨВҖШёВӨВҖ */}\n                <motion.div\n                    initial={{ opacity: 0, scale: 0.8 }}\n                    animate={{ opacity: 1, scale: 1 }}\n                    transition={{ delay: 0.5 }}\n                    className={cn(\"fixed top-20 sm:top-24 z-[60]\", isRTL ? \"right-4 sm:right-12\" : \"left-4 sm:left-12\")}\n                >\n                    <button\n                        onClick={viewMode === 'AGENCIES' ? () => window.location.href = '/client/dashboard' : resetToAgencies}\n                        className=\"group w-12 h-12 border border-white/10 rounded-2xl flex items-center justify-center bg-black/60 backdrop-blur-xl hover:border-accent-gold/50 hover:bg-accent-gold/10 transition-all duration-500 shadow-2xl\"\n                        title={isRTL ? \"в•Әв•Јв”ҳГӘв•ӘВ»в•ӘШұ\" : \"Back\"}\n                    >\n                        {isRTL ? <ChevronRight className=\"w-5 h-5 text-white/60 group-hover:text-accent-gold transition-colors\" /> : <ChevronLeft className=\"w-5 h-5 text-white/60 group-hover:text-accent-gold transition-colors\" />}\n                    </button>\n                </motion.div>\n\n                <main className=\"relative z-10 pt-28 sm:pt-32 px-4 sm:px-6 pb-24 max-w-[1400px] mx-auto min-h-screen flex flex-col\">\n\n                    {/* ШёВӨВҖШёВӨВҖ HEADER ШёВӨВҖШёВӨВҖ */}\n                    <header className=\"text-center mb-8 space-y-4\">\n                        <motion.span\n                            initial={{ opacity: 0, y: 10 }}\n                            animate={{ opacity: 1, y: 0 }}\n                            className=\"inline-block px-4 py-1.5 rounded-full bg-accent-gold/10 border border-accent-gold/20 text-[10px] font-black tracking-[0.3em] uppercase text-accent-gold\"\n                        >\n                            {isRTL ? \"в”ҳГ в•Әв”Ӯв•ӘШІв”ҳГӘв•ӘВ»в•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв–’в”ҳГ©в”ҳГ в”ҳГЁ\" : \"DIGITAL COMPONENTS REGISTRY\"}\n                        </motion.span>\n                        <motion.h1\n                            initial={{ opacity: 0, y: 20 }}\n                            animate={{ opacity: 1, y: 0 }}\n                            transition={{ delay: 0.2 }}\n                            className=\"text-4xl md:text-6xl font-black uppercase tracking-tighter\"\n                        >\n                            {viewMode === 'AGENCIES' && (isRTL ? \"в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШұ\" : \"SELECT AGENCY\")}\n                            {viewMode === 'PARTS' && (isRTL\n                                ? `в”ҳГ©в•Әв•–в•Әв•Ј в•Әв•‘в”ҳГЁв•ӘШҜв•Әв–’ ${getAgencyDisplayName(selectedAgency!)}`\n                                : `${getAgencyDisplayName(selectedAgency!)} SPARE PARTS`)}\n                        </motion.h1>\n                        <motion.p\n                            initial={{ opacity: 0 }}\n                            animate={{ opacity: 1 }}\n                            transition={{ delay: 0.3 }}\n                            className=\"text-white/40 text-sm font-medium uppercase tracking-[0.2em]\"\n                        >\n                            {viewMode === 'AGENCIES' && (isRTL ? \"в•ӘШҜв•ӘШ°в•ӘШөв•ӘШі в•Әв•Јв”ҳВҶ в•Әв•–в•Әв–’в”ҳГЁв”ҳГ© в•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в”ҳГўв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв”ҳВҶв•Әв•Јв•ӘШұ\" : \"BROWSE BY MANUFACTURER LOGO\")}\n                            {viewMode === 'PARTS' && (isRTL ? `в”ҳГўв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•ӘШҜв•ӘШөв•ӘШұ ШёВҖВӨ в”ҳВҒв”ҳВ„в•ӘШІв•Әв–’ в•ӘШ°в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘШ«в•ӘВ»в”ҳВҶв•ӘШҜв”ҳГ§` : 'ALL COMPONENTS ШёВҖВӨ FILTER BY MODEL BELOW')}\n                        </motion.p>\n                    </header>\n\n                    {/* ШёВӨВҖШёВӨВҖ SEARCH + MODEL FILTER CHIPS ШёВӨВҖШёВӨВҖ */}\n                    <motion.div\n                        initial={{ opacity: 0, y: 20 }}\n                        animate={{ opacity: 1, y: 0 }}\n                        transition={{ delay: 0.4 }}\n                        className=\"relative max-w-3xl mx-auto w-full mb-10\"\n                    >\n                        {/* в•Әв”Өв•Әв–’в”ҳГЁв•Әв•– в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі */}\n                        <div className=\"relative flex items-center bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-2xl p-1 sm:p-2 shadow-2xl overflow-hidden group mb-4\">\n                            <div className=\"flex-1 flex items-center px-2 sm:px-4 gap-2 sm:gap-4\">\n                                <Search className=\"w-4 h-4 sm:w-5 sm:h-5 text-accent-gold group-hover:scale-110 transition-transform\" />\n                                {viewMode === 'AGENCIES' ? (\n                                    <input\n                                        type=\"text\"\n                                        placeholder={isRTL ? \"в•ӘШҜв•ӘШ°в•ӘШөв•ӘШі в•Әв•Јв”ҳВҶ в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШұ (в•ӘШІв”ҳГӘв”ҳГЁв”ҳГӘв•ӘШІв•ӘШҜв•ӘГ® в”ҳГўв”ҳГЁв•ӘШҜ...)\" : \"Search Agency (Toyota, Kia...)\"}\n                                        className=\"w-full bg-transparent border-none outline-none py-4 text-sm font-bold placeholder:text-white/20\"\n                                        value={agencySearchQuery}\n                                        onChange={(e) => setAgencySearchQuery(e.target.value)}\n                                    />\n                                ) : (\n                                    <input\n                                        type=\"text\"\n                                        placeholder={isRTL ? \"в•ӘШҜв•ӘШ°в•ӘШөв•ӘШі в•Әв•Јв”ҳВҶ в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ...\" : \"Search Part...\"}\n                                        className=\"w-full bg-transparent border-none outline-none py-4 text-sm font-bold placeholder:text-white/20\"\n                                        value={partSearchQuery}\n                                        onChange={(e) => setPartSearchQuery(e.target.value)}\n                                    />\n                                )}\n                            </div>\n                        </div>\n\n                        {/* в”ҳВҒв”ҳВ„в•ӘШҜв•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„в•ӘШҜв•ӘШІ Pill Chips - в•ӘШІв•Әв••в”ҳГ§в•Әв–’ в”ҳВҒв”ҳГ©в•Әв•– в”ҳВҒв”ҳГЁ в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Ј */}\n                        {viewMode === 'PARTS' && availableModels.length > 0 && (\n                            <motion.div\n                                initial={{ opacity: 0, y: -8 }}\n                                animate={{ opacity: 1, y: 0 }}\n                                className=\"flex flex-wrap gap-2 justify-center\"\n                            >\n                                <button\n                                    onClick={() => handleModelFilter('ALL')}\n                                    className={`px-4 py-2 rounded-full text-[10px] font-black uppercase tracking-widest border transition-all duration-300 ${\n                                        selectedModel === 'ALL'\n                                            ? 'bg-accent-gold text-black border-accent-gold shadow-lg shadow-accent-gold/30'\n                                            : 'bg-white/5 border-white/10 text-white/50 hover:border-accent-gold/40 hover:text-white'\n                                    }`}\n                                >\n                                    {isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„' : 'ALL'}\n                                    <span className=\"mx-1 opacity-60\">({parts.length})</span>\n                                </button>\n                                {availableModels.map(model => {\n                                    const count = parts.filter((p: any) => p.carModel === model).length;\n                                    return (\n                                        <button\n                                            key={model}\n                                            onClick={() => handleModelFilter(model)}\n                                            className={`px-4 py-2 rounded-full text-[10px] font-black uppercase tracking-widest border transition-all duration-300 ${\n                                                selectedModel === model\n                                                    ? 'bg-cinematic-neon-blue/20 text-cinematic-neon-blue border-cinematic-neon-blue/50 shadow-lg shadow-cinematic-neon-blue/10'\n                                                    : 'bg-white/5 border-white/10 text-white/50 hover:border-white/30 hover:text-white'\n                                            }`}\n                                        >\n                                            {model}\n                                            <span className=\"mx-1 opacity-50\">({count})</span>\n                                        </button>\n                                    );\n                                })}\n                            </motion.div>\n                        )}\n                    </motion.div>\n\n                    {/* ШёВӨВҖШёВӨВҖ CONTENT VIEWS ШёВӨВҖШёВӨВҖ */}\n                    <AnimatePresence mode=\"wait\">\n\n                        {viewMode === 'AGENCIES' && (\n                            <motion.div\n                                key=\"agencies-tech\"\n                                initial={{ opacity: 0, y: 30 }}\n                                animate={{ opacity: 1, y: 0 }}\n                                exit={{ opacity: 0, scale: 1.1, filter: \"blur(20px)\" }}\n                                className=\"max-w-6xl mx-auto py-16\"\n                            >\n                                <div className=\"grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6 sm:gap-y-10\">\n                                    {filteredAgencies.map((agency, idx) => (\n                                        <motion.div\n                                            key={agency.id}\n                                            initial={{ opacity: 0, y: 30 }}\n                                            animate={{ opacity: 1, y: 0 }}\n                                            transition={{ delay: idx * 0.05 }}\n                                            onClick={() => handleAgencySelect(agency)}\n                                            className=\"group flex flex-col items-center gap-5 cursor-pointer\"\n                                        >\n                                            {/* Brand Circle */}\n                                            <div className=\"relative w-32 h-32 md:w-48 md:h-48 rounded-full bg-white/[0.02] border border-white/10 flex items-center justify-center p-6 group-hover:border-cinematic-neon-blue/50 group-hover:bg-cinematic-neon-blue/5 transition-all duration-700 shadow-2xl overflow-hidden\">\n                                                {/* Animated Glow on Hover */}\n                                                <div className=\"absolute -inset-10 bg-cinematic-neon-blue/5 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700\" />\n                                                \n                                                <div className=\"relative w-full h-full p-4 bg-white rounded-full shadow-inner flex items-center justify-center group-hover:scale-110 transition-transform duration-700\">\n                                                    <Image\n                                                        src={agency.logo}\n                                                        alt={getAgencyDisplayName(agency)}\n                                                        fill\n                                                        className=\"object-contain p-4 group-hover:scale-110 transition-transform duration-700\"\n                                                        unoptimized\n                                                        referrerPolicy=\"no-referrer\"\n                                                    />\n                                                </div>\n                                            </div>\n\n                                            <div className=\"text-center\">\n                                                <h3 className=\"text-xl font-black uppercase tracking-widest group-hover:text-cinematic-neon-blue transition-colors\">\n                                                    {agency.name}\n      