         </motion.button>\r\n                    </div>\r\n\r\n                    {/* ШёВӨВҖШёВӨВҖ в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•Әв–“в”ҳГӘв”ҳВҶ ШёВӨВҖШёВӨВҖ */}\r\n                    <div className=\"absolute bottom-3 left-3\">\r\n                        <div className={cn(\r\n                            \"flex items-center gap-1.5 px-3 py-1.5 rounded-xl backdrop-blur-xl border shadow-lg\",\r\n                            stockBg,\r\n                            stock > 0 ? \"border-white/20\" : \"border-red-500/30\"\r\n                        )}>\r\n                            <Package className={cn(\"w-3.5 h-3.5\", stockColor)} />\r\n                            <span className={cn(\"text-[10px] font-black uppercase tracking-wider\", stockColor)}>\r\n                                {stockLabel}\r\n                            </span>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n                {/* ШёВӨВҖШёВӨВҖ в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ ШёВӨВҖШёВӨВҖ */}\r\n                <div className=\"p-5 space-y-4\">\r\n                    {/* в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•Әв–’в”ҳГўв•ӘШұ */}\r\n                    {(part.brand || part.brandName) && (\r\n                        <div className=\"flex items-center gap-2\">\r\n                            <div className=\"h-px flex-1 bg-gradient-to-r from-transparent via-amber-500/30 to-transparent\" />\r\n                            <p className=\"text-[9px] font-black text-amber-400/70 tracking-[0.3em] uppercase\">\r\n                                {part.brand || part.brandName}\r\n                            </p>\r\n                            <div className=\"h-px flex-1 bg-gradient-to-r from-transparent via-amber-500/30 to-transparent\" />\r\n                        </div>\r\n                    )}\r\n\r\n                    {/* в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ  */}\r\n                    <h3 className=\"text-base font-black leading-ti