 (no problems were reported from '@typescript-eslint/no-explicit-any').","line":176,"column":13,"severity":1,"nodeType":null,"fix":{"range":[9709,9771],"text":" "}},{"ruleId":null,"message":"Unused eslint-disable directive (no problems were reported from '@typescript-eslint/no-explicit-any').","line":187,"column":13,"severity":1,"nodeType":null,"fix":{"range":[10368,10430],"text":" "}},{"ruleId":null,"message":"Unused eslint-disable directive (no problems were reported from '@typescript-eslint/no-explicit-any').","line":198,"column":13,"severity":1,"nodeType":null,"fix":{"range":[10998,11060],"text":" "}}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":8,"fixableErrorCount":0,"fixableWarningCount":6,"source":"'use client';\r\n\r\n/**\r\n * в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ - в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШІв•ӘШөв”ҳГўв”ҳГ  HM CAR\r\n * ШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖШёВӨВҖ\r\n * в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в”ҳГ в”ҳГ©в•Әв”Ӯв”ҳГ в•ӘШұ в•ӘШӯв”ҳВ„в”ҳГ« 8 в•ӘШІв•ӘШ°в”ҳГӘв”ҳГЁв•ӘШ°в•ӘШҜв•ӘШІ:\r\n * 1. profile   - в•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в”ҳВҒ в•ӘШҜв”ҳВ„в•Әв”Өв•ӘВ«в•Әв•Ўв”ҳГЁ в”ҳГӘв”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’\r\n * 2. site      - в”ҳГ§в”ҳГӘв”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј (в•ӘШҜв”ҳВ„в•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’ в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳВҒ)\r\n * 3. home      - в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘШұ (Hero)\r\n * 4. social    - в•Әв–’в”ҳГӘв•ӘШҜв•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШҙв•ӘШІв”ҳГ в•ӘШҜв•Әв•Јв”ҳГЁ\r\n * 5. contact   - в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„\r\n * 6. currency  - в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШ«в•Әв”Ӯв•Әв•Јв•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•Әв•Ўв•Әв–’в”ҳВҒ\r\n * 7. features  - в”ҳГ©в•Әв”Ӯв”ҳГ  \"в”ҳВ„в”ҳГ в•ӘШҜв•Әв–‘в•ӘШҜ в•ӘШІв•ӘВ«в•ӘШІв•ӘШҜв•Әв–’в”ҳВҶв•ӘШҜ\"\r\n *\r\n * в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ в•ӘШұ (в”ҳГ в•ӘШҙв”ҳВ„в•ӘВ» _components/):\r\n * - ProfileTab : в•ӘШІв•ӘШ°в”ҳГӘв”ҳГЁв•ӘШ° в•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в”ҳВҒ в•ӘШҜв”ҳВ„в•Әв”Өв•ӘВ«в•Әв•Ўв”ҳГЁ\r\n * - SettingsTabs: в•ӘШ°в•ӘШҜв”ҳГ©в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШ°в”ҳГӘв”ҳГЁв•ӘШ°в•ӘШҜв•ӘШІ (Social, Contact, Currency, Site, Home, Features)\r\n */\r\n\r\nimport { motion } from 'framer-motion';\r\nimport { Suspense, useState, useEffect } from 'react';\r\nimport { useSearchParams } from 'next/navigation';\r\nimport { ArrowLeft, User, Globe, Phone, DollarSign, Camera, LayoutDashboard, Shield, Megaphone } from 'lucide-react';\r\nimport Link from 'next/link';\r\nimport { cn } from '@/lib/utils';\r\nimport { useLanguage } from '@/lib/LanguageContext';\r\nimport { useAuth } from '@/lib/AuthContext';\r\nimport { api } from '@/lib/api';\r\nimport AdminPageShell from '@/components/AdminPageShell';\r\n\r\n// ШёВӨВҖШёВӨВҖ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГўв”ҳГӘв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГ©в•Әв”Ӯв”ҳГ в•ӘШұ ШёВӨВҖШёВӨВҖ\r\nimport ProfileTab from './_components/ProfileTab';\r\nimport { SocialTab, ContactTab, CurrencyTab, SiteTab, HomeTab, FeaturesTab, MarketingTab } from './_components/SettingsTabs';\r\nimport AdsTab from './_components/AdsTab';\r\n\r\n// ШёВӨВҖШёВӨВҖ в•ӘШ«в”ҳВҶв”ҳГӘв•ӘШҜв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШІв•ӘШ°в”ҳГӘв”ҳГЁв•ӘШ°в•ӘШҜв•ӘШІ ШёВӨВҖШёВӨВҖ\r\ntype TabID = 'profile' | 'security' | 'social' | 'contact' | 'currency' | 'site' | 'home' | 'features' | 'ads' | 'marketing';\r\n\r\n// ШёВӨВҖШёВӨВҖ в•ӘШ«в”ҳВҶв”ҳГӘв•ӘШҜв•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ ШёВӨВҖШёВӨВҖ\r\ninterface SocialLinks { whatsapp: string; instagram: string; twitter: string; facebook: string; youtube: string; tiktok: string; snapchat: string; telegram: string; linkedin: string; }\r\ninterface ContactInfo { phone: string; email: string; address: string; workingHours: string; }\r\ninterface CurrencySettings { usdToSar: number; usdToKrw: number; activeCurrency: string; partsMultiplier: number; auctionMultiplier: number; }\r\ninterface SiteInfo { siteName: string; siteDescription: string; logoUrl: string; faviconUrl: string; }\r\ninterface HomeContent { heroTitle: string; heroSubtitle: string; heroVideoUrl: string; }\r\ninterface Feature { icon: string; title: string; desc: string;[key: string]: string; }\r\n\r\nexport default function AdminSettings() {\r\n    return (\r\n        <Suspense fallback={<div className=\"min-h-screen bg-black text-white flex items-center justify-center font-black uppercase tracking-[0.5em] italic animate-pulse\">Synchronizing Matrix...</div>}>\r\n            <AdminSettingsContent />\r\n        </Suspense>\r\n    );\r\n}\r\n\r\nfunction AdminSettingsContent() {\r\n    const { isRTL } = useLanguage();\r\n    const { user, refreshUser } = useAuth();\r\n    const searchParams = useSearchParams();\r\n    const tabParam = searchParams.get('tab') as TabID;\r\n    const [activeTab, setActiveTab] = useState<TabID>('profile');\r\n\r\n    useEffect(() => {\r\n        const allowedTabs: TabID[] = ['profile', 'security', 'social', 'contact', 'currency', 'site', 'home', 'features', 'ads', 'marketing'];\r\n        if (tabParam && allowedTabs.includes(tabParam)) {\r\n            setActiveTab(tabParam);\r\n        }\r\n    }, [tabParam]);\r\n    const [loading, setLoading] = useState(false);\r\n    const [message, setMessage] = useState({ type: '', text: '' });\r\n\r\n    // ШёВӨВҖШёВӨВҖ в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в”ҳВҒ в•ӘШҜв”ҳВ„в•Әв”Өв•ӘВ«в•Әв•Ўв”ҳГЁ ШёВӨВҖШёВӨВҖ\r\n    const [profileData, setProfileData] = useState({\r\n        name: '', username: '', email: '', phone: '',\r\n        currentPassword: '', newPassword: '', confirmPassword: ''\r\n    });\r\n\r\n    // ШёВӨВҖШёВӨВҖ в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШ°в”ҳГӘв”ҳГЁв•ӘШ°в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ«в•Әв–’в”ҳГ« ШёВӨВҖШёВӨВҖ\r\n    const [socialLinks, setSocialLinks] = useState<SocialLinks>({ whatsapp: '', instagram: '', twitter: '', facebook: '', youtube: '', tiktok: '', snapchat: '', telegram: '', linkedin: '' });\r\n    const [contactInfo, setContactInfo] = useState<ContactInfo>({ phone: '', email: '', address: '', workingHours: '' });\r\n    const [currencySettings, setCurrencySettings] = useState<CurrencySettings>({ usdToSar: 3.75, usdToKrw: 1300, activeCurrency: 'SAR', partsMultiplier: 1.15, auctionMultiplier: 1.1 });\r\n    const [siteInfo, setSiteInfo] = useState<SiteInfo>({ siteName: 'HM CAR', siteDescription: '', logoUrl: '', faviconUrl: '' });\r\n    const [homeContent, setHomeContent] = useState<HomeContent>({ heroTitle: '', heroSubtitle: '', heroVideoUrl: '' });\r\n    const [features, setFeatures] = useState<Feature[]>([]);\r\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\r\n    const [marketingPixels, setMarketingPixels] = useState<any>({ googleAnalyticsId: '', metaPixelId: '', snapchatPixelId: '', tiktokPixelId: '' });\r\n\r\n    // ШёВӨВҖШёВӨВҖ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШІв•ӘШө ШёВӨВҖШёВӨВҖ\r\n    useEffect(() => {\r\n        loadSettings();\r\n        if (user) {\r\n            setProfileData(prev => ({ ...prev, name: user.name || '', username: user.username || '', email: user.email || '', phone: user.phone || '' }));\r\n        }\r\n    }, [user]);\r\n\r\n    // ШёВӨВҖШёВӨВҖ в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ  в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳВҖ API ШёВӨВҖШёВӨВҖ\r\n    const loadSettings = async () => {\r\n        try {\r\n            const response = await api.settings.getAll();\r\n            if (response.success) {\r\n                setSocialLinks(response.data.socialLinks || {});\r\n                setContactInfo(response.data.contactInfo || {});\r\n                if (response.data.currencySettings) setCurrencySettings(response.data.currencySettings);\r\n                if (response.data.siteInfo) setSiteInfo(response.data.siteInfo);\r\n                if (response.data.homeContent) setHomeContent(response.data.homeContent);\r\n                if (response.data.homeContent) setHomeContent(response.data.homeContent);\r\n                if (response.data.features) setFeatures(response.data.features || []);\r\n                if (response.data.marketingPixels) {\r\n                    setMarketingPixels({\r\n                        googleAnalyticsId: response.data.marketingPixels.googleAnalyticsId || '',\r\n                        metaPixelId: response.data.marketingPixels.metaPixelId || '',\r\n                        snapchatPixelId: response.data.marketingPixels.snapchatPixelId || '',\r\n                        tiktokPixelId: response.data.marketingPixels.tiktokPixelId || '',\r\n                    });\r\n                }\r\n            }\r\n        } catch (error) { console.error('в”ҳВҒв•Әв”Өв”ҳВ„ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ:', error); }\r\n    };\r\n\r\n    // ШёВӨВҖШёВӨВҖ в•ӘВ»в”ҳГӘв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШөв”ҳВҒв•Әв•• в”ҳВ„в”ҳГўв”ҳВ„ в”ҳГ©в•Әв”Ӯв”ҳГ  ШёВӨВҖШёВӨВҖ\r\n\r\n    const handleSaveProfile = async (silent = false) => {\r\n        if (!silent) { setLoading(true); setMessage({ type: '', text: '' }); }\r\n        try {\r\n            const response = await api.users.updateProfile({ name: profileData.name, username: profileData.username, email: profileData.email, phone: profileData.phone });\r\n            if (response.success && response.data) {\r\n                const currentUserStr = localStorage.getItem('hm_user');\r\n                if (currentUserStr) {\r\n                    localStorage.setItem('hm_user', JSON.stringify({ ...JSON.parse(currentUserStr), ...response.data }));\r\n                    refreshUser();\r\n                }\r\n            }\r\n            // в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШӯв”ҳВҶ в”ҳГӘв”ҳВҸв•ӘШҙв•ӘВ»в•ӘШІ\r\n            if (profileData.newPassword) {\r\n                if (profileData.newPassword !== profileData.confirmPassword) {\r\n                    setMessage({ type: 'error', text: isRTL ? 'в”ҳГўв”ҳВ„в”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШІв•Әв•–в•ӘШҜв•ӘШ°в”ҳГ©в•ӘШұ' : 'Passwords do not match' });\r\n                    setLoading(false); return;\r\n                }\r\n                if (!profileData.currentPassword) {\r\n                    if (!silent) setMessage({ type: 'error', text: isRTL ? 'в”ҳГЁв•ӘШҙв•ӘШ° в•ӘШӯв•ӘВ»в•ӘВ«в•ӘШҜв”ҳВ„ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ' : 'Current password required' });\r\n                    setLoading(false); return;\r\n                }\r\n                await api.auth.changePassword({ currentPassword: profileData.currentPassword, newPassword: profileData.newPassword });\r\n                setProfileData(prev => ({ ...prev, currentPassword: '', newPassword: '', confirmPassword: '' }));\r\n            }\r\n            if (!silent) setMessage({ type: 'success', text: isRTL ? 'в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө' : 'Profile saved successfully' });\r\n        } catch (error) {\r\n            if (!silent) setMessage({ type: 'error', text: (error as Error).message || 'Error saving profile' });\r\n        } finally { if (!silent) setLoading(false); }\r\n    };\r\n\r\n    const handleSaveSocialLinks = async (silent = false) => {\r\n        if (!silent) { setLoading(true); setMessage({ type: '', text: '' }); }\r\n        try {\r\n            // eslint-disable-next-line @typescript-eslint/no-explicit-any\r\n            await api.settings.updateSocialLinks({ socialLinks: socialLinks as any });\r\n            if (!silent) setMessage({ type: 'success', text: isRTL ? 'в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в•Әв–’в”ҳГӘв•ӘШҜв•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„' : 'Social links saved' });\r\n        } catch (error) {\r\n            if (!silent) setMessage({ type: 'error', text: (error as Error).message || 'Error saving' });\r\n        } finally { if (!silent) setLoading(false); }\r\n    };\r\n\r\n    const handleSaveContactInfo = async (silent = false) => {\r\n        if (!silent) { setLoading(true); setMessage({ type: '', text: '' }); }\r\n        try {\r\n            // eslint-disable-next-line @typescript-eslint/no-explicit-any\r\n            await api.settings.updateContactInfo({ contactInfo: contactInfo as any });\r\n            if (!silent) setMessage({ type: 'success', text: isRTL ? 'в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„' : 'Contact info saved' });\r\n        } catch (error) {\r\n            if (!silent) setMessage({ type: 'error', text: (error as Error).message || 'Error saving' });\r\n        } finally { if (!silent) setLoading(false); }\r\n    };\r\n\r\n    const handleSaveCurrencySettings = async (silent = false) => {\r\n        if (!silent) { setLoading(true); setMessage({ type: '', text: '' }); }\r\n        try {\r\n            // eslint-disable-next-line @typescript-eslint/no-explicit-any\r\n            await api.settings.updateCurrencySettings({ currencySettings: currencySettings as any });\r\n            if (!silent) setMessage({ type: 'success', text: isRTL ? 'в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳВ„в•ӘШұ' : 'Currency settings saved' });\r\n        } catch (error) {\r\n            if (!silent) setMessage({ type: 'error', text: (error as Error).message || 'Error saving' });\r\n        } finally { if (!silent) setLoading(false); }\r\n    };\r\n\r\n    const handleSaveSiteInfo = async (silent = false) => {\r\n        if (!silent) { setLoading(true); setMessage({ type: '', text: '' }); }\r\n        try {\r\n            // eslint-disable-next-line @typescript-eslint/no-explicit-any\r\n            await api.settings.updateSiteInfo({ siteInfo: siteInfo as any });\r\n            if (!silent) setMessage({ type: 'success', text: isRTL ? 'в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј' : 'Site info saved' });\r\n        } catch (error) {\r\n            if (!silent) setMessage({ type: 'error', text: (error as Error).message || 'Error saving' });\r\n        } finally { if (!silent) setLoading(false); }\r\n    };\r\n\r\n    const handleSaveHomeContent = async (silent = false) => {\r\n        if (!silent) { setLoading(true); setMessage({ type: '', text: '' }); }\r\n        try {\r\n            // eslint-disable-next-line @typescript-eslint/no-explicit-any\r\n            await api.settings.updateHomeContent({ homeContent: homeContent as any });\r\n            if (!silent) setMessage({ type: 'success', text: isRTL ? 'в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘШұ' : 'Home content saved' });\r\n        } catch (error) {\r\n            if (!silent) setMessage({ type: 'error', text: (error as Error).message || 'Error saving' });\r\n        } finally { if (!silent) setLoading(false); }\r\n    };\r\n\r\n    const handleSaveFeatures = async (silent = false) => {\r\n        if (!silent) { setLoading(true); setMessage({ type: '', text: '' }); }\r\n        try {\r\n            await api.settings.updateFeatures({ features });\r\n            if (!silent) setMessage({ type: 'success', text: isRTL ? 'в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в”ҳГ в”ҳГ в”ҳГЁв•Әв–“в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј' : 'Features saved' });\r\n        } catch (error) {\r\n            if (!silent) setMessage({ type: 'error', text: (error as Error).message || 'Error saving' });\r\n        } finally { if (!silent) setLoading(false); }\r\n    };\r\n\r\n    const handleSaveMarketingPixels = async (silent = false) => {\r\n        if (!silent) { setLoading(true); setMessage({ type: '', text: '' }); }\r\n        try {\r\n            await api.settings.updateSiteInfo({ \r\n                siteInfo: { \r\n                    ...siteInfo, \r\n                    marketingPixels: marketingPixels // в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘВ»в•ӘШ« в”ҳГ§в”ҳГӘ в•ӘШҜв”ҳВ„в•ӘШөв”ҳВҒв•Әв•• в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШҙв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШҜв”ҳГ  в”ҳВ„в”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ\r\n                } as any \r\n            });\r\n            if (!silent) setMessage({ type: 'success', text: isRTL ? 'в•ӘШІв”ҳГ  в•ӘШөв”ҳВҒв•Әв•• в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳВҖ Pixels' : 'Pixels config saved' });\r\n        } catch (error) {\r\n            if (!silent) setMessage({ type: 'error', text: (error as Error).message || 'Error saving' });\r\n        } finally { if (!silent) setLoading(false); }\r\n    };\r\n\r\n    // ШёВӨВҖШёВӨВҖ в•Әв–’в”ҳВҒв•Әв•Ј в•ӘШҜв”ҳВ„в•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’ ШёВӨВҖШёВӨВҖ\r\n    const handleLogoUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {\r\n        const file = e.target.files?.[0];\r\n        if (!file) return;\r\n        setLoading(true);\r\n        try {\r\n            const formData = new FormData();\r\n            formData.append('image', file);\r\n            const res = await api.upload.image(formData);\r\n            if (res.success) {\r\n                setSiteInfo(prev => ({ ...prev, logoUrl: res.url }));\r\n                setMessage({ type: 'success', text: isRTL ? 'в•ӘШІв”ҳГ  в•Әв–’в”ҳВҒв•Әв•Ј в•ӘШҜв”ҳВ„в•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’ в•ӘШ°в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө' : 'Logo uploaded successfully' });\r\n            }\r\n        } catch (error) {\r\n            setMessage({ type: 'error', text: (error as Error).message || 'Upload failed' });\r\n        } finally { setLoading(false); }\r\n    };\r\n\r\n    // ШёВӨВҖШёВӨВҖ в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШ°в”ҳГӘв”ҳГЁв•ӘШ°в•ӘШҜв•ӘШІ ШёВӨВҖШёВӨВҖ\r\n    const tabs = [\r\n        { id: 'profile', label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в”ҳВҒ в•ӘШҜв”ҳВ„в•Әв”Өв•ӘВ«в•Әв•Ўв”ҳГЁ' : 'Profile', icon: User },\r\n        { id: 'site', label: isRTL ? 'в”ҳГ§в”ҳГӘв”ҳГЁв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј' : 'Site Identity', icon: Camera },\r\n        { id: 'home', label: isRTL ? 'в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘШұ' : 'Home Content', icon: LayoutDashboard },\r\n        { id: 'social', label: isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШҙв•ӘШІв”ҳГ в•ӘШҜв•Әв•Јв”ҳГЁ' : 'Social Links', icon: Globe },\r\n        { id: 'contact', label: isRTL ? 'в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„' : 'Contact Info', icon: Phone },\r\n        { id: 'currency', label: isRTL ? 'в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳВ„в•ӘШұ' : 'Currency', icon: DollarSign },\r\n        { id: 'features', label: isRTL ? 'в”ҳВ„в”ҳГ в•ӘШҜв•Әв–‘в•ӘШҜ в•ӘШІв•ӘВ«в•ӘШІв•ӘШҜв•Әв–’в”ҳВҶв•ӘШҜ' : 'Features', icon: Shield },\r\n        // ШёВӨВҖШёВӨВҖ в•ӘШІв•ӘШ°в”ҳГӘв”ҳГЁв•ӘШ° в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв”ҳВ„в•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ» ШёВӨВҖШёВӨВҖ\r\n        { id: 'ads', label: isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв”ҳВ„в•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ' : 'Ads', icon: Megaphone },\r\n        { id: 'marketing', label: isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШІв•ӘШІв•ӘШ°в•Әв•Ј в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв”ҳГӘв”ҳГЁв”ҳГ©в”ҳГЁ' : 'Pixels', icon: Globe },\r\n    ];\r\n    return (\r\n        <AdminPageShell\r\n                title={isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ' : 'SETTINGS'}\r\n                titleEn=\"SYSTEM CONFIG\"\r\n                backHref=\"/admin/dashboard\"\r\n                isRTL={isRTL}\r\n            >\r\n                {/* в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в”ҳВҶв•ӘШҙв•ӘШҜв•ӘШө / в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ« */}\r\n                {message.text && (\r\n                    <motion.div initial={{ opacity: 0, y: -10 }} animate={{ opacity: 1, y: 0 }}\r\n                        className={cn('mb-8 p-4 rounded-xl border text-center',\r\n                            message.type === 'success'\r\n                                ? 'bg-emerald-500/10 border-emerald-500/30 text-emerald-400'\r\n                                : 'bg-cinematic-neon-red/10 border-cinematic-neon-red/30 text-cinematic-neon-red')}>\r\n                        <span className=\"text-sm font-bold\">{message.text}</span>\r\n                    </motion.div>\r\n                )}\r\n\r\n                {/* ШёВӨВҖШёВӨВҖШёВӨВҖ в•Әв”Өв•Әв–’в”ҳГЁв•Әв•– в•ӘШҜв”ҳВ„в•ӘШІв•ӘШ°в”ҳГӘв”ҳГЁв•ӘШ°в•ӘШҜв•ӘШІ ШёВӨВҖШёВӨВҖШёВӨВҖ */}\r\n                <div className=\"flex flex-wrap gap-2 mb-8 p-2 bg-white/5 rounded-2xl border border-white/5\">\r\n                        {tabs.map(tab => {\r\n                            const Icon = tab.icon;\r\n                            return (\r\n                                <button key={tab.id}\r\n                                    onClick={() => setActiveTab(tab.id as TabID)}\r\n                                    className={cn(\r\n                                        'flex-1 min-w-[80px] flex items-center justify-center gap-2 py-3 rounded-xl font-bold text-xs uppercase tracking-wider transition-all',\r\n                                        activeTab === tab.id\r\n                                            ? 'bg-cinematic-neon-red text-white shadow-lg'\r\n                                            : 'text-white/40 hover:text-white hover:bg-white/5'\r\n                                    )}>\r\n                                    <Icon className=\"w-3.5 h-3.5\" />\r\n                                    <span className=\"hidden sm:inline\">{tab.label}</span>\r\n                                </button>\r\n                            );\r\n                        })}\r\n                    </div>\r\n\r\n                    {/* ШёВӨВҖШёВӨВҖШёВӨВҖ в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв•ӘШ°в”ҳГӘв”ҳГЁв•ӘШ° в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘВ»в•ӘВ» ШёВӨВҖШёВӨВҖШёВӨВҖ */}\r\n\r\n                    {activeTab === 'profile' && (\r\n                        <ProfileTab\r\n                            profileData={profileData}\r\n                            loading={loading}\r\n                            isRTL={isRTL}\r\n                            onProfileChange={setProfileData}\r\n                            onSave={handleSaveProfile}\r\n                            onSilentSave={() => handleSaveProfile(true)}\r\n                        />\r\n                    )}\r\n\r\n                    {activeTab === 'social' && (\r\n                        <SocialTab\r\n                            socialLinks={socialLinks}\r\n                            loading={loading}\r\n                            isRTL={isRTL}\r\n                            onSave={handleSaveSocialLinks}\r\n                            onLinkChange={setSocialLinks}\r\n                            setMessage={setMessage}\r\n                        />\r\n                    )}\r\n\r\n                    {activeTab === 'contact' && (\r\n                        <ContactTab\r\n                            contactInfo={contactInfo}\r\n                            loading={loading}\r\n                            isRTL={isRTL}\r\n                            onSave={handleSaveContactInfo}\r\n                            onSilentSave={() => handleSaveContactInfo(true)}\r\n                            onContactChange={setContactInfo}\r\n                        />\r\n                    )}\r\n\r\n                    {activeTab === 'currency' && (\r\n                        <CurrencyTab\r\n                            currencySettings={currencySettings}\r\n                            loading={loading}\r\n                            isRTL={isRTL}\r\n                            onSave={handleSaveCurrencySettings}\r\n                            onSilentSave={() => handleSaveCurrencySettings(true)}\r\n                            onCurrencyChange={setCurrencySettings}\r\n                        />\r\n                    )}\r\n\r\n                    {activeTab === 'site' && (\r\n                        <SiteTab\r\n                            siteInfo={siteInfo}\r\n                            loading={loading}\r\n                            isRTL={isRTL}\r\n                            onSave={handleSaveSiteInfo}\r\n                            onSilentSave={() => handleSaveSiteInfo(true)}\r\n                            onSiteChange={setSiteInfo}\r\n                            onLogoUpload={handleLogoUpload}\r\n                        />\r\n                    )}\r\n\r\n                    {activeTab === 'home' && (\r\n                        <HomeTab\r\n                            homeContent={homeContent}\r\n                            loading={loading}\r\n                            isRTL={isRTL}\r\n                            onSave={handleSaveHomeContent}\r\n                            onSilentSave={() => handleSaveHomeContent(true)}\r\n                            onHomeChange={setHomeContent}\r\n                        />\r\n                    )}\r\n\r\n                    {activeTab === 'features' && (\r\n                        <FeaturesTab\r\n                            features={features}\r\n                            loading={loading}\r\n                            isRTL={isRTL}\r\n                            onSave={handleSaveFeatures}\r\n                            onFeaturesChange={setFeatures}\r\n                        />\r\n                    )}\r\n\r\n                    {/* ШёВӨВҖШёВӨВҖ в•ӘШІв•ӘШ°в”ҳГӘв”ҳГЁв•ӘШ° в•ӘШӯв•ӘВ»в•ӘШҜв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв”ҳВ„в•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ ШёВӨВҖШёВӨВҖ */}\r\n                    {activeTab === 'ads' && (\r\n                        <AdsTab isRTL={isRTL} />\r\n                    )}\r\n\r\n                    {activeTab === 'marketing' && (\r\n                        <MarketingTab\r\n                            marketingPixels={marketingPixels}\r\n                            loading={loading}\r\n                            isRTL={isRTL}\r\n                            onSave={handleSaveMarketingPixels}\r\n                            onSilentSave={() => handleSaveMarketingPixels(true)}\r\n                            onMarketingChange={setMarketingPixels}\r\n                        />\r\n                    )}\r\n\r\n            </AdminPageShell>\r\n        );\r\n    }\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\social\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'removeLink' is assigned a value but never used.","line":92,"column":9,"nodeType":"Identifier","messageId":"unusedVar","endLine":92,"endColumn":19}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport { useEffect, useState } from \"react\";\nimport { MessageCircle, Save, Trash2, CheckCircle2, SquarePen, ArrowLeft } from \"lucide-react\";\nimport { motion } from \"framer-motion\";\nimport Link from \"next/link\";\nimport { useLanguage } from \"@/lib/LanguageContext\";\nimport { cn } from \"@/lib/utils\";\nimport { getSocialIcon } from \"@/lib/socialIcons\";\nimport { api } from \"@/lib/api\";\n\n// Social config uses simple runtime-shape\n\nfunction AdminSocialSettings() {\n  const { t, isRTL } = useLanguage();\n  const [config, setConfig] = useState({ whatsapp: \"\", links: [] as Array<{ platform: string; url: string }> });\n  const [saved, setSaved] = useState(false);\n  const platforms = [\n    { key: 'whatsapp', label: 'WhatsApp' },\n    { key: 'instagram', label: 'Instagram' },\n    { key: 'twitter', label: 'X' },\n    { key: 'facebook', label: 'Facebook' },\n    { key: 'youtube', label: 'YouTube' },\n    { key: 'tiktok', label: 'TikTok' },\n    { key: 'snapchat', label: 'Snapchat' },\n    { key: 'telegram', label: 'Telegram' },\n    { key: 'linkedin', label: 'LinkedIn' },\n  ];\n\n  useEffect(() => {\n    const fetchLinks = async () => {\n      try {\n        const response = await api.settings.getAll();\n        if (response.success && response.data.socialLinks) {\n          const sl = response.data.socialLinks;\n          const linksArray = Object.entries(sl)\n            .filter(([k, v]) => k !== 'whatsapp' && v)\n            .map(([k, v]) => ({ platform: k, url: v as string }));\n\n          setConfig({\n            whatsapp: sl.whatsapp || \"\",\n            links: linksArray\n          });\n        }\n      } catch (err) {\n        console.error(\"Failed to fetch social links\", err);\n      }\n    };\n    fetchLinks();\n  }, []);\n\n  const handleSave = async () => {\n    try {\n      // Convert links array back to object for schema\n      const socialLinks: Record<string, string> = { whatsapp: config.whatsapp };\n      config.links.forEach(l => {\n        if (l.platform && l.url) {\n          socialLinks[l.platform.toLowerCase()] = l.url;\n        }\n      });\n\n      const response = await api.settings.updateSocialLinks({ socialLinks });\n      if (response.success) {\n        setSaved(true);\n        setTimeout(() => setSaved(false), 2000);\n      }\n    } catch (err) {\n      console.error(\"Failed to save social links\", err);\n    }\n  };\n\n  const addLink = () => {\n    setConfig(prev => ({ ...prev, links: [...prev.links, { platform: \"\", url: \"\" }] }));\n  };\n\n  const setPlatformUrl = (platformKey: string, url: string) => {\n    const key = platformKey.toLowerCase();\n    setConfig(prev => {\n      const next = [...prev.links];\n      const idx = next.findIndex(l => (l.platform || '').toLowerCase() === key);\n      if (idx >= 0) next[idx] = { ...next[idx], platform: key, url };\n      else next.push({ platform: key, url });\n      return { ...prev, links: next };\n    });\n  };\n\n  const removePlatformUrl = (platformKey: string) => {\n    const key = platformKey.toLowerCase();\n    setConfig(prev => ({ ...prev, links: prev.links.filter(l => (l.platform || '').toLowerCase() !== key) }));\n  };\n\n  const removeLink = (idx: number) => {\n    setConfig(prev => ({ ...prev, links: prev.links.filter((_, i) => i !== idx) }));\n  };\n\n  return (\n    <div className={cn(\"min-h-screen bg-black text-white px-6 sm:px-12 lg:px-20 py-24\")}>\n      <div className=\"max-w-4xl mx-auto space-y-10\">\n        \n        {/* Navigation HUD */}\n        <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-8 mb-16\">\n            <div className=\"flex items-center gap-8\">\n                <Link href=\"/admin/dashboard\">\n                    <motion.button\n                        whileHover={{ scale: 1.1, x: isRTL ? 5 : -5 }}\n                        whileTap={{ scale: 0.9 }}\n                        className=\"p-5 rounded-2xl bg-white/5 border border-white/10 hover:border-cinematic-neon-blue/40 hover:bg-cinematic-neon-blue/10 transition-all group shadow-2xl\"\n                    >\n                        <ArrowLeft className={cn(\n                            \"w-7 h-7 text-white/40 group-hover:text-cinematic-neon-blue transition-colors\",\n                            isRTL && \"rotate-180\"\n                        )} />\n                    </motion.button>\n                </Link>\n\n                <div>\n                    <div className=\"flex items-center gap-4 mb-2\">\n                        <div className=\"h-[2px] w-12 bg-cinematic-neon-blue shadow-[0_0_15px_rgba(0,150,255,1)]\" />\n                        <span className=\"text-[10px] font-black uppercase tracking-[0.5em] text-cinematic-neon-blue italic\">HQ Control Settings</span>\n                    </div>\n                    <h1 className=\"text-3xl md:text-5xl font-black uppercase tracking-[0.4em]\">\n                        {t('socialSettings')}\n                    </h1>\n                </div>\n            </div>\n        </div>\n\n        <div className=\"glass-card p-8 bg-white/[0.02] border border-white/10 rounded-2xl space-y-6\">\n          <label className=\"block text-[10px] font-black uppercase tracking-[0.4em] text-white/60 mb-2\">\n            {t('whatsappNumber')}\n          </label>\n          <input\n            type=\"tel\"\n            placeholder={isRTL ? \"в”ҳГ в•ӘШів•ӘШҜв”ҳВ„: +9665xxxxxxxx\" : \"+9665xxxxxxxx\"}\n            value={config.whatsapp || \"\"}\n            onChange={(e) => setConfig(prev => ({ ...prev, whatsapp: e.target.value }))}\n            className={cn(\"w-full bg-white/[0.04] border border-white/10 rounded-xl px-5 py-4 text-sm text-white focus:outline-none focus:border-cinematic-neon-blue/40\", isRTL ? \"text-right\" : \"text-left\")}\n          />\n        </div>\n\n        <div className=\"glass-card p-8 bg-white/[0.02] border border-white/10 rounded-2xl\">\n          <div className=\"flex items-center justify-between mb-6\">\n            <h2 className=\"text-[11px] font-black uppercase tracking-[0.6em]\">{t('socialLinks')}</h2>\n            <button\n              onClick={addLink}\n              className=\"px-4 py-2 rounded-xl bg-cinematic-neon-blue/20 text-cinematic-neon-blue border border-cinematic-neon-blue/30 text-[10px] font-black uppercase tracking-[0.3em]\"\n            >\n              {t('addLink')}\n            </button>\n          </div>\n\n          <div className=\"space-y-4\">\n            {platforms.map((p) => {\n              const Icon = getSocialIcon(p.key) as React.ComponentType<{ className?: string }>;\n              const val = (config.links.find(l => (l.platform || '').toLowerCase() === p.key) || {}).url || \"\";\n              return (\n                <div key={p.key} className=\"flex items-center gap-4 bg-white/[0.02] border border-white/10 rounded-xl p-4\">\n                  <div className=\"w-12 h-12 rounded-full bg-black/40 border border-white/10 flex items-center justify-center\">\n                    {Icon ? <Icon className=\"w-6 h-6 text-white/80\" /> : <MessageCircle className=\"w-6 h-6 text-white/60\" />}\n                  </div>\n                  <div className=\"flex-1\">\n                    <div className=\"text-sm font-black\">{p.label}</div>\n                    <input\n                      type=\"url\"\n                      placeholder={isRTL ? \"https://...\" : \"https://...\"}\n                      value={val}\n                      onChange={(e) => setPlatformUrl(p.key, e.target.value)}\n                      className={cn(\"mt-2 w-full bg-white/[0.04] border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-cinematic-neon-blue/40\", isRTL ? \"text-right\" : \"text-left\")}\n                    />\n                  </div>\n                  <div className=\"flex items-center gap-2\">\n                    <button\n                      className=\"px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white/60 hover:text-white hover:bg-white/10 transition-all flex items-center gap-1 text-[9px] font-black uppercase\"\n                    >\n                      <SquarePen className=\"w-3 h-3\" />\n                      {isRTL ? 'в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„' : 'EDIT'}\n                    </button>\n                    <button\n                      onClick={() => removePlatformUrl(p.key)}\n                      className=\"px-3 py-2 rounded-lg bg-cinematic-neon-red/10 text-cinematic-neon-red border border-cinematic-neon-red/20 hover:bg-cinematic-neon-red hover:text-white transition-all flex items-center gap-1 text-[9px] font-black uppercase\"\n                    >\n                      <Trash2 className=\"w-3 h-3\" />\n                      {isRTL ? 'в•ӘШөв•Әв–‘в”ҳВҒ' : 'REMOVE'}\n                    </button>\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        </div>\n\n        <div className=\"flex items-center gap-4\">\n          <button\n            onClick={handleSave}\n            className=\"flex items-center gap-3 px-6 py-3 rounded-xl bg-white text-black font-black uppercase tracking-[0.3em] hover:bg-cinematic-neon-blue hover:text-white transition-all\"\n          >\n            <Save className=\"w-5 h-5\" /> {t('saveChanges')}\n          </button>\n          {saved && (\n            <div className=\"flex items-center gap-2 text-cinematic-neon-blue\">\n              <CheckCircle2 className=\"w-5 h-5\" />\n              <span className=\"text-[10px] font-black uppercase tracking-[0.3em]\">OK</span>\n            </div>\n          )}\n        </div>\n\n        <div className=\"text-white/40 text-sm\">\n          <Link href=\"/social\" className=\"underline hover:text-white\">\n            {t('publicSocialPage')}\n          </Link>\n        </div>\n      </div>\n    </div>\n  )\n}\n\nexport default AdminSocialSettings;\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\system\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Shield' is defined but never used.","line":5,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":16,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Shield"},"fix":{"range":[109,116],"text":""},"desc":"Remove unused variable \"Shield\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Activity' is defined but never used.","line":5,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":26,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Activity"},"fix":{"range":[115,125],"text":""},"desc":"Remove unused variable \"Activity\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Server' is defined but never used.","line":5,"column":38,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":44,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Server"},"fix":{"range":[135,143],"text":""},"desc":"Remove unused variable \"Server\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'GitCommit' is defined but never used.","line":5,"column":53,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":62,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"GitCommit"},"fix":{"range":[150,161],"text":""},"desc":"Remove unused variable \"GitCommit\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport { useState, useEffect } from 'react';\nimport { motion } from 'framer-motion';\nimport { Shield, Activity, Database, Server, Clock, GitCommit, HardDrive, Zap, RefreshCw } from 'lucide-react';\nimport { cn } from '@/lib/utils';\nimport { fetchAPI } from '@/lib/api';\nimport AdminPageShell from '@/components/AdminPageShell';\n\nexport default function SystemAuditPage() {\n    const isRTL = true;\n    const [loading, setLoading] = useState(true);\n    const [health, setHealth] = useState<any>(null);\n\n    const fetchData = async () => {\n        setLoading(true);\n        try {\n            const [healthRes] = await Promise.all([\n                fetchAPI('/api/v2/system/health')\n            ]);\n            \n            if (healthRes.success) setHealth(healthRes.data);\n        } catch (error) {\n            console.error('Failed to fetch system audit data:', error);\n        } finally {\n            setLoading(false);\n        }\n    };\n\n    useEffect(() => {\n        fetchData();\n        const interval = setInterval(fetchData, 30000); // в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в”ҳГўв”ҳВ„ в”ҳВҶв•Әв•Ўв”ҳВҒ в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©в•ӘШұ\n        return () => clearInterval(interval);\n    }, []);\n\n    const formatBytes = (bytes: number) => {\n        if (!bytes) return '0 MB';\n        return `${bytes} MB`;\n    };\n\n    const formatUptime = (seconds: number) => {\n        const d = Math.floor(seconds / (3600*24));\n        const h = Math.floor(seconds % (3600*24) / 3600);\n        const m = Math.floor(seconds % 3600 / 60);\n        if (d > 0) return `${d} в”ҳГЁв”ҳГӘв”ҳГ  ${h} в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШұ`;\n        if (h > 0) return `${h} в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШұ ${m} в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©в•ӘШұ`;\n        return `${m} в•ӘВ»в”ҳГ©в”ҳГЁв”ҳГ©в•ӘШұ`;\n    };\n\n    return (\n        <div className=\"relative min-h-screen text-white overflow-x-hidden\" dir=\"rtl\">\n            <AdminPageShell\n                title=\"в”ҳВҒв•ӘШөв•Әв•Ў в•ӘШҜв”ҳВ„в”ҳВҶв•Әв••в•ӘШҜв”ҳГ  в•ӘШҜв”ҳВ„в•Әв”Өв•ӘШҜв”ҳГ в”ҳВ„\"\n                titleEn=\"SYSTEM AUDIT & HEALTH\"\n                backHref=\"/admin/dashboard\"\n                isRTL={isRTL}\n                actions={\n                    <button onClick={fetchData} className=\"flex items-center gap-2 bg-orange-500 hover:bg-orange-400 text-black px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest transition-all\">\n                        <RefreshCw className={cn('w-4 h-4', loading && 'animate-spin')} />\n                        в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\n                    </button>\n                }\n            >\n                {loading && !health ? (\n                    <div className=\"flex bg-white/5 border border-white/10 rounded-2xl p-8 items-center justify-center\">\n                        <RefreshCw className=\"w-8 h-8 text-orange-500 animate-spin\" />\n                    </div>\n                ) : (\n                    <div className=\"space-y-6\">\n                        {/* ШёВӨВҖШёВӨВҖ Status Grid ШёВӨВҖШёВӨВҖ */}\n                        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\n                            {/* Database */}\n                            <motion.div initial={{ y: 20, opacity: 0 }} animate={{ y: 0, opacity: 1 }} className=\"bg-white/5 border border-white/10 p-5 rounded-2xl relative overflow-hidden group\">\n                                <div className=\"absolute top-0 right-0 w-24 h-24 bg-blue-500/10 rounded-full blur-2xl group-hover:bg-blue-500/20 transition-all\" />\n                                <div className=\"flex items-start justify-between relative z-10\">\n                                    <div>\n                                        <p className=\"text-[10px] text-white/40 uppercase tracking-widest font-black mb-1\">в”ҳГ©в•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ</p>\n                                        <h3 className=\"text-lg font-bold text-white flex items-center gap-2\">\n                                            {health?.database?.state === 'Connected' ? 'в”ҳГ в•ӘШІв•Әв•Ўв”ҳВ„' : 'в”ҳГ в”ҳВҒв•Әв•Ўв”ҳГӘв”ҳВ„'}\n                                            <span className={cn('w-2 h-2 rounded-full', health?.database?.state === 'Connected' ? 'bg-green-500 shadow-[0_0_8px_#22c55e]' : 'bg-red-500')} />\n                                        </h3>\n                                        <p className=\"text-xs text-blue-400 mt-2 font-mono\">в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘШҙв•ӘШҜв•ӘШ°в•ӘШұ: {health?.database?.latencyMs}ms</p>\n                                    </div>\n                                    <div className=\"w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center border border-blue-500/20\">\n                                        <Database className=\"w-5 h-5 text-blue-400\" />\n                                    </div>\n                                </div>\n                            </motion.div>\n\n                            {/* Server Memory */}\n                            <motion.div initial={{ y: 20, opacity: 0 }} animate={{ y: 0, opacity: 1 }} transition={{ delay: 0.1 }} className=\"bg-white/5 border border-white/10 p-5 rounded-2xl relative overflow-hidden group\">\n                                <div className=\"absolute top-0 right-0 w-24 h-24 bg-purple-500/10 rounded-full blur-2xl group-hover:bg-purple-500/20 transition-all\" />\n                                <div className=\"flex items-start justify-between relative z-10\">\n                                    <div>\n                                        <p className=\"text-[10px] text-white/40 uppercase tracking-widest font-black mb-1\">в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳГ§в”ҳВ„в•ӘШҜв”ҳГў в•ӘШҜв”ҳВ„в•Әв–‘в•ӘШҜв”ҳГўв•Әв–’в•ӘШұ RAM</p>\n                                        <h3 className=\"text-lg font-bold text-white\">{health?.server?.memory?.usagePercent}%</h3>\n                                        <p className=\"text-[10px] text-purple-400 mt-2 font-mono\">\n                                            в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ : {formatBytes(health?.server?.memory?.usedMB)} / в”ҳГўв”ҳВ„в”ҳГЁ: {formatBytes(health?.server?.memory?.totalMB)}\n                                        </p>\n                                    </div>\n                                    <div className=\"w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center border border-purple-500/20\">\n                                        <HardDrive className=\"w-5 h-5 text-purple-400\" />\n                                    </div>\n                                </div>\n                            </motion.div>\n\n                            {/* Uptime */}\n                            <motion.div initial={{ y: 20, opacity: 0 }} animate={{ y: 0, opacity: 1 }} transition={{ delay: 0.2 }} className=\"bg-white/5 border border-white/10 p-5 rounded-2xl relative overflow-hidden group\">\n                                <div className=\"absolute top-0 right-0 w-24 h-24 bg-green-500/10 rounded-full blur-2xl group-hover:bg-green-500/20 transition-all\" />\n                                <div className=\"flex items-start justify-between relative z-10\">\n                                    <div>\n                                        <p className=\"text-[10px] text-white/40 uppercase tracking-widest font-black mb-1\">в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШІв•Әв”Өв•Әв•‘в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ«в•ӘШҜв•ӘВ»в”ҳГ </p>\n                                        <h3 className=\"text-lg font-bold text-white max-w-[120px] truncate\">{formatUptime(health?.server?.uptimeSeconds || 0)}</h3>\n                                        <p className=\"text-[10px] text-green-400 mt-2\">Node.js {health?.server?.nodeVersion}</p>\n                                    </div>\n                                    <div className=\"w-10 h-10 rounded-xl bg-green-500/10 flex items-center justify-center border border-green-500/20\">\n                                        <Clock className=\"w-5 h-5 text-green-400\" />\n                                    </div>\n                                </div>\n                            </motion.div>\n\n                            {/* Socket */}\n                            <motion.div initial={{ y: 20, opacity: 0 }} animate={{ y: 0, opacity: 1 }} transition={{ delay: 0.3 }} className=\"bg-white/5 border border-white/10 p-5 rounded-2xl relative overflow-hidden group\">\n                                <div className=\"absolute top-0 right-0 w-24 h-24 bg-amber-500/10 rounded-full blur-2xl group-hover:bg-amber-500/20 transition-all\" />\n                                <div className=\"flex items-start justify-between relative z-10\">\n                                    <div>\n                                        <p className=\"text-[10px] text-white/40 uppercase tracking-widest font-black mb-1\">в•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІв•Әв•Ўв•ӘШҜв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’ Socket.io</p>\n                                        <h3 className=\"text-lg font-bold text-white\">{health?.services?.socketIo === 'Active' ? 'в”ҳГЁв•Әв•Јв”ҳГ в”ҳВ„ в•ӘШ°в”ҳГўв”ҳВҒв•ӘШҜв•ӘШ©в•ӘШұ' : 'в”ҳГ в•ӘШІв”ҳГӘв”ҳГ©в”ҳВҒ'}</h3>\n                                        <p className=\"text-xs text-amber-400 mt-2 uppercase tracking-widest\">{health?.services?.socketIo}</p>\n                                    </div>\n                                    <div className=\"w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center border border-amber-500/20\">\n                                        <Zap className=\"w-5 h-5 text-amber-400\" />\n                                    </div>\n                                </div>\n                            </motion.div>\n                        </div>\n\n                        {/* API Routes Table Removed */}\n                    </div>\n                )}\n            </AdminPageShell>\n        </div>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\users\\_components\\PermissionsGrid.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\users\\_components\\UserModals.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\admin\\users\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\auctions\\[id]\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\auctions\\live\\[id]\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\auctions\\my-bids\\page.tsx","messages":[{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":189,"column":49,"nodeType":"JSXOpeningElement","endLine":193,"endColumn":51}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\nimport { motion, AnimatePresence } from \"framer-motion\";\r\nimport { useState, useEffect } from \"react\";\r\nimport {\r\n    Gavel, Trophy, Clock, XCircle, TrendingUp,\r\n    ChevronLeft, ChevronRight,\r\n    Flame\r\n} from \"lucide-react\";\r\nimport Navbar from \"@/components/Navbar\";\r\nimport { cn } from \"@/lib/utils\";\r\nimport { useLanguage } from \"@/lib/LanguageContext\";\r\nimport { useSettings } from \"@/lib/SettingsContext\";\r\nimport { api } from \"@/lib/api\";\r\nimport Link from \"next/link\";\r\n\r\ntype BidStatus = 'won' | 'lost' | 'active' | 'outbid';\r\n\r\ninterface MyBid {\r\n    id: string;\r\n    auction: {\r\n        id: string;\r\n        title: string;\r\n        image: string;\r\n        endDate: string;\r\n        basePrice: number;\r\n    };\r\n    myAmount: number;\r\n    currentHighest: number;\r\n    status: BidStatus;\r\n    bidTime: string;\r\n    totalBids: number;\r\n}\r\n\r\nexport default function MyBidsPage() {\r\n    const { isRTL } = useLanguage();\r\n    const { formatPrice } = useSettings();\r\n    const [bids, setBids] = useState<MyBid[]>([]);\r\n    const [loading, setLoading] = useState(true);\r\n    const [filter, setFilter] = useState<'all' | BidStatus>('all');\r\n\r\n    useEffect(() => {\r\n        loadBids();\r\n    }, []);\r\n\r\n    const loadBids = async () => {\r\n        try {\r\n            const res = await api.bids?.myBids?.();\r\n            if (res?.success) {\r\n                setBids(res.data);\r\n            } else throw new Error();\r\n        } catch (error) {\r\n            console.error(\"Failed to load bids\", error);\r\n            setBids([]);\r\n        } finally {\r\n            setLoading(false);\r\n        }\r\n    };\r\n\r\n    const filtered = filter === 'all' ? bids : bids.filter(b => b.status === filter);\r\n\r\n    const stats = {\r\n        total: bids.length,\r\n        won: bids.filter(b => b.status === 'won').length,\r\n        active: bids.filter(b => b.status === 'active').length,\r\n        outbid: bids.filter(b => b.status === 'outbid').length,\r\n        lost: bids.filter(b => b.status === 'lost').length,\r\n    };\r\n\r\n    const getStatusMeta = (status: BidStatus) => ({\r\n        won: { label: isRTL ? 'в”ҳВҒв•Әв–“в•ӘШІ' : 'WON', color: 'text-green-400', bg: 'bg-green-400/10 border-green-400/30', icon: Trophy },\r\n        active: { label: isRTL ? 'в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГў' : 'ACTIVE', color: 'text-cinematic-neon-blue', bg: 'bg-cinematic-neon-blue/10 border-cinematic-neon-blue/30', icon: Flame },\r\n        outbid: { label: isRTL ? 'в•ӘШІв”ҳГ  в•ӘШІв•ӘШҙв•ӘШҜв”ҳГӘв•Әв–“в”ҳГў' : 'OUTBID', color: 'text-cinematic-neon-yellow', bg: 'bg-cinematic-neon-yellow/10 border-cinematic-neon-yellow/30', icon: TrendingUp },\r\n        lost: { label: isRTL ? 'в•ӘВ«в•Әв”Ӯв•Әв–’в•ӘШІ' : 'LOST', color: 'text-cinematic-neon-red', bg: 'bg-cinematic-neon-red/10 border-cinematic-neon-red/30', icon: XCircle },\r\n    }[status]);\r\n\r\n    const formatCountdown = (dateStr: string) => {\r\n        const diff = new Date(dateStr).getTime() - Date.now();\r\n        if (diff <= 0) return isRTL ? 'в•ӘШҜв”ҳВҶв•ӘШІв”ҳГ§в”ҳГ«' : 'Ended';\r\n        const h = Math.floor(diff / 3600000);\r\n        const m = Math.floor((diff % 3600000) / 60000);\r\n        return `${h}h ${m}m`;\r\n    };\r\n\r\n    if (loading) {\r\n        return (\r\n            <div className=\"min-h-screen bg-black flex items-center justify-center\">\r\n                <motion.div animate={{ rotate: 360 }} transition={{ repeat: Infinity, duration: 1, ease: 'linear' }}\r\n                    className=\"w-14 h-14 border-4 border-cinematic-neon-red border-t-transparent rounded-full\" />\r\n            </div>\r\n        );\r\n    }\r\n\r\n    return (\r\n        <div className=\"relative min-h-screen bg-black text-white font-sans overflow-hidden\">\r\n            <Navbar />\r\n\r\n            <div className=\"fixed inset-0 pointer-events-none z-0\">\r\n                <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(255,0,60,0.05),_transparent_55%)]\" />\r\n                <div className=\"absolute inset-0 bg-[linear-gradient(rgba(255,0,60,0.01)_1px,transparent_1px),linear-gradient(90deg,rgba(255,0,60,0.01)_1px,transparent_1px)] bg-[size:80px_80px]\" />\r\n            </div>\r\n\r\n            <main className=\"relative z-10 pt-32 pb-24 px-6 max-w-6xl mx-auto\">\r\n\r\n                {/* Back */}\r\n                <motion.div initial={{ opacity: 0, x: -20 }} animate={{ opacity: 1, x: 0 }} className=\"mb-10\">\r\n                    <Link href=\"/auctions\" className=\"inline-flex items-center gap-3 text-white/40 hover:text-white transition-colors group\">\r\n                        {isRTL ? <ChevronRight className=\"w-5 h-5\" /> : <ChevronLeft className=\"w-5 h-5 group-hover:-translate-x-1 transition-transform\" />}\r\n                        <span className=\"text-[11px] font-black uppercase tracking-[0.3em]\">\r\n                            {isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ' : 'AUCTIONS'}\r\n                        </span>\r\n                    </Link>\r\n                </motion.div>\r\n\r\n                {/* Header */}\r\n                <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} className=\"mb-12\">\r\n                    <div className=\"flex items-center gap-5\">\r\n                        <div className=\"p-4 rounded-2xl bg-cinematic-neon-red/10 border border-cinematic-neon-red/20\">\r\n                            <Gavel className=\"w-8 h-8 text-cinematic-neon-red\" />\r\n                        </div>\r\n                        <div>\r\n                            <h1 className=\"text-4xl md:text-5xl font-black uppercase tracking-tighter\">\r\n                                {isRTL ? 'в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШҜв•ӘШІв”ҳГЁ' : 'MY BIDS'}\r\n                            </h1>\r\n                            <p className=\"text-white/40 text-[11px] uppercase tracking-[0.3em] mt-1 font-bold\">\r\n                                {isRTL ? 'в•Әв”Ӯв•ӘШҙв”ҳВ„ в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГўв•ӘШҜв•ӘШІв”ҳГў в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ' : 'YOUR AUCTION PARTICIPATION HISTORY'}\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n                </motion.div>\r\n\r\n                {/* Stats Row */}\r\n                <div className=\"grid grid-cols-2 md:grid-cols-5 gap-4 mb-10\">\r\n                    {[\r\n                        { key: 'all', label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГўв”ҳВ„' : 'ALL', value: stats.total, color: 'text-white' },\r\n                        { key: 'won', label: isRTL ? 'в”ҳВҒв•Әв–“в•ӘШІ' : 'WON', value: stats.won, color: 'text-green-400' },\r\n                        { key: 'active', label: isRTL ? 'в”ҳГ в•Әв”Өв•ӘШҜв•Әв–’в”ҳГў' : 'ACTIVE', value: stats.active, color: 'text-cinematic-neon-blue' },\r\n                        { key: 'outbid', label: isRTL ? 'в•ӘШІв•ӘШҙв•ӘШҜв”ҳГӘв•Әв–“в”ҳГӘв”ҳГў' : 'OUTBID', value: stats.outbid, color: 'text-cinematic-neon-yellow' },\r\n                        { key: 'lost', label: isRTL ? 'в•ӘВ«в•Әв”Ӯв•Әв–’в•ӘШІ' : 'LOST', value: stats.lost, color: 'text-cinematic-neon-red' },\r\n                    ].map((s) => (\r\n                        <motion.button\r\n                            key={s.key}\r\n                            onClick={() => setFilter(s.key as any)}\r\n                            whileHover={{ scale: 1.05 }} whileTap={{ scale: 0.95 }}\r\n                            className={cn(\r\n                                \"glass-card p-6 bg-white/[0.01] border-white/5 text-center transition-all\",\r\n                                filter === s.key && \"border-cinematic-neon-red/30 bg-cinematic-neon-red/5\"\r\n                            )}\r\n                        >\r\n                            <div className={cn(\"text-3xl font-black tracking-tighter mb-2\", s.color)}>{s.value}</div>\r\n                            <div className=\"text-[9px] font-black uppercase tracking-[0.3em] text-white/50\">{s.label}</div>\r\n                        </motion.button>\r\n                    ))}\r\n                </div>\r\n\r\n                {/* Bids List */}\r\n                <AnimatePresence mode=\"popLayout\">\r\n                    {filtered.length === 0 ? (\r\n                        <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} className=\"text-center py-32\">\r\n                            <Gavel className=\"w-24 h-24 text-white/10 mx-auto mb-8\" />\r\n                            <h3 className=\"text-2xl font-black uppercase tracking-tight text-white/40\">\r\n                                {isRTL ? 'в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШҜв•ӘШІ' : 'NO BIDS FOUND'}\r\n                            </h3>\r\n                        </motion.div>\r\n                    ) : (\r\n                        <div className=\"space-y-6\">\r\n                            {filtered.map((bid, i) => {\r\n                                const meta = getStatusMeta(bid.status);\r\n                                const StatusIcon = meta.icon;\r\n                                const isLeading = bid.myAmount >= bid.currentHighest && bid.status === 'active';\r\n                                return (\r\n                                    <motion.div\r\n                                        key={bid.id}\r\n                                        layout\r\n                                        initial={{ opacity: 0, y: 30 }}\r\n                                        animate={{ opacity: 1, y: 0 }}\r\n                                        exit={{ opacity: 0, y: -20 }}\r\n                                        transition={{ delay: i * 0.08 }}\r\n                                        className={cn(\r\n                                            \"glass-card bg-white/[0.01] border-white/5 overflow-hidden hover:border-white/10 transition-all\",\r\n                                            bid.status === 'won' && \"border-green-400/20 shadow-[0_0_30px_rgba(74,222,128,0.08)]\",\r\n                                            bid.status === 'outbid' && \"border-cinematic-neon-yellow/10\",\r\n                                        )}\r\n                                    >\r\n                                        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-0\">\r\n\r\n                                            {/* Image */}\r\n                                            <div className=\"lg:col-span-3 relative overflow-hidden h-52 lg:h-auto\">\r\n                                                <img\r\n                                                    src={bid.auction.image}\r\n                                                    alt={bid.auction.title}\r\n                                                    className=\"w-full h-full object-cover grayscale-[20%] hover:grayscale-0 transition-all duration-700\"\r\n                                                />\r\n                                                <div className=\"absolute inset-0 bg-gradient-to-t lg:bg-gradient-to-r from-black/60 to-transparent\" />\r\n                                                {bid.status === 'won' && (\r\n                                                    <div className=\"absolute top-4 left-4 bg-green-400 text-black px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-widest flex items-center gap-2\">\r\n                                                        <Trophy className=\"w-3 h-3\" />\r\n                                                        {isRTL ? 'в”ҳВҒв•ӘШҜв•ӘШ®в•Әв–“!' : 'WINNER!'}\r\n                                                    </div>\r\n                                                )}\r\n                                                {bid.status === 'outbid' && (\r\n                                                    <div className=\"absolute top-4 left-4 bg-cinematic-neon-yellow text-black px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-widest\">\r\n                                                        {isRTL ? 'в•ӘШІв•ӘШҙв•ӘШҜв”ҳГӘв•Әв–“в”ҳГӘв”ҳГў!' : 'OUTBID!'}\r\n                                                    </div>\r\n                                                )}\r\n                                            </div>\r\n\r\n                                            {/* Info */}\r\n                                            <div className=\"lg:col-span-9 p-8 flex flex-col justify-between gap-6\">\r\n                                                <div className=\"flex flex-wrap items-start justify-between gap-4\">\r\n                                                    <div>\r\n                                                        <h3 className=\"text-xl md:text-2xl font-black uppercase italic tracking-tighter mb-2\">\r\n                                                            {bid.auction.title}\r\n                                                        </h3>\r\n                                                        <div className=\"flex items-center gap-3 flex-wrap\">\r\n                                                            <span className=\"text-[10px] font-black text-white/30 uppercase tracking-widest\">\r\n                                                                <Clock className=\"w-3 h-3 inline mr-1\" />\r\n                                                                {formatCountdown(bid.auction.endDate)}\r\n                                                            </span>\r\n                                                            <span className=\"text-white/20\">в”¬в•–</span>\r\n                                                            <span className=\"text-[10px] font-black text-white/30 uppercase tracking-widest\">\r\n                                                                {bid.totalBids} {isRTL ? 'в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШұ' : 'bids'}\r\n                                                            </span>\r\n                                                        </div>\r\n                                                    </div>\r\n                                                    <div className={cn(\r\n                                                        \"px-4 py-2 rounded-xl border flex items-center gap-2 text-[11px] font-black uppercase tracking-wider\",\r\n                                                        meta.bg, meta.color\r\n                                                    )}>\r\n                                                        <StatusIcon className=\"w-4 h-4\" />\r\n                                                        {meta.label}\r\n                                                    </div>\r\n                                                </div>\r\n\r\n                                                {/* Bid amounts */}\r\n                                                <div className=\"grid grid-cols-2 md:grid-cols-3 gap-6\">\r\n                                                    <div>\r\n                                                        <div className=\"text-[9px] font-black text-white/30 uppercase tracking-[0.3em] mb-1\">\r\n                                                            {isRTL ? 'в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШІв”ҳГЁ' : 'MY BID'}\r\n                                                        </div>\r\n                                                        <div className={cn(\r\n                                                            \"text-2xl font-black italic\",\r\n                                                            isLeading ? \"text-green-400\" : \"text-white\"\r\n                                                        )}>\r\n                                                            {formatPrice ? formatPrice(Number(bid.myAmount)) : `${Number(bid.myAmount).toLocaleString()} SAR`}\r\n                                                        </div>\r\n                                                    </div>\r\n                                                    <div>\r\n                                                        <div className=\"text-[9px] font-black text-white/30 uppercase tracking-[0.3em] mb-1\">\r\n                                                            {isRTL ? 'в•ӘШ«в•Әв•Јв”ҳВ„в”ҳГ« в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШұ' : 'HIGHEST BID'}\r\n                                                        </div>\r\n                                                        <div className=\"text-2xl font-black italic text-cinematic-neon-blue\">\r\n                                                            {formatPrice ? formatPrice(Number(bid.currentHighest)) : `${Number(bid.currentHighest).toLocaleString()} SAR`}\r\n                                                        </div>\r\n                                                    </div>\r\n                                                    <div>\r\n                                                        <div className=\"text-[9px] font-black text-white/30 uppercase tracking-[0.3em] mb-1\">\r\n                                                            {isRTL ? 'в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШұ' : 'BID TIME'}\r\n                                                        </div>\r\n                                                        <div className=\"text-sm font-bold text-white/60\">\r\n                                                            {new Date(bid.bidTime).toLocaleString(isRTL ? 'ar-SA' : 'en-US', {\r\n                                                                month: 'short', day: 'numeric',\r\n                                                                hour: '2-digit', minute: '2-digit'\r\n                                                            })}\r\n                                                        </div>\r\n                                                    </div>\r\n                                                </div>\r\n\r\n                                                {/* Difference bar (outbid) */}\r\n                                                {bid.status === 'outbid' && (\r\n                                                    <div className=\"space-y-2\">\r\n                                                        <div className=\"flex justify-between text-[9px] font-black text-white/30 uppercase tracking-widest\">\r\n                                                            <span>{isRTL ? 'в•ӘШ«в”ҳВҶв•ӘШІ в”ҳГ в•ӘШІв•ӘШ«в•ӘВ«в•Әв–’ в•ӘШ°в”ҳВҖ:' : 'You are behind by:'}</span>\r\n                                                            <span className=\"text-cinematic-neon-yellow\">\r\n                                                                {formatPrice ? formatPrice(Number(bid.currentHighest - bid.myAmount)) : `${(bid.currentHighest - bid.myAmount).toLocaleString()} SAR`}\r\n                                                            </span>\r\n                                                        </div>\r\n                                                        <div className=\"h-1.5 bg-white/5 rounded-full overflow-hidden\">\r\n                                                            <div\r\n                                                                className=\"h-full bg-cinematic-neon-yellow rounded-full transition-all duration-700\"\r\n                                                                data-width={Math.min((bid.myAmount / bid.currentHighest) * 100, 100)}\r\n                                                            />\r\n                                                        </div>\r\n                                                    </div>\r\n                                                )}\r\n\r\n                                                {/* CTA */}\r\n                                                <div className=\"flex gap-4 flex-wrap\">\r\n                                                    {bid.status === 'outbid' && (\r\n                                                        <Link href={`/auctions/${bid.auction.id}`}>\r\n                                                            <motion.button\r\n                                                                whileHover={{ scale: 1.05 }} whileTap={{ scale: 0.95 }}\r\n                                                                className=\"px-6 py-3 bg-cinematic-neon-red/10 border border-cinematic-neon-red/30 text-cinematic-neon-red rounded-xl text-[11px] font-black uppercase tracking-wide hover:bg-cinematic-neon-red/20 transition-all\"\r\n                                                            >\r\n                                                                {isRTL ? 'ШёШЈШ© в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ» в”ҳГ в•ӘШҙв•ӘВ»в•ӘВ»в•ӘШҜв”ҳГҜ' : 'ШёШЈШ© BID AGAIN'}\r\n                                                            </motion.button>\r\n                                                        </Link>\r\n                                                    )}\r\n                                                    {bid.status === 'active' && (\r\n                                                        <Link href={`/auctions/${bid.auction.id}`}>\r\n                                                            <motion.button\r\n                                                                whileHover={{ scale: 1.05 }} whileTap={{ scale: 0.95 }}\r\n                                                                className=\"px-6 py-3 bg-cinematic-neon-blue/10 border border-cinematic-neon-blue/30 text-cinematic-neon-blue rounded-xl text-[11px] font-black uppercase tracking-wide hover:bg-cinematic-neon-blue/20 transition-all\"\r\n                                                            >\r\n                                                                {isRTL ? 'в”ҳГ в•ӘШІв•ӘШҜв•ӘШ°в•Әв•Јв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»' : 'VIEW AUCTION'}\r\n                                                            </motion.button>\r\n                                                        </Link>\r\n                                                    )}\r\n                                                    {bid.status === 'won' && (\r\n                                                        <Link href=\"/orders\">\r\n                                                            <motion.button\r\n                                                                whileHover={{ scale: 1.05 }} whileTap={{ scale: 0.95 }}\r\n                                                                className=\"px-6 py-3 bg-green-400/10 border border-green-400/30 text-green-400 rounded-xl text-[11px] font-black uppercase tracking-wide hover:bg-green-400/20 transition-all\"\r\n                                                            >\r\n                                                                {isRTL ? 'вүЎШ§ГҙШ® в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ°' : 'вүЎШ§ГҙШ® VIEW ORDER'}\r\n                                                            </motion.button>\r\n                                                        </Link>\r\n                                                    )}\r\n                                                </div>\r\n                                            </div>\r\n                                        </div>\r\n                                    </motion.div>\r\n                                );\r\n                            })}\r\n                        </div>\r\n                    )}\r\n                </AnimatePresence>\r\n\r\n            </main>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\auctions\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Link' is defined but never used.","line":20,"column":8,"nodeType":"Identifier","messageId":"unusedVar","endLine":20,"endColumn":12,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Link"},"fix":{"range":[674,703],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":168,"column":53,"nodeType":"JSXOpeningElement","endLine":173,"endColumn":55},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":228,"column":53,"nodeType":"JSXOpeningElement","endLine":233,"endColumn":55}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\n/**\r\n * в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ (Auctions Page)\r\n * в•ӘШІв•Әв•Јв•Әв–’в•Әв•ў в•ӘШҙв”ҳГ в”ҳГЁв•Әв•Ј в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШІв•ӘШҜв•ӘШөв•ӘШұ в”ҳВ„в”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ .\r\n * в•ӘШІв”ҳВҶв”ҳГ©в•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШҙв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШІ в•ӘШӯв”ҳВ„в”ҳГ«:\r\n * 1. в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’ (LIVE): в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШІв•ӘШҙв•Әв–’в”ҳГЁ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в•ӘШІ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁ.\r\n * 2. в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в•Әв•ў (SHOWROOM): в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в”ҳГ в•Әв•Јв•Әв–’в”ҳГӘв•Әв•ўв•ӘШұ в”ҳВ„в”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв”ҳГЁв•ӘВ»в•ӘШұ в”ҳГЁв•ӘВ»в”ҳГӘв”ҳГЁв•ӘШҜв”ҳГҜ.\r\n * 3. в”ҳГ©в•ӘШҜв•ӘВ»в”ҳГ в•ӘШұ (UPCOMING): в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•Әв”Ӯв•ӘШІв•ӘШ°в•ӘВ»в•ӘШ« в”ҳГ©в•Әв–’в”ҳГЁв•ӘШ°в•ӘШҜв”ҳГҜ.\r\n */\r\n\r\nimport { motion, AnimatePresence } from \"framer-motion\";\r\nimport { useState, useEffect } from \"react\";\r\nimport { Gavel, AlertCircle, Radio, Car } from \"lucide-react\";\r\nimport Navbar from \"@/components/Navbar\";\r\nimport { cn } from \"@/lib/utils\";\r\nimport { useLanguage } from \"@/lib/LanguageContext\";\r\nimport { api } from \"@/lib/api\";\r\nimport { useSettings } from \"@/lib/SettingsContext\";\r\nimport Link from \"next/link\";\r\nimport { useAuth } from \"@/lib/AuthContext\";\r\nimport { useRouter } from \"next/navigation\";\r\nimport ClientPageHeader from \"@/components/ClientPageHeader\";\r\n\r\nexport default function Auctions() {\r\n    const router = useRouter();\r\n    const { isRTL } = useLanguage();\r\n    const { formatPrice } = useSettings();\r\n    const { isLoggedIn } = useAuth();\r\n    const [activeTab, setActiveTab] = useState('LIVE');\r\n    const [auctions, setAuctions] = useState<any[]>([]);\r\n    const [loading, setLoading] = useState(true);\r\n    const [imageErrors, setImageErrors] = useState<Record<string, boolean>>({});\r\n\r\n    const normalizeImage = (src?: string) => (typeof src === 'string' ? src.trim() : '');\r\n\r\n    useEffect(() => {\r\n        // в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШ°в”ҳВҶв•ӘШҜв•ӘШ©в”ҳГҜ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•ӘШІв•ӘШ°в”ҳГӘв”ҳГЁв•ӘШ° в•ӘШҜв”ҳВ„в”ҳГ в•ӘВ«в•ӘШІв•ӘШҜв•Әв–’ (LIVE, SHOWROOM, UPCOMING)\r\n        const loadData = async () => {\r\n            setLoading(true);\r\n            try {\r\n                if (activeTab === 'SHOWROOM') {\r\n                    // в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГЁв•ӘВ»в”ҳГӘв”ҳГЁв•ӘШұ в”ҳГ в”ҳВҶ в”ҳГ©в•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\r\n                    const data = await api.liveAuctions.list();\r\n                    if (data.success) setAuctions(data.data || []);\r\n                } else {\r\n                    // в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•Ўв•ӘШөв”ҳГЁв•ӘШөв•ӘШұ в”ҳВ„в”ҳВ„в”ҳВҖ API: 'live' в”ҳВ„в”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’ в”ҳГӘ 'upcoming' в”ҳВ„в”ҳВ„в”ҳГ©в•ӘШҜв•ӘВ»в”ҳГ \r\n                    const status = activeTab === 'LIVE' ? 'live' : 'upcoming';\r\n                    const data = await api.auctions.list({ status });\r\n                    if (data.success) setAuctions(data.data || []);\r\n                }\r\n\r\n            } catch (err) {\r\n                console.error(\"Failed to load data\", err);\r\n            } finally {\r\n                setLoading(false);\r\n            }\r\n        };\r\n        loadData();\r\n    }, [activeTab]);\r\n\r\n    return (\r\n        <div className={`relative min-h-screen bg-black text-white overflow-x-hidden ${isRTL ? 'font-arabic' : ''}`} dir={isRTL ? 'rtl' : 'ltr'}>\r\n            <Navbar />\r\n\r\n            <div className=\"pt-24 px-6 max-w-[1500px] mx-auto\">\r\n                <ClientPageHeader\r\n                    title={isRTL ? \"в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ\" : \"AUCTIONS\"}\r\n                    subtitle={activeTab === 'SHOWROOM' ? (isRTL ? \"в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’\" : \"LIVE SHOWROOM\") : (isRTL ? \"в•ӘШ°в•ӘШі в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’\" : \"LIVE FEED\")}\r\n                    icon={Gavel}\r\n                />\r\n            </div>\r\n\r\n            {/* ШёВӨВҖШёВӨВҖ VIDEO HERO ШёВӨВҖШёВӨВҖ */}\r\n            <div className=\"relative h-[85vh] 