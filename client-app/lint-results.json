\n        setCars((carsRes?.cars || []).filter((c: any) => String(c.make || c.title || '').toLowerCase().includes(String(brandName).toLowerCase())));\n        setParts((partsRes?.parts || []).filter((p: any) => String(p.brand || '').toLowerCase().includes(String(brandName).toLowerCase())));\n      } catch {\n      } finally {\n        setLoading(false);\n      }\n    })();\n  }, [params.key]);\n\n  return (\n    <div className=\"relative min-h-screen bg-black text-white overflow-hidden\">\n      <Navbar />\n      <main className=\"relative z-10 pt-24 pb-24 px-6 max-w-[1600px] mx-auto\">\n        <header className=\"mb-12 flex items-center gap-4\">\n          {brand?.logoUrl && (\n            <div className=\"w-12 h-12 rounded-xl border border-white/10 overflow-hidden\">\n              <img src={brand.logoUrl} alt={brand.name} className=\"w-full h-full object-cover\" />\n            </div>\n          )}\n          <h1 className=\"text-4xl md:text-5xl font-black uppercase tracking-tight\">\n            {brand?.name || params.key}\n          </h1>\n        </header>\n\n        {loading ? (\n          <div className=\"min-h-[40vh] flex items-center justify-center text-white/40\">\n            {isRTL ? 'в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„...' : 'Loading...'}\n          </div>\n        ) : (\n          <>\n            <section className=\"mb-16\">\n              <div className=\"flex items-center justify-between mb-4\">\n                <h2 className=\"text-2xl font-black uppercase\">{isRTL ? 'в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ' : 'Cars'}</h2>\n                <Link href=\"/showroom\" className=\"text-[10px] font-black uppercase tracking-[0.3em] text-white/60 hover:text-white flex items-center gap-1\">\n                  {isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в•Әв•ў' : 'Showroom'} <ArrowRight className={`w-4 h-4 ${isRTL ? 'rotate-180' : ''}`} />\n                </Link>\n              </div>\n              {cars.length === 0 ? (\n                <div className=\"text-white/30\">{isRTL ? 'в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в”ҳВ„в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•Әв–’в”ҳГўв•ӘШұ' : 'No cars for this brand'}</div>\n              ) : (\n                <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n                  <AnimatePresence mode=\"popLayout\">\n                    {cars.map((car, i) => (\n                      <motion.div key={car.id || car._id || i} initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0 }} transition={{ delay: i * 0.05 }}>\n                        <div className=\"group obsidian-card obsidian-card-hover h-full overflow-hidden\">\n                          <div className=\"relative h-56\">\n                            {(() => {\n                              const imageKey = `car-${car.id || car._id || i}`;\n                              const imageSrc = resolveCarImage(car);\n                              const showFallback = !imageSrc || imageErrors[imageKey];\n                              return showFallback ? (\n                                <div className=\"w-full h-full flex items-center justify-center bg-gradient-to-br from-white/5 via-black/40 to-black/80\">\n                                  <Car className=\"w-10 h-10 text-white/20\" />\n                                </div>\n                              ) : (\n                                <img\n                                  src={imageSrc}\n                                  alt={car.title}\n                                  className=\"w-full h-full object-cover grayscale-[30%] group-hover:grayscale-0 transition-all duration-700\"\n                                  onError={() => setImageErrors(prev => ({ ...prev, [imageKey]: true }))}\n                                />\n                              );\n                            })()}\n                            <div className=\"absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent\" />\n                          </div>\n                          <div className=\"p-6\">\n                            <div className=\"text-[9px] font-black text-white/50 uppercase tracking-[0.3em] mb-1\">{car.make}</div>\n                            <h3 className=\"text-lg font-black line-clamp-1\">{car.title}</h3>\n                            <div className=\"text-xl font-black text-[#c9a96e] italic mt-3\">\n                              {formatPrice(Number(car.price || car.priceSar || 0))}\n                            </div>\n                          </div>\n                        </div>\n                      </motion.div>\n                    ))}\n                  </AnimatePresence>\n                </div>\n              )}\n            </section>\n\n            <section>\n              <div className=\"flex items-center justify_between mb-4\">\n                <h2 className=\"text-2xl font-black uppercase\">{isRTL ? 'в”ҳГ©в•Әв•–в•Әв•Ј в•ӘШҜв”ҳВ„в•Әв•‘в”ҳГЁв•ӘШҜв•Әв–’' : 'Spare Parts'}</h2>\n                <Link href=\"/parts\" className=\"text-[10px] font-black uppercase tracking-[0.3em] text-white/60 hover:text-white flex items-center gap-1\">\n                  {isRTL ? 'в”ҳГ©в•Әв•–в•Әв•Ј в•ӘШҜв”ҳВ„в•Әв•‘в”ҳГЁв•ӘШҜв•Әв–’' : 'Parts'} <ArrowRight className={`w-4 h-4 ${isRTL ? 'rotate-180' : ''}`} />\n                </Link>\n              </div>\n              {parts.length === 0 ? (\n                <div className=\"text-white/30\">{isRTL ? 'в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в”ҳГ©в•Әв•–в•Әв•Ј в”ҳВ„в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•Әв–’в”ҳГўв•ӘШұ' : 'No parts for this brand'}</div>\n              ) : (\n                <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n                  <AnimatePresence mode=\"popLayout\">\n                    {parts.map((part, i) => (\n                      <motion.div key={part.id || part._id || i} initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0 }} transition={{ delay: i * 0.05 }}>\n                        <div className=\"group obsidian-card obsidian-card-hover p-6 h-full\">\n                          <div className=\"aspect-square bg-black/40 rounded-xl overflow-hidden mb-6 border border-white/5 relative group-hover:border-accent-gold/20 transition-colors\">\n                            {(() => {\n                              const imageKey = `part-${part.id || part._id || i}`;\n                              const imageSrc = resolvePartImage(part);\n                              const showFallback = !imageSrc || imageErrors[imageKey];\n                              return showFallback ? (\n                                <div className=\"w-full h-full flex items-center justify-center bg-gradient-to-br from-white/5 via-black/40 to-black/80\">\n                                  <Package className=\"w-10 h-10 text-white/20\" />\n                                </div>\n                              ) : (\n                                <img\n                                  src={imageSrc}\n                                  alt={part.name}\n                                  className=\"w-full h-full object-contain p-6 grayscale-[40%] opacity-60 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-110 transition-all duration-700\"\n                                  onError={() => setImageErrors(prev => ({ ...prev, [imageKey]: true }))}\n                                />\n                              );\n                            })()}\n                          </div>\n                          <div>\n                            <div className=\"text-[8px] font-bold uppercase tracking-[0.2em] text-white/50 mb-1\">{part.brand}</div>\n                            <h3 className=\"text-base font-black line-clamp-2\">{part.name}</h3>\n                          </div>\n                        </div>\n                      </motion.div>\n                    ))}\n                  </AnimatePresence>\n                </div>\n              )}\n            </section>\n          </>\n        )}\n      </main>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\brands\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\cars\\[id]\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\cars\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'getCarMakeLabel' is assigned a value but never used.","line":20,"column":7,"nodeType":"Identifier","messageId":"unusedVar","endLine":20,"endColumn":22},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'formatPrice' is assigned a value but never used.","line":54,"column":13,"nodeType":"Identifier","messageId":"unusedVar","endLine":54,"endColumn":24},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'total' is assigned a value but never used.","line":60,"column":12,"nodeType":"Identifier","messageId":"unusedVar","endLine":60,"endColumn":17},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'imageErrors' is assigned a value but never used.","line":63,"column":12,"nodeType":"Identifier","messageId":"unusedVar","endLine":63,"endColumn":23},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'setImageErrors' is assigned a value but never used.","line":63,"column":25,"nodeType":"Identifier","messageId":"unusedVar","endLine":63,"endColumn":39},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'resolveCarImage' is assigned a value but never used.","line":140,"column":11,"nodeType":"Identifier","mess