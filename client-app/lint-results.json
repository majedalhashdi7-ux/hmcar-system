ems-center gap-4 px-8 py-4 bg-white/5 rounded-2xl border border-white/10 shrink-0\">\n            <Clock className=\"w-5 h-5 text-cinematic-neon-blue\" />\n            <div className=\"text-right\">\n              <div className=\"text-[10px] font-black text-white/40 uppercase tracking-widest\">{isRTL ? 'в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳВ„' : 'WORKING HOURS'}</div>\n              <div className=\"text-sm font-black whitespace-nowrap uppercase tracking-tighter italic\">08:00 AM - 10:00 PM</div>\n            </div>\n          </div>\n        </div>\n      </main>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\components\\3d\\CinematicBackground.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\components\\3d\\CinematicLoader.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\components\\3d\\Scene3D.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'props' is defined but never used.","line":3,"column":33,"nodeType":"Identifier","messageId":"unusedVar","endLine":3,"endColumn":38}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nexport default function Scene3D(props: any) {\n    return <div className=\"hidden\" />;\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\components\\AdminHeader.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\components\\AdminNavb