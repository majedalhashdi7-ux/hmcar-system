   <SettingRow\r\n                                    icon={Bell}\r\n                                    title={isRTL ? 'в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ' : 'Auction Alerts'}\r\n                                    subtitle={isRTL ? 'в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШ°в•ӘВ»в•ӘШ© в•ӘШ«в”ҳГӘ в•ӘШҜв”ҳВҶв•ӘШІв”ҳГ§в•ӘШҜв•ӘШ© в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»' : 'Auction start & end alerts'}\r\n                                    value={notifications.auctionAlerts}\r\n                                    onChange={() => setNotifications(p => ({ ...p, auctionAlerts: !p.auctionAlerts }))}\r\n                                />\r\n                                <SettingRow\r\n                                    icon={Bell}\r\n                                    title={isRTL ? 'в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВҶв•ӘВ«в”ҳВҒв•ӘШҜв•Әв•ў в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•Әв•Јв•ӘШҜв•Әв–’' : 'Price Drop Alerts'}\r\n                                    subtitle={isRTL ? 'в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШІв•ӘВ«в”ҳВҒв”ҳГЁв•Әв•ў в•Әв”Ӯв•Әв•Јв•Әв–’ в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ в”ҳГ в•ӘШөв”ҳВҒв”ҳГӘв•Әв••в•ӘШұ' : 'When saved car price drops'}\r\n                                    value={notifications.priceDrops}\r\n                                    onChange={() => setNotifications(p => ({ ...p, priceDrops: !p.priceDrops }))}\r\n                                />\r\n                                <SettingRow\r\n                                    icon={Mail}\r\n                                    title={isRTL ? 'в•Әв–’в•Әв”Ӯв•ӘШҜв•ӘШ®в”ҳВ„ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ' : 'New Messages'}\r\n                                    subtitle={isRTL ? 'в•Әв•Јв”ҳВҶв•ӘВ» в”ҳГӘв•Әв•Ўв”ҳГӘв”ҳВ„ в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ' : 'When you receive a message'}\r\n                                    value={notifications.newMessages}\r\n                                    onChange={() => setNotifications(p => ({ ...p, newMessages: !p.newMessages }))}\r\n                                />\r\n                            </div>\r\n                        </div>\r\n                    </motion.section>\r\n\r\n                    {/* ШёВӨВҖШёВӨВҖШёВӨВҖ в•ӘШҜв”ҳВ„в”ҳГ в•Әв••в”ҳГ§в•Әв–’ ШёВӨВҖШёВӨВҖШёВӨВҖ */}\r\n                    <motion.section initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: 0.15 }}>\r\n                        <div className=\"rounded-2xl border border-white/[0.06] overflow-hidden\">\r\n                            <div className={cn('flex items-center gap-3 px-5 py-4 bg-white/[0.02] border-b border-white/[0.05]', isRTL && 'flex-row-reverse')}>\r\n                                <Palette className=\"w-4 h-4 text-[#c9a96e]/70\" strokeWidth={1.8} />\r\n                                <span className=\"text-[12px] font-bold text-white/50 uppercase tracking-[0.25em]\">\r\n                                    {isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•Әв••в”ҳГ§в•Әв–’' : 'Appearance'}\r\n                                </span>\r\n                            </div>\r\n                            <div className=\"p-3 space-y-2\">\r\n                                <SettingRow\r\n                                    icon={Moon}\r\n                                    title={isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШөв•Әв–’в”ҳГўв•ӘШҜв•ӘШІ в”ҳГӘв•ӘШҜв”ҳВ„в•ӘШІв•ӘШ«в•ӘШів”ҳГЁв•Әв–’в•ӘШҜв•ӘШІ' : 'Animations'}\r\n                                    subtitle={isRTL ? 'в•ӘШІв•ӘШ«в•ӘШів”ҳГЁв•Әв–’в•ӘШҜв•ӘШІ в•ӘШ°в•Әв•Ўв•Әв–’в”ҳГЁв•ӘШұ в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв”ҳГ©в”ҳВ„' : 'Visual effects while navigating'}\r\n                                    value={appearance.animations}\r\n                                    onChange={() => setAppearance(p => ({ ...p, animations: !p.animations }))}\r\n                                    iconColor=\"#a78bfa\"\r\n                                />\r\n                                <SettingRow\r\n                                    icon={Volume2}\r\n                                    title={isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ¬в•ӘШів•Әв–’в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•ӘШІв”ҳГЁв•ӘШұ' : 'Sound Effects'}\r\n                                    subtitle={isRTL ? 'в•ӘШ«в•Әв•Ўв”ҳГӘв•ӘШҜв•ӘШІ в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв•Әв–’в•ӘШҜв•ӘШ©в•ӘШҜв•ӘШІ' : 'Audio feedback on actions'}\r\n                                    value={appearance.soundEffects}\r\n                                    onChange={() => setAppearance(p => ({ ...p, soundEffects: !p.soundEffects }))}\r\n                                    iconColor=\"#a78bfa\"\r\n                                />\r\n                            </div>\r\n                        </div>\r\n                    </motion.section>\r\n\r\n                    {/* ШёВӨВҖШёВӨВҖШёВӨВҖ в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ ШёВӨВҖШёВӨВҖШёВӨВҖ */}\r\n                    <motion.section initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: 0.2 }}>\r\n                        <div className=\"rounded-2xl border border-white/[0.06] overflow-hidden\">\r\n                            <div className={cn('flex items-center gap-3 px-5 py-4 bg-white/[0.02] border-b border-white/[0.05]', isRTL && 'flex-row-reverse')}>\r\n                                <Lock className=\"w-4 h-4 text-[#c9a96e]/70\" strokeWidth={1.8} />\r\n                                <span className=\"text-[12px] font-bold text-white/50 uppercase tracking-[0.25em]\">\r\n                                    {isRTL ? 'в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’' : 'Change Password'}\r\n                                </span>\r\n                            </div>\r\n                            <div className=\"p-5\">\r\n                                {pwdMessage && (\r\n                                    <div className={cn(\r\n                                        'mb-4 p-3.5 rounded-xl text-[12px] font-semibold flex items-center gap-2',\r\n                                        pwdMessage.includes('ШёВЈГҙ')\r\n                                            ? 'bg-green-400/10 border border-green-400/20 text-green-400'\r\n                                            : 'bg-red-400/10 border border-red-400/20 text-red-400'\r\n                                    )}>\r\n                                        {pwdMessage}\r\n                                    </div>\r\n                                )}\r\n                                <form onSubmit={handlePasswordChange} className=\"space-y-4\">\r\n                                    {[\r\n                                        { key: 'current', label: isRTL ? 'в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ' : 'Current Password' },\r\n                                        { key: 'new', label: isRTL ? 'в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҙв•ӘВ»в”ҳГЁв•ӘВ»в•ӘШұ' : 'New Password' },\r\n                                        { key: 'confirm', label: isRTL ? 'в•ӘШІв•ӘШ«в”ҳГўв”ҳГЁв•ӘВ» в”ҳГўв”ҳВ„в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•Әв–’в”ҳГӘв•Әв–’' : 'Confirm Password' },\r\n                                    ].map((field) => (\r\n                                        <div key={field.key}>\r\n                                            <label className=\"block text-[11px] font-semibold text-white/40 mb-2\">\r\n                                                {field.label}\r\n                                            </label>\r\n                                            <div className=\"relative\">\r\n                                                <input\r\n                                                    type={showPwd ? 'text' : 'password'}\r\n                                                    value={passwords[field.key as keyof typeof passwords]}\r\n                                                    onChange={e => setPasswords(p => ({ ...p, [field.key]: e.target.value }))}\r\n                                                    className=\"w-full bg-white/[0.03] border border-white/[0.08] rounded-xl py-3.5 px-4 text-[14px] text-white focus:outline-none focus:border-[#c9a96e]/40 transition-all placeholder:text-white/20\"\r\n                                                    placeholder=\"ШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘШёВҖШӘ\"\r\n                                                />\r\n                                                {field.key === 'confirm' && (\r\n                                                    <button\r\n                                                        type=\"button\"\r\n                                                        onClick={() => setShowPwd(v => !v)}\r\n                                                        className=\"absolute right-3 top-1/2 -translate-y-1/2 text-white/25 hover:text-white/60 transition-colors\"\r\n                                                    >\r\n                                                        {showPwd ? <EyeOff className=\"w-4 h-4\" /> : <Eye className=\"w-4 h-4\" />}\r\n                                                    </button>\r\n                                                )}\r\n                                            </div>\r\n                                        </div>\r\n                                    ))}\r\n                                    <button\r\n                                        type=\"submit\"\r\n                                        disabled={saving}\r\n                                        className=\"w-full py-3.5 rounded-xl bg-white/[0.05] border border-white/10 text-white/70 hover:text-white hover:bg-white/[0.08] font-semibold text-[13px] transition-all disabled:opacity-50 flex items-center justify-center gap-2\"\r\n                                    >\r\n                                        <Lock className=\"w-4 h-4\" strokeWidth={1.8} />\r\n                                        {isRTL ? 'в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘШі в”ҳГўв”ҳВ„в”ҳ