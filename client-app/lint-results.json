\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\register\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\robots.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\search\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\showroom\\[id]\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'e' is defined but never used.","line":95,"column":29,"nodeType":"Identifier","messageId":"unusedVar","endLine":95,"endColumn":30}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\n/**\r\n * в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в•Әв•ў\r\n * в•ӘШІв”ҳВҸв•Әв•Јв•Әв–’в•Әв•ў в•Әв•Јв”ҳВҶв•ӘВ» в•ӘШҜв”ҳВ„в•Әв•ўв•Әв•‘в•Әв•– в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШ«в”ҳГЁ в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в•Әв•ў в•ӘШ«в”ҳГӘ в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘШұ\r\n * в•ӘШІв•ӘШөв•ӘШІв”ҳГӘв”ҳГЁ в•Әв•Јв”ҳВ„в”ҳГ« в•Әв•Ўв”ҳГӘв•Әв–’в•ӘГ® в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВҒв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГўв•ӘШҜв”ҳГ в”ҳВ„в•ӘШұв•ӘГ® в”ҳГӘв•Әв–“в•Әв–’ в•Әв•–в”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в•Әв•Јв•ӘШ°в•Әв–’ в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ°\r\n */\r\n\r\nimport { useState, useEffect } from 'react';\r\nimport { useParams, useRouter } from 'next/navigation';\r\nimport { motion, AnimatePresence } from 'framer-motion';\r\nimport {\r\n    ChevronLeft, MessageCircle, Fuel, Gauge, Settings2,\r\n    Calendar, Car, Tag, CheckCircle, AlertCircle, Image as ImageIcon\r\n} from 'lucide-react';\r\nimport Navbar from '@/components/Navbar';\r\nimport Image from 'next/image';\r\nimport { api } from '@/lib/api';\r\nimport { useLanguage } from '@/lib/LanguageContext';\r\nimport { useSettings } from '@/lib/SettingsContext';\r\nimport { cn } from '@/lib/utils';\r\n\r\nconst toFiniteNumber = (value: unknown): number | null => {\r\n    const num = Number(value);\r\n    return Number.isFinite(num) ? num : null;\r\n};\r\n\r\nexport default function ShowroomCarDetail() {\r\n    const { id } = useParams();\r\n    const router = useRouter();\r\n    const { isRTL } = useLanguage();\r\n    const { formatPrice, formatPriceFromUsd, currency } = useSettings();\r\n\r\n    // в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ\r\n    const [car, setCar] = useState<any>(null);\r\n    const [loading, setLoading] = useState(true);\r\n    const [error, setError] = useState('');\r\n    const [activeImage, setActiveImage] = useState(0);\r\n    const [whatsapp, setWhatsapp] = useState('');\r\n    const [showInvoice, setShowInvoice] = useState(false);\r\n\r\n    // в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳВҖ API\r\n    useEffect(() => {\r\n        const loadCar = async () => {\r\n            try {\r\n                setLoading(true);\r\n                const res = await api.cars.getById(id as string);\r\n                if (res?.success && res.data) {\r\n                    setCar(res.data);\r\n                } else {\r\n                    setError(isRTL ? 'в”ҳВ„в”ҳГ  в”ҳГЁв•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШів”ҳГӘв•Әв–’ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ' : 'Car not found');\r\n                }\r\n            } catch (err) {\r\n                console.error('Failed to load car:', err);\r\n                setError(isRTL ? 'в•ӘШөв•ӘВ»в•ӘШі в•ӘВ«в•Әв•–в•ӘШ« в”ҳВҒв”ҳГЁ в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШ°в”ҳГЁв•ӘШҜв”ҳВҶв•ӘШҜв•ӘШІ' : 'Failed to load car data');\r\n            } finally {\r\n                setLoading(false);\r\n            }\r\n        };\r\n        if (id) loadCar();\r\n    }, [id, isRTL]);\r\n\r\n    // в•ӘШҙв”ҳВ„в•ӘШ° в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ° в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШҜв”ҳГ в•ӘШұ\r\n    useEffect(() => {\r\n        api.settings.getPublic().then((res: any) => {\r\n            if (res?.success && res.data?.socialLinks?.whatsapp) {\r\n                setWhatsapp(res.data.socialLinks.whatsapp);\r\n            } else {\r\n                // [[ARABIC_COMMENT]] в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШҜв”ҳВ„в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГўв”ҳГӘв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳВҒв•ӘШІв•Әв–’в•ӘШҜв•Әв•ўв”ҳГЁ в•ӘШӯв•Әв–‘в•ӘШҜ в”ҳВ„в”ҳГ  в”ҳГЁв”ҳВҸв•Әв•Јв”ҳГЁв”ҳЩ‘в”ҳВҶ в•ӘШҜв”ҳВ„в•ӘШ«в•ӘВ»в”ҳГ в”ҳВҶ в•Әв–’в”ҳГ©в”ҳГ в•ӘШҜв”ҳГҜ\r\n                setWhatsapp('+821080880014');\r\n            }\r\n        }).catch(() => {\r\n            setWhatsapp('+821080880014');\r\n        });\r\n    }, []);\r\n\r\n    // в•ӘШӯв•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„ в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ° в”ҳГ в•Әв•Ј в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ\r\n    const handleWhatsappPurchase = async () => {\r\n        if (!car) return;\r\n        const carMake = typeof car.make === 'object' ? car.make?.name : car.make;\r\n        const baseUsd = getBaseUsd(car);\r\n        const price = formatPriceFromUsd\r\n            ? formatPriceFromUsd(baseUsd)\r\n            : (formatPrice ? formatPrice(Number(car.priceSar || car.price || 0)) : `${Number(car.priceSar || car.price || 0).toLocaleString()} SAR`);\r\n\r\n        // [[ARABIC_COMMENT]] в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв•–в”ҳВ„в•ӘШ° в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ в”ҳГӘв•ӘШӯв”ҳВҶв•Әв”Өв•ӘШҜв•ӘШ© в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’ в”ҳВ„в”ҳВ„в•ӘШ«в•ӘВ»в”ҳГ в”ҳВҶ в”ҳГ©в•ӘШ°в”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҶв”ҳГ©в”ҳВ„ в”ҳВ„в”ҳВ„в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ°\r\n        try {\r\n            let buyerId = null;\r\n            if (typeof window !== 'undefined') {\r\n                const userJson = localStorage.getItem('hm_user');\r\n                if (userJson) {\r\n                    try {\r\n                        const u = JSON.parse(userJson);\r\n                        buyerId = u?._id || u?.id;\r\n                    } catch(e) {}\r\n                }\r\n            }\r\n\r\n            await api.orders.create({\r\n                buyerId: buyerId || null,\r\n                items: [{\r\n                    itemType: 'car',\r\n                    refId: (car as any)._id || (car as any).id || id,\r\n                    titleSnapshot: car.title,\r\n                    qty: 1,\r\n                    unitPriceSar: car.priceSar || car.price || 0\r\n                }],\r\n                pricing: {\r\n                    grandTotalSar: car.priceSar || car.price || 0\r\n                },\r\n                channel: 'whatsapp',\r\n                notes: `Clicked buy from Showroom car page`\r\n            });\r\n        } catch (err) {\r\n            console.error('Failed to log order:', err);\r\n        }\r\n\r\n        // [[ARABIC_COMMENT]] в•ӘШ°в”ҳВҶв•ӘШҜв•ӘШ© в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ° в”ҳГ в•Әв•Ј в”ҳГўв”ҳВ„ в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ\r\n        const msg = isRTL\r\n            ? `в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШҜв”ҳГ  в•Әв•Јв”ҳВ„в”ҳГЁв”ҳГўв”ҳГ в•ӘГ®\\n\\nвүЎШ§ГҙГҜ *в•Әв•–в”ҳВ„в•ӘШ° в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ в”ҳГ в”ҳВҶ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в•Әв•ў*\\n\\nвүЎШ§ШЈГ№ *в”ҳГ в•Әв•Јв”ҳВ„в”ҳГӘв”ҳГ в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ:*\\nШёВҖШӘ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв”Ӯв”ҳГ : ${car.title}\\nШёВҖШӘ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•Әв–’в”ҳГўв•ӘШұ: ${carMake}\\nШёВҖШӘ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„: ${car.model}\\nШёВҖШӘ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҶв•ӘШұ: ${car.year}\\nШёВҖШӘ в•ӘШҜв”ҳВ„в”ҳВ„в”ҳГӘв”ҳВҶ: ${car.color || 'в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШөв•ӘВ»в•ӘВ»'}\\nШёВҖШӘ в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв”ҳВҒв•ӘШұ: ${car.mileage ? car.mileage.toLocaleString() + ' в”ҳГўв”ҳГ ' : 'в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШөв•ӘВ»в•ӘВ»'}\\nШёВҖШӘ в”ҳВҶв”ҳГӘв•Әв•Ј в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в”ҳГӘв•ӘВ»: ${car.fuelType || 'в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШөв•ӘВ»в•ӘВ»'}\\nШёВҖШӘ в”ҳВҶв•ӘШҜв”ҳГ©в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШөв•Әв–’в”ҳГўв•ӘШұ: ${car.transmission || 'в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘШөв•ӘВ»в•ӘВ»'}\\n\\nвүЎШ§Щ’в–‘ *в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’: ${price}*\\n\\nв•ӘШ«в•Әв–’в•ӘШҙв”ҳГӘ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Јв”ҳГЁ в”ҳВ„в”ҳВ„в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳВҒв•Әв”Ӯв•ӘШҜв•Әв–’ в•Әв•Јв”ҳВҶ в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ.`\r\n            : `Hello,\\n\\nвүЎШ§ГҙГҜ *Car Purchase Request from Showroom*\\n\\nвүЎШ§ШЈГ№ *Car Details:*\\nШёВҖШӘ Name: ${car.title}\\nШёВҖШӘ Make: ${carMake}\\nШёВҖШӘ Model: ${car.model}\\nШёВҖШӘ Year: ${car.year}\\nШёВҖШӘ Color: ${car.color || 'N/A'}\\nШёВҖШӘ Mileage: ${car.mileage ? car.mileage.toLocaleString() + ' km' : 'N/A'}\\nШёВҖШӘ Fuel: ${car.fuelType || 'N/A'}\\nШёВҖШӘ Transmission: ${car.transmission || 'N/A'}\\n\\nвүЎШ§Щ’в–‘ *Price: ${price}*\\n\\nPlease contact me regarding this vehicle.`;\r\n\r\n        // [[ARABIC_COMMENT]] в•ӘШҜв•Әв”Ӯв•ӘШІв•ӘВ«в•ӘВ»в”ҳГ  в•ӘШҜв”ҳВ„в•Әв–’в”ҳГ©в”ҳГ  в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв”ҳВҒв”ҳГӘв•Әв•• в•ӘШ«в”ҳГӘ в•ӘШҜв”ҳВ„в•ӘШҜв”ҳВҒв•ӘШІв•Әв–’в•ӘШҜв•Әв•ўв”ҳГЁ - в•ӘВ»в•ӘШҜв•ӘШ®в”ҳГ в•ӘШҜв”ҳГҜ в”ҳГЁв•Әв•Јв”ҳГ в”ҳВ„\r\n        const phone = String(whatsapp || '+821080880014').replace(/\\D/g, '');\r\n        window.open(`https://wa.me/${phone}?text=${encodeURIComponent(msg)}`, '_blank');\r\n    };\r\n\r\n\r\n    // в•Әв•Јв•Әв–’в•Әв•ў в•Әв”Өв•ӘШҜв•Әв”Өв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„\r\n    if (loading) {\r\n        return (\r\n            <div className=\"min-h-screen bg-black flex items-center justify-center\">\r\n                <Navbar />\r\n                <div className=\"text-center space-y-4\">\r\n                    <div className=\"w-16 h-16 border-2 border-[#c9a96e]/30 border-t-[#c9a96e] rounded-full animate-spin mx-auto\" />\r\n                    <p className=\"text-white/30 text-[11px] uppercase tracking-[0.4em] font-black animate-pulse\">\r\n                        {isRTL ? 'в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГ в”ҳГЁв”ҳВ„...' : 'LOADING...'}\r\n                    </p>\r\n                </div>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    // в•Әв•Јв•Әв–’в•Әв•ў в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв•–в•ӘШ«\r\n    if (error || !car) {\r\n        return (\r\n            <div className=\"min-h-screen bg-black flex flex-col items-center justify-center gap-6\">\r\n                <Navbar />\r\n                <AlertCircle className=\"w-20 h-20 text-white/10\" />\r\n                <h1 className=\"text-2xl font-black uppercase text-white/30 tracking-widest\">\r\n                    {error || (isRTL ? 'в”ҳВ„в”ҳГ  в”ҳГЁв•ӘШІв”ҳГ  в•ӘШҜв”ҳВ„в•Әв•Јв•ӘШів”ҳГӘв•Әв–’ в•Әв•Јв”ҳВ„в”ҳГ« в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ' : 'Car not found')}\r\n                </h1>\r\n                <button\r\n                    onClick={() => router.back()}\r\n                    className=\"px-8 py-4 bg-[#c9a96e]/10 border border-[#c9a96e]/30 rounded-2xl text-[#c9a96e] text-[11px] font-black uppercase tracking-widest hover:bg-[#c9a96e]/20 transition-all\"\r\n                >\r\n                    {isRTL ? 'в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГӘв•ӘВ»в•ӘШұ' : 'GO BACK'}\r\n                </button>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    const getBaseUsd = (payload: any) => {\r\n        const baseUsd = toFiniteNumber(payload?.basePriceUsd);\r\n        if (baseUsd && baseUsd > 0) return baseUsd;\r\n\r\n        const priceUsd = toFiniteNumber(payload?.priceUsd);\r\n        if (priceUsd && priceUsd > 0) return priceUsd;\r\n\r\n        const priceSar = toFiniteNumber(payload?.priceSar ?? payload?.price);\r\n        if (priceSar && priceSar > 0) return priceSar / Number(currency.usdToSar || 1);\r\n\r\n        const priceKrw = toFiniteNumber(payload?.priceKrw);\r\n        if (priceKrw && priceKrw > 0) return priceKrw / Number(currency.usdToKrw || 1);\r\n\r\n        return 0;\r\n    };\r\n\r\n    const carMake = typeof car.make === 'object' ? car.make?.name : car.make;\r\n    const images = car.images?.filter(Boolean) || [];\r\n    const baseUsd = getBaseUsd(car);\r\n    const displayPrice = formatPriceFromUsd\r\n        ? formatPriceFromUsd(baseUsd)\r\n        : (formatPrice ? formatPrice(Number(car.priceSar || car.price || 0)) : `${Number(car.priceSar || car.price || 0).toLocaleString()} SAR`);\r\n\r\n    const specs = [\r\n        { icon: Calendar, label: isRTL ? 'в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҶв•ӘШұ' : 'YEAR', value: car.year },\r\n        { icon: Gauge, label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв”ҳВҒв•ӘШұ' : 'MILEAGE', value: car.mileage ? `${car.mileage.toLocaleString()} ${isRTL ? 'в”ҳГўв”ҳГ ' : 'KM'}` : 'ШёВҖВӨ' },\r\n        { icon: Fuel, label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГ©в”ҳГӘв•ӘВ»' : 'FUEL', value: car.fuelType || 'ШёВҖВӨ' },\r\n        { icon: Settings2, label: isRTL ? 'в”ҳВҶв•ӘШҜв”ҳГ©в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШөв•Әв–’в”ҳГўв•ӘШұ' : 'TRANSMISSION', value: car.transmission || 'ШёВҖВӨ' },\r\n        { icon: Car, label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШ®в•ӘШұ' : 'CATEGORY', value: car.category || 'ШёВҖВӨ' },\r\n        { icon: Tag, label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳВ„в”ҳГӘв”ҳВҶ' : 'COLOR', value: car.color || 'ШёВҖВӨ' },\r\n    ];\r\n\r\n    return (\r\n        <div\r\n            className=\"relative min-h-screen bg-[#050505] text-white overflow-x-hidden scroll-smooth\"\r\n            dir={isRTL ? 'rtl' : 'ltr'}\r\n        >\r\n            <Navbar />\r\n\r\n            {/* в•ӘВ«в”ҳВ„в”ҳВҒв”ҳГЁв•ӘШұ в•Әв–“в•ӘВ«в•Әв–’в”ҳВҒв”ҳГЁв•ӘШұ */}\r\n            <div className=\"fixed inset-0 pointer-events-none z-0\">\r\n                <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(201,169,110,0.05)_0%,transparent_60%)]\" />\r\n            </div>\r\n\r\n            <main className=\"relative z-10 pt-28 pb-24 px-4 sm:px-6 max-w-7xl mx-auto\">\r\n\r\n                {/* в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГӘв•ӘВ»в•ӘШұ */}\r\n                <motion.button\r\n                    initial={{ opacity: 0, x: -20 }}\r\n                    animate={{ opacity: 1, x: 0 }}\r\n                    onClick={() => {\r\n                        window.scrollTo({ top: 0, behavior: 'smooth' });\r\n                        setTimeout(() => router.back(), 300);\r\n                    }}\r\n                    className=\"flex items-center gap-2 mb-10 px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-white/60 hover:text-white hover:bg-white/10 transition-all group w-fit\"\r\n                >\r\n                    <ChevronLeft className={cn('w-4 h-4 transition-transform group-hover:-translate-x-1', isRTL && 'rotate-180 group-hover:translate-x-1')} />\r\n                    <span className=\"text-[10px] font-black uppercase tracking-[0.2em]\">\r\n                        {isRTL ? 'в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГӘв•ӘВ»в•ӘШұ в”ҳВ„в”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в•Әв•ў' : 'BACK TO SHOWROOM'}\r\n                    </span>\r\n                </motion.button>\r\n\r\n                <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-12\">\r\n\r\n                    {/* в”ҳГ©в•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•Әв–’ */}\r\n                    <motion.div\r\n                        initial={{ opacity: 0, y: 30 }}\r\n                        animate={{ opacity: 1, y: 0 }}\r\n                        transition={{ duration: 0.6 }}\r\n                        className=\"space-y-4\"\r\n                    >\r\n                        {/* в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘШұ */}\r\n                        <div className=\"relative aspect-[4/3] rounded-3xl overflow-hidden border border-white/10 bg-white/[0.02]\">\r\n                            {images.length > 0 ? (\r\n                                <Image\r\n                                    src={images[activeImage]}\r\n                                    alt={car.title}\r\n                                    fill\r\n                                    className=\"object-cover\"\r\n                                    unoptimized\r\n                                />\r\n                            ) : (\r\n                                <div className=\"w-full h-full flex items-center justify-center\">\r\n                                    <ImageIcon className=\"w-20 h-20 text-white/10\" />\r\n                                </div>\r\n                            )}\r\n\r\n                            {/* в•Әв”Өв•ӘШҜв•Әв–’в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в•ӘШұ */}\r\n                            <div className=\"absolute top-4 right-4 flex gap-2\">\r\n                                <span className=\"px-3 py-1 bg-[#c9a96e]/20 border border-[#c9a96e]/40 rounded-lg text-[10px] font-black text-[#c9a96e] uppercase tracking-widest backdrop-blur-md\">\r\n                                    {isRTL ? 'в”ҳГ в•Әв•Јв•Әв–’в•Әв•ў' : 'SHOWROOM'}\r\n                                </span>\r\n                                {car.isActive && (\r\n                                    <span className=\"px-3 py-1 bg-green-400/20 border border-green-400/40 rounded-lg text-[10px] font-black text-green-400 uppercase tracking-widest backdrop-blur-md flex items-center gap-1\">\r\n                                        <CheckCircle className=\"w-3 h-3\" />\r\n                                        {isRTL ? 'в”ҳГ в•ӘШІв”ҳГӘв”ҳВҒв•Әв–’' : 'AVAILABLE'}\r\n                                    </span>\r\n                                )}\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳГӘв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Ўв•Әв•‘в•Әв–’в•ӘШұ */}\r\n                        {images.length > 1 && (\r\n                            <div className=\"flex gap-3 overflow-x-auto pb-2\">\r\n                                {images.map((img: string, idx: number) => (\r\n                                    <button\r\n                                        key={idx}\r\n                                        onClick={() => setActiveImage(idx)}\r\n                                        className={cn(\r\n                                            'relative w-20 h-20 shrink-0 rounded-xl overflow-hidden border-2 transition-all',\r\n                                            activeImage === idx\r\n                                                ? 'border-[#c9a96e] shadow-[0_0_15px_rgba(201,169,110,0.4)]'\r\n                                                : 'border-white/10 opacity-50 hover:opacity-80'\r\n                                        )}\r\n                                    >\r\n                                        <Image src={img} alt={`в•Әв•Ўв”ҳГӘв•Әв–’в•ӘШұ ${idx + 1}`} fill className=\"object-cover\" unoptimized />\r\n                                    </button>\r\n                                ))}\r\n                            </div>\r\n                        )}\r\n                    </motion.div>\r\n\r\n                    {/* в”ҳГ©в•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ */}\r\n                    <motion.div\r\n                        initial={{ opacity: 0, y: 30 }}\r\n                        animate={{ opacity: 1, y: 0 }}\r\n                        transition={{ duration: 0.6, delay: 0.1 }}\r\n                        className=\"space-y-8\"\r\n                    >\r\n                        {/* в•ӘШҜв”ҳВ„в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в”ҳГӘв•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’ */}\r\n                        <div>\r\n                            <div className=\"text-[11px] font-black text-[#c9a96e]/70 uppercase tracking-[0.4em] mb-2 italic\">\r\n                                {carMake}\r\n                            </div>\r\n                            <h1 className=\"text-4xl md:text-5xl font-black uppercase italic tracking-tighter mb-4 leading-tight\">\r\n                                {car.title}\r\n                            </h1>\r\n                            <div className=\"text-3xl font-black text-[#c9a96e]\">\r\n                                {displayPrice}\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВҒв•ӘШҜв•ӘШІ */}\r\n                        <div className=\"grid grid-cols-2 sm:grid-cols-3 gap-4\">\r\n                            {specs.map((spec, i) => (\r\n                                <motion.div\r\n                                    key={spec.label}\r\n                                    initial={{ opacity: 0, y: 10 }}\r\n                                    animate={{ opacity: 1, y: 0 }}\r\n                                    transition={{ delay: i * 0.05 + 0.2 }}\r\n                                    className=\"bg-white/[0.02] border border-white/8 rounded-2xl p-4 space-y-2 hover:border-[#c9a96e]/20 transition-all\"\r\n                                >\r\n                                    <spec.icon className=\"w-4 h-4 text-[#c9a96e]/60\" />\r\n                                    <div className=\"text-[9px] font-black uppercase tracking-[0.3em] text-white/30\">{spec.label}</div>\r\n                                    <div className=\"text-sm font-black text-white/80 capitalize\">{spec.value}</div>\r\n                                </motion.div>\r\n                            ))}\r\n                        </div>\r\n\r\n                        {/* в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳВҒ */}\r\n                        {car.description && (\r\n                            <div className=\"bg-white/[0.02] border border-white/8 rounded-2xl p-6\">\r\n                                <div className=\"text-[9px] font-black uppercase tracking-[0.3em] text-white/30 mb-3\">\r\n                                    {isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳВҒ' : 'DESCRIPTION'}\r\n                                </div>\r\n                                <p className=\"text-white/60 text-sm leading-relaxed\">{car.description}</p>\r\n                            </div>\r\n                        )}\r\n\r\n                        {/* в•ӘШ«в•Әв–“в•Әв–’в•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШҜв•Әв•ўв•ӘШҜв”ҳВҒв•ӘШұ в”ҳВ„в•Әв•–в”ҳВ„в•ӘШ°в•ӘШҜв•ӘШІв”ҳГЁ + в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ° */}\r\n                        <div className=\"space-y-4 pt-4\">\r\n                            {/* в•Әв–“в•Әв–’ в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в•Әв•Јв•ӘШ°в•Әв–’ в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ° */}\r\n                            <motion.button\r\n                                whileHover={{ scale: 1.02 }}\r\n                                whileTap={{ scale: 0.98 }}\r\n                                onClick={handleWhatsappPurchase}\r\n                                className=\"w-full py-5 bg-green-500/90 hover:bg-green-500 rounded-2xl text-black font-black uppercase text-[13px] tracking-[0.3em] shadow-[0_0_40px_rgba(34,197,94,0.3)] hover:shadow-[0_0_60px_rgba(34,197,94,0.5)] transition-all flex items-center justify-center gap-3\"\r\n                            >\r\n                                <MessageCircle className=\"w-5 h-5\" />\r\n                                {isRTL ? 'в•Әв•–в”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ© в•Әв•Јв•ӘШ°в•Әв–’ в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ°' : 'BUY VIA WHATSAPP'}\r\n                            </motion.button>\r\n\r\n                            {/* в•Әв–“в•Әв–’ в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ */}\r\n                            <button\r\n                                onClick={() => setShowInvoice(true)}\r\n                                className=\"w-full py-4 bg-white/5 border border-white/10 rounded-2xl text-white/60 font-black uppercase text-[11px] tracking-[0.3em] hover:bg-white/10 hover:text-white transition-all\"\r\n                            >\r\n                                {isRTL ? 'в•Әв•Јв•Әв–’в•Әв•ў в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ' : 'VIEW INVOICE'}\r\n                            </button>\r\n                        </div>\r\n                    </motion.div>\r\n                </div>\r\n            </main>\r\n\r\n            {/* [[ARABIC_COMMENT]] в”ҳВҶв•ӘШҜв”ҳВҒв•Әв–‘в•ӘШұ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ */}\r\n            <AnimatePresence>\r\n                {showInvoice && (\r\n                    <motion.div\r\n                        initial={{ opacity: 0 }}\r\n                        animate={{ opacity: 1 }}\r\n                        exit={{ opacity: 0 }}\r\n                        className=\"fixed inset-0 z-[100] bg-black/90 backdrop-blur-xl flex items-center justify-center p-6 overflow-y-auto\"\r\n                        onClick={() => setShowInvoice(false)}\r\n                    >\r\n                        <motion.div\r\n                            initial={{ scale: 0.9, y: 20 }}\r\n                            animate={{ scale: 1, y: 0 }}\r\n                            exit={{ scale: 0.9, y: 20 }}\r\n                            onClick={e => e.stopPropagation()}\r\n                            className=\"bg-[#0a0a0a] border border-white/10 rounded-3xl w-full max-w-md overflow-hidden my-8\"\r\n                        >\r\n                            {/* в•Әв–’в•ӘШ«в•Әв”Ӯ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ */}\r\n                            <div className=\"p-8 border-b border-white/5 text-center bg-[#c9a96e]/5\">\r\n                                <div className=\"text-2xl font-black text-[#c9a96e] mb-1\">HM CAR</div>\r\n                                <div className=\"text-[10px] text-white/40 uppercase tracking-[0.3em]\">\r\n                                    {isRTL ? 'в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ в”ҳГ в•ӘШ°в•ӘВ»в•ӘШ®в”ҳГЁв•ӘШұ' : 'PRELIMINARY INVOICE'}\r\n                                </div>\r\n                            </div>\r\n\r\n                            {/* в•ӘШІв”ҳВҒв•ӘШҜв•Әв•Ўв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ */}\r\n                            <div className=\"p-8 space-y-4\">\r\n                                {[\r\n                                    { label: isRTL ? 'в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ' : 'VEHICLE', value: car.title },\r\n                                    { label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•Әв–’в”ҳГўв•ӘШұ' : 'MAKE', value: carMake },\r\n                                    { label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘВ»в”ҳГЁв”ҳВ„' : 'MODEL', value: car.model },\r\n                                    { label: isRTL ? 'в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҶв•ӘШұ' : 'YEAR', value: car.year },\r\n                                    { label: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳВ„в”ҳГӘв”ҳВҶ' : 'COLOR', value: car.color || 'ШёВҖВӨ' },\r\n                                    { label: isRTL ? 'в”ҳВҶв•ӘШҜв”ҳГ©в”ҳВ„ в•ӘШҜв”ҳВ„в•ӘШөв•Әв–’в”ҳГўв•ӘШұ' : 'TRANSMISSION', value: car.transmission || 'ШёВҖВӨ' },\r\n                                ].map(item => (\r\n                                    <div key={item.label} className=\"flex justify-between items-center border-b border-white/5 pb-3\">\r\n                                        <span className=\"text-[10px] font-black uppercase tracking-[0.2em] text-white/40\">{item.label}</span>\r\n                                        <span className=\"text-[12px] font-bold text-white/80\">{item.value}</span>\r\n                                    </div>\r\n                                ))}\r\n                                <div className=\"flex justify-between items-center pt-4\">\r\n                                    <span className=\"text-[11px] font-black uppercase tracking-[0.3em] text-[#c9a96e]\">\r\n                                        {isRTL ? 'в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’ в•ӘШҜв”ҳВ„в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ' : 'TOTAL PRICE'}\r\n                                    </span>\r\n                                    <span className=\"text-xl font-black text-[#c9a96e]\">{displayPrice}</span>\r\n                                </div>\r\n                            </div>\r\n\r\n                            {/* в•ӘШ«в•Әв–“в•Әв–’в•ӘШҜв•Әв–’ в•ӘШҜв”ҳВ„в”ҳВҒв•ӘШҜв•ӘШІв”ҳГӘв•Әв–’в•ӘШұ */}\r\n                            <div className=\"p-6 border-t border-white/5 grid grid-cols-2 gap-3\">\r\n                                <button\r\n                                    onClick={handleWhatsappPurchase}\r\n                                    className=\"py-4 bg-green-500/90 rounded-xl text-black font-black text-[10px] uppercase tracking-widest flex items-center justify-center gap-2\"\r\n                                >\r\n                                    <MessageCircle className=\"w-4 h-4\" />\r\n                                    {isRTL ? 'в•Әв”Өв•Әв–’в•ӘШҜв•ӘШ©' : 'BUY'}\r\n                                </button>\r\n                                <button\r\n                                    onClick={() => setShowInvoice(false)}\r\n                                    className=\"py-4 bg-white/5 border border-white/10 rounded-xl text-white/60 font-black text-[10px] uppercase tracking-widest\"\r\n                                >\r\n                                    {isRTL ? 'в•ӘШӯв•Әв•‘в”ҳВ„в•ӘШҜв”ҳГ©' : 'CLOSE'}\r\n                                </button>\r\n                            </div>\r\n                        </motion.div>\r\n                    </motion.div>\r\n                )}\r\n            </AnimatePresence>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\showroom\\page.tsx","messages":[],"suppressedMessages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Link' is defined but never us