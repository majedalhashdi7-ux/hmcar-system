olumn":13,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Headphones"},"fix":{"range":[96,110],"text":""},"desc":"Remove unused variable \"Headphones\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'t' is assigned a value but never used.","line":21,"column":11,"nodeType":"Identifier","messageId":"unusedVar","endLine":21,"endColumn":12}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport { motion } from \"framer-motion\";\nimport {\n  MessageCircle,\n  Mail,\n  Phone,\n  Headphones,\n  ArrowRight,\n  ChevronLeft,\n  Clock,\n  ShieldCheck\n} from \"lucide-react\";\nimport { useLanguage } from \"@/lib/LanguageContext\";\nimport { useAuth } from \"@/lib/AuthContext\";\nimport Link from \"next/link\";\nimport Navbar from \"@/components/Navbar\";\nimport { cn } from \"@/lib/utils\";\n\nexport default function SupportPage() {\n  const { t, isRTL } = useLanguage();\n  const { isLoggedIn } = useAuth();\n\n  const supportOptions = [\n    {\n      id: 'live-chat',\n      title: isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШҜв•ӘВ»в•ӘШів•ӘШұ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’в•ӘШұ' : 'LIVE SUPPORT CHAT',\n      desc: isRTL ? 'в•ӘШІв•ӘШөв•ӘВ»в•ӘШі в”ҳГ в•Әв•Ј в”ҳВҒв•Әв–’в”ҳГЁв”ҳГ©в”ҳВҶв•ӘШҜ в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’в•ӘШұ в•Әв•Јв•ӘШ°в•Әв–’ в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј' : 'Talk to our team directly through the site',\n      icon: MessageCircle,\n      href: isLoggedIn ? '/messages' : '/login?redirect=/messages',\n      color: 'text-cinematic-neon-blue',\n      bg: 'bg-cinematic-neon-blue/10',\n      border: 'border-cinematic-neon-blue/20',\n      tag: isLoggedIn ? (isRTL ? 'в”ҳВҶв•Әв”Өв•Әв•– в•ӘШҜв”ҳВ„в•ӘШӘв”ҳВҶ' : 'ACTIVE NOW') : (isRTL ? 'в”ҳГЁв•ӘШІв•Әв•–в”ҳВ„в•ӘШ° в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘВ»в•ӘВ«в”ҳГӘв”ҳВ„' : 'REQUIRES LOGIN')\n    },\n    {\n      id: 'whatsapp',\n      title: isRTL ? 'в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ° в”ҳГ в•ӘШ°в•ӘШҜв•Әв”Өв•Әв–’' : 'DIRECT WHATSAPP',\n      desc: isRTL ? 'в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Јв”ҳВҶв•ӘШҜ в”ҳВҒв”ҳГӘв•Әв–’в•ӘШҜв”ҳГҜ в•Әв•Јв•ӘШ°в•Әв–’ в•ӘШІв•Әв•–в•ӘШ°в”ҳГЁв”ҳГ© в•ӘШҜв”ҳВ„в”ҳГӘв•ӘШҜв•ӘШІв•Әв”Ӯв•ӘШҜв•ӘШ°' : 'Contact us instantly via WhatsApp app',\n      icon: Phone,\n      href: 'https://wa.me/967781007805',\n      color: 'text-green-400',\n      bg: 'bg-green-400/10',\n      border: 'border-green-400/20',\n      tag: isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШ«в•Әв”Ӯв•Әв–’в•Әв•Ј в•Әв–’в•ӘВ»в•ӘШӘ' : 'FASTEST RESPONSE'\n    },\n    {\n      id: 'contact-form',\n      title: isRTL ? 'в”ҳВҶв”ҳГ в”ҳГӘв•Әв–‘в•ӘШҙ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„' : 'CONTACT FORM',\n      desc: isRTL ? 'в•ӘШ«в•Әв–’в•Әв”Ӯв”ҳВ„ в”ҳВ„в”ҳВҶв•ӘШҜ в•Әв–’в•Әв”Ӯв•ӘШҜв”ҳВ„в•ӘШұ в”ҳГӘв•Әв”Ӯв”ҳВҶв•Әв–’в•ӘВ» в•Әв•Јв”ҳВ„в”ҳГЁв”ҳГў в•Әв•Јв•ӘШ°в•Әв–’ в•ӘШҜв”ҳВ„в•ӘШ°в•Әв–’в”ҳГЁв•ӘВ»' : 'Send us a message and we will email back',\n      icon: Mail,\n      href: '/contact',\n      color: 'text-cinematic-neon-red',\n      bg: 'bg-cinematic-neon-red/10',\n      border: 'border-cinematic-neon-red/20',\n      tag: isRTL ? 'в•ӘШҜв•Әв”Ӯв•ӘШІв”ҳВҒв•Әв”Ӯв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в•Әв•Јв•ӘШҜв”ҳГ в•ӘШұ' : 'GENERAL INQUIRIES'\n    }\n  ];\n\n  return (\n    <div className=\"relative min-h-screen bg-black text-white font-sans overflow-hidden\">\n      <Navbar />\n\n      {/* Background Effects */}\n      <div className=\"fixed inset-0 pointer-events-none z-0\">\n        <div className=\"absolute top-0 right-0 w-[500px] h-[500px] bg-cinematic-neon-blue/10 blur-[150px] rounded-full translate-x-1/2 -translate-y-1/2\" />\n        <div className=\"absolute bottom-0 left-0 w-[500px] h-[500px] bg-cinematic-neon-red/5 blur-[150px] rounded-full -translate-x-1/2 translate-y-1/2\" />\n      </div>\n\n      <main className=\"relative z-10 pt-32 pb-24 px-6 max-w-6xl mx-auto\">\n        <header className=\"mb-16 text-center md:text-right\">\n          <Link href=\"/\" className=\"inline-flex items-center gap-2 mb-8 px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-white/60 hover:text-white hover:bg-white/10 transition-all group\">\n            <ChevronLeft className={cn(\"w-4 h-4 transition-transform group-hover:-translate-x-1\", isRTL && \"rotate-180 group-hover:translate-x-1\")} />\n            <span className=\"text-[10px] font-black uppercase tracking-[0.2em]\">{isRTL ? 'в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГӘв•ӘВ»в•ӘШұ в”ҳВ„в”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘШұ' : 'BACK TO HOME'}</span>\n          </Link>\n\n          <div className=\"flex items-center gap-4 mb-6 justify-center md:justify-start\">\n            <div className=\"h-[2px] w-12 bg-cinematic-neon-blue shadow-[0_0_10px_rgba(0,240,255,1)]\" />\n            <span className=\"text-[10px] font-black uppercase tracking-[0.5em] text-cinematic-neon-blue italic\">Support Center</span>\n          </div>\n\n          <h1 className=\"text-6xl md:text-8xl font-black tracking-tighter uppercase italic leading-[0.85] mb-8\">\n            {isRTL ? 'в”ҳГ в•Әв–’в”ҳГўв•Әв–“' : 'SUPPORT'} <br />\n            <span className=\"text-transparent bg-clip-text bg-gradient-to-b from-white to-white/20\">\n              {isRTL ? 'в•ӘШҜв”ҳВ„в•ӘВ»в•Әв•Јв”ҳГ  в”ҳГӘв•ӘШҜв”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в•ӘШұ' : 'CENTER'}\n            </span>\n          </h1>\n\n          <p className=\"text-white/40 text-lg md:text-xl font-medium max-w-2xl mt-6 uppercase leading-relaxed tracking-wide\">\n            {isRTL\n              ? 'в”ҳВҶв•ӘШөв”ҳВҶ в”ҳГ§в”ҳВҶв•ӘШҜ в”ҳВ„в”ҳГ в•Әв”Ӯв•ӘШҜв•Әв•Јв•ӘВ»в•ӘШІв”ҳГў в”ҳВҒв”ҳГЁ в”ҳГўв”ҳВ„ в•ӘВ«в•Әв•–в”ҳГӘв•ӘШұ. в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в•Әв•–в•Әв–’в”ҳГЁв”ҳГ©в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв”ҳГЁ в•ӘШІв”ҳВҒв•Әв•ўв”ҳВ„в”ҳГ§в•ӘШҜ в”ҳВ„в”ҳВ„в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Ј в”ҳВҒв•Әв–’в”ҳГЁв”ҳГ©в”ҳВҶв•ӘШҜ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШІв•Әв–’в”ҳВҒ.'\n              : 'We are here to help you every step of the way. Choose your preferred method to contact our professional team.'}\n          </p>\n        </header>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8 mb-20\">\n          {supportOptions.map((opt, i) => (\n            <motion.div\n              key={opt.id}\n              initial={{ opacity: 0, y: 30 }}\n              animate={{ opacity: 1, y: 0 }}\n              transition={{ delay: i * 0.1 }}\n              whileHover={{ y: -10 }}\n              className=\"group\"\n            >\n              <Link href={opt.href}>\n                <div className={cn(\n                  \"h-full p-10 rounded-[3rem] border bg-white/[0.02] hover:bg-white/[0.05] transition-all relative overflow-hidden flex flex-col items-start gap-8\",\n                  opt.border\n                )}>\n                  {/* Decorative background icon */}\n                  <opt.icon className=\"absolute -bottom-6 -right-6 w-32 h-32 opacity-[0.03] group-hover:scale-110 transition-transform duration-700\" />\n\n                  <div className=\"w-full flex justify-between items-start\">\n                    <div className={cn(\"p-5 rounded-2xl shadow-xl\", opt.bg, opt.color)}>\n                      <opt.icon className=\"w-8 h-8\" />\n                    </div>\n                    <div className={cn(\"px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-widest border border-white/10\", opt.color)}>\n                      {opt.tag}\n                    </div>\n                  </div>\n\n                  <div>\n                    <h3 className=\"text-2xl font-black italic uppercase tracking-tighter mb-3\">{opt.title}</h3>\n                    <p className=\"text-white/40 text-sm font-bold leading-relaxed\">{opt.desc}</p>\n                  </div>\n\n                  <div className=\"mt-auto w-full pt-8 flex items-center justify-between border-t border-white/5\">\n                    <span className=\"text-[10px] font-black uppercase tracking-[0.3em] group-hover:translate-x-2 transition-transform duration-500 flex items-center gap-2\">\n                      {isRTL ? 'в•ӘШҜв•ӘШ°в•ӘВ»в•ӘШ« в•ӘШҜв”ҳВ„в•Ә