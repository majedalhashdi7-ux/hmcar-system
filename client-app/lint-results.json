                   brand === b.name ? \"text-luxury-gold\" : \"text-white/40 group-hover:text-white\"\n                                    )}>\n                                        {b.name}\n                                    </span>\n                                </div>\n                            ))\n                        )}\n                    </div>\n                </motion.div>\n\n                {/* Search & Mobile Filter Bar */}\n                <AnimatePresence>\n                    {showFilters && (\n                        <motion.div\n                            initial={{ height: 0, opacity: 0 }}\n                            animate={{ height: 'auto', opacity: 1 }}\n                            exit={{ height: 0, opacity: 0 }}\n                            className=\"overflow-hidden mb-12\"\n                        >\n                            <div className=\"bg-white/3 border border-white/10 rounded-3xl p-8 grid grid-cols-1 md:grid-cols-4 gap-8\">\n                                {/* Search */}\n                                <div className=\"space-y-4\">\n                                    <label className=\"text-[10px] font-black text-white/30 uppercase tracking-widest\">{isRTL ? rawText('в•ӘШ°в•ӘШөв•ӘШі в”ҳВҶв•Әв•Ўв”ҳГЁ') : rawText('TEXT SEARCH')}</label>\n                                    <div className=\"relative\">\n                                        <Search className=\"absolute top-1/2 -translate-y-1/2 left-4 w-4 h-4 text-white/20\" />\n                                        <input\n                                            type=\"text\" value={q} onChange={handleSearchChange}\n                                            placeholder={isRTL ? rawText('в•ӘШҜв•Әв”Ӯв”ҳГ  в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ...') : rawText('Car name...')}\n                                            className=\"w-full bg-black/40 border border-white/10 rounded-xl py-4 pl-12 pr-4 text-sm font-bold outline-none focus:border-luxury-gold/50 transition-all\"\n                                        />\n                                    </div>\n                                </div>\n\n                                {/* Agency */}\n                                <div className=\"space-y-4\">\n                                    <label htmlFor=\"agency-select\" className=\"text-[10px] font-black text-white/30 uppercase tracking-widest\">{isRTL ? rawText('в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШұ (в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•Әв–’в”ҳГўв•ӘШұ)') : rawText('AGENCY (MAKE)')}</label>\n                                    <select\n                                        id=\"agency-select\"\n                                        title={isRTL ? rawText('в•ӘШҜв•ӘВ«в•ӘШІв•Әв–’ в•ӘШҜв”ҳВ„в”ҳГӘв”ҳГўв•ӘШҜв”ҳВ„в•ӘШұ') : rawText('Select Agency')}\n                                        value={brand} onChange={e => { setBrand(e.target.value); setPage(1); }}\n                                        className=\"w-full bg-black/40 border border-white/10 rounded-xl py-4 px-4 text-sm font-bold outline-none focus:border-luxury-gold/50 appearance-none\"\n                                    >\n                                        <option value=\"\">{isRTL ? rawText('в”ҳГўв”ҳВ„ в•ӘШҜв”ҳВ„в”ҳГ в•ӘШҜв•Әв–’в”ҳГўв•ӘШҜв•ӘШІ') : rawText('ALL MAKES')}</option>\n                                        {brands.map(b => <option key={b.name} value={b.name}>{b.name}</option>)}\n                                    </select>\n                                </div>\n\n                                {/* Price Range */}\n                                <div className=\"space-y-4\">\n                                    <label className=\"text-[10px] font-black text-white/30 uppercase tracking-widest\">{isRTL ? rawText('в•ӘШҜв”ҳВ„в”ҳВҶв•Әв•–в•ӘШҜв”ҳГ© в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’в”ҳГЁ') : rawText('PRICE SPECTRUM')}</label>\n                                    <div className=\"flex gap-2 flex-wrap\">\n                                        {priceRanges.map(r => (\n                                            <button\n                                                key={r.id} onClick={() => { setPriceRange(priceRange === r.id ? '' : r.id); setPage(1); }}\n                                                className={cn(\n                                                    \"px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all\",\n                                                    priceRange === r.id ? \"bg-luxury-gold/20 text-luxury-gold border border-luxury-gold/30\" : \"bg-white/5 text-white/40 border border-white/5 hover:border-white/20\"\n                                                )}\n                                            >\n                                                {r.label}\n                                            </button>\n                                        ))}\n                                    </div>\n                                </div>\n\n                                <div className=\"flex items-end\">\n                                    <button\n                                        onClick={clearFilters}\n                                        className=\"w-full flex items-center justify-center gap-2 py-4 text-[10px] font-black uppercase tracking-widest text-red-400/60 hover:text-red-400 transition-colors\"\n                                    >\n                                        <X className=\"w-4 h-4\" />\n                                        {isRTL ? rawText('в•ӘШІв•Әв•Ўв”ҳВҒв”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в”ҳВҒв”ҳВ„в•ӘШҜв•ӘШІв•Әв–’') : rawText('CLEAR SETTINGS')}\n                                    </button>\n                                </div>\n                            </div>\n                        </motion.div>\n                    )}\n                </AnimatePresence>\n\n                {/* Grid */}\n                {loading && page === 1 ? (\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8\">\n                        {Array.from({ length: 12 }).map((_, i) => (\n                            <div key={i} className=\"aspect-4/5 rounded-[2.5rem] bg-white/2 border border-white/5 animate-pulse\" />\n                        ))}\n                    </div>\n                ) : cars.length === 0 ? (\n                    <div className=\"py-48 text-center bg-white/1 border border-dashed border-white/10 rounded-[3rem]\">\n                        <div className=\"w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-8 border border-white/10\">\n                            <Car className=\"w-10 h-10 text-white/10\" />\n                        </div>\n                        <h2 className=\"text-3xl font-black uppercase italic tracking-tighter mb-4\">{isRTL ? rawText('в”ҳВ„в•ӘШҜ в•ӘШІв”ҳГӘв•ӘШҙв•ӘВ» в”ҳВҶв•ӘШІв•ӘШҜв•ӘШ®в•ӘШҙ') : rawText('OFF-LINE')}</h2>\n                        <p className=\"text-white/40 text-[10px] font-bold uppercase tracking-[0.3em]\">{isRTL ? rawText('в•ӘШҙв•Әв–’в•ӘШ° в•ӘШІв•Әв•Јв•ӘВ»в”ҳГЁв”ҳВ„ в•ӘВ«в”ҳГЁв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•ӘШ°в•ӘШөв•ӘШі') : rawText('RECONFIGURE SEARCH PARAMETERS')}</p>\n                    </div>\n                ) : (\n                    <>\n                        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8\">\n                            {cars.map((car, i) => (\n                                <CarCard\n                                    key={String(car.id || car._id || `car-${i}`)}\n                                    car={car}\n                                    index={i}\n                                    onClick={() => {\n                                        if (!isLoggedIn) router.push('/login');\n                                        else router.push(`/cars/${car.id || car._id}`);\n                                    }}\n                                    onLoginRequired={() => router.push('/login')}\n                                />\n                            ))}\n                        </div>\n\n                        {/* Pagination */}\n                        {totalPages > 1 && (\n                            <div className=\"mt-24 flex items-center justify-center gap-12\">\n                                <button\n                                    onClick={() => { setPage(p => Math.max(1, p - 1)); window.scrollTo({ top: 0, behavior: 'smooth' }); }}\n                                    disabled={page === 1}\n                                    className=\"px-8 py-4 rounded-xl border border-white/10 text-[10px] font-black uppercase tracking-widest hover:bg-white/5 disabled:opacity-20 transition-all flex items-center gap-3\"\n                                >\n                                    <ArrowLeft className={cn(\"w-4 h-4\", isRTL && \"rotate-180\")} />\n                                    {isRTL ? rawText('в•ӘШҜв”ҳВ„в•Әв”Ӯв•ӘШҜв•ӘШ°в”ҳГ©') : rawText('PREVIOUS')}\n                                </button>\n                                <div className=\"flex items-center gap-4 text-xs font-black italic\">\n                                    <span className=\"text-luxury-gold\">{page}</span>\n                                    <span className=\"w-1 h-1 rounded-full bg-white/20\" />\n                                    <span className=\"text-white/40\">{totalPages}</span>\n                                </div>\n                                <button\n                                    onClick={() => { setPage(p => Math.min(totalPages, p + 1)); window.scrollTo({ top: 0, behavior: 'smooth' }); }}\n                                    disabled={page === totalPages}\n                                    className=\"px-8 py-4 rounded-xl border border-white/10 text-[10px] font-black uppercase tracking-widest hover:bg-white/5 disabled:opacity-20 transition-all flex items-center gap-3\"\n                                >\n                                    {isRTL ? rawText('в•ӘШҜв”ҳВ„в•ӘШІв•ӘШҜв”ҳВ„в”ҳГЁ') : rawText('NEXT')}\n                                    <ArrowRight className={cn(\"w-4 h-4\", isRTL && \"rotate-180\")} />\n                                </button>\n                            </div>\n                        )}\n                    </>\n                )}\n\n            </main>\n        </div>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\cart\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\cart\\share\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'motion' is defined but never used.","line":5,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":16,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"motion"},"fix":{"range":[141,148],"text":""},"desc":"Remove unused variable \"motion\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AnimatePresence' is defined but never used.","line":5,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":33,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"AnimatePresence"},"fix":{"range":[132,188],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\nimport React, { useState, useEffect, Suspense } from 'react';\r\nimport { useSearchParams } from 'next/navigation';\r\nimport { motion, AnimatePresence } from 'framer-motion';\r\nimport { Package, AlertCircle, Share2 as Share2Icon, MessageCircle } from 'lucide-react';\r\nimport Image from 'next/image';\r\nimport Link from 'next/link';\r\nimport Navbar from '@/components/Navbar';\r\nimport { useLanguage } from '@/lib/LanguageContext';\r\nimport { useSettings } from '@/lib/SettingsContext';\r\nimport { api } from '@/lib/api';\r\nimport { ProductModalData } from '@/components/ProductModal';\r\n\r\nfunction SharedCartContent() {\r\n    const searchParams = useSearchParams();\r\n    const { isRTL } = useLanguage();\r\n    const { formatPriceFromUsd, socialLinks, currency } = useSettings();\r\n    const [items, setItems] = useState<ProductModalData[]>([]);\r\n    const [loading, setLoading] = useState(true);\r\n\r\n    const itemsParam = searchParams.get('items');\r\n\r\n    useEffect(() => {\r\n        if (!itemsParam) {\r\n            setLoading(false);\r\n            return;\r\n        }\r\n\r\n        const loadItems = async () => {\r\n            try {\r\n                const ids = itemsParam.split(',');\r\n                const promises = ids.map(id => api.cars.getById(id).catch(() => api.parts.list({ id }).then(res => res.parts.find((p: any) => p.id === id))));\r\n\r\n                const results = await Promise.all(promises);\r\n                const validItems = results.filter(Boolean).map(res => {\r\n                    const data = res.data || res;\r\n                    return {\r\n                        id: data.id || data._id,\r\n                        title: data.title || data.name,\r\n                        price: data.basePriceUsd || data.priceUsd || data.price || data.priceSar,\r\n                        images: data.images || [],\r\n                        type: data.category ? 'car' : 'part',\r\n                        make: data.make,\r\n                        brand: data.brand,\r\n                        year: data.year,\r\n                        displayCurrency: data.basePriceUsd || data.priceUsd ? 'USD' : (data.priceKrw ? 'KRW' : 'SAR')\r\n                    } as ProductModalData;\r\n                });\r\n\r\n                setItems(validItems);\r\n            } catch (err) {\r\n                console.error('Failed to load shared items', err);\r\n            } finally {\r\n                setLoading(false);\r\n            }\r\n        };\r\n\r\n        loadItems();\r\n    }, [itemsParam, isRTL]);\r\n\r\n    const toBaseUsd = (item: ProductModalData) => {\r\n        const amount = Number(item.price || 0);\r\n        if (!Number.isFinite(amount) || amount <= 0) return 0;\r\n\r\n        const sourceCurrency = (item.displayCurrency || 'SAR') as 'SAR' | 'USD' | 'KRW';\r\n        if (sourceCurrency === 'USD') return amount;\r\n        if (sourceCurrency === 'KRW') return amount / Number(currency.usdToKrw || 1);\r\n        return amount / Number(currency.usdToSar || 1);\r\n    };\r\n\r\n    const totalUsd = items.reduce((sum, item) => sum + toBaseUsd(item), 0);\r\n\r\n    const contactAdmin = () => {\r\n        const phone = (socialLinks?.whatsapp || '+821080880014').replace(/\\D/g, '');\r\n        const msg = isRTL\r\n            ? `в”ҳГ в•Әв–’в•ӘШөв•ӘШ°в•ӘШҜв”ҳГҜв•ӘГ® в•ӘШ«в”ҳВҶв•ӘШҜ в•ӘШ«в•Әв–’в•ӘШҜв•ӘШҙв•Әв•Ј в•Әв”Ӯв”ҳВ„в•ӘШұ в•ӘШІв•Әв”Ӯв”ҳГӘв”ҳГ© в”ҳГ в•Әв”Өв•ӘШІв•Әв–’в”ҳГўв•ӘШұ в•ӘШІв•ӘШөв•ӘШІв”ҳГӘв”ҳГЁ в•Әв•Јв”ҳВ„в”ҳГ« ${items.length} в”ҳГ в”ҳВҶв•ӘШІв•ӘШҙв•ӘШҜв•ӘШІ.\\nв•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШұ: ${window.location.href}`\r\n            : `Hello, I am reviewing a shared cart with ${items.length} items.\\nCart link: ${window.location.href}`;\r\n        window.open(`https://wa.me/${phone}?text=${encodeURIComponent(msg)}`, '_blank');\r\n    };\r\n\r\n    if (loading) {\r\n        return (\r\n            <div className=\"flex flex-col items-center justify-center py-32 space-y-4\">\r\n                <div className=\"w-12 h-12 border-4 border-[#c9a96e]/20 border-t-[#c9a96e] rounded-full animate-spin\" />\r\n                <p className=\"text-white/40 text-[10px] font-black uppercase tracking-[0.2em]\">\r\n                    {isRTL ? 'в•ӘШҙв•ӘШҜв•Әв–’в”ҳГЁ в•ӘШҙв”ҳВ„в•ӘШ° в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШұ...' : 'FETCHING SHARED CART...'}\r\n                </p>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    if (!itemsParam || items.length === 0) {\r\n        return (\r\n            <div className=\"text-center py-32 space-y-6\">\r\n                <div className=\"w-20 h-20 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center mx-auto text-red-400\">\r\n                    <AlertCircle className=\"w-10 h-10\" />\r\n                </div>\r\n                <h2 className=\"text-2xl font-black text-white/40\">{isRTL ? 'в•ӘШҜв”ҳВ„в•Әв–’в•ӘШҜв•ӘШ°в•Әв•– в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•Ўв•ӘШҜв”ҳВ„в•ӘШө' : 'Invalid Link'}</h2>\r\n                <Link href=\"/showroom\">\r\n                    <button className=\"px-8 py-3 bg-white/5 border border-white/10 rounded-2xl text-white/60 text-[11px] font-black uppercase tracking-widest hover:bg-white/10 transition-all\">\r\n                        {isRTL ? 'в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГӘв•ӘВ»в•ӘШұ в”ҳВ„в”ҳВ„в”ҳГ в•ӘШІв•ӘШҙв•Әв–’' : 'GO TO STORE'}\r\n                    </button>\r\n                </Link>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    return (\r\n        <div className=\"space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-700\">\r\n            <div className=\"flex items-center justify-between\">\r\n                <div>\r\n                    <h1 className=\"text-3xl font-black uppercase tracking-tight flex items-center gap-3\">\r\n                        <Share2Icon className=\"w-7 h-7 text-[#c9a96e]\" />\r\n                        {isRTL ? 'в•Әв”Ӯв”ҳВ„в•ӘШұ в”ҳГ в•Әв”Өв•ӘШІв•Әв–’в”ҳГўв•ӘШұ' : 'Shared Cart'}\r\n                    </h1>\r\n                    <p className=\"text-white/30 text-xs mt-1\">\r\n                        {isRTL ? `в•ӘШІв•ӘШөв•ӘШІв”ҳГӘв”ҳГЁ в•Әв•Јв”ҳВ„в”ҳГ« ${items.length} в”ҳГ в”ҳВҶв•ӘШІв•ӘШҙв•ӘШҜв•ӘШІ в”ҳГ в”ҳВҶ HM CAR` : `Contains ${items.length} premium items from HM CAR`}\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n            <div className=\"space-y-3\">\r\n                {items.map((item) => (\r\n                    <div key={item.id} className=\"flex gap-4 bg-white/[0.02] border border-white/8 rounded-2xl p-4\">\r\n                        <div className=\"relative w-20 h-20 rounded-xl overflow-hidden shrink-0 bg-white/5 border border-white/5\">\r\n                            {item.images?.[0] ? (\r\n                                <Image src={item.images[0]} alt={item.title} fill className=\"object-cover\" />\r\n                            ) : (\r\n                                <div className=\"w-full h-full flex items-center justify-center\"><Package className=\"w-8 h-8 text-white/10\" /></div>\r\n                            )}\r\n                        </div>\r\n                        <div className=\"flex-1 min-w-0\">\r\n                            <div className=\"text-[9px] font-black uppercase tracking-widest text-[#c9a96e]/60 mb-1\">\r\n                                {item.type === 'car' ? (isRTL ? 'в•Әв”Ӯв”ҳГЁв•ӘШҜв•Әв–’в•ӘШұ' : 'CAR') : (isRTL ? 'в”ҳГ©в•Әв•–в•Әв•Јв•ӘШұ в•Әв•‘в”ҳГЁв•ӘШҜв•Әв–’' : 'PART')}\r\n                                {item.make && ` ШёВҖШӘ ${item.make}`}\r\n                                {item.brand && ` ШёВҖШӘ ${item.brand}`}\r\n                            </div>\r\n                            <h3 className=\"font-bold text-sm text-white/90 truncate\">{item.title}</h3>\r\n                            <div className=\"text-[#c9a96e] font-black text-base mt-1\">\r\n                                {formatPriceFromUsd ? formatPriceFromUsd(toBaseUsd(item)) : `${item.price?.toLocaleString()} SAR`}\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                ))}\r\n            </div>\r\n\r\n            <div className=\"bg-[#c9a96e]/5 border border-[#c9a96e]/20 rounded-3xl p-6 space-y-4\">\r\n                <div className=\"flex justify-between items-center border-b border-white/5 pb-4\">\r\n                    <span className=\"text-[11px] font-black uppercase tracking-widest text-white/40\">\r\n                        {isRTL ? 'в•ӘШӯв•ӘШҙв”ҳГ в•ӘШҜв”ҳВ„в”ҳГЁ в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв•Јв•Әв–’' : 'TOTAL PRICE'}\r\n                    </span>\r\n                    <span className=\"text-2xl font-black text-[#c9a96e]\">\r\n                        {formatPriceFromUsd ? formatPriceFromUsd(totalUsd) : `${totalUsd.toLocaleString()} SAR`}\r\n                    </span>\r\n                </div>\r\n                <button\r\n                    onClick={contactAdmin}\r\n                    className=\"w-full py-4 bg-green-500 hover:bg-green-400 rounded-2xl text-black font-black uppercase text-[12px] tracking-[0.2em] shadow-[0_0_30px_rgba(34,197,94,0.2)] transition-all flex items-center justify-center gap-2\"\r\n                >\r\n                    <MessageCircle className=\"w-5 h-5\" />\r\n                    {isRTL ? 'в•ӘШІв”ҳГӘв•ӘШҜв•Әв•Ўв”ҳВ„ в”ҳГ в•Әв•Јв”ҳВҶв•ӘШҜ в•ӘШ°в•ӘВ«в•Әв•Ўв”ҳГӘв•Әв•Ў в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВ„в•ӘШұ' : 'INQUIRE ABOUT THIS CART'}\r\n                </button>\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n\r\nexport default function SharedCartPage() {\r\n    return (\r\n        <div className=\"relative min-h-screen bg-[#050505] text-white\">\r\n            <Navbar />\r\n            <main className=\"relative z-10 pt-28 pb-32 px-4 sm:px-6 max-w-2xl mx-auto\">\r\n                <Suspense fallback={<div className=\"text-center py-32 text-white/20 uppercase tracking-widest text-[11px] font-black animate-pulse\">Initializing shared link...</div>}>\r\n                    <SharedCartContent />\r\n                </Suspense>\r\n            </main>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\client\\dashboard\\page.tsx","messages":[],"suppressedMessages":[{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":266,"column":41,"nodeType":"JSXOpeningElement","endLine":270,"endColumn":43,"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\client\\layout.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AnimatePresence' is defined but never used.","line":5,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":33,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"AnimatePresence"},"fix":{"range":[111,128],"text":""},"desc":"Remove unused variable \"AnimatePresence\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'pathname' is assigned a value but never used.","line":340,"column":11,"nodeType":"Identifier","messageId":"unusedVar","endLine":340,"endColumn":19}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\nimport { usePathname } from 'next/navigation';\r\nimport Link from 'next/link';\r\nimport { motion, AnimatePresence } from 'framer-motion';\r\nimport {\r\n    LayoutGrid,\r\n    ShoppingBag,\r\n    Heart,\r\n    Bell,\r\n    Settings,\r\n    User,\r\n    Sparkles,\r\n    LogOut,\r\n    Car,\r\n    Gavel,\r\n    ChevronLeft,\r\n    ChevronRight,\r\n    MessageCircle,\r\n    Languages,\r\n    Wrench,\r\n} from 'lucide-react';\r\nimport { useLanguage } from '@/lib/LanguageContext';\r\nimport { useAuth } from '@/lib/AuthContext';\r\nimport { useRouter } from 'next/navigation';\r\nimport { cn } from '@/lib/utils';\r\nimport { useUI } from '@/lib/UIContext';\r\n\r\nconst rawText = (value: string) => value;\r\n\r\n// ШёВӨВҖШёВӨВҖ в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв”ҳГ©в”ҳВ„ в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘШұ ШёВӨВҖШёВӨВҖ\r\nconst NAV_ITEMS = [\r\n    { href: '/client/dashboard', icon: LayoutGrid, labelAr: 'в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘШұ', labelEn: 'Home', match: ['/client/dashboard'] },\r\n    { href: '/orders', icon: ShoppingBag, labelAr: 'в•Әв•–в”ҳВ„в•ӘШ°в•ӘШҜв•ӘШІв”ҳГЁ', labelEn: 'Orders', match: ['/orders'] },\r\n    { href: '/client/smart-alerts', icon: Sparkles, labelAr: 'в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§в•ӘШҜв•ӘШІв”ҳГЁ', labelEn: 'Alerts', match: ['/client/smart-alerts'], highlight: true },\r\n    { href: '/favorites', icon: Heart, labelAr: 'в•ӘШҜв”ҳВ„в”ҳГ в”ҳВҒв•Әв•ўв”ҳВ„в•ӘШұ', labelEn: 'Favorites', match: ['/favorites'] },\r\n    { href: '/client/settings', icon: Settings, labelAr: 'в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ', labelEn: 'Settings', match: ['/client/settings'] },\r\n    { href: '/client/messages', icon: MessageCircle, labelAr: 'в•ӘШҜв”ҳВ„в•Әв–’в•Әв”Ӯв•ӘШҜв•ӘШ®в”ҳВ„', labelEn: 'Messages', match: ['/client/messages'] },\r\n];\r\n\r\n// ШёВӨВҖШёВӨВҖ в•Әв–’в”ҳГӘв•ӘШҜв•ӘШ°в•Әв•– в•ӘШҜв”ҳВ„в”ҳГӘв•Әв•Ўв”ҳГӘв”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Ӯв•Әв–’в”ҳГЁв•Әв•Ј в”ҳВҒв”ҳГЁ в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в”ҳГЁв•Әв•– в•ӘШҜв”ҳВ„в•ӘШҙв•ӘШҜв”ҳВҶв•ӘШ°в”ҳГЁ ШёВӨВҖШёВӨВҖ\r\nconst QUICK_LINKS = [\r\n    { href: '/gallery', icon: Car, labelAr: 'в•ӘШҜв”ҳВ„в”ҳГ в•Әв•Јв•Әв–’в•Әв•ў', labelEn: 'Showroom' },\r\n    { href: '/auctions', icon: Gavel, labelAr: 'в•ӘШҜв”ҳВ„в”ҳГ в•Әв–“в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ', labelEn: 'Auctions' },\r\n    { href: '/parts', icon: Wrench, labelAr: 'в”ҳГ©в•Әв•–в•Әв•Ј в•ӘШҜв”ҳВ„в•Әв•‘в”ҳГЁв•ӘШҜв•Әв–’', labelEn: 'Parts' },\r\n    { href: '/notifications', icon: Bell, labelAr: 'в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ', labelEn: 'Notifications' },\r\n    { href: '/client/profile', icon: User, labelAr: 'в•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в”ҳВҒ в•ӘШҜв”ҳВ„в•Әв”Өв•ӘВ«в•Әв•Ўв”ҳГЁ', labelEn: 'Profile' },\r\n];\r\n\r\nfunction ClientSidebar() {\r\n    const pathname = usePathname();\r\n    const { isRTL, toggleLanguage } = useLanguage();\r\n    const { user, logout } = useAuth();\r\n    const router = useRouter();\r\n    const { setFavoritesOpen, setNotificationsOpen } = useUI();\r\n\r\n    const isActive = (paths: string[]) => paths.some(p => pathname === p || pathname.startsWith(p + '/'));\r\n\r\n    const handleLogout = () => {\r\n        logout();\r\n        router.push('/');\r\n    };\r\n\r\n    return (\r\n        <aside className={cn(\r\n            'hidden lg:flex flex-col w-64 xl:w-72 bg-[#0c0c0f] border-white/6 min-h-screen sticky top-0 h-screen overflow-y-auto',\r\n            isRTL ? 'border-l' : 'border-r'\r\n        )}>\r\n            {/* Logo + User */}\r\n            <div className=\"p-6 border-b border-white/6\">\r\n                {/* Logo */}\r\n                <Link href=\"/\" className=\"flex items-center gap-2.5 mb-6 group\">\r\n                    <div className=\"w-9 h-9 rounded-xl bg-cinematic-neon-gold/15 border border-cinematic-neon-gold/25 flex items-center justify-center\">\r\n                        <span className=\"font-black text-cinematic-neon-gold text-sm\">{rawText('HM')}</span>\r\n                    </div>\r\n                    <div>\r\n                        <div className=\"font-black text-white text-base leading-none\">{rawText('HM')} <span className=\"text-cinematic-neon-gold\">{rawText('CAR')}</span></div>\r\n                        <div className=\"text-[9px] text-white/25 font-bold uppercase tracking-[0.2em] mt-0.5\">\r\n                            {isRTL ? rawText('в•ӘШ°в”ҳГӘв•ӘШҜв•ӘШ°в•ӘШұ в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„') : rawText('Client Portal')}\r\n                        </div>\r\n                    </div>\r\n                </Link>\r\n\r\n                {/* User Card */}\r\n                <div className=\"flex items-center gap-3 p-3 rounded-2xl bg-white/3 border border-white/6\">\r\n                    <div className=\"w-10 h-10 rounded-xl bg-linear-to-br from-cinematic-neon-gold/30 to-cinematic-neon-gold/10 flex items-center justify-center text-cinematic-neon-gold font-black text-base shrink-0\">\r\n                        {user?.name?.charAt(0)?.toUpperCase() || rawText('?')}\r\n                    </div>\r\n                    <div className=\"min-w-0 flex-1\">\r\n                        <div className=\"text-[13px] font-bold text-white truncate\">{user?.name || (isRTL ? rawText('в•ӘШҜв”ҳВ„в•Әв•Јв”ҳГ в”ҳГЁв”ҳВ„') : rawText('Guest'))}</div>\r\n                        <div className=\"text-[10px] text-cinematic-neon-gold/70 font-bold uppercase tracking-wider\">\r\n                            {isRTL ? rawText('в•Әв•Јв•Әв•ўв”ҳГӘ в”ҳВҶв•Әв”Өв•Әв•–') : rawText('Active Member')}\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            {/* Main Nav */}\r\n            <nav className=\"flex-1 p-4 space-y-1\">\r\n                <div className=\"text-[9px] font-black text-white/20 uppercase tracking-[0.3em] px-3 mb-3\">\r\n                    {isRTL ? rawText('в•ӘШҜв”ҳВ„в”ҳГ©в•ӘШҜв•ӘШ®в”ҳГ в•ӘШұ') : rawText('Menu')}\r\n                </div>\r\n                {NAV_ITEMS.map((item) => {\r\n                    const active = isActive(item.match);\r\n                    const Icon = item.icon;\r\n                    const isDrawerItem = item.href === '/favorites' || item.href === '/notifications';\r\n\r\n                    const handleClick = (e: React.MouseEvent) => {\r\n                        if (isDrawerItem) {\r\n                            e.preventDefault();\r\n                            if (item.href === '/favorites') setFavoritesOpen(true);\r\n                            if (item.href === '/notifications') setNotificationsOpen(true);\r\n                        }\r\n                    };\r\n\r\n                    return (\r\n                        <Link key={item.href} href={item.href} onClick={handleClick}>\r\n                            <motion.div\r\n                                whileHover={{ x: isRTL ? -4 : 4 }}\r\n                                className={cn(\r\n                                    'flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 group relative',\r\n                                    isRTL ? 'flex-row-reverse text-right' : '',\r\n                                    active\r\n                                        ? 'bg-cinematic-neon-gold/10 border border-cinematic-neon-gold/20 text-cinematic-neon-gold'\r\n                                        : 'text-white/40 hover:text-white hover:bg-white/4'\r\n                                )}\r\n                            >\r\n                                {item.highlight && !active && (\r\n                                    <div className=\"absolute top-2 right-2 w-1.5 h-1.5 rounded-full bg-cinematic-neon-gold animate-pulse\" />\r\n                                )}\r\n                                <Icon className={cn('w-4.5 h-4.5 shrink-0', active ? 'text-cinematic-neon-gold' : '')} strokeWidth={active ? 2.5 : 1.8} />\r\n                                <span className=\"text-[13px] font-semibold\">{isRTL ? item.labelAr : item.labelEn}</span>\r\n                                {active && (\r\n                                    <motion.div\r\n                                        layoutId=\"sidebar-active\"\r\n                                        className={cn('absolute top-1/2 -translate-y-1/2 w-0.5 h-5 rounded-full bg-cinematic-neon-gold', isRTL ? 'right-0' : 'left-0')}\r\n                                        transition={{ type: 'spring', damping: 25, stiffness: 300 }}\r\n                                    />\r\n                                )}\r\n                            </motion.div>\r\n                        </Link>\r\n                    );\r\n                })}\r\n\r\n                {/* Divider */}\r\n                <div className=\"my-4 border-t border-white/5\" />\r\n\r\n                <div className=\"text-[9px] font-black text-white/20 uppercase tracking-[0.3em] px-3 mb-3\">\r\n                    {isRTL ? rawText('в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј') : rawText('Browse')}\r\n                </div>\r\n\r\n                {QUICK_LINKS.map((item) => {\r\n                    const Icon = item.icon;\r\n                    const isDrawerItem = item.href === '/favorites' || item.href === '/notifications';\r\n\r\n                    const handleClick = (e: React.MouseEvent) => {\r\n                        if (isDrawerItem) {\r\n                            e.preventDefault();\r\n                            if (item.href === '/favorites') setFavoritesOpen(true);\r\n                            if (item.href === '/notifications') setNotificationsOpen(true);\r\n                        }\r\n                    };\r\n\r\n                    return (\r\n                        <Link key={item.href} href={item.href} onClick={handleClick}>\r\n                            <motion.div\r\n                                whileHover={{ x: isRTL ? -4 : 4 }}\r\n                                className={cn(\r\n                                    'flex items-center gap-3 px-3 py-2.5 rounded-xl text-white/30 hover:text-white/70 hover:bg-white/3 transition-all duration-200',\r\n                                    isRTL ? 'flex-row-reverse text-right' : ''\r\n                                )}\r\n                            >\r\n                                <Icon className=\"w-4 h-4 shrink-0\" strokeWidth={1.5} />\r\n                                <span className=\"text-[12px] font-medium\">{isRTL ? item.labelAr : item.labelEn}</span>\r\n                            </motion.div>\r\n                        </Link>\r\n                    );\r\n                })}\r\n            </nav>\r\n\r\n            {/* Footer */}\r\n            <div className=\"p-4 border-t border-white/6\">\r\n                <button\r\n                    onClick={toggleLanguage}\r\n                    className={cn(\r\n                        'w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-white/30 hover:text-white/60 hover:bg-white/3 transition-all mb-1',\r\n                        isRTL ? 'flex-row-reverse' : ''\r\n                    )}\r\n                    title={isRTL ? 'в•ӘШІв•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в•ӘШҜв”ҳВ„в”ҳВ„в•Әв•‘в•ӘШұ' : 'Toggle Language'}\r\n                >\r\n                    <Languages className=\"w-4 h-4 shrink-0 text-accent-gold\" strokeWidth={1.5} />\r\n                    <span className=\"text-[12px] font-medium\">{isRTL ? rawText('English') : rawText('в•ӘШҜв”ҳВ„в•Әв•Јв•Әв–’в•ӘШ°в”ҳГЁв•ӘШұ')}</span>\r\n                </button>\r\n                <button\r\n                    onClick={handleLogout}\r\n                    className={cn(\r\n                        'w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-red-400/50 hover:text-red-400 hover:bg-red-400/6 transition-all',\r\n                        isRTL ? 'flex-row-reverse' : ''\r\n                    )}\r\n                >\r\n                    <LogOut className=\"w-4 h-4 shrink-0\" strokeWidth={1.5} />\r\n                    <span className=\"text-[12px] font-medium\">{isRTL ? rawText('в•ӘШІв•Әв”Ӯв•ӘШҙв”ҳГЁв”ҳВ„ в•ӘШҜв”ҳВ„в•ӘВ«в•Әв–’в”ҳГӘв•ӘШҙ') : rawText('Sign Out')}</span>\r\n                </button>\r\n            </div>\r\n        </aside>\r\n    );\r\n}\r\n\r\nfunction ClientBottomBar() {\r\n    const pathname = usePathname();\r\n    const { isRTL } = useLanguage();\r\n    const { setFavoritesOpen, setNotificationsOpen } = useUI();\r\n\r\n    const isActive = (paths: string[]) => paths.some(p => pathname === p || pathname.startsWith(p + '/'));\r\n\r\n    return (\r\n        <nav\r\n            className=\"fixed bottom-0 left-0 right-0 z-50 lg:hidden bg-[#0c0c0f]/95 backdrop-blur-2xl border-t border-white/6\"\r\n            style={{ paddingBottom: 'env(safe-area-inset-bottom, 0px)' }}\r\n        >\r\n            <div className=\"flex items-center justify-around px-2 pt-2 pb-2 max-w-md mx-auto\">\r\n                {NAV_ITEMS.map((item) => {\r\n                    const active = isActive(item.match);\r\n                    const Icon = item.icon;\r\n                    const isDrawerItem = item.href === '/favorites' || item.href === '/notifications';\r\n\r\n                    const handleClick = (e: React.MouseEvent) => {\r\n                        if (isDrawerItem) {\r\n                            e.preventDefault();\r\n                            if (item.href === '/favorites') setFavoritesOpen(true);\r\n                            if (item.href === '/notifications') setNotificationsOpen(true);\r\n                        }\r\n                    };\r\n\r\n                    return (\r\n                        <Link key={item.href} href={item.href} className=\"flex-1\" onClick={handleClick}>\r\n                            <motion.div\r\n                                whileTap={{ scale: 0.85 }}\r\n                                className=\"flex flex-col items-center gap-1 relative\"\r\n                            >\r\n                                {/* в”ҳВҶв”ҳГ©в•Әв•–в•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§ */}\r\n                                {item.highlight && !active && (\r\n                                    <div className=\"absolute -top-0.5 right-1/4 w-1.5 h-1.5 rounded-full bg-cinematic-neon-gold animate-pulse\" />\r\n                                )}\r\n\r\n                                {/* в•ӘШ«в”ҳГЁв”ҳГ©в”ҳГӘв”ҳВҶв•ӘШұ */}\r\n                                <div className={cn(\r\n                                    'relative flex items-center justify-center w-10 h-8 rounded-xl transition-all duration-300',\r\n                                    active ? 'bg-cinematic-neon-gold/15' : ''\r\n                                )}>\r\n                                    {active && (\r\n                                        <motion.div\r\n                                            layoutId=\"bottom-bar-bg\"\r\n                                            className=\"absolute inset-0 rounded-xl bg-cinematic-neon-gold/10\"\r\n                                            transition={{ type: 'spring', damping: 20, stiffness: 300 }}\r\n                                        />\r\n                                    )}\r\n                                    <Icon\r\n                                        className={cn('w-5 h-5 relative z-10 transition-colors duration-200', active ? 'text-cinematic-neon-gold' : 'text-white/25')}\r\n                                        strokeWidth={active ? 2.5 : 1.8}\r\n                                    />\r\n                                </div>\r\n\r\n                                {/* в•ӘШҜв”ҳВ„в•ӘШІв•Әв”Ӯв”ҳГ в”ҳГЁв•ӘШұ */}\r\n                                <span className={cn(\r\n                                    'text-[9px] font-bold tracking-wide transition-colors duration-200',\r\n                                    active ? 'text-cinematic-neon-gold' : 'text-white/25'\r\n                                )}>\r\n                                    {isRTL ? item.labelAr : item.labelEn}\r\n                                </span>\r\n                            </motion.div>\r\n                        </Link>\r\n                    );\r\n                })}\r\n            </div>\r\n        </nav>\r\n    );\r\n}\r\n\r\nfunction ClientTopBar() {\r\n    const pathname = usePathname();\r\n    const { isRTL } = useLanguage();\r\n    const router = useRouter();\r\n    const { setNotificationsOpen } = useUI();\r\n\r\n    // в•ӘШІв•ӘШөв•ӘВ»в”ҳГЁв•ӘВ» в•Әв•Јв”ҳВҶв”ҳГӘв•ӘШҜв”ҳВҶ в•ӘШҜв”ҳВ„в•Әв•Ўв”ҳВҒв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШөв•ӘШҜв”ҳВ„в”ҳГЁв•ӘШұ\r\n    const getPageTitle = () => {\r\n        if (pathname.includes('/dashboard')) return isRTL ? 'в”ҳВ„в”ҳГӘв•ӘШөв•ӘШұ в•ӘШҜв”ҳВ„в•ӘШІв•ӘШөв”ҳГўв”ҳГ ' : 'Dashboard';\r\n        if (pathname.includes('/smart-alerts')) return isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв•ӘШ°в”ҳГЁв”ҳГ§в•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в•Әв–‘в”ҳГўв”ҳГЁв•ӘШұ' : 'Smart Alerts';\r\n        if (pathname.includes('/settings')) return isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШӯв•Әв•Јв•ӘВ»в•ӘШҜв•ӘВ»в•ӘШҜв•ӘШІ' : 'Settings';\r\n        if (pathname.includes('/profile')) return isRTL ? 'в•ӘШҜв”ҳВ„в”ҳГ в”ҳВ„в”ҳВҒ в•ӘШҜв”ҳВ„в•Әв”Өв•ӘВ«в•Әв•Ўв”ҳГЁ' : 'Profile';\r\n        return 'HM CAR';\r\n    };\r\n\r\n    const showBack = pathname !== '/client/dashboard';\r\n\r\n    return (\r\n        <header className={cn(\r\n            'lg:hidden sticky top-0 z-40 bg-[#0c0c0f]/95 backdrop-blur-2xl border-b border-white/6 px-4 py-3.5 flex items-center',\r\n            isRTL ? 'flex-row-reverse' : ''\r\n        )}>\r\n            {showBack ? (\r\n                <button\r\n                    onClick={() => router.back()}\r\n                    className={cn(\r\n                        'w-9 h-9 rounded-xl bg-white/4 border border-white/8 flex items-center justify-center text-white/50 hover:text-white transition-all shrink-0',\r\n                        isRTL ? 'ml-3' : 'mr-3'\r\n                    )}\r\n                >\r\n                    {isRTL ? <ChevronRight className=\"w-4.5 h-4.5\" /> : <ChevronLeft className=\"w-4.5 h-4.5\" />}\r\n                </button>\r\n            ) : (\r\n                <div className={cn('flex items-center gap-2 shrink-0', isRTL ? 'ml-3' : 'mr-3')}>\r\n                    <div className=\"w-7 h-7 rounded-lg bg-cinematic-neon-gold/15 border border-cinematic-neon-gold/25 flex items-center justify-center\">\r\n                        <span className=\"font-black text-cinematic-neon-gold text-[10px]\">{rawText('HM')}</span>\r\n                    </div>\r\n                </div>\r\n            )}\r\n\r\n            <h1 className=\"flex-1 text-[15px] font-bold text-white tracking-tight text-center\">\r\n                {getPageTitle()}\r\n            </h1>\r\n\r\n            <button \r\n                onClick={() => setNotificationsOpen(true)}\r\n                className={cn(\r\n                    'w-9 h-9 rounded-xl bg-white/4 border border-white/8 flex items-center justify-center text-white/40 hover:text-white transition-all shrink-0',\r\n                    isRTL ? 'mr-3' : 'ml-3'\r\n                )}\r\n                title={isRTL ? 'в•ӘШҜв”ҳВ„в•ӘШӯв•Әв”Өв•Әв•Јв•ӘШҜв•Әв–’в•ӘШҜв•ӘШІ' : 'Notifications'}\r\n            >\r\n                <Bell className=\"w-4 h-4\" />\r\n            </button>\r\n        </header>\r\n    );\r\n}\r\n\r\nexport default function ClientLayout({ children }: { children: React.ReactNode }) {\r\n    const { isRTL } = useLanguage();\r\n    const pathname = usePathname();\r\n\r\n    return (\r\n        <div className={cn('min-h-screen bg-[#080809] text-white flex', isRTL ? 'rtl' : 'ltr')}>\r\n            {/* в•ӘШҜв”ҳВ„в•Әв”Өв•Әв–’в”ҳГЁв•Әв•– в•ӘШҜв”ҳВ„в•ӘШҙв•ӘШҜв”ҳВҶв•ӘШ°в”ҳГЁ - в•Әв”Өв•ӘШҜв•Әв”Өв•ӘШҜв•ӘШІ в•ӘШҜв”ҳВ„в”ҳГўв”ҳГ в•ӘШ°в”ҳГЁв”ҳГӘв•ӘШІв•Әв–’ */}\r\n            <ClientSidebar />\r\n\r\n            {/* в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ« в•ӘШҜв”ҳВ„в•Әв–’в•ӘШ®в”ҳГЁв•Әв”Ӯв”ҳГЁ */}\r\n            <div className=\"flex-1 flex flex-col min-h-screen min-w-0\">\r\n                {/* в•Әв”Өв•Әв–’в”ҳГЁв•Әв•– в•ӘШҜв”ҳВ„в•ӘШ«в•Әв•Јв”ҳВ„в”ҳГ« в”ҳВ„в”ҳВ„в”ҳГ в”ҳГӘв•ӘШ°в•ӘШҜв”ҳГЁв”ҳВ„ */}\r\n                <ClientTopBar />\r\n\r\n                {/* в•ӘШҜв”ҳВ„в”ҳГ в•ӘШөв•ӘШІв”ҳГӘв”ҳГ« */}\r\n                <main className=\"flex-1 pb-24 lg:pb-0 relative\">\r\n                    <div className=\"h-full relative z-0 animate-in fade-in zoom-in-95 duration-500\">\r\n                        {children}\r\n                    </div>\r\n                </main>\r\n            </div>\r\n\r\n            {/* в•Әв”Өв•Әв–’в”ҳГЁв•Әв•– в•ӘШҜв”ҳВ„в•ӘШІв”ҳВҶв”ҳГ©в”ҳВ„ в•ӘШҜв”ҳВ„в•Әв”Ӯв”ҳВҒв”ҳВ„в”ҳГЁ - в•ӘШҜв”ҳВ„в”ҳГ в”ҳГӘв•ӘШ°в•ӘШҜв”ҳГЁв”ҳВ„ */}\r\n            <ClientBottomBar />\r\n        </div>\r\n    );\r\n}\r\n\r\n\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\car-auction\\client-app\\src\\app\\clien