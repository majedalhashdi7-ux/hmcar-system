# Vercel import file example (NO REAL SECRETS)
# انسخ هذا الملف محليًا وغيّر القيم ثم استورده في Vercel.
# لا ترفعه إلى GitHub بعد وضع كلمة المرور.

NODE_ENV=production
BASE_URL=https://car-auction-sand.vercel.app

# بيانات قاعدة البيانات (يجب أن تكون صحيحة 100% في Vercel)
MONGO_URI=mongodb+srv://<db_user>:<db_password>@cluster0.example.mongodb.net/database_name?retryWrites=true&w=majority

# أسرار الجلسة والتوكن (غيّرها لقيم قوية وعشوائية)
SESSION_SECRET=ضع_هنا_سلسلة_عشوائية_قوية
JWT_SECRET=ضع_هنا_سلسلة_عشوائية_قوية
